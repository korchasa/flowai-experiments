+      "runs doctor: missing --run <run-id> (the run to diagnose).",
+    );
+  }
+  return {
+    workflowDir: workflow ? normalizeWorkflowDir(workflow) : undefined,
+    runId,
+    repair,
+    json,
+  };
+}
