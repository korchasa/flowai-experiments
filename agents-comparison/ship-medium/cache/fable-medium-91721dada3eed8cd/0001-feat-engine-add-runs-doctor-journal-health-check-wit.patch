+/**
+ * @module
+ * `runs doctor` core (FR-E83): diagnose a run's durability artifacts —
+ * journal integrity, replay invariants, filesystem cross-check, stale
+ * lock — and optionally apply safe mechanical repairs (torn final
+ * journal line, stale lock removal).
+ *
+ * The doctor never re-implements replay: state reconstruction is
+ * delegated to the EXISTING {@link replayRunJournal}. The line-level
+ * scan below is journal *lexing* (find every malformed line, unknown
+ * kind, seq/event_id anomaly), which the replayer intentionally does
+ * not surface because it stops at the first corruption.
+ */
+
+import type { RunJournalEvent } from "../types.ts";
+import {
+  getJournalPath,
+  isKnownJournalEventKind,
+  replayRunJournal,
+} from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+import {
+  defaultLockPath,
+  isRunLive,
+  type LockInfo,
+  readLockInfo,
+} from "./lock.ts";
+
+/** One diagnosed problem with its severity, stable code, and evidence path. */
+export interface DoctorFinding {
+  /** `error` fails the run health check (exit 1); `warning` does not. */
+  severity: "error" | "warning";
+  /** Stable machine-readable finding code (e.g. `torn_final_line`). */
+  code: string;
+  /** Human-readable description of the problem. */
+  message: string;
+  /** Filesystem path evidencing the finding. */
+  path: string;
+}
+
+/** One mechanical repair applied by `--repair`. */
+export interface DoctorRepair {
+  /** Stable machine-readable repair code (e.g. `torn_final_line_removed`). */
+  code: string;
+  /** Human-readable description of what was changed. */
+  message: string;
+  /** Filesystem path that was modified. */
+  path: string;
+}
+
+/** Full diagnosis (and optional repair) result for one run. */
+export interface DoctorReport {
+  /** Diagnosed run id. */
+  run_id: string;
+  /** Workflow folder the run belongs to. */
+  workflow_dir: string;
+  /** Every problem found, in check order. */
+  findings: DoctorFinding[];
+  /** Mechanical repairs applied (empty without `--repair`). */
+  repairs: DoctorRepair[];
+  /** Reason repairs were refused, when `--repair` was requested and denied. */
+  repair_refused?: string;
+  /** Number of `error`-severity findings. */
+  errors: number;
+  /** Number of `warning`-severity findings. */
+  warnings: number;
+  /** True when no `error`-severity findings remain. */
+  ok: boolean;
+}
+
+/** Options for {@link runDoctor}. */
+export interface DoctorOptions {
+  /** Workflow folder containing `workflow.yaml` and `runs/`. */
+  workflowDir: string;
+  /** Run id to diagnose (one per invocation). */
+  runId: string;
+  /** Apply safe mechanical repairs (torn final line, stale lock). */
+  repair?: boolean;
+  /** Emit the report as JSON instead of the human-readable grouping. */
+  json?: boolean;
+}
+
+/** Result of {@link runDoctor}: report, rendered output, process exit code. */
+export interface DoctorResult {
+  /** Structured report (also the `--json` payload). */
+  report: DoctorReport;
+  /** Rendered output — JSON or severity-grouped human-readable text. */
+  output: string;
+  /** 0 when no ERRORs and repairs (if requested) were not refused; else 1. */
+  exitCode: 0 | 1;
+}
+
+/** Journal lifecycle kinds that require a prior `node_declared`. */
+const NODE_LIFECYCLE_KINDS = new Set([
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+]);
+
+/** Terminal run event kinds; nothing may legally follow them. */
+const TERMINAL_KINDS = new Set(["run_completed", "run_failed", "run_aborted"]);
+
+/** Run-dir children that are runtime infrastructure, never node dirs. */
+const INFRA_DIR_NAMES = new Set(["logs", "worktree", ".hitl-inbox"]);
+
+/** Finding codes that mark the journal itself as damaged. Repairs are
+ * refused while any of these (beyond the torn final line) is present —
+ * the doctor must not guess at semantic repairs. */
+const JOURNAL_ERROR_CODES = new Set([
+  "journal_missing",
+  "garbage_line",
+  "unknown_event_kind",
+  "non_monotonic_seq",
+  "replay_failed",
+  "event_after_terminal",
+  "undeclared_node",
+  "unmatched_attempt",
+  "cost_divergence",
+]);
+
+/** Floating-point tolerance for cost-sum comparison (USD). */
+const COST_EPSILON = 1e-9;
+
+interface JournalScan {
+  findings: DoctorFinding[];
+  /** Events that parsed as JSON objects, in file order (line-level only). */
+  events: RunJournalEvent[];
+  /** Byte length of the journal up to (excluding) the torn final line. */
+  tornTailByteLength?: number;
+  /** True when the journal file does not exist. */
+  missing: boolean;
+}
+
+/** Line-level integrity scan of `journal.jsonl`. Reports every problem
+ * instead of stopping at the first one (unlike the replayer). */
+async function scanJournal(journalPath: string): Promise<JournalScan> {
+  const findings: DoctorFinding[] = [];
+  let content: string;
+  try {
+    content = await Deno.readTextFile(journalPath);
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) {
+      findings.push({
+        severity: "error",
+        code: "journal_missing",
+        message: "journal.jsonl does not exist for this run",
+        path: journalPath,
+      });
+      return { findings, events: [], missing: true };
+    }
+    throw error;
+  }
+
+  const endedWithNewline = content.endsWith("\n");
+  const lines = content.split("\n");
+  if (endedWithNewline) lines.pop();
+
+  const events: RunJournalEvent[] = [];
+  let tornTailByteLength: number | undefined;
+  let lastSeq: number | undefined;
+  const seenEventIds = new Set<string>();
+  let lineStart = 0;
+  for (let i = 0; i < lines.length; i++) {
+    const line = lines[i];
+    const nextLineStart = lineStart + line.length + 1;
+    if (line.trim() === "") {
+      lineStart = nextLineStart;
+      continue;
+    }
+    let event: RunJournalEvent;
+    try {
+      event = JSON.parse(line) as RunJournalEvent;
+    } catch {
+      const isFinalLine = i === lines.length - 1 && !endedWithNewline;
+      if (isFinalLine) {
+        findings.push({
+          severity: "warning",
+          code: "torn_final_line",
+          message: `torn/garbage final line (expected crash artifact): line ${
+            i + 1
+          }`,
+          path: journalPath,
+        });
+        tornTailByteLength = new TextEncoder()
+          .encode(content.slice(0, lineStart)).length;
+      } else {
+        findings.push({
+          severity: "error",
+          code: "garbage_line",
+          message: `unparsable non-final journal line ${i + 1}`,
+          path: journalPath,
+        });
+      }
+      lineStart = nextLineStart;
+      continue;
+    }
+    if (!isKnownJournalEventKind(event.kind)) {
+      findings.push({
+        severity: "error",
+        code: "unknown_event_kind",
+        message: `unknown event kind "${event.kind}" at line ${i + 1}`,
+        path: journalPath,
+      });
+    }
+    if (lastSeq !== undefined && event.seq <= lastSeq) {
+      findings.push({
+        severity: "error",
+        code: "non_monotonic_seq",
+        message: `non-monotonic seq at line ${
+          i + 1
+        }: ${event.seq} after ${lastSeq}`,
+        path: journalPath,
+      });
+    }
+    lastSeq = event.seq;
+    if (seenEventIds.has(event.event_id)) {
+      findings.push({
+        severity: "warning",
+        code: "duplicate_event_id",
+        message: `duplicate event_id "${event.event_id}" at line ${i + 1} ` +
+          "(replayer dedupes it)",
+        path: journalPath,
+      });
+    }
+    seenEventIds.add(event.event_id);
+    events.push(event);
+    lineStart = nextLineStart;
+  }
+  return { findings, events, tornTailByteLength, missing: false };
+}
+
+/** Replay invariants — delegated to the EXISTING replayer; the doctor
+ * only inspects the replay result field-by-field. */
+async function checkReplayInvariants(
+  runDir: string,
+  findings: DoctorFinding[],
+): Promise<void> {
+  const journalPath = getJournalPath(runDir);
+  let replay;
+  try {
+    replay = await replayRunJournal(runDir);
+  } catch (error) {
+    findings.push({
+      severity: "error",
+      code: "replay_failed",
+      message: `replay failed: ${(error as Error).message}`,
+      path: journalPath,
+    });
+    return;
+  }
+
+  let terminalSeen: string | undefined;
+  const declaredNodes = new Set<string>();
+  const undeclaredReported = new Set<string>();
+  const openAttempts = new Map<string, number>();
+  const lastAttemptCost = new Map<string, number>();
+
+  for (const event of replay.events) {
+    if (terminalSeen) {
+      findings.push({
+        severity: "error",
+        code: "event_after_terminal",
+        message:
+          `event "${event.kind}" (seq ${event.seq}) after terminal event ` +
+          `"${terminalSeen}"`,
+        path: journalPath,
+      });
+    }
+    if (TERMINAL_KINDS.has(event.kind)) terminalSeen = event.kind;
+    if (event.kind === "node_declared") declaredNodes.add(event.node_id);
+    if (NODE_LIFECYCLE_KINDS.has(event.kind) && "node_id" in event) {
+      if (
+        !declaredNodes.has(event.node_id) &&
+        !undeclaredReported.has(event.node_id)
+      ) {
+        undeclaredReported.add(event.node_id);
+        findings.push({
+          severity: "error",
+          code: "undeclared_node",
+          message:
+            `lifecycle event for node "${event.node_id}" that was never ` +
+            "declared (no node_declared event)",
+          path: journalPath,
+        });
+      }
+    }
+    if (event.kind === "attempt_started") {
+      const key = `${event.node_id}:${event.iteration ?? ""}`;
+      openAttempts.set(key, (openAttempts.get(key) ?? 0) + 1);
+    }
+    if (event.kind === "attempt_completed") {
+      const key = `${event.node_id}:${event.iteration ?? ""}`;
+      const open = openAttempts.get(key) ?? 0;
+      if (open <= 0) {
+        findings.push({
+          severity: "error",
+          code: "unmatched_attempt",
+          message: `attempt_completed (seq ${event.seq}) for node ` +
+            `"${event.node_id}" without a matching attempt_started`,
+          path: journalPath,
+        });
+      } else {
+        openAttempts.set(key, open - 1);
+      }
+      // Only successful attempts feed the cost expectation: the engine
+      // records spent cost on failed attempts too, but markNodeFailed
+      // never copies it into the node snapshot, so total_cost_usd
+      // legitimately excludes it.
+      if (event.cost_usd !== undefined && event.success === true) {
+        lastAttemptCost.set(event.node_id, event.cost_usd);
+      }
+    }
+  }
+
+  // Cost divergence: the replayer recomputes total_cost_usd from node
+  // snapshots, so the independent expectation comes from the journal's
+  // attempt-level costs (node cost = final attempt's cumulative cost),
+  // falling back to the replayed node cost for nodes without attempts.
+  const nodeIds = new Set([
+    ...Object.keys(replay.state.nodes),
+    ...lastAttemptCost.keys(),
+  ]);
+  let expectedTotal = 0;
+  for (const nodeId of nodeIds) {
+    expectedTotal += lastAttemptCost.get(nodeId) ??
+      replay.state.nodes[nodeId]?.cost_usd ?? 0;
+  }
+  const replayedTotal = replay.state.total_cost_usd ?? 0;
+  if (Math.abs(expectedTotal - replayedTotal) > COST_EPSILON) {
+    findings.push({
+      severity: "error",
+      code: "cost_divergence",
+      message: `replayed total_cost_usd ${replayedTotal} diverges from the ` +
+        `per-node cost sum ${expectedTotal}`,
+      path: journalPath,
+    });
+  }
+}
+
+/** Relative path of a declared node dir under the run dir, derived from
+ * the `node_directory_declared.node_dir` value (which the engine writes
+ * as `<workflowDir>/runs/<runId>/[<phase>/]<nodeId>`). */
+function declaredRelPath(nodeDir: string, runId: string): string {
+  const marker = `runs/${runId}/`;
+  const idx = nodeDir.lastIndexOf(marker);
+  if (idx !== -1) return nodeDir.slice(idx + marker.length);
+  const segments = nodeDir.split("/").filter((s) => s !== "");
+  return segments[segments.length - 1] ?? nodeDir;
+}
+
+/** Filesystem cross-check: orphan node dirs, declared-but-missing dirs,
+ * and a stale `runs/.lock` referencing this run. */
+async function checkFilesystem(
+  workflowDir: string,
+  runId: string,
+  events: RunJournalEvent[],
+  findings: DoctorFinding[],
+): Promise<{ staleLock: boolean }> {
+  const runDir = getRunDir(runId, workflowDir);
+  const declaredRel = new Set<string>();
+  const mentionedNodeIds = new Set<string>();
+  for (const event of events) {
+    if (event.kind === "node_directory_declared") {
+      declaredRel.add(declaredRelPath(event.node_dir, runId));
+    }
+    if ("node_id" in event) mentionedNodeIds.add(event.node_id);
+    if ("loop_node_id" in event) mentionedNodeIds.add(event.loop_node_id);
+  }
+
+  const reportOrphan = (rel: string) => {
+    findings.push({
+      severity: "warning",
+      code: "orphan_node_dir",
+      message:
+        `directory "${rel}" on disk is not mentioned by any journal event`,
+      path: `${runDir}/${rel}`,
+    });
+  };
+
+  for await (const entry of Deno.readDir(runDir)) {
+    if (!entry.isDirectory) continue;
+    const name = entry.name;
+    if (INFRA_DIR_NAMES.has(name)) continue;
+    if (declaredRel.has(name) || mentionedNodeIds.has(name)) continue;
+    const isPhasePrefix = [...declaredRel].some((rel) =>
+      rel.startsWith(`${name}/`)
+    );
+    if (!isPhasePrefix) {
+      reportOrphan(name);
+      continue;
+    }
+    for await (const child of Deno.readDir(`${runDir}/${name}`)) {
+      if (!child.isDirectory) continue;
+      const rel = `${name}/${child.name}`;
+      if (declaredRel.has(rel) || mentionedNodeIds.has(child.name)) continue;
+      reportOrphan(rel);
+    }
+  }
+
+  for (const rel of declaredRel) {
+    let exists = false;
+    try {
+      exists = (await Deno.stat(`${runDir}/${rel}`)).isDirectory;
+    } catch (error) {
+      if (!(error instanceof Deno.errors.NotFound)) throw error;
+    }
+    if (!exists) {
+      findings.push({
+        severity: "error",
+        code: "missing_declared_dir",
+        message:
+          `journal declares node directory "${rel}" but it is missing on disk`,
+        path: `${runDir}/${rel}`,
+      });
+    }
+  }
+
+  let staleLock = false;
+  const lockPath = defaultLockPath(workflowDir);
+  let lockInfo: LockInfo | undefined;
+  try {
+    lockInfo = await readLockInfo(lockPath);
+  } catch {
+    // No lock, or unreadable/corrupted lock — not this run's concern.
+  }
+  if (lockInfo?.run_id === runId && !(await isRunLive(workflowDir, runId))) {
+    staleLock = true;
+    findings.push({
+      severity: "warning",
+      code: "stale_lock",
+      message: `runs/.lock references this run but its process ` +
+        `(pid ${lockInfo.pid}) is no longer alive`,
+      path: lockPath,
+    });
+  }
+  return { staleLock };
+}
+
+/** Apply the safe mechanical repairs after refusal checks passed. */
+async function applyRepairs(
+  workflowDir: string,
+  runId: string,
+  scan: JournalScan,
+  staleLock: boolean,
+): Promise<DoctorRepair[]> {
+  const repairs: DoctorRepair[] = [];
+  const runDir = getRunDir(runId, workflowDir);
+  const journalPath = getJournalPath(runDir);
+
+  if (scan.tornTailByteLength !== undefined) {
+    const original = await Deno.readFile(journalPath);
+    await Deno.writeFile(`${journalPath}.bak`, original);
+    const tmpPath = `${journalPath}.tmp`;
+    await Deno.writeFile(
+      tmpPath,
+      original.slice(0, scan.tornTailByteLength),
+    );
+    await Deno.rename(tmpPath, journalPath);
+    repairs.push({
+      code: "torn_final_line_removed",
+      message:
+        "removed the torn final journal line (backup at journal.jsonl.bak)",
+      path: journalPath,
+    });
+  }
+
+  if (staleLock) {
+    const lockPath = defaultLockPath(workflowDir);
+    await Deno.remove(lockPath);
+    repairs.push({
+      code: "stale_lock_removed",
+      message: "removed stale runs/.lock referencing this run",
+      path: lockPath,
+    });
+  }
+  return repairs;
+}
+
+/** Render the severity-grouped human-readable report. */
+function formatReport(report: DoctorReport): string {
+  const lines: string[] = [
+    `Run doctor: ${report.run_id} (${report.workflow_dir})`,
+    "",
+  ];
+  for (const severity of ["error", "warning"] as const) {
+    const group = report.findings.filter((f) => f.severity === severity);
+    if (group.length === 0) continue;
+    lines.push(`${severity.toUpperCase()} (${group.length}):`);
+    for (const finding of group) {
+      lines.push(`  [${finding.code}] ${finding.message}`);
+      lines.push(`      ${finding.path}`);
+    }
+    lines.push("");
+  }
+  if (report.repair_refused !== undefined) {
+    lines.push(`Repair refused: ${report.repair_refused}`, "");
+  } else if (report.repairs.length > 0) {
+    lines.push(`Repairs applied (${report.repairs.length}):`);
+    for (const repair of report.repairs) {
+      lines.push(`  [${repair.code}] ${repair.message}`);
+      lines.push(`      ${repair.path}`);
+    }
+    lines.push("");
+  }
+  lines.push(
+    report.ok
+      ? `OK: no errors, ${report.warnings} warning(s).`
+      : `FAIL: ${report.errors} error(s), ${report.warnings} warning(s).`,
+  );
+  return lines.join("\n");
+}
+
+/** Diagnose one run and optionally repair it (FR-E83). Pure of stdout
+ * and process exit so unit tests can drive it on fabricated run dirs. */
+export async function runDoctor(options: DoctorOptions): Promise<DoctorResult> {
+  const { workflowDir, runId } = options;
+  const runDir = getRunDir(runId, workflowDir);
+  const findings: DoctorFinding[] = [];
+  let repairs: DoctorRepair[] = [];
+  let repairRefused: string | undefined;
+
+  let runDirExists = false;
+  try {
+    runDirExists = (await Deno.stat(runDir)).isDirectory;
+  } catch (error) {
+    if (!(error instanceof Deno.errors.NotFound)) throw error;
+  }
+
+  let staleLock = false;
+  let scan: JournalScan | undefined;
+  if (!runDirExists) {
+    findings.push({
+      severity: "error",
+      code: "run_dir_missing",
+      message: `run directory does not exist`,
+      path: runDir,
+    });
+  } else {
+    scan = await scanJournal(getJournalPath(runDir));
+    findings.push(...scan.findings);
+    if (!scan.missing) {
+      await checkReplayInvariants(runDir, findings);
+    }
+    ({ staleLock } = await checkFilesystem(
+      workflowDir,
+      runId,
+      scan.events,
+      findings,
+    ));
+  }
+
+  if (options.repair) {
+    const journalErrors = findings.filter(
+      (f) => f.severity === "error" && JOURNAL_ERROR_CODES.has(f.code),
+    );
+    if (await isRunLive(workflowDir, runId)) {
+      repairRefused =
+        "the run is currently active (runs/.lock held by a live process); " +
+        "nothing was modified";
+    } else if (journalErrors.length > 0) {
+      repairRefused =
+        `the journal has ${journalErrors.length} error(s) beyond the torn ` +
+        "final line; doctor does not guess at semantic repairs — nothing " +
+        "was modified";
+    } else if (scan) {
+      repairs = await applyRepairs(workflowDir, runId, scan, staleLock);
+    }
+  }
+
+  const errors = findings.filter((f) => f.severity === "error").length;
+  const warnings = findings.filter((f) => f.severity === "warning").length;
+  const report: DoctorReport = {
+    run_id: runId,
+    workflow_dir: workflowDir,
+    findings,
+    repairs,
+    ...(repairRefused !== undefined ? { repair_refused: repairRefused } : {}),
+    errors,
+    warnings,
+    ok: errors === 0,
+  };
+  const exitCode = errors === 0 && repairRefused === undefined ? 0 : 1;
+  const output = options.json
+    ? JSON.stringify(report, null, 2)
+    : formatReport(report);
+  return { report, output, exitCode };
+}
