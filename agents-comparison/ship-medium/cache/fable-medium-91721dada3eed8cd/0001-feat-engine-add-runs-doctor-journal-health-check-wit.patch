+    "20260611T120000",
+    "--repair",
+    "--json",
+  ]);
+  assertEquals(parsed.workflowDir, ".flowai-workflow/github-inbox");
+  assertEquals(parsed.runId, "20260611T120000");
+  assertEquals(parsed.repair, true);
+  assertEquals(parsed.json, true);
+});
+
+Deno.test("parseRunsDoctorArgs — defaults and missing --run rejects", () => {
+  const parsed = parseRunsDoctorArgs(["--run", "r1"]);
+  assertEquals(parsed.workflowDir, undefined);
+  assertEquals(parsed.repair, false);
+  assertEquals(parsed.json, false);
+  assertThrows(
+    () => parseRunsDoctorArgs(["--workflow", "wf"]),
+    Error,
+    "--run",
+  );
+});
+
+Deno.test("parseRunsDoctorArgs — unexpected positional rejects", () => {
+  assertThrows(
+    () => parseRunsDoctorArgs(["--run", "r1", "stray"]),
+    Error,
+    "stray",
+  );
+});
+
+Deno.test("CLI --help — mentions runs doctor (FR-E83)", () => {
+  const usage = getUsageText();
+  assert(usage.includes("runs doctor"));
+  assert(usage.includes("--repair"));
+});
