+/** Parsed flags for the `runs doctor` subcommand (FR-E83). */
+export interface RunsDoctorArgs {
+  /** Workflow folder (trailing slashes stripped). `undefined` when the
+   * user did not pass `--workflow <dir>`; the caller falls back to the
+   * shared `resolveActiveWorkflow` resolver (FR-E78). */
+  workflowDir: string | undefined;
+  /** Run id to diagnose. */
+  runId: string;
+  /** Apply safe mechanical repairs. */
+  repair: boolean;
+  /** Emit machine-readable JSON findings. */
+  json: boolean;
+}
+
+/**
+ * Parse `runs doctor [--workflow <dir>] --run <id> [--repair] [--json]`
+ * (FR-E83). Flags only — no positionals are accepted. `--workflow <dir>`
+ * and `--workflow=<dir>` (likewise `--run`) are both accepted, matching
+ * the `answer` subcommand's style.
+ */
+export function parseRunsDoctorArgs(args: string[]): RunsDoctorArgs {
+  let workflow: string | undefined;
+  let runId: string | undefined;
+  let repair = false;
+  let json = false;
+  for (let i = 0; i < args.length; i++) {
+    const a = args[i];
+    if (a === "--workflow") {
+      workflow = args[++i];
+      continue;
+    }
+    if (a.startsWith("--workflow=")) {
+      workflow = a.slice("--workflow=".length);
+      continue;
+    }
+    if (a === "--run") {
+      runId = args[++i];
+      continue;
+    }
+    if (a.startsWith("--run=")) {
+      runId = a.slice("--run=".length);
+      continue;
+    }
+    if (a === "--repair") {
+      repair = true;
+      continue;
+    }
