+} from "./run-journal.ts";
+import type { RunJournalEvent } from "../types.ts";
+
+const RUN_ID = "run-doctor";
+
+async function withWorkflow(
+  fn: (workflowDir: string, runDir: string) => Promise<void>,
+): Promise<void> {
+  const workflowDir = await Deno.makeTempDir();
+  const runDir = join(workflowDir, "runs", RUN_ID);
+  try {
+    await Deno.mkdir(runDir, { recursive: true });
+    await fn(workflowDir, runDir);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+}
+
+async function writeCleanJournal(runDir: string): Promise<RunJournalEvent[]> {
+  const writer = await RunJournalWriter.open(runDir, RUN_ID);
+  await writer.append({
+    kind: "run_started",
+    config_path: "workflow.yaml",
+    started_at: "2026-06-11T00:00:00.000Z",
+    args: {},
+    env: {},
+  });
+  await writer.append({
+    kind: "workflow_loaded",
+    config_path: "workflow.yaml",
+    name: "doctor-test",
+    version: "1",
+  });
+  await writer.append({
+    kind: "node_declared",
+    node_id: "build",
+    node_type: "agent",
+    label: "Build",
+  });
+  await writer.append({
+    kind: "node_directory_declared",
+    node_id: "build",
+    node_dir: join(runDir, "build"),
+  });
+  await Deno.mkdir(join(runDir, "build"), { recursive: true });
+  await writer.append({
+    kind: "attempt_started",
+    node_id: "build",
+  });
+  await writer.append({
+    kind: "attempt_completed",
+    node_id: "build",
+    continuations: 0,
+    cost_usd: 0.25,
+    success: true,
+  });
+  await writer.append({
+    kind: "node_completed",
+    node_id: "build",
+    status: "completed",
+    timestamp: "2026-06-11T00:00:01.000Z",
+    node: {
+      status: "completed",
+      cost_usd: 0.25,
+      completed_at: "2026-06-11T00:00:01.000Z",
+    },
+    metadata: {},
+  });
+  await writer.append({
+    kind: "run_completed",
+    status: "completed",
+    completed_at: "2026-06-11T00:00:02.000Z",
+  });
+  return (await replayRunJournal(runDir)).events;
+}
+
+function codes(findings: RunDoctorFinding[]): string[] {
+  return findings.map((finding) => finding.code).sort();
+}
