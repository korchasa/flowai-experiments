+/** Parse `runs doctor --workflow <dir> --run <runId> [--repair] [--json]`. */
+export function parseRunsDoctorArgs(args: string[]): RunsDoctorArgs {
+  const [subcommand, ...rest] = args;
+  if (subcommand !== "doctor") {
+    throw new Error(
+      "runs: missing subcommand. Usage: flowai-workflow runs doctor " +
+        "--workflow <dir> --run <run-id> [--repair] [--json]",
+    );
+  }
+  let workflowDir: string | undefined;
+  let runId: string | undefined;
+  let repair = false;
+  let json = false;
+  for (let i = 0; i < rest.length; i++) {
+    const arg = rest[i];
+    if (arg === "--workflow") {
+      workflowDir = normalizeWorkflowDir(rest[++i] ?? "");
+      continue;
+    }
+    if (arg.startsWith("--workflow=")) {
+      workflowDir = normalizeWorkflowDir(arg.slice("--workflow=".length));
+      continue;
+    }
+    if (arg === "--run") {
+      runId = rest[++i];
+      continue;
+    }
+    if (arg.startsWith("--run=")) {
+      runId = arg.slice("--run=".length);
+      continue;
+    }
+    if (arg === "--repair") {
+      repair = true;
+      continue;
+    }
+    if (arg === "--json") {
+      json = true;
+      continue;
+    }
+    throw new Error(`runs doctor: unknown argument '${arg}'`);
+  }
+  if (!workflowDir) {
+    throw new Error("runs doctor: missing --workflow <dir>");
+  }
+  if (!runId) {
+    throw new Error("runs doctor: missing --run <run-id>");
+  }
+  return { workflowDir, runId, repair, json };
+}
