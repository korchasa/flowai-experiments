+Deno.test("FR-E83 repair refusal", async () => {
+  await withWorkflow(async (workflowDir, runDir) => {
+    await writeCleanJournal(runDir);
+    await Deno.writeTextFile(getJournalPath(runDir), "{bad\n", {
+      append: true,
+    });
+    const corruptBefore = await Deno.readTextFile(getJournalPath(runDir));
+
+    const corruptRepair = await doctorRun({
+      workflowDir,
+      runId: RUN_ID,
+      repair: true,
+    });
+
+    assertEquals(corruptRepair.hasErrors, true);
+    assertEquals(codes(corruptRepair.findings), [
+      "JOURNAL_MALFORMED_LINE",
+      "REPAIR_REFUSED",
+    ]);
+    assertEquals(
+      await Deno.readTextFile(getJournalPath(runDir)),
+      corruptBefore,
+    );
+
+    const cleanText = corruptBefore.slice(0, -6);
+    const cleanLines = cleanText.trimEnd().split("\n");
+    const postTerminal = {
+      kind: "workflow_loaded",
+      schema_version: 1,
+      run_id: RUN_ID,
+      seq: 99,
+      event_id: "post-terminal-refusal",
+      ts: "2026-06-11T00:00:03.000Z",
+      config_path: "workflow.yaml",
+      name: "doctor-test",
+      version: "1",
+    };
+    await Deno.writeTextFile(
+      getJournalPath(runDir),
+      [...cleanLines, JSON.stringify(postTerminal), ""].join("\n"),
+    );
+    await Deno.writeTextFile(
+      defaultLockPath(workflowDir),
+      JSON.stringify({
+        pid: 99999999,
+        hostname: "test",
+        run_id: RUN_ID,
+        started_at: "2026-06-11T00:00:00.000Z",
+      }) + "\n",
+    );
+
+    const semanticRepair = await doctorRun({
+      workflowDir,
+      runId: RUN_ID,
+      repair: true,
+    });
+
+    assertEquals(codes(semanticRepair.findings), [
+      "EVENT_AFTER_TERMINAL",
+      "REPAIR_REFUSED",
+      "STALE_LOCK",
+    ]);
+    assert(await Deno.stat(defaultLockPath(workflowDir)));
+
+    await Deno.writeTextFile(getJournalPath(runDir), cleanText);
+    await Deno.writeTextFile(
+      defaultLockPath(workflowDir),
+      JSON.stringify({
+        pid: Deno.pid,
+        hostname: "test",
+        run_id: RUN_ID,
+        started_at: "2026-06-11T00:00:00.000Z",
+      }) + "\n",
+    );
+
+    const liveRepair = await doctorRun({
+      workflowDir,
+      runId: RUN_ID,
+      repair: true,
+    });
+
+    assertEquals(codes(liveRepair.findings), ["REPAIR_REFUSED"]);
+    assertObjectMatch(liveRepair.findings[0], { severity: "ERROR" });
+  });
+});
