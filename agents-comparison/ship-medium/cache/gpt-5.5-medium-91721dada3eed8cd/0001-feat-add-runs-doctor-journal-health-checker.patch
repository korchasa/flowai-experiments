index 0000000..f1c3be3
--- /dev/null
+++ b/src/state/run-doctor.ts
@@ -0,0 +1,550 @@
+import { isAbsolute, join, relative } from "@std/path";
+import type { RunJournalEvent, RunJournalEventKind } from "../types.ts";
+import { defaultLockPath, isProcessAlive, readLockInfo } from "./lock.ts";
+import { getJournalPath, replayRunJournal } from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+
+export type RunDoctorSeverity = "ERROR" | "WARNING";
+
+export interface RunDoctorFinding {
+  severity: RunDoctorSeverity;
+  code: string;
+  message: string;
+  evidence_path: string;
+}
+
+export interface RunDoctorRepair {
+  code: string;
+  message: string;
+  evidence_path: string;
+}
+
+export interface RunDoctorOptions {
+  workflowDir: string;
+  runId: string;
+  repair?: boolean;
+}
+
+export interface RunDoctorReport {
+  workflowDir: string;
+  runId: string;
+  runDir: string;
+  findings: RunDoctorFinding[];
+  repairs: RunDoctorRepair[];
+  hasErrors: boolean;
+}
+
+interface ParsedJournal {
+  events: RunJournalEvent[];
+  findings: RunDoctorFinding[];
+  tornFinalLine: boolean;
+  validPrefix: string;
+  fullText: string;
+}
+
+const knownKinds = new Set<RunJournalEventKind>([
+  "run_started",
+  "run_metadata_updated",
+  "workflow_loaded",
+  "node_declared",
+  "node_directory_declared",
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+  "attempt_started",
+  "attempt_completed",
+  "continuation_exhausted",
+  "loop_iteration_started",
+  "loop_iteration_completed",
+  "loop_iteration_failed",
+  "run_completed",
+  "run_failed",
+  "run_aborted",
+]);
+
+const terminalKinds = new Set(["run_completed", "run_failed", "run_aborted"]);
+const lifecycleKinds = new Set([
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+]);
+
+export async function doctorRun(
+  options: RunDoctorOptions,
+): Promise<RunDoctorReport> {
+  const workflowDir = options.workflowDir;
+  const runId = options.runId;
+  const runDir = getRunDir(runId, workflowDir);
+  const repairs: RunDoctorRepair[] = [];
+  const parsed = await parseJournalForDoctor(runDir);
+  const findings = [...parsed.findings];
+  const lock = await inspectLock(workflowDir, runId);
+  if (lock.finding) findings.push(lock.finding);
+
+  inspectRawJournalEvents(parsed.events, findings, getJournalPath(runDir));
+
+  const hasBlockingParseError = findings.some((finding) =>
+    finding.severity === "ERROR" &&
+    finding.code === "JOURNAL_MALFORMED_LINE"
+  );
+
+  if (!hasBlockingParseError) {
+    try {
+      const replay = await replayRunJournal(runDir);
+      inspectReplayInvariants(parsed.events, replay.state, findings, runDir);
+    } catch (error) {
+      findings.push({
+        severity: "ERROR",
+        code: "REPLAY_FAILED",
+        message: error instanceof Error ? error.message : String(error),
+        evidence_path: getJournalPath(runDir),
+      });
+    }
+  } else {
+    inspectReplayInvariants(parsed.events, undefined, findings, runDir);
+  }
+
+  await inspectFilesystem(runDir, parsed.events, findings);
+
+  if (options.repair) {
+    await applyRepairs({
+      workflowDir,
+      runId,
+      runDir,
+      parsed,
+      findings,
+      lock,
+      repairs,
+    });
+  }
+
+  return {
+    workflowDir,
+    runId,
+    runDir,
+    findings,
+    repairs,
+    hasErrors: findings.some((finding) => finding.severity === "ERROR"),
+  };
+}
+
+export function formatDoctorReport(report: RunDoctorReport): string {
+  const errors = report.findings.filter((finding) =>
+    finding.severity === "ERROR"
+  );
+  const warnings = report.findings.filter((finding) =>
+    finding.severity === "WARNING"
+  );
+  const lines = [
+    `Run doctor: ${report.runId}`,
+    `Workflow: ${report.workflowDir}`,
+    "",
+    "ERROR",
+    ...formatFindingGroup(errors),
+    "",
+    "WARNING",
+    ...formatFindingGroup(warnings),
+    "",
+    "REPAIR",
+    ...(report.repairs.length === 0
+      ? ["- none"]
+      : report.repairs.map((repair) =>
+        `- ${repair.code}: ${repair.message} (${repair.evidence_path})`
+      )),
+    "",
+    `OK: ${errors.length === 0 ? "no errors" : `${errors.length} error(s)`}; ` +
+    `${warnings.length} warning(s)`,
+  ];
+  return `${lines.join("\n")}\n`;
+}
+
+function formatFindingGroup(findings: RunDoctorFinding[]): string[] {
+  if (findings.length === 0) return ["- none"];
+  return findings.map((finding) =>
+    `- ${finding.code}: ${finding.message} (${finding.evidence_path})`
+  );
+}
+
+async function parseJournalForDoctor(runDir: string): Promise<ParsedJournal> {
+  const journalPath = getJournalPath(runDir);
+  let fullText = "";
+  try {
+    fullText = await Deno.readTextFile(journalPath);
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) {
+      return {
+        events: [],
+        findings: [{
+          severity: "ERROR",
+          code: "JOURNAL_MISSING",
+          message: "journal.jsonl is missing",
+          evidence_path: journalPath,
+        }],
+        tornFinalLine: false,
+        validPrefix: "",
+        fullText: "",
+      };
+    }
+    throw error;
+  }
+
+  const endedWithNewline = fullText.endsWith("\n");
+  const lines = fullText.split("\n");
+  if (endedWithNewline) lines.pop();
+
+  const events: RunJournalEvent[] = [];
+  const findings: RunDoctorFinding[] = [];
+  let tornFinalLine = false;
+  let validPrefixEnd = 0;
+  let lineStart = 0;
+
+  for (let i = 0; i < lines.length; i++) {
+    const line = lines[i];
+    const nextLineStart = lineStart + line.length + 1;
+    if (line.trim() === "") {
+      validPrefixEnd = nextLineStart;
+      lineStart = nextLineStart;
+      continue;
+    }
+    try {
+      const event = JSON.parse(line) as RunJournalEvent;
+      events.push(event);
+      validPrefixEnd = nextLineStart;
+    } catch (error) {
+      const isFinal = i === lines.length - 1 && !endedWithNewline;
+      findings.push({
+        severity: isFinal ? "WARNING" : "ERROR",
+        code: isFinal ? "JOURNAL_TORN_FINAL_LINE" : "JOURNAL_MALFORMED_LINE",
+        message: isFinal
+          ? "final journal line is truncated or garbage"
+          : `journal line ${i + 1} is not valid JSON: ${
+            error instanceof Error ? error.message : String(error)
+          }`,
+        evidence_path: `${journalPath}:${i + 1}`,
+      });
+      if (isFinal) tornFinalLine = true;
+    }
+    lineStart = nextLineStart;
+  }
+
+  return {
+    events,
+    findings,
+    tornFinalLine,
+    validPrefix: fullText.slice(0, validPrefixEnd),
+    fullText,
+  };
+}
+
+function inspectRawJournalEvents(
+  events: RunJournalEvent[],
+  findings: RunDoctorFinding[],
+  journalPath: string,
+): void {
+  const eventIds = new Set<string>();
+  let previousSeq: number | undefined;
+
+  for (const event of events) {
+    if (!knownKinds.has(event.kind)) {
+      findings.push({
+        severity: "ERROR",
+        code: "UNKNOWN_EVENT_KIND",
+        message: `unknown journal event kind '${event.kind}'`,
+        evidence_path: journalPath,
+      });
+    }
+    if (typeof event.seq !== "number" || !Number.isFinite(event.seq)) {
+      findings.push({
+        severity: "ERROR",
+        code: "NON_MONOTONIC_SEQ",
+        message: `event '${event.event_id}' has invalid seq`,
+        evidence_path: journalPath,
+      });
+    } else if (previousSeq !== undefined && event.seq <= previousSeq) {
+      findings.push({
+        severity: "ERROR",
+        code: "NON_MONOTONIC_SEQ",
+        message: `seq ${event.seq} is not greater than ${previousSeq}`,
+        evidence_path: journalPath,
+      });
+    }
+    if (event.event_id && eventIds.has(event.event_id)) {
+      findings.push({
+        severity: "WARNING",
+        code: "DUPLICATE_EVENT_ID",
+        message: `duplicate event_id '${event.event_id}'`,
+        evidence_path: journalPath,
+      });
+    }
+    eventIds.add(event.event_id);
+    previousSeq = typeof event.seq === "number" ? event.seq : previousSeq;
+  }
+}
+
+function inspectReplayInvariants(
+  events: RunJournalEvent[],
+  state:
+    | { total_cost_usd?: number; nodes: Record<string, { cost_usd?: number }> }
+    | undefined,
+  findings: RunDoctorFinding[],
+  runDir: string,
+): void {
+  const journalPath = getJournalPath(runDir);
+  const declared = new Set<string>();
+  const startedAttempts = new Map<string, number>();
+  let terminalSeen = false;
+
+  for (const event of events) {
+    if (terminalSeen) {
+      findings.push({
+        severity: "ERROR",
+        code: "EVENT_AFTER_TERMINAL",
+        message: `event '${event.kind}' appears after terminal run event`,
+        evidence_path: journalPath,
+      });
+    }
+    if (terminalKinds.has(event.kind)) terminalSeen = true;
+
+    if (event.kind === "node_declared") declared.add(event.node_id);
+    if (lifecycleKinds.has(event.kind) && "node_id" in event) {
+      if (!declared.has(event.node_id)) {
+        findings.push({
+          severity: "ERROR",
+          code: "NODE_EVENT_UNDECLARED",
+          message:
+            `node lifecycle event references undeclared node '${event.node_id}'`,
+          evidence_path: journalPath,
+        });
+      }
+    }
+    if (event.kind === "attempt_started") {
+      const key = attemptKey(event.node_id, event.iteration);
+      startedAttempts.set(key, (startedAttempts.get(key) ?? 0) + 1);
+    }
+    if (event.kind === "attempt_completed") {
+      const key = attemptKey(event.node_id, event.iteration);
+      const count = startedAttempts.get(key) ?? 0;
+      if (count === 0) {
+        findings.push({
+          severity: "ERROR",
+          code: "ATTEMPT_WITHOUT_START",
+          message:
+            `attempt_completed has no matching attempt_started for '${event.node_id}'`,
+          evidence_path: journalPath,
+        });
+      } else {
+        startedAttempts.set(key, count - 1);
+      }
+    }
+  }
+
+  if (state) {
+    const sum = Object.values(state.nodes).reduce((acc, node) => {
+      return acc + (typeof node.cost_usd === "number" ? node.cost_usd : 0);
+    }, 0);
+    if ((state.total_cost_usd ?? 0) !== sum) {
+      findings.push({
+        severity: "ERROR",
+        code: "COST_DIVERGENCE",
+        message:
+          `replayed total_cost_usd (${state.total_cost_usd}) differs from per-node sum (${sum})`,
+        evidence_path: journalPath,
+      });
+    }
+  }
+}
+
+function attemptKey(nodeId: string, iteration: number | undefined): string {
+  return `${nodeId}:${iteration ?? ""}`;
+}
+
+async function inspectFilesystem(
+  runDir: string,
+  events: RunJournalEvent[],
+  findings: RunDoctorFinding[],
+): Promise<void> {
+  const declared = new Set(
+    events
+      .filter((event) => event.kind === "node_directory_declared")
+      .map((event) =>
+        normalizePath(resolveEvidencePath(runDir, event.node_dir))
+      ),
+  );
+  for (const dir of declared) {
+    try {
+      const stat = await Deno.stat(dir);
+      if (!stat.isDirectory) throw new Error("not a directory");
+    } catch {
+      findings.push({
+        severity: "ERROR",
+        code: "MISSING_DECLARED_NODE_DIR",
+        message: `declared node directory is missing: ${dir}`,
+        evidence_path: dir,
+      });
+    }
+  }
+
+  const dirs = await listRunDirs(runDir);
+  for (const dir of dirs) {
+    const normalized = normalizePath(dir);
+    if (declared.has(normalized)) continue;
+    const isParentOfDeclared = [...declared].some((declaredDir) =>
+      relative(normalized, declaredDir).split("/")[0] !== ".." &&
+      relative(normalized, declaredDir) !== ""
+    );
+    if (isParentOfDeclared) continue;
+    findings.push({
+      severity: "WARNING",
+      code: "ORPHAN_NODE_DIR",
+      message:
+        `directory is not mentioned by journal node_directory_declared events: ${dir}`,
+      evidence_path: dir,
+    });
+  }
+}
+
+async function listRunDirs(runDir: string): Promise<string[]> {
+  const dirs: string[] = [];
+  async function walk(dir: string): Promise<void> {
+    let entries: Deno.DirEntry[];
+    try {
+      entries = [];
+      for await (const entry of Deno.readDir(dir)) entries.push(entry);
+    } catch (error) {
+      if (error instanceof Deno.errors.NotFound) return;
+      throw error;
+    }
+    for (const entry of entries) {
+      if (!entry.isDirectory) continue;
+      if (["logs", "worktree", ".hitl-inbox"].includes(entry.name)) continue;
+      const path = join(dir, entry.name);
+      dirs.push(path);
+      await walk(path);
+    }
+  }
+  await walk(runDir);
+  return dirs;
+}
+
+function resolveEvidencePath(runDir: string, path: string): string {
+  if (isAbsolute(path) || path.startsWith(runDir)) return path;
+  return join(Deno.cwd(), path);
+}
+
+function normalizePath(path: string): string {
+  return path.replaceAll("\\", "/").replace(/\/+$/, "");
+}
+
+async function inspectLock(
+  workflowDir: string,
+  runId: string,
+): Promise<{
+  liveForRun: boolean;
+  staleForRun: boolean;
+  finding?: RunDoctorFinding;
+}> {
+  const lockPath = defaultLockPath(workflowDir);
+  try {
+    const lock = await readLockInfo(lockPath);
+    if (lock.run_id !== runId) {
+      return { liveForRun: false, staleForRun: false };
+    }
+    const alive = isProcessAlive(lock.pid);
+    if (alive) return { liveForRun: true, staleForRun: false };
+    return {
+      liveForRun: false,
+      staleForRun: true,
+      finding: {
+        severity: "WARNING",
+        code: "STALE_LOCK",
+        message:
+          `runs/.lock references run '${runId}' with dead pid ${lock.pid}`,
+        evidence_path: lockPath,
+      },
+    };
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) {
+      return { liveForRun: false, staleForRun: false };
+    }
+    return {
+      liveForRun: false,
+      staleForRun: false,
+      finding: {
+        severity: "ERROR",
+        code: "LOCK_UNREADABLE",
+        message: error instanceof Error ? error.message : String(error),
+        evidence_path: lockPath,
+      },
+    };
+  }
+}
+
+async function applyRepairs(args: {
+  workflowDir: string;
+  runId: string;
+  runDir: string;
+  parsed: ParsedJournal;
+  findings: RunDoctorFinding[];
+  lock: { liveForRun: boolean; staleForRun: boolean };
+  repairs: RunDoctorRepair[];
+}): Promise<void> {
+  const journalErrorCodes = new Set([
+    "JOURNAL_MISSING",
+    "JOURNAL_MALFORMED_LINE",
+    "UNKNOWN_EVENT_KIND",
+    "NON_MONOTONIC_SEQ",
+    "REPLAY_FAILED",
+    "EVENT_AFTER_TERMINAL",
+    "NODE_EVENT_UNDECLARED",
+    "ATTEMPT_WITHOUT_START",
+    "COST_DIVERGENCE",
+  ]);
+  const journalErrors = args.findings.filter((finding) =>
+    finding.severity === "ERROR" && journalErrorCodes.has(finding.code)
+  );
+  if (args.lock.liveForRun) {
+    args.findings.push({
+      severity: "ERROR",
+      code: "REPAIR_REFUSED",
+      message: `run '${args.runId}' is currently active`,
+      evidence_path: defaultLockPath(args.workflowDir),
+    });
+    return;
+  }
+  if (journalErrors.length > 0) {
+    args.findings.push({
+      severity: "ERROR",
+      code: "REPAIR_REFUSED",
+      message: "journal has errors beyond a torn final line",
+      evidence_path: getJournalPath(args.runDir),
+    });
+    return;
+  }
+
+  if (args.parsed.tornFinalLine) {
+    const journalPath = getJournalPath(args.runDir);
+    await Deno.writeTextFile(`${journalPath}.bak`, args.parsed.fullText);
+    const tmpPath = `${journalPath}.tmp`;
+    await Deno.writeTextFile(tmpPath, args.parsed.validPrefix);
+    await Deno.rename(tmpPath, journalPath);
+    args.repairs.push({
+      code: "REPAIR_TORN_FINAL_LINE",
+      message: "removed torn final journal line",
+      evidence_path: journalPath,
+    });
+  }
+
+  if (args.lock.staleForRun) {
+    const lockPath = defaultLockPath(args.workflowDir);
+    await Deno.remove(lockPath);
+    args.repairs.push({
+      code: "REPAIR_STALE_LOCK",
+      message: "removed stale runs/.lock",
+      evidence_path: lockPath,
+    });
+  }
+}
