+/**
+ * @module
+ * Run journal health checker and safe mechanical repair utility (FR-E83).
+ */
+
+import { basename, isAbsolute, join, normalize } from "@std/path";
+import type { RunJournalEvent, RunJournalEventKind } from "../types.ts";
+import { defaultLockPath, readLockInfo } from "./lock.ts";
+import { getJournalPath, replayRunJournal } from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+
+export type DoctorSeverity = "ERROR" | "WARNING" | "OK";
+
+export interface DoctorFinding {
+  severity: DoctorSeverity;
+  code: string;
+  message: string;
+  evidence_path: string;
+}
+
+export interface DoctorReport {
+  workflowDir: string;
+  runId: string;
+  runDir: string;
+  findings: DoctorFinding[];
+  hasErrors: boolean;
+}
+
+export interface DoctorOptions {
+  workflowDir: string;
+  runId: string;
+}
+
+interface ParsedJournal {
+  events: RunJournalEvent[];
+  findings: DoctorFinding[];
+  ignoredPartialTail: boolean;
+  validContent: string;
+  tornTailContent: string;
+}
+
+const TERMINAL_KINDS = new Set<RunJournalEventKind>([
+  "run_completed",
+  "run_failed",
+  "run_aborted",
+]);
+
+const NODE_LIFECYCLE_KINDS = new Set<RunJournalEventKind>([
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+]);
+
+// Keep this set aligned with RunJournalEventKind in ../types.ts.
+const KNOWN_EVENT_KINDS = new Set<string>([
+  "run_started",
+  "run_metadata_updated",
+  "workflow_loaded",
+  "node_declared",
+  "node_directory_declared",
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+  "attempt_started",
+  "attempt_completed",
+  "continuation_exhausted",
+  "loop_iteration_started",
+  "loop_iteration_completed",
+  "loop_iteration_failed",
+  "run_completed",
+  "run_failed",
+  "run_aborted",
+]);
+
+const IGNORED_RUN_DIRS = new Set(["logs", "worktree"]);
+
+export async function doctorRun(options: DoctorOptions): Promise<DoctorReport> {
+  const runDir = getRunDir(options.runId, options.workflowDir);
+  const parsed = await parseJournalForDoctor(runDir);
+  const findings = [...parsed.findings];
+
+  if (!findings.some((finding) => finding.code === "JOURNAL_MISSING")) {
+    findings.push(...await inspectReplay(runDir, parsed.events));
+    findings.push(
+      ...await inspectFilesystem(options.workflowDir, runDir, parsed.events),
+    );
+  }
+
+  if (!findings.some((finding) => finding.severity !== "OK")) {
+    findings.push({
+      severity: "OK",
+      code: "OK",
+      message: "Run durability artifacts look healthy.",
+      evidence_path: runDir,
+    });
+  }
+
+  return buildReport(options.workflowDir, options.runId, runDir, findings);
+}
+
+export async function repairRun(options: DoctorOptions): Promise<DoctorReport> {
+  const runDir = getRunDir(options.runId, options.workflowDir);
+  const liveLockFinding = await inspectLiveLock(options.workflowDir, runDir);
+  if (liveLockFinding) {
+    throw new Error(
+      `Refusing repair: run is currently active (${liveLockFinding.message}).`,
+    );
+  }
+
+  const parsed = await parseJournalForDoctor(runDir);
+  const initialFindings = [
+    ...parsed.findings,
+    ...await inspectReplay(runDir, parsed.events),
+    ...await inspectFilesystem(options.workflowDir, runDir, parsed.events),
+  ];
+
+  const disallowedJournalError = initialFindings.find((finding) =>
+    finding.severity === "ERROR" && isJournalRepairBlocker(finding.code)
+  );
+  if (disallowedJournalError) {
+    throw new Error(
+      "Refusing repair: journal has errors beyond a torn final line.",
+    );
+  }
+
+  const repairFindings: DoctorFinding[] = [];
+  if (parsed.ignoredPartialTail) {
+    await rewriteJournalWithoutTail(runDir, parsed.validContent);
+    repairFindings.push({
+      severity: "OK",
+      code: "REPAIR_TORN_FINAL_LINE",
+      message: "Backed up journal.jsonl and removed torn final line.",
+      evidence_path: getJournalPath(runDir),
+    });
+  }
+
+  const staleLock = initialFindings.find((finding) =>
+    finding.code === "STALE_LOCK"
+  );
+  if (staleLock) {
+    await Deno.remove(defaultLockPath(options.workflowDir));
+    repairFindings.push({
+      severity: "OK",
+      code: "REPAIR_STALE_LOCK",
+      message: "Removed stale workflow lock for this run.",
+      evidence_path: defaultLockPath(options.workflowDir),
+    });
+  }
+
+  return buildReport(options.workflowDir, options.runId, runDir, [
+    ...initialFindings,
+    ...repairFindings,
+  ]);
+}
+
+export function formatDoctorJson(report: DoctorReport): string {
+  return JSON.stringify({ findings: report.findings }, null, 2);
+}
+
+export function formatDoctorReport(report: DoctorReport): string {
+  const lines = [
+    `Run doctor: ${report.runId}`,
+    `Run dir: ${report.runDir}`,
+  ];
+  for (const severity of ["ERROR", "WARNING", "OK"] as const) {
+    const group = report.findings.filter((finding) =>
+      finding.severity === severity
+    );
+    if (group.length === 0) continue;
+    lines.push("", severity);
+    for (const finding of group) {
+      lines.push(
+        `- ${finding.code}: ${finding.message} (${finding.evidence_path})`,
+      );
+    }
+  }
+  return `${lines.join("\n")}\n`;
+}
+
+async function parseJournalForDoctor(runDir: string): Promise<ParsedJournal> {
+  const journalPath = getJournalPath(runDir);
+  let content: string;
+  try {
+    content = await Deno.readTextFile(journalPath);
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) {
+      return {
+        events: [],
+        findings: [{
+          severity: "ERROR",
+          code: "JOURNAL_MISSING",
+          message: "journal.jsonl is missing.",
+          evidence_path: journalPath,
+        }],
+        ignoredPartialTail: false,
+        validContent: "",
+        tornTailContent: "",
+      };
+    }
+    throw error;
+  }
+
+  const lines = content.split("\n");
+  const endedWithNewline = content.endsWith("\n");
+  if (endedWithNewline) lines.pop();
+
+  const events: RunJournalEvent[] = [];
+  const findings: DoctorFinding[] = [];
+  let validContent = content;
+  let tornTailContent = "";
+  let lineStart = 0;
+  let previousSeq: number | undefined;
+  const seenEventIds = new Set<string>();
+
+  for (let i = 0; i < lines.length; i++) {
+    const line = lines[i];
+    const nextLineStart = lineStart + line.length + 1;
+    if (line.trim() === "") {
+      lineStart = nextLineStart;
+      continue;
+    }
+    let raw: unknown;
+    try {
+      raw = JSON.parse(line);
+    } catch (error) {
+      const isTail = i === lines.length - 1 && !endedWithNewline;
+      if (isTail) {
+        validContent = content.slice(0, lineStart);
+        tornTailContent = content.slice(lineStart);
+        findings.push({
+          severity: "WARNING",
+          code: "TORN_FINAL_LINE",
+          message:
+            "Final journal line is truncated or garbage and will be ignored by replay.",
+          evidence_path: `${journalPath}:${i + 1}`,
+        });
+      } else {
+        findings.push({
+          severity: "ERROR",
+          code: "JOURNAL_PARSE_ERROR",
+          message: `Journal line is not valid JSON: ${
+            error instanceof Error ? error.message : String(error)
+          }`,
+          evidence_path: `${journalPath}:${i + 1}`,
+        });
+      }
+      lineStart = nextLineStart;
+      continue;
+    }
+
+    const event = raw as RunJournalEvent;
+    events.push(event);
+    if (!KNOWN_EVENT_KINDS.has(String(event.kind))) {
+      findings.push({
+        severity: "ERROR",
+        code: "UNKNOWN_EVENT_KIND",
+        message: `Unknown journal event kind '${String(event.kind)}'.`,
+        evidence_path: `${journalPath}:${i + 1}`,
+      });
+    }
+    if (previousSeq !== undefined && event.seq <= previousSeq) {
+      findings.push({
+        severity: "ERROR",
+        code: "NON_MONOTONIC_SEQ",
+        message:
+          `Sequence ${event.seq} is not greater than previous sequence ${previousSeq}.`,
+        evidence_path: `${journalPath}:${i + 1}`,
+      });
+    }
+    previousSeq = typeof event.seq === "number" ? event.seq : previousSeq;
+    if (seenEventIds.has(event.event_id)) {
+      findings.push({
+        severity: "WARNING",
+        code: "DUPLICATE_EVENT_ID",
+        message:
+          `Duplicate event_id '${event.event_id}' will be deduplicated by replay.`,
+        evidence_path: `${journalPath}:${i + 1}`,
+      });
+    } else {
+      seenEventIds.add(event.event_id);
+    }
+    lineStart = nextLineStart;
+  }
+
+  return {
+    events,
+    findings,
+    ignoredPartialTail: tornTailContent !== "",
+    validContent,
+    tornTailContent,
+  };
+}
+
+async function inspectReplay(
+  runDir: string,
+  events: readonly RunJournalEvent[],
+): Promise<DoctorFinding[]> {
+  const findings: DoctorFinding[] = [];
+  try {
+    const replay = await replayRunJournal(runDir);
+    findings.push(...inspectReplayState(runDir, replay.state, events));
+  } catch (error) {
+    findings.push({
+      severity: "ERROR",
+      code: "REPLAY_FAILED",
+      message: `Journal replay failed: ${
+        error instanceof Error ? error.message : String(error)
+      }`,
+      evidence_path: getJournalPath(runDir),
+    });
+  }
+
+  const declaredNodes = new Set(
+    events
+      .filter((
+        event,
+      ): event is Extract<RunJournalEvent, { kind: "node_declared" }> =>
+        event.kind === "node_declared"
+      )
+      .map((event) => event.node_id),
+  );
+  const attemptsStarted = new Set<string>();
+  let terminalSeen: RunJournalEvent | undefined;
+
+  for (const event of events) {
+    if (terminalSeen) {
+      findings.push({
+        severity: "ERROR",
+        code: "EVENT_AFTER_TERMINAL",
+        message:
+          `Event '${event.kind}' appears after terminal event '${terminalSeen.kind}'.`,
+        evidence_path: getJournalPath(runDir),
+      });
+    }
+    if (TERMINAL_KINDS.has(event.kind)) terminalSeen = event;
+
+    if (NODE_LIFECYCLE_KINDS.has(event.kind)) {
+      const nodeId =
+        (event as Extract<RunJournalEvent, { node_id: string }>).node_id;
+      if (!declaredNodes.has(nodeId)) {
+        findings.push({
+          severity: "ERROR",
+          code: "UNDECLARED_NODE_EVENT",
+          message:
+            `Node lifecycle event '${event.kind}' references undeclared node '${nodeId}'.`,
+          evidence_path: getJournalPath(runDir),
+        });
+      }
+    }
+
+    if (event.kind === "attempt_started") {
+      attemptsStarted.add(attemptKey(event.node_id, event.iteration));
+    }
+    if (
+      event.kind === "attempt_completed" ||
+      event.kind === "continuation_exhausted"
+    ) {
+      if (!attemptsStarted.has(attemptKey(event.node_id, event.iteration))) {
+        findings.push({
+          severity: "ERROR",
+          code: "ATTEMPT_WITHOUT_START",
+          message:
+            `Attempt completion for node '${event.node_id}' has no matching attempt_started event.`,
+          evidence_path: getJournalPath(runDir),
+        });
+      }
+    }
+  }
+
+  return findings;
+}
+
+function inspectReplayState(
+  runDir: string,
+  state: {
+    total_cost_usd?: unknown;
+    nodes: Record<string, { cost_usd?: unknown }>;
+  },
+  events: readonly RunJournalEvent[],
+): DoctorFinding[] {
+  const findings: DoctorFinding[] = [];
+  if (state.total_cost_usd === undefined) return [];
+  const total = Number(state.total_cost_usd);
+  const sum = Object.values(state.nodes).reduce((acc, node) => {
+    return acc + (typeof node.cost_usd === "number" ? node.cost_usd : 0);
+  }, 0);
+  if (Math.abs(total - sum) >= 0.000001) {
+    findings.push({
+      severity: "ERROR",
+      code: "COST_DIVERGENCE",
+      message:
+        `Replayed total_cost_usd ${total} differs from per-node cost sum ${sum}.`,
+      evidence_path: getJournalPath(runDir),
+    });
+  }
+
+  const attemptCosts = new Map<string, number>();
+  for (const event of events) {
+    if (
+      event.kind === "attempt_completed" &&
+      typeof event.cost_usd === "number"
+    ) {
+      attemptCosts.set(event.node_id, event.cost_usd);
+    }
+  }
+  if (attemptCosts.size > 0) {
+    const attemptSum = [...attemptCosts.values()].reduce(
+      (acc, value) => acc + value,
+      0,
+    );
+    if (Math.abs(attemptSum - sum) >= 0.000001) {
+      findings.push({
+        severity: "ERROR",
+        code: "COST_DIVERGENCE",
+        message:
+          `Attempt cost sum ${attemptSum} differs from per-node cost sum ${sum}.`,
+        evidence_path: getJournalPath(runDir),
+      });
+    }
+  }
+
+  return findings;
+}
+
+async function inspectFilesystem(
+  workflowDir: string,
+  runDir: string,
+  events: readonly RunJournalEvent[],
+): Promise<DoctorFinding[]> {
+  const findings: DoctorFinding[] = [];
+  const declaredDirs = new Set(
+    events
+      .filter((
+        event,
+      ): event is Extract<
+        RunJournalEvent,
+        { kind: "node_directory_declared" }
+      > => event.kind === "node_directory_declared")
+      .map((event) => declaredNodeDirPath(runDir, event.node_dir)),
+  );
+  const actualDirs = await collectNodeDirs(runDir, declaredDirs);
+
+  for (const dir of actualDirs) {
+    if (!declaredDirs.has(dir)) {
+      findings.push({
+        severity: "ERROR",
+        code: "ORPHAN_NODE_DIR",
+        message:
+          `Node directory exists on disk but is not declared in the journal: ${dir}`,
+        evidence_path: dir,
+      });
+    }
+  }
+  for (const dir of declaredDirs) {
+    try {
+      const stat = await Deno.stat(dir);
+      if (!stat.isDirectory) throw new Error("not a directory");
+    } catch {
+      findings.push({
+        severity: "ERROR",
+        code: "MISSING_NODE_DIR",
+        message:
+          `Journal declares a node directory that is missing on disk: ${dir}`,
+        evidence_path: dir,
+      });
+    }
+  }
+
+  const lockFinding = await inspectLock(workflowDir, runDir);
+  if (lockFinding) findings.push(lockFinding);
+  return findings;
+}
+
+async function inspectLock(
+  workflowDir: string,
+  runDir: string,
+): Promise<DoctorFinding | undefined> {
+  const lockPath = defaultLockPath(workflowDir);
+  let info;
+  try {
+    info = await readLockInfo(lockPath);
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return undefined;
+    throw error;
+  }
+  if (info.run_id !== basename(runDir)) return undefined;
+  if (isProcessAlive(info.pid)) {
+    return undefined;
+  }
+  return {
+    severity: "WARNING",
+    code: "STALE_LOCK",
+    message: `Lock references dead process ${info.pid}.`,
+    evidence_path: lockPath,
+  };
+}
+
+async function inspectLiveLock(
+  workflowDir: string,
+  runDir: string,
+): Promise<DoctorFinding | undefined> {
+  const lockPath = defaultLockPath(workflowDir);
+  let info;
+  try {
+    info = await readLockInfo(lockPath);
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return undefined;
+    throw error;
+  }
+  if (info.run_id !== basename(runDir) || !isProcessAlive(info.pid)) {
+    return undefined;
+  }
+  return {
+    severity: "ERROR",
+    code: "LIVE_LOCK",
+    message: `Lock is held by live process ${info.pid}.`,
+    evidence_path: lockPath,
+  };
+}
+
+async function collectNodeDirs(
+  runDir: string,
+  declaredDirs: ReadonlySet<string>,
+): Promise<Set<string>> {
+  const dirs = new Set<string>();
+  try {
+    for await (const entry of Deno.readDir(runDir)) {
+      if (
+        !entry.isDirectory || IGNORED_RUN_DIRS.has(entry.name) ||
+        entry.name.startsWith(".")
+      ) {
+        continue;
+      }
+      const top = normalize(join(runDir, entry.name));
+      const isDeclaredParent = [...declaredDirs].some((dir) =>
+        normalize(join(dir, "..")) === top
+      );
+      if (!isDeclaredParent) dirs.add(top);
+      try {
+        for await (const child of Deno.readDir(top)) {
+          if (child.isDirectory) dirs.add(normalize(join(top, child.name)));
+        }
+      } catch {
+        // Permission or race errors are surfaced by later stat checks when relevant.
+      }
+    }
+  } catch (error) {
+    if (!(error instanceof Deno.errors.NotFound)) throw error;
+  }
+  return dirs;
+}
+
+function declaredNodeDirPath(runDir: string, nodeDir: string): string {
+  if (isAbsolute(nodeDir)) return normalize(nodeDir);
+  const marker = `runs/${basename(runDir)}/`;
+  const markerIndex = nodeDir.indexOf(marker);
+  if (markerIndex >= 0) {
+    return normalize(join(runDir, nodeDir.slice(markerIndex + marker.length)));
+  }
+  return normalize(join(runDir, nodeDir));
+}
+
+function attemptKey(nodeId: string, iteration: number | undefined): string {
+  return `${nodeId}:${iteration ?? ""}`;
+}
+
+function buildReport(
+  workflowDir: string,
+  runId: string,
+  runDir: string,
+  findings: DoctorFinding[],
+): DoctorReport {
+  return {
+    workflowDir,
+    runId,
+    runDir,
+    findings,
+    hasErrors: findings.some((finding) => finding.severity === "ERROR"),
+  };
+}
+
+function isProcessAlive(pid: number): boolean {
+  try {
+    Deno.kill(pid, "SIGCONT");
+    return true;
+  } catch {
+    return false;
+  }
+}
+
+function isJournalRepairBlocker(code: string): boolean {
+  return [
+    "JOURNAL_MISSING",
+    "JOURNAL_PARSE_ERROR",
+    "UNKNOWN_EVENT_KIND",
+    "NON_MONOTONIC_SEQ",
+    "REPLAY_FAILED",
+    "EVENT_AFTER_TERMINAL",
+    "UNDECLARED_NODE_EVENT",
+    "ATTEMPT_WITHOUT_START",
+    "COST_DIVERGENCE",
+  ].includes(code);
+}
+
+async function rewriteJournalWithoutTail(
+  runDir: string,
+  validContent: string,
+): Promise<void> {
+  const journalPath = getJournalPath(runDir);
+  await Deno.copyFile(journalPath, `${journalPath}.bak`);
+  const tmpPath = `${journalPath}.tmp`;
+  await Deno.writeTextFile(tmpPath, validContent);
+  await Deno.rename(tmpPath, journalPath);
+}
