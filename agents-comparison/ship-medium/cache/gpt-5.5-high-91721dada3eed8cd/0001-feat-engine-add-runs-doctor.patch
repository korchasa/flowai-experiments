+/** Parse `runs doctor --workflow <dir> --run <run-id> [--repair] [--json]`. */
+export function parseRunsDoctorArgs(args: string[]): RunsDoctorArgs {
+  let workflowDir: string | undefined;
+  let runId: string | undefined;
+  let repair = false;
+  let json = false;
+  for (let i = 0; i < args.length; i++) {
+    const arg = args[i];
+    if (arg === "--workflow") {
+      workflowDir = args[++i];
+      continue;
+    }
+    if (arg.startsWith("--workflow=")) {
+      workflowDir = arg.slice("--workflow=".length);
+      continue;
+    }
+    if (arg === "--run") {
+      runId = args[++i];
+      continue;
+    }
+    if (arg.startsWith("--run=")) {
+      runId = arg.slice("--run=".length);
+      continue;
+    }
+    if (arg === "--repair") {
+      repair = true;
+      continue;
+    }
+    if (arg === "--json") {
+      json = true;
+      continue;
+    }
+    throw new Error(`runs doctor: unknown argument '${arg}'.`);
+  }
+  if (!workflowDir) {
+    throw new Error("runs doctor: missing --workflow <dir>.");
+  }
+  if (!runId) {
+    throw new Error("runs doctor: missing --run <run-id>.");
+  }
+  return {
+    workflowDir: normalizeWorkflowDir(workflowDir),
+    runId,
+    repair,
+    json,
+  };
+}
