new file mode 100644
index 0000000..44c8027
--- /dev/null
+++ b/src/state/doctor.ts
@@ -0,0 +1,593 @@
+/**
+ * @module
+ * `runs doctor` — run durability health checker with safe mechanical repair
+ * (FR-E83).
+ *
+ * Diagnoses a run's durable artifacts in three passes and reports EVERY
+ * problem found (not just the first):
+ *
+ *  1. **Journal integrity** — lexical line scan of `journal.jsonl` (JSON
+ *     parse, known `kind`, monotonic `seq`, duplicate `event_id`). This is
+ *     NOT a second replayer: it reconstructs no state.
+ *  2. **Replay invariants** — the EXISTING replayer
+ *     (`run-journal.ts::replayRunJournal`) is the single source of replay
+ *     truth; doctor only inspects its result (events after a terminal run
+ *     event, undeclared-node lifecycle, unmatched `attempt_completed`,
+ *     cost-sum divergence).
+ *  3. **Filesystem cross-check** — orphan node directories, declared
+ *     directories missing on disk, stale `runs/.lock`.
+ *
+ * `--repair` applies ONLY mechanical fixes (torn final journal line with a
+ * `journal.jsonl.bak` backup + atomic tmp/rename rewrite; stale-lock
+ * removal) and refuses — modifying nothing — when the run is active or the
+ * journal has errors beyond the torn final line.
+ */
+
+import { join } from "@std/path";
+import { getJournalPath, replayRunJournal } from "./run-journal.ts";
+import {
+  defaultLockPath,
+  isProcessAlive,
+  isRunLive,
+  readLockInfo,
+} from "./lock.ts";
+import { getRunDir } from "./state.ts";
+import { RUN_JOURNAL_EVENT_KINDS } from "../types.ts";
+import type { NodeLifecycleJournalEvent, RunJournalEvent } from "../types.ts";
+
+/** Severity of a single doctor finding. ERRORs flip the exit code to 1. */
+export type DoctorSeverity = "error" | "warning";
+
+/** One diagnosed problem: severity, stable code, message, evidence path. */
+export interface DoctorFinding {
+  /** Finding severity; any `error` makes the report not-ok (exit 1). */
+  severity: DoctorSeverity;
+  /** Stable machine-readable finding code (e.g. `JOURNAL_TORN_TAIL`). */
+  code: string;
+  /** Human-readable description of the problem. */
+  message: string;
+  /** Path of the artifact the finding is evidence for, when applicable. */
+  path?: string;
+}
+
+/** One mechanical repair that was applied by `--repair`. */
+export interface DoctorRepair {
+  /** Stable repair code (`REPAIR_TORN_TAIL`, `REPAIR_STALE_LOCK`). */
+  code: string;
+  /** Human-readable description of what was changed. */
+  message: string;
+  /** Path of the repaired artifact. */
+  path: string;
+}
+
+/** Full machine-readable doctor report (`--json` prints it verbatim). */
+export interface DoctorReport {
+  /** Diagnosed run id. */
+  run_id: string;
+  /** Workflow folder the run belongs to. */
+  workflow_dir: string;
+  /** All findings, in check order (journal → replay → filesystem). */
+  findings: DoctorFinding[];
+  /** Mechanical repairs applied (empty without `--repair`). */
+  repairs: DoctorRepair[];
+  /** Number of `error` findings. */
+  errors: number;
+  /** Number of `warning` findings. */
+  warnings: number;
+  /** True when the report contains zero `error` findings (exit 0). */
+  ok: boolean;
+}
+
+/** Parameters for {@link doctorRun}. */
+export interface DoctorRunParams {
+  /** Workflow folder containing `workflow.yaml` and `runs/`. */
+  workflowDir: string;
+  /** Run id to diagnose (one run per invocation). */
+  runId: string;
+  /** When true, apply safe mechanical repairs before the final report. */
+  repair?: boolean;
+}
+
+const TERMINAL_KINDS: ReadonlySet<string> = new Set([
+  "run_completed",
+  "run_failed",
+  "run_aborted",
+]);
+
+const NODE_LIFECYCLE_KINDS: ReadonlySet<string> = new Set([
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+]);
+
+const KNOWN_KINDS: ReadonlySet<string> = new Set(RUN_JOURNAL_EVENT_KINDS);
+
+/** Run-root entries that are engine infrastructure, never node output dirs. */
+const INFRA_RUN_DIR_ENTRIES: ReadonlySet<string> = new Set([
+  "logs",
+  "worktree",
+  ".hitl-inbox",
+]);
+
+/** Journal/replay finding codes that make the journal untrustworthy beyond
+ * the torn final line — `--repair` refuses while any of these is present
+ * (doctor must not guess at semantic repairs). Filesystem findings do not
+ * block mechanical repairs. */
+const REPAIR_BLOCKING_CODES: ReadonlySet<string> = new Set([
+  "JOURNAL_MISSING",
+  "JOURNAL_GARBAGE_LINE",
+  "JOURNAL_UNKNOWN_KIND",
+  "JOURNAL_NON_MONOTONIC_SEQ",
+  "REPLAY_FAILED",
+  "EVENT_AFTER_TERMINAL",
+  "NODE_NOT_DECLARED",
+  "ATTEMPT_WITHOUT_START",
+  "COST_SUM_DIVERGENCE",
+]);
+
+/** Internal diagnosis result: findings plus repair-relevant facts. */
+interface Diagnosis {
+  findings: DoctorFinding[];
+  /** Byte length of the valid journal prefix when a torn tail was found. */
+  tornTailValidByteLength?: number;
+  /** Lock path when a stale lock for this run was found. */
+  staleLockPath?: string;
+}
+
+/**
+ * Diagnose one run and (optionally) apply safe mechanical repairs.
+ * Never throws for in-scope degradation — problems become findings;
+ * only environment failures (e.g. unreadable directories) propagate.
+ */
+export async function doctorRun(
+  params: DoctorRunParams,
+): Promise<DoctorReport> {
+  const { workflowDir, runId, repair = false } = params;
+  const diagnosis = await diagnoseRun(workflowDir, runId);
+  if (!repair) return buildReport(params, diagnosis.findings, []);
+
+  // Refusal checks BEFORE any modification (clear error, nothing modified).
+  if (await isRunLive(workflowDir, runId)) {
+    return buildReport(params, [...diagnosis.findings, {
+      severity: "error",
+      code: "REPAIR_REFUSED",
+      message: `run '${runId}' is currently active ` +
+        `(lock held by a live process) — refusing to repair`,
+      path: defaultLockPath(workflowDir),
+    }], []);
+  }
+  const blocking = diagnosis.findings.filter(
+    (f) => f.severity === "error" && REPAIR_BLOCKING_CODES.has(f.code),
+  );
+  if (blocking.length > 0) {
+    return buildReport(params, [...diagnosis.findings, {
+      severity: "error",
+      code: "REPAIR_REFUSED",
+      message: `journal has ${blocking.length} error(s) beyond the torn ` +
+        `final line (${blocking.map((f) => f.code).join(", ")}) — ` +
+        `refusing semantic repairs, nothing modified`,
+      path: getJournalPath(getRunDir(runId, workflowDir)),
+    }], []);
+  }
+
+  const repairs: DoctorRepair[] = [];
+  if (diagnosis.tornTailValidByteLength !== undefined) {
+    const journalPath = getJournalPath(getRunDir(runId, workflowDir));
+    repairs.push(
+      await repairTornTail(journalPath, diagnosis.tornTailValidByteLength),
+    );
+  }
+  if (diagnosis.staleLockPath !== undefined) {
+    await Deno.remove(diagnosis.staleLockPath);
+    repairs.push({
+      code: "REPAIR_STALE_LOCK",
+      message: `removed stale lock referencing run '${runId}' (dead process)`,
+      path: diagnosis.staleLockPath,
+    });
+  }
+  if (repairs.length === 0) {
+    return buildReport(params, diagnosis.findings, []);
+  }
+  // Re-diagnose so the final report reflects the healed state.
+  const post = await diagnoseRun(workflowDir, runId);
+  return buildReport(params, post.findings, repairs);
+}
+
+/** Render a {@link DoctorReport} as a human-readable, severity-grouped text. */
+export function formatDoctorReport(report: DoctorReport): string {
+  const lines: string[] = [
+    `Doctor report — run ${report.run_id} (workflow: ${report.workflow_dir})`,
+  ];
+  for (const severity of ["error", "warning"] as const) {
+    const group = report.findings.filter((f) => f.severity === severity);
+    if (group.length === 0) continue;
+    lines.push("", `${severity.toUpperCase()} (${group.length}):`);
+    for (const f of group) {
+      lines.push(`  - [${f.code}] ${f.message}`);
+      if (f.path) lines.push(`      at: ${f.path}`);
+    }
+  }
+  if (report.repairs.length > 0) {
+    lines.push("", `Repairs applied (${report.repairs.length}):`);
+    for (const r of report.repairs) {
+      lines.push(`  - [${r.code}] ${r.message}`, `      at: ${r.path}`);
+    }
+  }
+  lines.push(
+    "",
+    report.ok
+      ? `OK — no errors found (${report.warnings} warning(s)).`
+      : `FAILED — ${report.errors} error(s), ${report.warnings} warning(s).`,
+  );
+  return lines.join("\n");
+}
+
+function buildReport(
+  params: DoctorRunParams,
+  findings: DoctorFinding[],
+  repairs: DoctorRepair[],
+): DoctorReport {
+  const errors = findings.filter((f) => f.severity === "error").length;
+  return {
+    run_id: params.runId,
+    workflow_dir: params.workflowDir,
+    findings,
+    repairs,
+    errors,
+    warnings: findings.length - errors,
+    ok: errors === 0,
+  };
+}
+
+async function diagnoseRun(
+  workflowDir: string,
+  runId: string,
+): Promise<Diagnosis> {
+  const runDir = getRunDir(runId, workflowDir);
+  const journalPath = getJournalPath(runDir);
+  const findings: DoctorFinding[] = [];
+
+  let journalText: string | undefined;
+  try {
+    journalText = await Deno.readTextFile(journalPath);
+  } catch (error) {
+    if (!(error instanceof Deno.errors.NotFound)) throw error;
+    findings.push({
+      severity: "error",
+      code: "JOURNAL_MISSING",
+      message: `journal.jsonl not found for run '${runId}'`,
+      path: journalPath,
+    });
+  }
+
+  let tornTailValidByteLength: number | undefined;
+  if (journalText !== undefined) {
+    const scan = scanJournalIntegrity(journalText, journalPath);
+    findings.push(...scan.findings);
+    tornTailValidByteLength = scan.tornTailValidByteLength;
+
+    let replay;
+    try {
+      replay = await replayRunJournal(runDir);
+    } catch (error) {
+      findings.push({
+        severity: "error",
+        code: "REPLAY_FAILED",
+        message: `journal replay failed: ${
+          error instanceof Error ? error.message : String(error)
+        }`,
+        path: journalPath,
+      });
+    }
+    if (replay) {
+      findings.push(
+        ...checkReplayInvariants(replay.events, replay.state, journalPath),
+      );
+      findings.push(
+        ...await crossCheckFilesystem(replay.events, runDir, runId),
+      );
+    }
+  }
+
+  const lock = await checkLock(workflowDir, runId);
+  if (lock) findings.push(lock.finding);
+
+  return {
+    findings,
+    tornTailValidByteLength,
+    staleLockPath: lock?.lockPath,
+  };
+}
+
+/** Lexical journal scan: line-level JSON validity, known kinds, monotonic
+ * seq, duplicate event ids. Reconstructs no state (the replayer owns that). */
+function scanJournalIntegrity(
+  text: string,
+  journalPath: string,
+): { findings: DoctorFinding[]; tornTailValidByteLength?: number } {
+  const findings: DoctorFinding[] = [];
+  if (text === "") return { findings };
+
+  const endedWithNewline = text.endsWith("\n");
+  const lines = text.split("\n");
+  if (endedWithNewline) lines.pop();
+
+  const seenEventIds = new Set<string>();
+  let prevSeq: number | undefined;
+  let tornTailValidByteLength: number | undefined;
+  let lineStart = 0;
+  for (let i = 0; i < lines.length; i++) {
+    const line = lines[i];
+    const nextLineStart = lineStart + line.length + 1;
+    if (line.trim() === "") {
+      lineStart = nextLineStart;
+      continue;
+    }
+    let parsed: unknown;
+    try {
+      parsed = JSON.parse(line);
+    } catch {
+      const isPartialTail = i === lines.length - 1 && !endedWithNewline;
+      if (isPartialTail) {
+        // The expected crash artifact — the writer/replayer already
+        // tolerate it (run-journal.ts truncates it on the next open).
+        findings.push({
+          severity: "warning",
+          code: "JOURNAL_TORN_TAIL",
+          message: `final line ${i + 1} is truncated (torn write); ` +
+            `the replayer ignores it — repairable with --repair`,
+          path: journalPath,
+        });
+        tornTailValidByteLength = new TextEncoder()
+          .encode(text.slice(0, lineStart)).length;
+      } else {
+        findings.push({
+          severity: "error",
+          code: "JOURNAL_GARBAGE_LINE",
+          message: `line ${i + 1} is not valid JSON (mid-file corruption)`,
+          path: journalPath,
+        });
+      }
+      lineStart = nextLineStart;
+      continue;
+    }
+
+    const event = parsed as Partial<RunJournalEvent>;
+    if (typeof event.kind !== "string" || !KNOWN_KINDS.has(event.kind)) {
+      findings.push({
+        severity: "error",
+        code: "JOURNAL_UNKNOWN_KIND",
+        message: `line ${i + 1} has unknown event kind '${String(event.kind)}'`,
+        path: journalPath,
+      });
+    }
+    const eventId = event.event_id;
+    if (typeof eventId === "string" && seenEventIds.has(eventId)) {
+      // The replayer dedupes these — anomaly worth surfacing, not fatal.
+      findings.push({
+        severity: "warning",
+        code: "JOURNAL_DUPLICATE_EVENT_ID",
+        message: `line ${i + 1} duplicates event_id '${eventId}' ` +
+          `(replayer dedupes it)`,
+        path: journalPath,
+      });
+      lineStart = nextLineStart;
+      continue;
+    }
+    if (typeof eventId === "string") seenEventIds.add(eventId);
+    if (typeof event.seq === "number") {
+      if (prevSeq !== undefined && event.seq <= prevSeq) {
+        findings.push({
+          severity: "error",
+          code: "JOURNAL_NON_MONOTONIC_SEQ",
+          message: `line ${i + 1} has seq ${event.seq} after ${prevSeq} ` +
+            `(per-run seq must be monotonic)`,
+          path: journalPath,
+        });
+      }
+      prevSeq = event.seq;
+    }
+    lineStart = nextLineStart;
+  }
+  return { findings, tornTailValidByteLength };
+}
+
+/** Inspect the existing replayer's deduped event list for semantic
+ * invariant violations. */
+function checkReplayInvariants(
+  events: RunJournalEvent[],
+  state: { total_cost_usd?: number },
+  journalPath: string,
+): DoctorFinding[] {
+  const findings: DoctorFinding[] = [];
+  const declaredNodes = new Set<string>();
+  const openAttempts = new Map<string, number>();
+  const latestNodeCost = new Map<string, number | undefined>();
+  let terminal: RunJournalEvent | undefined;
+
+  for (const event of events) {
+    if (terminal) {
+      findings.push({
+        severity: "error",
+        code: "EVENT_AFTER_TERMINAL",
+        message: `event '${event.kind}' (seq ${event.seq}) appears after ` +
+          `terminal '${terminal.kind}' (seq ${terminal.seq})`,
+        path: journalPath,
+      });
+    } else if (TERMINAL_KINDS.has(event.kind)) {
+      terminal = event;
+    }
+
+    if (event.kind === "node_declared") declaredNodes.add(event.node_id);
+
+    if (NODE_LIFECYCLE_KINDS.has(event.kind)) {
+      const lifecycle = event as NodeLifecycleJournalEvent;
+      if (!declaredNodes.has(lifecycle.node_id)) {
+        findings.push({
+          severity: "error",
+          code: "NODE_NOT_DECLARED",
+          message: `'${lifecycle.kind}' (seq ${lifecycle.seq}) references ` +
+            `node '${lifecycle.node_id}' that was never declared`,
+          path: journalPath,
+        });
+      }
+      latestNodeCost.set(lifecycle.node_id, lifecycle.cost_usd);
+    }
+
+    if (event.kind === "attempt_started") {
+      const key = attemptKey(event.node_id, event.iteration);
+      openAttempts.set(key, (openAttempts.get(key) ?? 0) + 1);
+    }
+    if (event.kind === "attempt_completed") {
+      const key = attemptKey(event.node_id, event.iteration);
+      const open = openAttempts.get(key) ?? 0;
+      if (open > 0) {
+        openAttempts.set(key, open - 1);
+      } else {
+        findings.push({
+          severity: "error",
+          code: "ATTEMPT_WITHOUT_START",
+          message: `'attempt_completed' (seq ${event.seq}) for node ` +
+            `'${event.node_id}' has no matching 'attempt_started'`,
+          path: journalPath,
+        });
+      }
+    }
+  }
+
+  // Replayed total derives from node snapshots; the per-node `cost_usd`
+  // metadata on the same lifecycle events is the independent evidence —
+  // drift between the two means a tampered journal or an engine bug.
+  if (latestNodeCost.size > 0) {
+    const expected = [...latestNodeCost.values()]
+      .reduce((sum: number, cost) => sum + (cost ?? 0), 0);
+    const actual = state.total_cost_usd ?? 0;
+    if (Math.abs(expected - actual) > 1e-9) {
+      findings.push({
+        severity: "error",
+        code: "COST_SUM_DIVERGENCE",
+        message: `replayed total_cost_usd ${actual} diverges from the sum ` +
+          `of per-node cost_usd ${expected}`,
+        path: journalPath,
+      });
+    }
+  }
+  return findings;
+}
+
+function attemptKey(nodeId: string, iteration: number | undefined): string {
+  return `${nodeId}:${iteration ?? ""}`;
+}
+
+/** Cross-check declared node directories against the run dir on disk. */
+async function crossCheckFilesystem(
+  events: RunJournalEvent[],
+  runDir: string,
+  runId: string,
+): Promise<DoctorFinding[]> {
+  const findings: DoctorFinding[] = [];
+  const declared = new Set<string>();
+  const marker = `runs/${runId}/`;
+  for (const event of events) {
+    if (event.kind !== "node_directory_declared") continue;
+    const idx = event.node_dir.lastIndexOf(marker);
+    if (idx === -1) continue; // unparseable declaration — skip, not guess
+    const rel = event.node_dir.slice(idx + marker.length).replace(/\/+$/, "");
+    if (rel) declared.add(rel);
+  }
+
+  for (const rel of declared) {
+    if (!(await isDirectory(join(runDir, rel)))) {
+      findings.push({
+        severity: "error",
+        code: "MISSING_DECLARED_DIR",
+        message: `journal declares node directory '${rel}' ` +
+          `but it is missing on disk`,
+        path: join(runDir, rel),
+      });
+    }
+  }
+
+  for await (const entry of Deno.readDir(runDir)) {
+    if (!entry.isDirectory) continue;
+    if (INFRA_RUN_DIR_ENTRIES.has(entry.name)) continue;
+    if (declared.has(entry.name)) continue;
+    const isPhaseDir = [...declared]
+      .some((rel) => rel.startsWith(`${entry.name}/`));
+    if (!isPhaseDir) {
+      findings.push(orphanFinding(entry.name, runDir));
+      continue;
+    }
+    for await (const child of Deno.readDir(join(runDir, entry.name))) {
+      if (!child.isDirectory) continue;
+      const rel = `${entry.name}/${child.name}`;
+      if (!declared.has(rel)) findings.push(orphanFinding(rel, runDir));
+    }
+  }
+  return findings;
+}
+
+function orphanFinding(rel: string, runDir: string): DoctorFinding {
+  return {
+    severity: "warning",
+    code: "ORPHAN_NODE_DIR",
+    message: `directory '${rel}' exists on disk but no journal event ` +
+      `mentions it`,
+    path: join(runDir, rel),
+  };
+}
+
+/** Detect a stale `runs/.lock` referencing this run with a dead process. */
+async function checkLock(
+  workflowDir: string,
+  runId: string,
+): Promise<{ finding: DoctorFinding; lockPath: string } | undefined> {
+  const lockPath = defaultLockPath(workflowDir);
+  try {
+    const info = await readLockInfo(lockPath);
+    if (info.run_id !== runId || isProcessAlive(info.pid)) return undefined;
+    return {
+      lockPath,
+      finding: {
+        severity: "warning",
+        code: "STALE_LOCK",
+        message: `runs/.lock references this run (pid ${info.pid}, ` +
+          `host ${info.hostname}) but the process is no longer alive — ` +
+          `repairable with --repair`,
+        path: lockPath,
+      },
+    };
+  } catch {
+    // No lock, or a lock that does not parse — not this run's finding.
+    return undefined;
+  }
+}
+
+/** Repair the torn final journal line: back up the journal, then atomically
+ * rewrite it without the torn tail (write tmp + rename). */
+async function repairTornTail(
+  journalPath: string,
+  validByteLength: number,
+): Promise<DoctorRepair> {
+  const original = await Deno.readFile(journalPath);
+  await Deno.writeFile(`${journalPath}.bak`, original);
+  const tmpPath = `${journalPath}.tmp`;
+  await Deno.writeFile(tmpPath, original.subarray(0, validByteLength));
+  await Deno.rename(tmpPath, journalPath);
+  return {
+    code: "REPAIR_TORN_TAIL",
+    message: `removed the torn final line (backup at ${journalPath}.bak)`,
+    path: journalPath,
+  };
+}
+
+async function isDirectory(path: string): Promise<boolean> {
+  try {
+    return (await Deno.stat(path)).isDirectory;
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return false;
+    throw error;
+  }
+}
