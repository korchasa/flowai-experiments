+/** Lock state relative to a specific run, for diagnostics (FR-E83 doctor).
+ * - `absent`     — no lock file.
+ * - `corrupt`    — lock file present but not parseable as {@link LockInfo}.
+ * - `other-run`  — lock names a different run id.
+ * - `live`       — lock names this run AND its PID is a live process.
+ * - `stale`      — lock names this run but its recorded PID is dead. */
+export type RunLockStatus =
+  | "absent"
+  | "corrupt"
+  | "other-run"
+  | "live"
+  | "stale";
+
+/** Classification of `<workflowDir>/runs/.lock` relative to `runId`. */
+export interface RunLockClassification {
+  /** Lock state relative to `runId`. */
+  status: RunLockStatus;
+  /** Lock file path inspected. */
+  path: string;
+  /** Parsed lock content when readable. */
+  info?: LockInfo;
+}
+
+/** Classify the workflow lock relative to a specific run (FR-E83). Reuses
+ * {@link readLockInfo} + {@link isProcessAlive} so doctor never re-implements
+ * lock-file parsing or PID-liveness. Never throws — a missing/corrupt lock is
+ * reported as a status, not an exception. */
+export async function classifyRunLock(
+  workflowDir: string,
+  runId: string,
+): Promise<RunLockClassification> {
+  const path = defaultLockPath(workflowDir);
+  let info: LockInfo;
+  try {
+    info = await readLockInfo(path);
+  } catch (err) {
+    if (err instanceof Deno.errors.NotFound) return { status: "absent", path };
+    if (err instanceof SyntaxError) return { status: "corrupt", path };
+    throw err;
+  }
+  if (info.run_id !== runId) return { status: "other-run", path, info };
+  return {
+    status: isProcessAlive(info.pid) ? "live" : "stale",
+    path,
+    info,
+  };
+}
