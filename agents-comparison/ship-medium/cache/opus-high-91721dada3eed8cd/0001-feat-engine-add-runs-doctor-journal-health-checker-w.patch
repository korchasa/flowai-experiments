+/** Parsed flags for the `runs doctor` subcommand (FR-E83). */
+export interface DoctorArgs {
+  /** Workflow folder containing `workflow.yaml` and `runs/`. */
+  workflowDir: string;
+  /** Target run id to diagnose. */
+  runId: string;
+  /** Apply safe mechanical repairs instead of diagnose-only. */
+  repair: boolean;
+  /** Emit a machine-readable findings list instead of a human report. */
+  json: boolean;
+}
+
+/**
+ * Parse `runs doctor --workflow <dir> --run <id> [--repair] [--json]` (FR-E83).
+ * Mirrors the existing per-subcommand loop style (`--flag value` and
+ * `--flag=value`). Both `--workflow` and `--run` are mandatory — this command
+ * targets exactly one run and never falls back to workflow auto-resolution.
+ */
+export function parseDoctorArgs(args: string[]): DoctorArgs {
+  let workflowDir: string | undefined;
+  let runId: string | undefined;
+  let repair = false;
+  let json = false;
+  for (let i = 0; i < args.length; i++) {
+    const a = args[i];
+    if (a === "--workflow") {
+      workflowDir = args[++i];
+    } else if (a.startsWith("--workflow=")) {
+      workflowDir = a.slice("--workflow=".length);
+    } else if (a === "--run") {
+      runId = args[++i];
+    } else if (a.startsWith("--run=")) {
+      runId = a.slice("--run=".length);
+    } else if (a === "--repair") {
+      repair = true;
+    } else if (a === "--json") {
+      json = true;
+    } else {
+      throw new Error(
+        `runs doctor: unexpected argument '${a}'. Usage: ` +
+          "flowai-workflow runs doctor --workflow <dir> --run <id> " +
+          "[--repair] [--json]",
+      );
+    }
+  }
+  if (!workflowDir) throw new Error("runs doctor: missing --workflow <dir>.");
+  if (!runId) throw new Error("runs doctor: missing --run <id>.");
+  return {
+    workflowDir: normalizeWorkflowDir(workflowDir),
+    runId,
+    repair,
+    json,
+  };
+}
