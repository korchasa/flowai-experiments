new file mode 100644
index 0000000..5f2b982
--- /dev/null
+++ b/src/state/doctor.ts
@@ -0,0 +1,590 @@
+/**
+ * @module
+ * `runs doctor` — journal health checker with mechanical repair (FR-E83).
+ *
+ * Diagnoses a run's durability artifacts (`journal.jsonl`, node output
+ * directories, `runs/.lock`) and, with repair enabled, applies ONLY safe
+ * mechanical fixes. The EXISTING replayer (`replayRunJournal`) is the single
+ * source of replay truth — this module never re-implements replay; it scans
+ * the journal at the line level for integrity (which the replayer cannot do
+ * because it throws on the first hard error), then orchestrates one replay and
+ * inspects its result.
+ *
+ * Every problem is reported (not just the first), grouped by severity. The
+ * caller maps `hasErrors(report)` to exit 1 and a no-error report to exit 0.
+ */
+
+import type { RunJournalEvent, RunJournalReplayResult } from "../types.ts";
+import {
+  getJournalPath,
+  replayRunJournal,
+  RUN_JOURNAL_EVENT_KINDS,
+} from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+import { classifyRunLock, releaseLock } from "./lock.ts";
+
+/** Severity of a doctor finding. ERROR forces exit 1; WARNING does not. */
+export type DoctorSeverity = "error" | "warning";
+
+/** A single diagnosed problem. `code` is a stable dotted id whose first
+ * segment is the check group (`journal` / `replay` / `fs` / `lock`). */
+export interface DoctorFinding {
+  /** Whether this problem forces a non-zero exit. */
+  severity: DoctorSeverity;
+  /** Stable machine code, e.g. `journal.garbage_line`. */
+  code: string;
+  /** Human-readable description. */
+  message: string;
+  /** Evidence path (file, file:line, or directory) the operator can inspect. */
+  evidence: string;
+}
+
+/** Result of {@link diagnoseRun}: findings plus the groups that ran clean. */
+export interface DoctorReport {
+  /** Run id inspected. */
+  runId: string;
+  /** Every problem found, in check order. */
+  findings: DoctorFinding[];
+  /** Display labels of check groups that ran and produced no finding. */
+  okGroups: string[];
+}
+
+/** One mechanical fix applied by {@link repairRun}. */
+export interface RepairAction {
+  /** Stable machine code of the applied fix. */
+  code: string;
+  /** Human-readable description of what changed. */
+  message: string;
+}
+
+/** Outcome of a repair attempt. */
+export interface RepairOutcome {
+  /** True when repair refused and modified nothing. */
+  refused: boolean;
+  /** Why repair refused (present iff `refused`). */
+  reason?: string;
+  /** Fixes applied (empty when refused or nothing to repair). */
+  actions: RepairAction[];
+}
+
+/** True when the report contains at least one ERROR finding. */
+export function hasErrors(report: DoctorReport): boolean {
+  return report.findings.some((f) => f.severity === "error");
+}
+
+const GROUP_LABELS: Record<string, string> = {
+  journal: "Journal integrity",
+  replay: "Replay invariants",
+  fs: "Filesystem cross-check",
+  lock: "Lock",
+};
+
+const RESERVED_RUN_DIRS = new Set(["logs", ".hitl-inbox"]);
+const KNOWN_KINDS = new Set<string>(RUN_JOURNAL_EVENT_KINDS);
+const NODE_LIFECYCLE_KINDS = new Set<string>([
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+]);
+const TERMINAL_KINDS = new Set<string>([
+  "run_completed",
+  "run_failed",
+  "run_aborted",
+]);
+
+interface JournalScan {
+  findings: DoctorFinding[];
+  /** Successfully parsed events, in file order (any `kind`). */
+  events: RunJournalEvent[];
+}
+
+/** Diagnose a run's durability artifacts (FR-E83). Never throws on a degraded
+ * run — every fault becomes a finding. */
+export async function diagnoseRun(
+  opts: { workflowDir: string; runId: string },
+): Promise<DoctorReport> {
+  const { workflowDir, runId } = opts;
+  const runDir = getRunDir(runId, workflowDir);
+  const journalPath = getJournalPath(runDir);
+  const findings: DoctorFinding[] = [];
+  const checked = new Set<string>();
+
+  // --- a. Journal integrity ---
+  checked.add("journal");
+  let content: string | undefined;
+  try {
+    content = await Deno.readTextFile(journalPath);
+  } catch (err) {
+    if (!(err instanceof Deno.errors.NotFound)) throw err;
+    findings.push({
+      severity: "error",
+      code: "journal.missing",
+      message: "journal.jsonl not found for this run",
+      evidence: journalPath,
+    });
+  }
+
+  let scan: JournalScan | undefined;
+  if (content !== undefined) {
+    scan = scanJournal(content, journalPath);
+    findings.push(...scan.findings);
+  }
+
+  // --- b. Replay invariants (existing replayer is the single truth) ---
+  if (content !== undefined) {
+    const hasJournalError = findings.some(
+      (f) => f.severity === "error" && f.code.startsWith("journal."),
+    );
+    let replay: RunJournalReplayResult | undefined;
+    try {
+      replay = await replayRunJournal(runDir);
+    } catch (err) {
+      // The replayer throws on hard corruption the integrity scan already
+      // flagged (garbage line); only surface replay.failed when it did not.
+      if (!hasJournalError) {
+        findings.push({
+          severity: "error",
+          code: "replay.failed",
+          message: `replay failed: ${
+            err instanceof Error ? err.message : String(err)
+          }`,
+          evidence: journalPath,
+        });
+      }
+    }
+    if (replay) {
+      checked.add("replay");
+      findings.push(...checkReplayInvariants(replay, journalPath));
+    }
+  }
+
+  // --- c. Filesystem cross-check (uses parsed declared events) ---
+  if (scan) {
+    checked.add("fs");
+    findings.push(...await checkFilesystem(scan.events, runDir, runId));
+  }
+
+  // --- lock ---
+  checked.add("lock");
+  const lock = await classifyRunLock(workflowDir, runId);
+  if (lock.status === "stale") {
+    findings.push({
+      severity: "warning",
+      code: "lock.stale",
+      message:
+        `runs/.lock references this run but its process (pid ${lock.info?.pid}) is not alive`,
+      evidence: lock.path,
+    });
+  }
+
+  const okGroups: string[] = [];
+  for (const group of ["journal", "replay", "fs", "lock"]) {
+    if (!checked.has(group)) continue;
+    if (findings.some((f) => f.code.startsWith(`${group}.`))) continue;
+    okGroups.push(GROUP_LABELS[group]);
+  }
+
+  return { runId, findings, okGroups };
+}
+
+/** Line-level integrity scan mirroring the writer's torn-tail tolerance:
+ * only a final line lacking a trailing newline may be torn (a WARNING); any
+ * other unparseable line is a hard ERROR. */
+function scanJournal(content: string, journalPath: string): JournalScan {
+  const findings: DoctorFinding[] = [];
+  const events: RunJournalEvent[] = [];
+  if (content === "") return { findings, events };
+
+  const endedWithNewline = content.endsWith("\n");
+  const lines = content.split("\n");
+  if (endedWithNewline) lines.pop();
+
+  let prevSeq = -Infinity;
+  const seenIds = new Set<string>();
+
+  for (let i = 0; i < lines.length; i++) {
+    const line = lines[i];
+    if (line.trim() === "") continue;
+    const at = `${journalPath}:${i + 1}`;
+    let event: RunJournalEvent;
+    try {
+      event = JSON.parse(line) as RunJournalEvent;
+    } catch (err) {
+      const isPartialTail = i === lines.length - 1 && !endedWithNewline;
+      if (isPartialTail) {
+        findings.push({
+          severity: "warning",
+          code: "journal.torn_tail",
+          message:
+            "final line is truncated/garbage (expected crash artifact; repairable)",
+          evidence: at,
+        });
+      } else {
+        findings.push({
+          severity: "error",
+          code: "journal.garbage_line",
+          message: `non-final line does not parse as JSON: ${
+            err instanceof Error ? err.message : String(err)
+          }`,
+          evidence: at,
+        });
+      }
+      continue;
+    }
+
+    events.push(event);
+
+    if (!KNOWN_KINDS.has(event.kind)) {
+      findings.push({
+        severity: "error",
+        code: "journal.unknown_kind",
+        message: `unknown event kind '${event.kind}'`,
+        evidence: at,
+      });
+    }
+    if (typeof event.seq === "number") {
+      if (event.seq <= prevSeq) {
+        findings.push({
+          severity: "warning",
+          code: "journal.seq_non_monotonic",
+          message:
+            `seq ${event.seq} is not greater than previous seq ${prevSeq}`,
+          evidence: at,
+        });
+      }
+      prevSeq = event.seq;
+    }
+    if (typeof event.event_id === "string") {
+      if (seenIds.has(event.event_id)) {
+        findings.push({
+          severity: "warning",
+          code: "journal.duplicate_event_id",
+          message:
+            `duplicate event_id '${event.event_id}' (replayer dedupes it)`,
+          evidence: at,
+        });
+      } else {
+        seenIds.add(event.event_id);
+      }
+    }
+  }
+
+  return { findings, events };
+}
+
+/** Field-by-field invariant checks over the replayed result. */
+function checkReplayInvariants(
+  replay: RunJournalReplayResult,
+  journalPath: string,
+): DoctorFinding[] {
+  const findings: DoctorFinding[] = [];
+  const declared = new Set<string>();
+  for (const ev of replay.events) {
+    if (ev.kind === "node_declared") declared.add(ev.node_id);
+  }
+
+  let terminalSeen = false;
+  const attemptStarted = new Set<string>();
+  const lastNodeCost = new Map<string, number>();
+
+  for (const ev of replay.events) {
+    if (terminalSeen) {
+      findings.push({
+        severity: "error",
+        code: "replay.event_after_terminal",
+        message:
+          `event '${ev.kind}' (seq ${ev.seq}) appears after a terminal run event`,
+        evidence: journalPath,
+      });
+    }
+    if (TERMINAL_KINDS.has(ev.kind)) terminalSeen = true;
+
+    if (NODE_LIFECYCLE_KINDS.has(ev.kind) && "node_id" in ev) {
+      if (!declared.has(ev.node_id)) {
+        findings.push({
+          severity: "error",
+          code: "replay.node_never_declared",
+          message:
+            `lifecycle event '${ev.kind}' references node '${ev.node_id}' that was never declared`,
+          evidence: journalPath,
+        });
+      }
+    }
+
+    if (ev.kind === "attempt_started") {
+      attemptStarted.add(`${ev.node_id}#${ev.iteration ?? ""}`);
+    }
+    if (ev.kind === "attempt_completed") {
+      if (!attemptStarted.has(`${ev.node_id}#${ev.iteration ?? ""}`)) {
+        findings.push({
+          severity: "error",
+          code: "replay.attempt_unmatched",
+          message: `attempt_completed for node '${ev.node_id}'${
+            ev.iteration !== undefined ? ` (iteration ${ev.iteration})` : ""
+          } has no matching attempt_started`,
+          evidence: journalPath,
+        });
+      }
+    }
+
+    if (ev.kind === "node_completed" || ev.kind === "node_failed") {
+      lastNodeCost.set(ev.node_id, ev.cost_usd ?? 0);
+    }
+  }
+
+  // The replayer keeps state.total_cost_usd == Σ node.cost_usd by
+  // construction; we cross-check it against the per-node cost facts recorded
+  // at the top level of each terminal node lifecycle event. A mismatch means
+  // the journal's redundant cost copies disagree (tamper/bug).
+  let recordedSum = 0;
+  for (const cost of lastNodeCost.values()) recordedSum += cost;
+  const replayedTotal = replay.state.total_cost_usd ?? 0;
+  if (Math.abs(recordedSum - replayedTotal) > 1e-9) {
+    findings.push({
+      severity: "error",
+      code: "replay.cost_divergence",
+      message:
+        `replayed total_cost_usd ${replayedTotal} diverges from the sum of ` +
+        `per-node cost_usd ${recordedSum}`,
+      evidence: journalPath,
+    });
+  }
+
+  return findings;
+}
+
+/** Cross-check declared node directories against what is on disk. Advisory
+ * (WARNING only): the engine declares every node's dir up-front but creates it
+ * lazily, so drift in either direction is expected, not corruption. */
+async function checkFilesystem(
+  events: RunJournalEvent[],
+  runDir: string,
+  runId: string,
+): Promise<DoctorFinding[]> {
+  const findings: DoctorFinding[] = [];
+  const declaredRel = new Set<string>();
+  for (const ev of events) {
+    if (ev.kind !== "node_directory_declared") continue;
+    const rel = relNodeDir(runDir, ev.node_dir, runId);
+    if (rel === undefined) continue;
+    declaredRel.add(rel);
+    if (!(await pathExists(`${runDir}/${rel}`))) {
+      findings.push({
+        severity: "warning",
+        code: "fs.declared_dir_missing",
+        message:
+          `journal declares node directory '${rel}' but it is missing on disk`,
+        evidence: `${runDir}/${rel}`,
+      });
+    }
+  }
+
+  // Orphans: directories under the run dir that no journal event mentions.
+  // Walk the top level, descending one level into declared phase containers.
+  const declaredTop = new Set<string>();
+  for (const rel of declaredRel) declaredTop.add(rel.split("/")[0]);
+
+  for (const name of await subdirs(runDir)) {
+    if (RESERVED_RUN_DIRS.has(name)) continue;
+    if (declaredRel.has(name)) continue; // declared flat node dir
+    if (declaredTop.has(name)) {
+      // Phase container — its declared children are fine; flag undeclared ones.
+      for (const child of await subdirs(`${runDir}/${name}`)) {
+        if (!declaredRel.has(`${name}/${child}`)) {
+          findings.push(orphanFinding(`${runDir}/${name}/${child}`));
+        }
+      }
+      continue;
+    }
+    findings.push(orphanFinding(`${runDir}/${name}`));
+  }
+
+  return findings;
+}
+
+function orphanFinding(dir: string): DoctorFinding {
+  return {
+    severity: "warning",
+    code: "fs.orphan_node_dir",
+    message: "directory on disk is not mentioned by any journal event (orphan)",
+    evidence: dir,
+  };
+}
+
+/** Strip the run-dir prefix from a declared (workDir-relative) node_dir. */
+function relNodeDir(
+  runDir: string,
+  nodeDir: string,
+  runId: string,
+): string | undefined {
+  if (nodeDir.startsWith(`${runDir}/`)) return nodeDir.slice(runDir.length + 1);
+  const marker = `runs/${runId}/`;
+  const idx = nodeDir.indexOf(marker);
+  if (idx !== -1) return nodeDir.slice(idx + marker.length);
+  return undefined;
+}
+
+async function pathExists(path: string): Promise<boolean> {
+  try {
+    await Deno.stat(path);
+    return true;
+  } catch (err) {
+    if (err instanceof Deno.errors.NotFound) return false;
+    throw err;
+  }
+}
+
+async function subdirs(dir: string): Promise<string[]> {
+  const out: string[] = [];
+  try {
+    for await (const entry of Deno.readDir(dir)) {
+      if (entry.isDirectory) out.push(entry.name);
+    }
+  } catch (err) {
+    if (!(err instanceof Deno.errors.NotFound)) throw err;
+  }
+  return out;
+}
+
+/** Diagnose then apply ONLY safe mechanical repairs (FR-E83). Refuses,
+ * modifying nothing, when the run is active or the journal has any error
+ * beyond the torn final line. */
+export async function repairRun(
+  opts: { workflowDir: string; runId: string },
+): Promise<{ report: DoctorReport; outcome: RepairOutcome }> {
+  const { workflowDir, runId } = opts;
+  const report = await diagnoseRun(opts);
+  const runDir = getRunDir(runId, workflowDir);
+  const journalPath = getJournalPath(runDir);
+
+  const lock = await classifyRunLock(workflowDir, runId);
+  if (lock.status === "live") {
+    return {
+      report,
+      outcome: {
+        refused: true,
+        reason: "run is currently active (lock held by a live process)",
+        actions: [],
+      },
+    };
+  }
+  // The torn final line is the only journal fault repair touches; any ERROR
+  // means a fault beyond it, so doctor must not guess a semantic repair.
+  if (hasErrors(report)) {
+    return {
+      report,
+      outcome: {
+        refused: true,
+        reason:
+          "journal has errors beyond the torn final line; refusing to guess semantic repairs",
+        actions: [],
+      },
+    };
+  }
+
+  const actions: RepairAction[] = [];
+
+  if (report.findings.some((f) => f.code === "journal.torn_tail")) {
+    const content = await Deno.readTextFile(journalPath);
+    const lastNewline = content.lastIndexOf("\n");
+    const validPrefix = lastNewline === -1
+      ? ""
+      : content.slice(0, lastNewline + 1);
+    await Deno.copyFile(journalPath, `${journalPath}.bak`);
+    const tmp = `${journalPath}.tmp`;
+    await Deno.writeTextFile(tmp, validPrefix);
+    await Deno.rename(tmp, journalPath);
+    actions.push({
+      code: "repaired_torn_line",
+      message:
+        `removed torn final line; backup preserved at ${journalPath}.bak`,
+    });
+  }
+
+  if (report.findings.some((f) => f.code === "lock.stale")) {
+    await releaseLock(lock.path);
+    actions.push({
+      code: "removed_stale_lock",
+      message: `removed stale lock ${lock.path}`,
+    });
+  }
+
+  return { report, outcome: { refused: false, actions } };
+}
+
+/** Machine-readable findings object for `--json`. */
+export function toJson(
+  report: DoctorReport,
+  outcome?: RepairOutcome,
+): Record<string, unknown> {
+  const errors = report.findings.filter((f) => f.severity === "error").length;
+  const warnings = report.findings.length - errors;
+  const json: Record<string, unknown> = {
+    run_id: report.runId,
+    ok: !hasErrors(report),
+    findings: report.findings.map((f) => ({
+      severity: f.severity,
+      code: f.code,
+      message: f.message,
+      evidence: f.evidence,
+    })),
+    summary: { errors, warnings },
+  };
+  if (outcome) {
+    json.repair = {
+      refused: outcome.refused,
+      ...(outcome.reason ? { reason: outcome.reason } : {}),
+      actions: outcome.actions,
+    };
+  }
+  return json;
+}
+
+/** Human-readable report grouped by severity, with an OK summary. */
+export function renderReport(
+  report: DoctorReport,
+  outcome?: RepairOutcome,
+): string {
+  const errors = report.findings.filter((f) => f.severity === "error");
+  const warnings = report.findings.filter((f) => f.severity === "warning");
+  const lines: string[] = [`runs doctor — run ${report.runId}`, ""];
+
+  const renderGroup = (title: string, items: DoctorFinding[]) => {
+    lines.push(`${title} (${items.length}):`);
+    if (items.length === 0) lines.push("  (none)");
+    for (const f of items) {
+      lines.push(`  [${f.code}] ${f.message}`);
+      lines.push(`      ${f.evidence}`);
+    }
+    lines.push("");
+  };
+
+  renderGroup("ERROR", errors);
+  renderGroup("WARNING", warnings);
+
+  lines.push("OK:");
+  if (report.okGroups.length === 0) lines.push("  (none)");
+  for (const g of report.okGroups) lines.push(`  ${g}: OK`);
+  lines.push("");
+
+  if (outcome) {
+    lines.push("REPAIR:");
+    if (outcome.refused) {
+      lines.push(`  refused — ${outcome.reason}`);
+    } else if (outcome.actions.length === 0) {
+      lines.push("  nothing to repair");
+    } else {
+      for (const a of outcome.actions) lines.push(`  [${a.code}] ${a.message}`);
+    }
+    lines.push("");
+  }
+
+  lines.push(
+    hasErrors(report)
+      ? `RESULT: ${errors.length} error(s), ${warnings.length} warning(s) — exit 1`
+      : `RESULT: no errors, ${warnings.length} warning(s) — exit 0`,
+  );
+  return lines.join("\n");
+}
