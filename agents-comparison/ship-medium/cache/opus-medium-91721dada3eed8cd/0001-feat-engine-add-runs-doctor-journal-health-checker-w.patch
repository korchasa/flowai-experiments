+/**
+ * @module
+ * `runs doctor` — journal health checker with safe mechanical repair (FR-E83).
+ *
+ * Diagnoses a run's durability artifacts (`journal.jsonl`, node directories,
+ * `runs/.lock`) and can apply ONLY safe mechanical repairs. Replay invariants
+ * are evaluated through the EXISTING replayer
+ * ({@link replayRunJournal}) — this module orchestrates and inspects the replay
+ * result; it never re-implements replay. The journal-integrity pass is a
+ * line-level lint (parse each line, no state reconstruction), distinct from
+ * replay.
+ */
+
+import type { RunJournalEvent, RunJournalEventKind } from "../types.ts";
+import { getJournalPath, replayRunJournal } from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+import {
+  defaultLockPath,
+  isLockHeldByLiveProcess,
+  type LockInfo,
+  readLockInfo,
+} from "./lock.ts";
+
+/** Severity of a doctor finding. */
+export type Severity = "error" | "warning";
+
+/** One diagnosed problem (or lack thereof) about a run's durability state. */
+export interface DoctorFinding {
+  /** Whether this finding fails the run (`error`) or is tolerable (`warning`). */
+  severity: Severity;
+  /** Stable machine code, e.g. `journal.torn_final_line`. */
+  code: string;
+  /** Human-readable description. */
+  message: string;
+  /** Path or location the finding points at, when applicable. */
+  evidence?: string;
+}
+
+/** Structured result of {@link diagnoseRun}. */
+export interface DoctorReport {
+  /** Every problem found, in check order (journal → replay → filesystem). */
+  findings: DoctorFinding[];
+  /** True iff at least one finding has severity `error`. */
+  hasError: boolean;
+}
+
+/** One repair action applied by {@link repairRun}. */
+export interface RepairAction {
+  /** Stable machine code, e.g. `repair.torn_final_line`. */
+  code: string;
+  /** Human-readable description of what was changed. */
+  message: string;
+  /** Path the repair touched. */
+  evidence?: string;
+}
+
+/** Structured result of {@link repairRun}. */
+export interface RepairOutcome {
+  /** Repairs actually applied (empty when refused or nothing to do). */
+  applied: RepairAction[];
+  /** Set with a clear reason when the repair was refused; nothing was modified. */
+  refused?: string;
+}
+
+/** Parameters shared by {@link diagnoseRun} and {@link repairRun}. */
+export interface DoctorParams {
+  /** Workflow folder containing `runs/` (the dir that holds `workflow.yaml`). */
+  workflowDir: string;
+  /** Target run id. */
+  runId: string;
+}
+
+/** Runtime allow-list of journal event `kind` values, mirroring
+ * {@link RunJournalEventKind} in `types.ts` (types are compile-time only, so a
+ * runtime set is required to flag unknown kinds). Keep in sync with that union. */
+const KNOWN_KINDS: ReadonlySet<RunJournalEventKind> = new Set<
+  RunJournalEventKind
+>([
+  "run_started",
+  "run_metadata_updated",
+  "workflow_loaded",
+  "node_declared",
+  "node_directory_declared",
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+  "attempt_started",
+  "attempt_completed",
+  "continuation_exhausted",
+  "loop_iteration_started",
+  "loop_iteration_completed",
+  "loop_iteration_failed",
+  "run_completed",
+  "run_failed",
+  "run_aborted",
+]);
+
+const TERMINAL_KINDS: ReadonlySet<string> = new Set([
+  "run_completed",
+  "run_failed",
+  "run_aborted",
+]);
+
+const NODE_LIFECYCLE_KINDS: ReadonlySet<string> = new Set([
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+]);
+
+/** Directories under a run dir that are runtime metadata, not node outputs. */
+const RESERVED_RUN_CHILDREN: ReadonlySet<string> = new Set([
+  "logs",
+  "worktree",
+  ".hitl-inbox",
+]);
+
+const COST_EPSILON = 1e-9;
+
+/** Outcome of the line-level journal integrity scan, consumed by both the
+ * report and the repair planner. */
+interface JournalScan {
+  findings: DoctorFinding[];
+  /** Byte length of the valid prefix before a torn final line (repair target). */
+  tornTailByteLength?: number;
+  /** Whether the file is missing entirely. */
+  missing: boolean;
+}
+
+/** Diagnose a run's durability artifacts. Never throws on a degraded run —
+ * every problem (including a replay exception) is reported as a finding. */
+export async function diagnoseRun(params: DoctorParams): Promise<DoctorReport> {
+  const { workflowDir, runId } = params;
+  const runDir = getRunDir(runId, workflowDir);
+  const findings: DoctorFinding[] = [];
+
+  // (a) Journal integrity — own line-level scan.
+  const scan = await scanJournalIntegrity(runDir);
+  findings.push(...scan.findings);
+
+  // (b) Replay invariants — via the EXISTING replayer.
+  if (!scan.missing) {
+    await appendReplayFindings(runDir, findings);
+  }
+
+  // (c) Filesystem cross-check.
+  await appendFilesystemFindings(runDir, workflowDir, runId, findings);
+
+  return { findings, hasError: findings.some((f) => f.severity === "error") };
+}
+
+/** Line-level journal integrity scan (check a). */
+async function scanJournalIntegrity(runDir: string): Promise<JournalScan> {
+  const journalPath = getJournalPath(runDir);
+  const findings: DoctorFinding[] = [];
+  let content: string;
+  try {
+    content = await Deno.readTextFile(journalPath);
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) {
+      findings.push({
+        severity: "error",
+        code: "journal.missing",
+        message: "journal.jsonl does not exist",
+        evidence: journalPath,
+      });
+      return { findings, missing: true };
+    }
+    throw error;
+  }
+
+  if (content === "") {
+    findings.push({
+      severity: "error",
+      code: "journal.empty",
+      message: "journal.jsonl is empty (no run_started event)",
+      evidence: journalPath,
+    });
+    return { findings, missing: false };
+  }
+
+  const endedWithNewline = content.endsWith("\n");
+  const lines = content.split("\n");
+  if (endedWithNewline) lines.pop();
+
+  let tornTailByteLength: number | undefined;
+  let lineStart = 0;
+  let maxSeq = -Infinity;
+  const seenEventIds = new Set<string>();
+
+  for (let i = 0; i < lines.length; i++) {
+    const line = lines[i];
+    const nextLineStart = lineStart + line.length + 1;
+    if (line.trim() === "") {
+      lineStart = nextLineStart;
+      continue;
+    }
+    let event: RunJournalEvent;
+    try {
+      event = JSON.parse(line) as RunJournalEvent;
+    } catch (error) {
+      const isFinal = i === lines.length - 1 && !endedWithNewline;
+      const reason = error instanceof Error ? error.message : String(error);
+      if (isFinal) {
+        tornTailByteLength = byteLength(content.slice(0, lineStart));
+        findings.push({
+          severity: "warning",
+          code: "journal.torn_final_line",
+          message:
+            `truncated/garbage final line (expected crash artifact): ${reason}`,
+          evidence: `${journalPath}:${i + 1}`,
+        });
+      } else {
+        findings.push({
+          severity: "error",
+          code: "journal.unparsable_line",
+          message: `non-final line does not parse as JSON: ${reason}`,
+          evidence: `${journalPath}:${i + 1}`,
+        });
+      }
+      lineStart = nextLineStart;
+      continue;
+    }
+
+    const kind = event.kind;
+    if (!KNOWN_KINDS.has(kind)) {
+      findings.push({
+        severity: "error",
+        code: "journal.unknown_kind",
+        message: `unknown event kind '${String(kind)}'`,
+        evidence: `${journalPath}:${i + 1}`,
+      });
+    }
+
+    const eventId = event.event_id;
+    const isDuplicate = eventId !== undefined && seenEventIds.has(eventId);
+    if (isDuplicate) {
+      findings.push({
+        severity: "warning",
+        code: "journal.duplicate_event_id",
+        message: `duplicate event_id '${eventId}' (replayer dedupes on replay)`,
+        evidence: `${journalPath}:${i + 1}`,
+      });
+    } else if (eventId !== undefined) {
+      seenEventIds.add(eventId);
+    }
+
+    const seq = event.seq;
+    if (typeof seq === "number") {
+      if (!isDuplicate && seq <= maxSeq) {
+        findings.push({
+          severity: "error",
+          code: "journal.non_monotonic_seq",
+          message: `non-monotonic seq ${seq} (previous max ${maxSeq})`,
+          evidence: `${journalPath}:${i + 1}`,
+        });
+      }
+      if (seq > maxSeq) maxSeq = seq;
+    }
+    lineStart = nextLineStart;
+  }
+
+  return { findings, tornTailByteLength, missing: false };
+}
+
+/** Replay-invariant checks (check b) using the existing replayer. */
+async function appendReplayFindings(
+  runDir: string,
+  findings: DoctorFinding[],
+): Promise<void> {
+  let events: RunJournalEvent[];
+  let replayedTotalCost: number | undefined;
+  try {
+    const result = await replayRunJournal(runDir);
+    events = result.events;
+    replayedTotalCost = result.state.total_cost_usd;
+  } catch (error) {
+    // Only surface a fresh ERROR when no parse-level error already explains
+    // the failure — avoids double-reporting mid-file garbage.
+    if (!findings.some((f) => f.severity === "error")) {
+      findings.push({
+        severity: "error",
+        code: "replay.failed",
+        message: `replay failed: ${
+          error instanceof Error ? error.message : String(error)
+        }`,
+        evidence: getJournalPath(runDir),
+      });
+    }
+    return;
+  }
+
+  const declaredNodes = new Set<string>();
+  const attemptStarted = new Set<string>();
+  // Per node: cost from the completing attempt (last attempt cost wins,
+  // mirroring how `markNodeCompleted` records the completing attempt's cost).
+  const lastAttemptCost = new Map<string, number>();
+  // Per node: cost recorded on the replayed node snapshot.
+  const nodeSnapshotCost = new Map<string, number>();
+  let terminalSeen = false;
+
+  for (const event of events) {
+    if (terminalSeen) {
+      findings.push({
+        severity: "error",
+        code: "replay.event_after_terminal",
+        message:
+          `event '${event.kind}' (seq ${event.seq}) appears after a terminal run event`,
+        evidence: `seq ${event.seq}`,
+      });
+    }
+    if (TERMINAL_KINDS.has(event.kind)) terminalSeen = true;
+
+    if (event.kind === "node_declared") {
+      declaredNodes.add(event.node_id);
+    }
+
+    if (NODE_LIFECYCLE_KINDS.has(event.kind) && "node_id" in event) {
+      const nodeId = event.node_id as string;
+      if (!declaredNodes.has(nodeId)) {
+        findings.push({
+          severity: "error",
+          code: "replay.undeclared_node",
+          message:
+            `node lifecycle event '${event.kind}' for never-declared node '${nodeId}'`,
+          evidence: `seq ${event.seq}`,
+        });
+      }
+      const cost = (event as { node?: { cost_usd?: number } }).node?.cost_usd;
+      if (typeof cost === "number") nodeSnapshotCost.set(nodeId, cost);
+    }
+
+    if (event.kind === "attempt_started") {
+      attemptStarted.add(event.node_id);
+    }
+    if (
+      event.kind === "attempt_completed" ||
+      event.kind === "continuation_exhausted"
+    ) {
+      if (!attemptStarted.has(event.node_id)) {
+        findings.push({
+          severity: "error",
+          code: "replay.attempt_completed_without_started",
+          message:
+            `attempt_completed for node '${event.node_id}' without a matching attempt_started`,
+          evidence: `seq ${event.seq}`,
+        });
+      }
+      if (typeof event.cost_usd === "number") {
+        lastAttemptCost.set(event.node_id, event.cost_usd);
+      }
+    }
+  }
+
+  // Cost reconciliation over nodes that recorded an attempt cost: the
+  // replayed node snapshot cost must match the completing attempt's cost.
+  let snapshotSum = 0;
+  let attemptSum = 0;
+  for (const [nodeId, attemptCost] of lastAttemptCost) {
+    attemptSum += attemptCost;
+    snapshotSum += nodeSnapshotCost.get(nodeId) ?? 0;
+  }
+  if (
+    lastAttemptCost.size > 0 &&
+    Math.abs(snapshotSum - attemptSum) > COST_EPSILON
+  ) {
+    findings.push({
+      severity: "error",
+      code: "replay.cost_divergence",
+      message: `replayed per-node cost ${snapshotSum} diverges from recorded ` +
+        `attempt cost ${attemptSum}` +
+        (replayedTotalCost !== undefined
+          ? ` (replayed total_cost_usd ${replayedTotalCost})`
+          : ""),
+    });
+  }
+}
+
+/** Filesystem cross-check (check c): orphan/missing node dirs + stale lock. */
+async function appendFilesystemFindings(
+  runDir: string,
+  workflowDir: string,
+  runId: string,
+  findings: DoctorFinding[],
+): Promise<void> {
+  // Re-parse the journal (tolerantly) to collect mentioned node ids and
+  // declared directories. Reuse the replayer's event list when it replays;
+  // otherwise read lines directly so a degraded journal still cross-checks.
+  const { mentionedNodes, declaredDirs } = await collectJournalNodeRefs(runDir);
+
+  // Declared-but-missing directories.
+  for (const [nodeId, dirPath] of declaredDirs) {
+    if (!(await dirExists(dirPath))) {
+      findings.push({
+        severity: "error",
+        code: "fs.declared_dir_missing",
+        message:
+          `journal declares node '${nodeId}' dir but it is missing on disk`,
+        evidence: dirPath,
+      });
+    }
+  }
+
+  // Orphan directories on disk under the run dir.
+  await appendOrphanFindings(runDir, mentionedNodes, findings);
+
+  // Stale lock for this run.
+  const lockPath = defaultLockPath(workflowDir);
+  let info: LockInfo | undefined;
+  try {
+    info = await readLockInfo(lockPath);
+  } catch {
+    info = undefined; // absent or corrupt lock — not this run's concern here.
+  }
+  if (info && info.run_id === runId && !isLockHeldByLiveProcess(info)) {
+    findings.push({
+      severity: "warning",
+      code: "fs.stale_lock",
+      message:
+        `runs/.lock references this run (pid ${info.pid}) but the process is not alive`,
+      evidence: lockPath,
+    });
+  }
+}
+
+/** Collect node ids mentioned anywhere in the journal and the on-disk paths of
+ * directories the journal explicitly declares. Tolerant of degraded journals. */
+async function collectJournalNodeRefs(
+  runDir: string,
+): Promise<{
+  mentionedNodes: Set<string>;
+  declaredDirs: Map<string, string>;
+}> {
+  const mentionedNodes = new Set<string>();
+  const declaredDirs = new Map<string, string>();
+  let content: string;
+  try {
+    content = await Deno.readTextFile(getJournalPath(runDir));
+  } catch {
+    return { mentionedNodes, declaredDirs };
+  }
+  for (const line of content.split("\n")) {
+    const trimmed = line.trim();
+    if (!trimmed) continue;
+    let event: RunJournalEvent;
+    try {
+      event = JSON.parse(trimmed) as RunJournalEvent;
+    } catch {
+      continue; // torn/garbage line — skip for cross-check.
+    }
+    if ("node_id" in event && typeof event.node_id === "string") {
+      mentionedNodes.add(event.node_id);
+    }
+    if ("loop_node_id" in event && typeof event.loop_node_id === "string") {
+      mentionedNodes.add(event.loop_node_id);
+    }
+    if (event.kind === "node_directory_declared") {
+      const onDisk = resolveDeclaredDir(runDir, event.node_dir);
+      declaredDirs.set(event.node_id, onDisk);
+    }
+  }
+  return { mentionedNodes, declaredDirs };
+}
+
+/** Resolve a workDir-relative declared `node_dir` to its path under `runDir`.
+ * The declared path is `…/runs/<runId>/<tail>`; the tail (node id, optionally
+ * phase-prefixed) is appended to the actual `runDir`. Falls back to treating
+ * the whole value as already run-relative. */
+function resolveDeclaredDir(runDir: string, nodeDir: string): string {
+  // Strip a leading `…/runs/<runId>/` prefix to get the in-run tail.
+  const m = nodeDir.match(/(?:^|\/)runs\/[^/]+\/(.+)$/);
+  if (m) return `${runDir}/${m[1]}`;
+  // Already a bare tail (no runs/<id>/ prefix).
+  return `${runDir}/${nodeDir.replace(/^\/+/, "")}`;
+}
+
+/** Walk the immediate (and one phase-level) children of `runDir`, flagging any
+ * node directory whose name is not mentioned by the journal. */
+async function appendOrphanFindings(
+  runDir: string,
+  mentionedNodes: Set<string>,
+  findings: DoctorFinding[],
+): Promise<void> {
+  let children: Deno.DirEntry[];
+  try {
+    children = [];
+    for await (const entry of Deno.readDir(runDir)) children.push(entry);
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return;
+    throw error;
+  }
+
+  for (const child of children) {
+    if (!child.isDirectory) continue;
+    if (RESERVED_RUN_CHILDREN.has(child.name)) continue;
+    if (mentionedNodes.has(child.name)) continue;
+
+    // Possibly a phase grouping dir: if it holds known node-id children,
+    // treat it as a phase and check the grandchildren instead.
+    const childPath = `${runDir}/${child.name}`;
+    const grandchildren: string[] = [];
+    let hasKnownGrandchild = false;
+    for await (const g of Deno.readDir(childPath)) {
+      if (!g.isDirectory) continue;
+      grandchildren.push(g.name);
+      if (mentionedNodes.has(g.name)) hasKnownGrandchild = true;
+    }
+    if (hasKnownGrandchild) {
+      for (const g of grandchildren) {
+        if (!mentionedNodes.has(g)) {
+          findings.push({
+            severity: "error",
+            code: "fs.orphan_dir",
+            message:
+              `node directory '${child.name}/${g}' on disk is mentioned by no journal event`,
+            evidence: `${childPath}/${g}`,
+          });
+        }
+      }
+      continue;
+    }
+
+    findings.push({
+      severity: "error",
+      code: "fs.orphan_dir",
+      message:
+        `node directory '${child.name}' on disk is mentioned by no journal event`,
+      evidence: childPath,
+    });
+  }
+}
+
+/** Apply ONLY safe mechanical repairs for the given report. Fail-safe: refuses
+ * (modifying nothing) when the run is active or the journal has errors beyond a
+ * torn final line. */
+export async function repairRun(
+  params: DoctorParams,
+  report: DoctorReport,
+): Promise<RepairOutcome> {
+  const { workflowDir, runId } = params;
+  const runDir = getRunDir(runId, workflowDir);
+  const lockPath = defaultLockPath(workflowDir);
+
+  // Refuse if the run is currently active (this run's lock held by a live pid).
+  let info: LockInfo | undefined;
+  try {
+    info = await readLockInfo(lockPath);
+  } catch {
+    info = undefined;
+  }
+  if (info && info.run_id === runId && isLockHeldByLiveProcess(info)) {
+    return {
+      applied: [],
+      refused:
+        `run '${runId}' is currently active (lock pid ${info.pid} is alive); refusing to modify durability artifacts`,
+    };
+  }
+
+  // Refuse the journal rewrite if any non-torn-tail journal/replay error exists.
+  const blockingErrors = report.findings.filter(
+    (f) =>
+      f.severity === "error" &&
+      (f.code.startsWith("journal.") || f.code.startsWith("replay.")),
+  );
+  if (blockingErrors.length > 0) {
+    return {
+      applied: [],
+      refused:
+        `journal has ${blockingErrors.length} error(s) beyond a torn final line; ` +
+        `doctor only applies mechanical fixes and will not guess at semantic repairs`,
+    };
+  }
+
+  const applied: RepairAction[] = [];
+
+  // Repair a torn final line: backup, write tmp, atomic rename.
+  const torn = report.findings.find((f) =>
+    f.code === "journal.torn_final_line"
+  );
+  if (torn) {
+    const scan = await scanJournalIntegrity(runDir);
+    if (scan.tornTailByteLength !== undefined) {
+      const journalPath = getJournalPath(runDir);
+      const raw = await Deno.readFile(journalPath);
+      await Deno.writeFile(`${journalPath}.bak`, raw);
+      const valid = raw.subarray(0, scan.tornTailByteLength);
+      const tmpPath = `${journalPath}.tmp`;
+      await Deno.writeFile(tmpPath, valid);
+      await Deno.rename(tmpPath, journalPath);
+      applied.push({
+        code: "repair.torn_final_line",
+        message:
+          "dropped torn final journal line (backup at journal.jsonl.bak)",
+        evidence: journalPath,
+      });
+    }
+  }
+
+  // Remove a stale lock for this run.
+  const stale = report.findings.find((f) => f.code === "fs.stale_lock");
+  if (stale) {
+    await Deno.remove(lockPath);
+    applied.push({
+      code: "repair.stale_lock",
+      message: "removed stale runs/.lock for this run",
+      evidence: lockPath,
+    });
+  }
+
+  return { applied };
+}
+
+/** Render a human-readable report grouped by severity (ERROR / WARNING / OK). */
+export function formatReport(report: DoctorReport): string {
+  const errors = report.findings.filter((f) => f.severity === "error");
+  const warnings = report.findings.filter((f) => f.severity === "warning");
+  const lines: string[] = [];
+  if (errors.length > 0) {
+    lines.push(`ERROR (${errors.length}):`);
+    for (const f of errors) lines.push(formatFindingLine(f));
+  }
+  if (warnings.length > 0) {
+    lines.push(`WARNING (${warnings.length}):`);
+    for (const f of warnings) lines.push(formatFindingLine(f));
+  }
+  if (errors.length === 0 && warnings.length === 0) {
+    lines.push("OK: no problems found.");
+  }
+  lines.push(
+    `Summary: ${errors.length} error(s), ${warnings.length} warning(s).`,
+  );
+  return lines.join("\n");
+}
+
+function formatFindingLine(f: DoctorFinding): string {
+  const ev = f.evidence ? ` [${f.evidence}]` : "";
+  return `  - [${f.code}] ${f.message}${ev}`;
+}
+
+async function dirExists(path: string): Promise<boolean> {
+  try {
+    const stat = await Deno.stat(path);
+    return stat.isDirectory;
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return false;
+    throw error;
+  }
+}
+
+function byteLength(text: string): number {
+  return new TextEncoder().encode(text).length;
+}
