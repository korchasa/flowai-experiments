+/** Parsed arguments for the `runs doctor` subcommand (FR-E83). */
+export interface RunsDoctorArgs {
+  /** Workflow folder containing `runs/` (`--workflow <dir>`). */
+  workflowDir: string;
+  /** Target run id (`--run <runId>`). */
+  runId: string;
+  /** Apply safe mechanical repairs (`--repair`). */
+  repair: boolean;
+  /** Emit machine-readable JSON findings (`--json`). */
+  json: boolean;
+}
+
+/**
+ * Parse `runs doctor --workflow <dir> --run <runId> [--repair] [--json]`
+ * (FR-E83). Follows the existing manual flag-loop style; both `--flag value`
+ * and `--flag=value` forms are accepted for `--workflow`/`--run`.
+ */
+export function parseRunsDoctorArgs(args: string[]): RunsDoctorArgs {
+  let workflowDir: string | undefined;
+  let runId: string | undefined;
+  let repair = false;
+  let json = false;
+  for (let i = 0; i < args.length; i++) {
+    const a = args[i];
+    if (a === "--workflow") {
+      workflowDir = args[++i];
+    } else if (a.startsWith("--workflow=")) {
+      workflowDir = a.slice("--workflow=".length);
+    } else if (a === "--run") {
+      runId = args[++i];
+    } else if (a.startsWith("--run=")) {
+      runId = a.slice("--run=".length);
+    } else if (a === "--repair") {
+      repair = true;
+    } else if (a === "--json") {
+      json = true;
+    } else {
+      throw new Error(`runs doctor: unexpected argument: ${a}`);
+    }
+  }
+  if (!workflowDir) {
+    throw new Error(
+      "runs doctor: missing --workflow <dir>. " +
+        "Usage: flowai-workflow runs doctor --workflow <dir> --run <runId> " +
+        "[--repair] [--json]",
+    );
+  }
+  if (!runId) {
+    throw new Error("runs doctor: missing --run <runId>.");
+  }
+  return {
+    workflowDir: normalizeWorkflowDir(workflowDir),
+    runId,
+    repair,
+    json,
+  };
+}
+
+/**
+ * Run the `runs doctor` subcommand (FR-E83): diagnose a run's durability
+ * artifacts, optionally applying safe mechanical repairs. Exit 0 when no
+ * ERRORs and no refusal; 1 otherwise.
+ */
+async function runRunsDoctor(args: string[]): Promise<never> {
+  try {
+    const parsed = parseRunsDoctorArgs(args);
+    const report: DoctorReport = await diagnoseRun({
+      workflowDir: parsed.workflowDir,
+      runId: parsed.runId,
+    });
+    let repair: RepairOutcome | undefined;
+    if (parsed.repair) {
+      repair = await repairRun(
+        { workflowDir: parsed.workflowDir, runId: parsed.runId },
+        report,
+      );
+    }
+    if (parsed.json) {
+      console.log(JSON.stringify(
+        {
+          ok: !report.hasError && !(repair?.refused),
+          findings: report.findings,
+          ...(repair
+            ? { repairs: repair.applied, refused: repair.refused ?? null }
+            : {}),
+        },
+        null,
+        2,
+      ));
+    } else {
+      console.log(formatReport(report));
+      if (repair) {
+        if (repair.refused) {
+          console.log(`Repair refused: ${repair.refused}`);
+        } else if (repair.applied.length === 0) {
+          console.log("Repair: no mechanical repairs applicable.");
+        } else {
+          console.log("Repairs applied:");
+          for (const action of repair.applied) {
+            const ev = action.evidence ? ` [${action.evidence}]` : "";
+            console.log(`  - [${action.code}] ${action.message}${ev}`);
+          }
+        }
+      }
+    }
+    const failed = report.hasError || Boolean(repair?.refused);
+    Deno.exit(failed ? 1 : 0);
+  } catch (err) {
+    console.error(`Error: ${(err as Error).message}`);
+    Deno.exit(2);
+  }
+}
