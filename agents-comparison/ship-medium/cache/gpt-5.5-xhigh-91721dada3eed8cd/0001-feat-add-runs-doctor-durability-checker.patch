@@ -0,0 +1,740 @@
+/**
+ * @module
+ * Run durability doctor for one workflow run (FR-E83).
+ *
+ * The doctor inspects journal integrity, replay invariants, run-directory
+ * shape, and the per-workflow lock. Durable state reconstruction remains owned
+ * by `run-journal.ts`; this module orchestrates that replayer and compares the
+ * replay result with surrounding durability artifacts.
+ */
+
+import { basename, isAbsolute, resolve } from "@std/path";
+
+import { loadConfig, workflowConfigPath } from "../config/config.ts";
+import type {
+  RunJournalEvent,
+  RunJournalEventKind,
+  WorkflowConfig,
+} from "../types.ts";
+import { defaultLockPath, readLockInfo } from "./lock.ts";
+import { getJournalPath, replayRunJournal } from "./run-journal.ts";
+import { getNodeDir, getRunDir, PhaseRegistry } from "./state.ts";
+
+/** Severity for a doctor finding. */
+export type DoctorSeverity = "ERROR" | "WARNING";
+
+/** One machine-readable doctor finding. */
+export interface DoctorFinding {
+  /** Finding severity. Any `ERROR` makes the command exit non-zero. */
+  severity: DoctorSeverity;
+  /** Stable snake_case finding code. */
+  code: string;
+  /** Human-readable diagnostic. */
+  message: string;
+  /** Path or path-like evidence location. Always populated for JSON output. */
+  evidence_path: string;
+}
+
+/** One repair action applied by `--repair`. */
+export interface DoctorRepair {
+  /** Stable snake_case repair code. */
+  code: string;
+  /** Human-readable repair summary. */
+  message: string;
+  /** Path modified by the repair. */
+  evidence_path: string;
+}
+
+/** Options for {@link runDoctor}. */
+export interface RunDoctorOptions {
+  /** Workflow folder containing `workflow.yaml` and `runs/`. */
+  workflowDir: string;
+  /** Target run ID under `<workflowDir>/runs/`. */
+  runId: string;
+  /** Apply safe mechanical repairs after diagnosis. */
+  repair?: boolean;
+}
+
+/** Result returned by {@link runDoctor}. */
+export interface RunDoctorResult {
+  /** Target workflow directory. */
+  workflowDir: string;
+  /** Target run ID. */
+  runId: string;
+  /** Target run directory. */
+  runDir: string;
+  /** Findings collected from all doctor phases. */
+  findings: DoctorFinding[];
+  /** Safe repairs applied during this invocation. */
+  repairs: DoctorRepair[];
+  /** Process exit code implied by findings. */
+  exitCode: 0 | 1;
+}
+
+interface ParsedJournal {
+  events: Array<{ event: RunJournalEvent; line: number }>;
+  findings: DoctorFinding[];
+  tornFinalLine: boolean;
+  validByteLength?: number;
+}
+
+interface LockStatus {
+  lockPath: string;
+  live: boolean;
+  staleForTarget: boolean;
+}
+
+const VALID_JOURNAL_KINDS: readonly RunJournalEventKind[] = [
+  "run_started",
+  "run_metadata_updated",
+  "workflow_loaded",
+  "node_declared",
+  "node_directory_declared",
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+  "attempt_started",
+  "attempt_completed",
+  "continuation_exhausted",
+  "loop_iteration_started",
+  "loop_iteration_completed",
+  "loop_iteration_failed",
+  "run_completed",
+  "run_failed",
+  "run_aborted",
+];
+
+const LIFECYCLE_KINDS = new Set<string>([
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+]);
+
+const TERMINAL_KINDS = new Set<string>([
+  "run_completed",
+  "run_failed",
+  "run_aborted",
+]);
+
+const INFRA_DIRS = new Set(["logs", "worktree", ".hitl-inbox"]);
+
+/** Diagnose and optionally repair one run's durability artifacts. */
+export async function runDoctor(
+  opts: RunDoctorOptions,
+): Promise<RunDoctorResult> {
+  const workflowDir = opts.workflowDir.replace(/\/+$/, "");
+  const runDir = getRunDir(opts.runId, workflowDir);
+  const parsed = await parseJournalForDoctor(runDir);
+  const findings = [...parsed.findings];
+
+  let config: WorkflowConfig | undefined;
+  try {
+    config = await loadConfig(workflowConfigPath(workflowDir));
+  } catch (error) {
+    findings.push(finding(
+      "ERROR",
+      "workflow_load_failed",
+      `Cannot load workflow config: ${messageOf(error)}`,
+      workflowConfigPath(workflowDir),
+    ));
+  }
+
+  const replay = await replayForDoctor(runDir);
+  if (replay.finding) findings.push(replay.finding);
+
+  inspectReplayInvariants(parsed.events, replay.state, findings);
+  await inspectFilesystem({
+    workflowDir,
+    runId: opts.runId,
+    runDir,
+    config,
+    events: parsed.events,
+    findings,
+  });
+
+  const lock = await inspectLock(workflowDir, opts.runId, findings);
+  const repairs: DoctorRepair[] = [];
+  if (opts.repair) {
+    await applyRepairs({
+      runDir,
+      parsed,
+      findings,
+      repairs,
+      lock,
+    });
+  }
+
+  return {
+    workflowDir,
+    runId: opts.runId,
+    runDir,
+    findings,
+    repairs,
+    exitCode: findings.some((item) => item.severity === "ERROR") ? 1 : 0,
+  };
+}
+
+/** Render only the machine-readable finding list requested by `--json`. */
+export function formatDoctorJson(result: RunDoctorResult): string {
+  return JSON.stringify(result.findings, null, 2);
+}
+
+/** Render a human-readable report grouped by severity. */
+export function formatDoctorReport(result: RunDoctorResult): string {
+  const lines = [
+    `runs doctor: ${result.workflowDir} / ${result.runId}`,
+  ];
+  for (const severity of ["ERROR", "WARNING"] as const) {
+    const group = result.findings.filter((finding) =>
+      finding.severity === severity
+    );
+    lines.push("", `${severity}: ${group.length === 0 ? "none" : ""}`);
+    for (const finding of group) {
+      lines.push(
+        `- ${finding.code}: ${finding.message} (${finding.evidence_path})`,
+      );
+    }
+  }
+
+  lines.push(
+    "",
+    result.exitCode === 0
+      ? `OK: ${result.findings.length} finding(s), no errors.`
+      : `FAIL: blocked by ${
+        result.findings.filter((finding) => finding.severity === "ERROR")
+          .length
+      } error(s).`,
+  );
+
+  if (result.repairs.length > 0) {
+    lines.push("", "Repairs:");
+    for (const repair of result.repairs) {
+      lines.push(
+        `- ${repair.code}: ${repair.message} (${repair.evidence_path})`,
+      );
+    }
+  }
+
+  return lines.join("\n") + "\n";
+}
+
+async function parseJournalForDoctor(runDir: string): Promise<ParsedJournal> {
+  const journalPath = getJournalPath(runDir);
+  let content: string;
+  try {
+    content = await Deno.readTextFile(journalPath);
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) {
+      return {
+        events: [],
+        tornFinalLine: false,
+        findings: [
+          finding(
+            "ERROR",
+            "journal_missing",
+            "journal.jsonl is missing",
+            journalPath,
+          ),
+        ],
+      };
+    }
+    return {
+      events: [],
+      tornFinalLine: false,
+      findings: [
+        finding(
+          "ERROR",
+          "journal_read_failed",
+          `Cannot read journal: ${messageOf(error)}`,
+          journalPath,
+        ),
+      ],
+    };
+  }
+
+  const findings: DoctorFinding[] = [];
+  const events: Array<{ event: RunJournalEvent; line: number }> = [];
+  const endedWithNewline = content.endsWith("\n");
+  const lines = content.split("\n");
+  if (endedWithNewline) lines.pop();
+
+  let lineStart = 0;
+  let tornFinalLine = false;
+  let validByteLength: number | undefined;
+  let lastSeq: number | undefined;
+  const eventIds = new Set<string>();
+
+  for (let index = 0; index < lines.length; index++) {
+    const line = lines[index];
+    const lineNumber = index + 1;
+    const nextLineStart = lineStart + line.length + 1;
+    if (line.trim() === "") {
+      lineStart = nextLineStart;
+      continue;
+    }
+
+    let raw: unknown;
+    try {
+      raw = JSON.parse(line);
+    } catch (error) {
+      const finalLine = index === lines.length - 1;
+      if (finalLine && !endedWithNewline) {
+        tornFinalLine = true;
+        validByteLength = new TextEncoder().encode(
+          content.slice(0, lineStart),
+        ).length;
+        findings.push(finding(
+          "WARNING",
+          "journal_torn_final_line",
+          `Ignoring torn final journal line ${lineNumber}: ${messageOf(error)}`,
+          `${journalPath}:${lineNumber}`,
+        ));
+        break;
+      }
+      findings.push(finding(
+        "ERROR",
+        "journal_malformed_line",
+        `Malformed journal line ${lineNumber}: ${messageOf(error)}`,
+        `${journalPath}:${lineNumber}`,
+      ));
+      lineStart = nextLineStart;
+      continue;
+    }
+
+    if (!isRecord(raw)) {
+      findings.push(finding(
+        "ERROR",
+        "journal_invalid_record",
+        `Journal line ${lineNumber} is not a JSON object`,
+        `${journalPath}:${lineNumber}`,
+      ));
+      lineStart = nextLineStart;
+      continue;
+    }
+
+    const kind = raw.kind;
+    if (typeof kind !== "string" || !isJournalKind(kind)) {
+      findings.push(finding(
+        "ERROR",
+        "unknown_event_kind",
+        `Unknown journal event kind at line ${lineNumber}: ${String(kind)}`,
+        `${journalPath}:${lineNumber}`,
+      ));
+    }
+
+    const seq = raw.seq;
+    if (typeof seq === "number") {
+      if (lastSeq !== undefined && seq <= lastSeq) {
+        findings.push(finding(
+          "ERROR",
+          "non_monotonic_seq",
+          `Journal seq ${seq} at line ${lineNumber} is not greater than ${lastSeq}`,
+          `${journalPath}:${lineNumber}`,
+        ));
+      }
+      lastSeq = seq;
+    } else {
+      findings.push(finding(
+        "ERROR",
+        "journal_invalid_seq",
+        `Journal line ${lineNumber} has invalid seq`,
+        `${journalPath}:${lineNumber}`,
+      ));
+    }
+
+    const eventId = raw.event_id;
+    if (typeof eventId === "string") {
+      if (eventIds.has(eventId)) {
+        findings.push(finding(
+          "WARNING",
+          "duplicate_event_id",
+          `Duplicate event_id '${eventId}' at line ${lineNumber}`,
+          `${journalPath}:${lineNumber}`,
+        ));
+      }
+      eventIds.add(eventId);
+    } else {
+      findings.push(finding(
+        "ERROR",
+        "journal_invalid_event_id",
+        `Journal line ${lineNumber} has invalid event_id`,
+        `${journalPath}:${lineNumber}`,
+      ));
+    }
+
+    events.push({ event: raw as unknown as RunJournalEvent, line: lineNumber });
+    lineStart = nextLineStart;
+  }
+
+  return { events, findings, tornFinalLine, validByteLength };
+}
+
+async function replayForDoctor(
+  runDir: string,
+): Promise<{
+  state?: Awaited<ReturnType<typeof replayRunJournal>>["state"];
+  finding?: DoctorFinding;
+}> {
+  try {
+    return { state: (await replayRunJournal(runDir)).state };
+  } catch (error) {
+    return {
+      finding: finding(
+        "ERROR",
+        "journal_replay_failed",
+        `Journal replay failed: ${messageOf(error)}`,
+        getJournalPath(runDir),
+      ),
+    };
+  }
+}
+
+function inspectReplayInvariants(
+  events: Array<{ event: RunJournalEvent; line: number }>,
+  state: Awaited<ReturnType<typeof replayRunJournal>>["state"] | undefined,
+  findings: DoctorFinding[],
+): void {
+  let terminalLine: number | undefined;
+  const declaredNodes = new Set<string>();
+  const attemptStarts = new Map<string, number>();
+  const latestEventCostByNode = new Map<string, number>();
+
+  for (const { event, line } of events) {
+    if (terminalLine !== undefined) {
+      findings.push(finding(
+        "ERROR",
+        "event_after_terminal",
+        `Event '${event.kind}' appears after terminal run event at line ${terminalLine}`,
+        `${eventPath(events, line)}`,
+      ));
+    }
+    if (TERMINAL_KINDS.has(event.kind)) terminalLine = line;
+
+    if (event.kind === "node_declared") declaredNodes.add(event.node_id);
+
+    if (event.kind === "attempt_started") {
+      const key = attemptKey(event.node_id, event.iteration);
+      attemptStarts.set(key, (attemptStarts.get(key) ?? 0) + 1);
+    }
+    if (event.kind === "attempt_completed") {
+      const key = attemptKey(event.node_id, event.iteration);
+      const count = attemptStarts.get(key) ?? 0;
+      if (count === 0) {
+        findings.push(finding(
+          "ERROR",
+          "attempt_completed_without_started",
+          `attempt_completed has no matching attempt_started for '${key}'`,
+          `${eventPath(events, line)}`,
+        ));
+      } else {
+        attemptStarts.set(key, count - 1);
+      }
+    }
+
+    if (LIFECYCLE_KINDS.has(event.kind) && "node_id" in event) {
+      if (!declaredNodes.has(event.node_id)) {
+        findings.push(finding(
+          "ERROR",
+          "undeclared_node_lifecycle",
+          `Node lifecycle event '${event.kind}' references undeclared node '${event.node_id}'`,
+          `${eventPath(events, line)}`,
+        ));
+      }
+      if ("cost_usd" in event && typeof event.cost_usd === "number") {
+        latestEventCostByNode.set(event.node_id, event.cost_usd);
+      } else if (
+        "metadata" in event && typeof event.metadata?.cost_usd === "number"
+      ) {
+        latestEventCostByNode.set(event.node_id, event.metadata.cost_usd);
+      } else if ("node" in event && typeof event.node.cost_usd === "number") {
+        latestEventCostByNode.set(event.node_id, event.node.cost_usd);
+      }
+    }
+  }
+
+  if (terminalLine !== undefined) {
+    for (const [key, count] of attemptStarts) {
+      if (count <= 0) continue;
+      findings.push(finding(
+        "ERROR",
+        "attempt_started_without_completed",
+        `attempt_started has no matching attempt_completed for '${key}'`,
+        `${eventPath(events, terminalLine)}`,
+      ));
+    }
+  }
+
+  if (!state) return;
+  const stateCost = state.total_cost_usd ?? 0;
+  const nodeCost = Object.values(state.nodes).reduce(
+    (sum, node) => sum + (node.cost_usd ?? 0),
+    0,
+  );
+  const eventCost = latestEventCostByNode.size === 0
+    ? nodeCost
+    : [...latestEventCostByNode.values()].reduce((sum, cost) => sum + cost, 0);
+  if (!sameMoney(stateCost, nodeCost) || !sameMoney(stateCost, eventCost)) {
+    findings.push(finding(
+      "ERROR",
+      "cost_sum_divergence",
+      `Replayed total_cost_usd ${stateCost} diverges from per-node cost sum ${eventCost}`,
+      "journal.jsonl",
+    ));
+  }
+}
+
+async function inspectFilesystem(params: {
+  workflowDir: string;
+  runId: string;
+  runDir: string;
+  config: WorkflowConfig | undefined;
+  events: Array<{ event: RunJournalEvent; line: number }>;
+  findings: DoctorFinding[];
+}): Promise<void> {
+  const declaredDirs = new Set<string>();
+  const mentionedNodeIds = new Set<string>();
+  for (const { event } of params.events) {
+    if ("node_id" in event) mentionedNodeIds.add(event.node_id);
+    if ("loop_node_id" in event) mentionedNodeIds.add(event.loop_node_id);
+    if (event.kind === "node_directory_declared") {
+      declaredDirs.add(resolveEvidencePath(event.node_dir));
+    }
+  }
+
+  if (params.config) {
+    const registry = PhaseRegistry.fromConfig(params.config);
+    for (const nodeId of Object.keys(params.config.nodes)) {
+      const path = getNodeDir(
+        params.runId,
+        nodeId,
+        params.workflowDir,
+        registry,
+      );
+      if (mentionedNodeIds.has(nodeId)) {
+        declaredDirs.add(resolveEvidencePath(path));
+      }
+    }
+  }
+
+  for (const declaredPath of declaredDirs) {
+    try {
+      const stat = await Deno.stat(declaredPath);
+      if (!stat.isDirectory) throw new Error("path is not a directory");
+    } catch (error) {
+      if (error instanceof Deno.errors.NotFound) {
+        params.findings.push(finding(
+          "WARNING",
+          "missing_declared_node_directory",
+          "Journal declares a node directory that is missing on disk",
+          declaredPath,
+        ));
+      } else {
+        params.findings.push(finding(
+          "ERROR",
+          "node_directory_stat_failed",
+          `Cannot inspect declared node directory: ${messageOf(error)}`,
+          declaredPath,
+        ));
+      }
+    }
+  }
+
+  const actualDirs = await listActualNodeDirectories(
+    params.runDir,
+    params.config,
+  );
+  for (const dir of actualDirs) {
+    if (mentionedNodeIds.has(basename(dir))) continue;
+    params.findings.push(finding(
+      "WARNING",
+      "orphan_node_directory",
+      "Node directory exists on disk but no journal event mentions it",
+      dir,
+    ));
+  }
+}
+
+async function inspectLock(
+  workflowDir: string,
+  runId: string,
+  findings: DoctorFinding[],
+): Promise<LockStatus> {
+  const lockPath = defaultLockPath(workflowDir);
+  try {
+    const info = await readLockInfo(lockPath);
+    const live = isProcessAlive(info.pid);
+    if (info.run_id === runId && !live) {
+      findings.push(finding(
+        "WARNING",
+        "stale_lock",
+        `runs/.lock references run '${runId}' but pid ${info.pid} is not alive`,
+        lockPath,
+      ));
+    }
+    return {
+      lockPath,
+      live,
+      staleForTarget: info.run_id === runId && !live,
+    };
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) {
+      return { lockPath, live: false, staleForTarget: false };
+    }
+    findings.push(finding(
+      "WARNING",
+      "lock_read_failed",
+      `Cannot read runs/.lock: ${messageOf(error)}`,
+      lockPath,
+    ));
+    return { lockPath, live: false, staleForTarget: false };
+  }
+}
+
+async function applyRepairs(params: {
+  runDir: string;
+  parsed: ParsedJournal;
+  findings: DoctorFinding[];
+  repairs: DoctorRepair[];
+  lock: LockStatus;
+}): Promise<void> {
+  if (params.lock.live) {
+    params.findings.push(finding(
+      "ERROR",
+      "repair_refused_live_lock",
+      "Refusing repair because the workflow lock is held by a live process",
+      params.lock.lockPath,
+    ));
+    return;
+  }
+
+  if (params.findings.some((item) => item.severity === "ERROR")) {
+    params.findings.push(finding(
+      "ERROR",
+      "repair_refused_journal_errors",
+      "Refusing repair because diagnosis found errors beyond a torn final line",
+      getJournalPath(params.runDir),
+    ));
+    return;
+  }
+
+  if (
+    params.parsed.tornFinalLine &&
+    params.parsed.validByteLength !== undefined
+  ) {
+    const journalPath = getJournalPath(params.runDir);
+    const original = await Deno.readFile(journalPath);
+    await Deno.writeFile(`${journalPath}.bak`, original);
+    const tmpPath = `${journalPath}.tmp`;
+    await Deno.writeFile(
+      tmpPath,
+      original.slice(0, params.parsed.validByteLength),
+    );
+    await Deno.rename(tmpPath, journalPath);
+    params.repairs.push({
+      code: "repair_torn_final_line",
+      message: "Backed up journal and removed torn final line",
+      evidence_path: journalPath,
+    });
+  }
+
+  if (params.lock.staleForTarget) {
+    await Deno.remove(params.lock.lockPath);
+    params.repairs.push({
+      code: "repair_stale_lock",
+      message: "Removed stale workflow lock for target run",
+      evidence_path: params.lock.lockPath,
+    });
+  }
+}
+
+async function listActualNodeDirectories(
+  runDir: string,
+  config: WorkflowConfig | undefined,
+): Promise<string[]> {
+  const dirs: string[] = [];
+  const phaseNames = new Set<string>();
+  if (config?.phases) {
+    for (const phase of Object.keys(config.phases)) phaseNames.add(phase);
+  } else if (config) {
+    for (const node of Object.values(config.nodes)) {
+      if (node.phase) phaseNames.add(node.phase);
+    }
+  }
+
+  let entries: Deno.DirEntry[];
+  try {
+    entries = [];
+    for await (const entry of Deno.readDir(runDir)) entries.push(entry);
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return dirs;
+    throw error;
+  }
+
+  for (const entry of entries) {
+    if (!entry.isDirectory || INFRA_DIRS.has(entry.name)) continue;
+    const path = `${runDir}/${entry.name}`;
+    if (phaseNames.has(entry.name)) {
+      for await (const child of Deno.readDir(path)) {
+        if (child.isDirectory) dirs.push(`${path}/${child.name}`);
+      }
+      continue;
+    }
+    dirs.push(path);
+  }
+  return dirs.map(resolveEvidencePath);
+}
+
+function attemptKey(nodeId: string, iteration: number | undefined): string {
+  return `${nodeId}#${iteration ?? ""}`;
+}
+
+function eventPath(
+  events: Array<{ event: RunJournalEvent; line: number }>,
+  line: number,
+): string {
+  const runId = events.find(({ event }) => "run_id" in event)?.event.run_id ??
+    "unknown";
+  return `journal.jsonl:${line}:${runId}`;
+}
+
+function isJournalKind(kind: string): kind is RunJournalEventKind {
+  return VALID_JOURNAL_KINDS.includes(kind as RunJournalEventKind);
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return value !== null && typeof value === "object" && !Array.isArray(value);
+}
+
+function isProcessAlive(pid: number): boolean {
+  try {
+    Deno.kill(pid, "SIGCONT");
+    return true;
+  } catch {
+    return false;
+  }
+}
+
+function sameMoney(a: number, b: number): boolean {
+  return Math.abs(a - b) < 0.000000001;
+}
+
+function resolveEvidencePath(path: string): string {
+  return isAbsolute(path) ? path : resolve(path);
+}
+
+function finding(
+  severity: DoctorSeverity,
+  code: string,
+  message: string,
+  evidencePath: string,
+): DoctorFinding {
+  return { severity, code, message, evidence_path: evidencePath };
+}
+
+function messageOf(error: unknown): string {
+  return error instanceof Error ? error.message : String(error);
+}
