+function printUsage(): void {
+  console.log(getUsageText());
+}
+
+interface RunsDoctorCliArgs {
+  workflowDir: string;
+  runId: string;
+  repair: boolean;
+  json: boolean;
+}
+
+function parseRunsDoctorArgs(args: string[]): RunsDoctorCliArgs {
+  let workflowDir: string | undefined;
+  let runId: string | undefined;
+  let repair = false;
+  let json = false;
+
+  for (let i = 0; i < args.length; i++) {
+    const arg = args[i];
+    if (arg === "--workflow") {
+      workflowDir = normalizeWorkflowDir(args[++i] ?? "");
+      continue;
+    }
+    if (arg.startsWith("--workflow=")) {
+      workflowDir = normalizeWorkflowDir(arg.slice("--workflow=".length));
+      continue;
+    }
+    if (arg === "--run") {
+      runId = args[++i];
+      continue;
+    }
+    if (arg.startsWith("--run=")) {
+      runId = arg.slice("--run=".length);
+      continue;
+    }
+    if (arg === "--repair") {
+      repair = true;
+      continue;
+    }
+    if (arg === "--json") {
+      json = true;
+      continue;
+    }
+    throw new Error(`runs doctor: unknown argument ${arg}`);
+  }
+
+  if (!workflowDir) {
+    throw new Error("runs doctor: missing --workflow <dir>");
+  }
+  if (!runId) {
+    throw new Error("runs doctor: missing --run <run-id>");
+  }
+  return { workflowDir, runId, repair, json };
+}
+
+async function runRuns(args: string[]): Promise<never> {
+  const [subcommand, ...rest] = args;
+  if (subcommand !== "doctor") {
+    console.error(`Error: unknown runs subcommand: ${subcommand ?? ""}`);
+    printUsage();
+    Deno.exit(1);
+  }
+  try {
+    const parsed = parseRunsDoctorArgs(rest);
+    const result = await runDoctor({
+      workflowDir: parsed.workflowDir,
+      runId: parsed.runId,
+      repair: parsed.repair,
+    });
+    console.log(
+      parsed.json ? formatDoctorJson(result) : formatDoctorReport(result),
+    );
+    Deno.exit(result.exitCode);
+  } catch (err) {
+    console.error(`Error: ${(err as Error).message}`);
+    Deno.exit(2);
+  }
 }
 
