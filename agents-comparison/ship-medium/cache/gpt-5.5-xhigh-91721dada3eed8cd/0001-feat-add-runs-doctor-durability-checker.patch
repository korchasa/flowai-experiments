+async function appendCompletedRun(
+  writer: RunJournalWriter,
+  opts: { topLevelCost?: number; nodeCost?: number } = {},
+): Promise<void> {
+  const nodeCost = opts.nodeCost ?? 0.25;
+  const topLevelCost = opts.topLevelCost ?? nodeCost;
+  await writer.append({
+    kind: "node_completed",
+    node_id: "build",
+    status: "completed",
+    timestamp: TS,
+    node: { status: "completed", cost_usd: nodeCost },
+    metadata: { cost_usd: topLevelCost },
+    cost_usd: topLevelCost,
+  });
+  await writer.append({
+    kind: "run_completed",
+    status: "completed",
+    completed_at: TS,
+  });
+}
+
+async function appendRawEvent(
+  fixture: Fixture,
+  event: Record<string, unknown>,
+): Promise<void> {
+  await Deno.writeTextFile(
+    getJournalPath(fixture.runDir),
+    `${JSON.stringify(event)}\n`,
+    { append: true },
+  );
+}
+
+function codes(result: { findings: Array<{ code: string }> }): string[] {
+  return result.findings.map((finding) => finding.code);
+}
