@@ -0,0 +1,724 @@
+/**
+ * @module
+ * `runs doctor` — run durability health checker with safe mechanical repair
+ * (FR-E83).
+ *
+ * Diagnoses a single run's durability artifacts — the append-only
+ * `journal.jsonl`, the surrounding run directory, and the per-workflow
+ * `runs/.lock` — and (with `--repair`) applies ONLY narrow, reversible,
+ * mechanical fixes. This module is the testable core; `cli.ts` is a thin
+ * parse/print/exit wrapper over it (same thin-interface/fat-core split as
+ * `commands.ts`).
+ *
+ * Three diagnostic phases, EVERY problem reported (not just the first):
+ *   a. Journal integrity — lexical line scan (NOT replay; the replayer aborts
+ *      on the first bad line and so cannot enumerate problems).
+ *   b. Replay invariants — orchestrates the EXISTING replayer
+ *      (`replayRunJournal`) and inspects its result. No second replayer.
+ *   c. Filesystem cross-check — run-dir node directories vs journal facts,
+ *      plus a stale-lock probe.
+ *
+ * Path/lock knowledge is reused from the sibling `state.ts` / `run-journal.ts`
+ * / `lock.ts` helpers — doctor constructs no paths and re-parses no lock file
+ * of its own.
+ */
+
+import { join } from "@std/path";
+import type { RunJournalEvent } from "../types.ts";
+import { getRunDir } from "./state.ts";
+import { getJournalPath, replayRunJournal } from "./run-journal.ts";
+import {
+  defaultLockPath,
+  isProcessAlive,
+  type LockInfo,
+  readLockInfo,
+  releaseLock,
+} from "./lock.ts";
+
+/** Severity of a single doctor finding. ERRORs drive exit code 1. */
+export type DoctorSeverity = "error" | "warning";
+
+/** One machine-readable finding (the `--json` element shape). */
+export interface DoctorFinding {
+  /** ERROR fails the run (exit 1); WARNING is advisory (exit 0). */
+  severity: DoctorSeverity;
+  /** Stable kebab-case identifier, e.g. `journal-torn-tail`. */
+  code: string;
+  /** Human-readable detail. */
+  message: string;
+  /** Path the finding refers to (journal / directory / lock). */
+  evidence: string;
+}
+
+/** Outcome of a `--repair` pass. */
+export interface RepairOutcome {
+  /** True when doctor declined to touch anything (clear reason, no writes). */
+  refused: boolean;
+  /** Why the repair was refused; set iff `refused`. */
+  reason?: string;
+  /** Human-readable list of mechanical fixes actually applied. */
+  applied: string[];
+  /** Path of the `journal.jsonl.bak` written before a torn-line rewrite. */
+  backupPath?: string;
+}
+
+/** Full doctor report for one run. */
+export interface DoctorReport {
+  /** The diagnosed run id. */
+  run_id: string;
+  /** Resolved run directory. */
+  run_dir: string;
+  /** True when no ERROR-severity finding exists. */
+  ok: boolean;
+  /** Findings, ERRORs first then WARNINGs (stable within severity). */
+  findings: DoctorFinding[];
+  /** Present only when `--repair` ran. */
+  repair?: RepairOutcome;
+}
+
+/** Inputs for {@link diagnoseRun} / {@link runDoctor}. */
+export interface DoctorOptions {
+  /** Workflow folder containing `workflow.yaml` and `runs/`. */
+  workflowDir: string;
+  /** Target run id (the `--run` value). */
+  runId: string;
+  /** When true, attempt the mechanical repairs after diagnosing. */
+  repair?: boolean;
+}
+
+/** Internal diagnosis state threaded from {@link diagnoseRun} into repair. */
+interface DiagnoseInternals {
+  journalPath: string;
+  lockPath: string;
+  /** Raw journal text, when the file exists (reused by repair). */
+  journalContent?: string;
+  /** Char offset where the torn final line begins (for atomic truncation). */
+  tornTail?: { lineStartChar: number; validByteLength: number };
+  /** Stale lock that names this run with a dead PID. */
+  staleLock?: { lockPath: string; pid: number };
+  /** A live process holds the lock for THIS run — repair must refuse. */
+  runActive: boolean;
+  /** Any ERROR finding exists (blocks semantic-free repair). */
+  hasErrors: boolean;
+}
+
+/** Valid journal event `kind` values. Mirrors the `RunJournalEventKind` union
+ * in `types.ts`; kept as a runtime Set because the union has no runtime form. */
+const VALID_KINDS: ReadonlySet<string> = new Set([
+  "run_started",
+  "run_metadata_updated",
+  "workflow_loaded",
+  "node_declared",
+  "node_directory_declared",
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+  "attempt_started",
+  "attempt_completed",
+  "continuation_exhausted",
+  "loop_iteration_started",
+  "loop_iteration_completed",
+  "loop_iteration_failed",
+  "run_completed",
+  "run_failed",
+  "run_aborted",
+]);
+
+const TERMINAL_KINDS: ReadonlySet<string> = new Set([
+  "run_completed",
+  "run_failed",
+  "run_aborted",
+]);
+
+const NODE_LIFECYCLE_KINDS: ReadonlySet<string> = new Set([
+  "node_started",
+  "node_completed",
+  "node_failed",
+  "node_waiting",
+  "node_skipped",
+]);
+
+/** Run-dir entries that are runtime metadata / git worktree, never node
+ * directories — excluded from orphan detection (top level only). */
+const RESERVED_DIR_NAMES: ReadonlySet<string> = new Set([
+  "logs",
+  "worktree",
+  ".hitl-inbox",
+  ".git",
+]);
+
+/** Tolerance for the per-node cost reconciliation (USD float noise). */
+const COST_EPSILON = 1e-9;
+
+/**
+ * Diagnose a run's durability artifacts. Pure read — never mutates the run
+ * directory. Returns the report plus internal state the repair step needs.
+ */
+export async function diagnoseRun(
+  options: DoctorOptions,
+): Promise<{ report: DoctorReport; internals: DiagnoseInternals }> {
+  const { workflowDir, runId } = options;
+  const runDir = getRunDir(runId, workflowDir);
+  const journalPath = getJournalPath(runDir);
+  const lockPath = defaultLockPath(workflowDir);
+
+  const findings: DoctorFinding[] = [];
+  const internals: DiagnoseInternals = {
+    journalPath,
+    lockPath,
+    runActive: false,
+    hasErrors: false,
+  };
+
+  // --- Phase a: journal integrity (lexical scan, not replay) ---
+  let journalReadable = false;
+  let journalContent: string | undefined;
+  try {
+    journalContent = await Deno.readTextFile(journalPath);
+    internals.journalContent = journalContent;
+    journalReadable = true;
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) {
+      findings.push({
+        severity: "error",
+        code: "journal-missing",
+        message: "journal.jsonl does not exist; the run has no durable record",
+        evidence: journalPath,
+      });
+    } else {
+      throw error;
+    }
+  }
+
+  if (journalReadable && journalContent !== undefined) {
+    scanJournalIntegrity(journalContent, journalPath, findings, internals);
+  }
+
+  // --- Phase b: replay invariants (existing replayer only) ---
+  // A non-final parse error makes `replayRunJournal` throw on the same line we
+  // already flagged; skip replay so we never double-report it.
+  const hasHardParseError = findings.some(
+    (f) => f.code === "journal-unparsable-line" || f.code === "journal-missing",
+  );
+  if (!hasHardParseError) {
+    let replay: Awaited<ReturnType<typeof replayRunJournal>> | undefined;
+    try {
+      replay = await replayRunJournal(runDir);
+    } catch (error) {
+      // Structural replay failures the lexical scan cannot see (missing
+      // run_started, mixed-run journal) surface here.
+      findings.push({
+        severity: "error",
+        code: "replay-failed",
+        message: `journal failed to replay: ${
+          error instanceof Error ? error.message : String(error)
+        }`,
+        evidence: journalPath,
+      });
+    }
+    if (replay) {
+      checkReplayInvariants(replay, journalPath, findings);
+      // --- Phase c (directory portion): needs the replayed event list ---
+      await checkFilesystem(runDir, replay.events, findings);
+    }
+  }
+  // When the journal is unreadable/garbled the directory cross-check is
+  // skipped (no trustworthy declared-dir set) — only the lock probe is safe.
+
+  // --- Phase c (lock portion always runs) ---
+  await checkLock(lockPath, runId, findings, internals);
+
+  internals.hasErrors = findings.some((f) => f.severity === "error");
+  const report: DoctorReport = {
+    run_id: runId,
+    run_dir: runDir,
+    ok: !internals.hasErrors,
+    findings: sortFindings(findings),
+  };
+  return { report, internals };
+}
+
+/** Diagnose, then (when `repair`) apply mechanical fixes. */
+export async function runDoctor(options: DoctorOptions): Promise<DoctorReport> {
+  const { report, internals } = await diagnoseRun(options);
+  if (options.repair) {
+    report.repair = await applyRepair(internals);
+  }
+  return report;
+}
+
+/** Phase a: scan each line for structural integrity. Mirrors the replayer's
+ * line/byte bookkeeping so a torn final line is identified identically. */
+function scanJournalIntegrity(
+  content: string,
+  journalPath: string,
+  findings: DoctorFinding[],
+  internals: DiagnoseInternals,
+): void {
+  if (content === "") return;
+  const endedWithNewline = content.endsWith("\n");
+  const lines = content.split("\n");
+  if (endedWithNewline) lines.pop();
+
+  const seenEventIds = new Set<string>();
+  let prevSeq: number | undefined;
+  let lineStart = 0;
+
+  for (let i = 0; i < lines.length; i++) {
+    const line = lines[i];
+    const nextLineStart = lineStart + line.length + 1;
+    if (line.trim() === "") {
+      lineStart = nextLineStart;
+      continue;
+    }
+    let parsed: Record<string, unknown> | undefined;
+    try {
+      parsed = JSON.parse(line) as Record<string, unknown>;
+    } catch (error) {
+      const isPartialTail = i === lines.length - 1 && !endedWithNewline;
+      const detail = error instanceof Error ? error.message : String(error);
+      if (isPartialTail) {
+        findings.push({
+          severity: "warning",
+          code: "journal-torn-tail",
+          message:
+            `final line is truncated/garbage (${detail}); the expected crash ` +
+            `artifact — repairable by dropping it`,
+          evidence: `${journalPath}:${i + 1}`,
+        });
+        internals.tornTail = {
+          lineStartChar: lineStart,
+          validByteLength: new TextEncoder().encode(content.slice(0, lineStart))
+            .length,
+        };
+      } else {
+        findings.push({
+          severity: "error",
+          code: "journal-unparsable-line",
+          message: `line ${i + 1} is not valid JSON (${detail})`,
+          evidence: `${journalPath}:${i + 1}`,
+        });
+      }
+      lineStart = nextLineStart;
+      continue;
+    }
+
+    const kind = parsed.kind;
+    if (typeof kind !== "string" || !VALID_KINDS.has(kind)) {
+      findings.push({
+        severity: "error",
+        code: "journal-unknown-kind",
+        message: `line ${i + 1} has unknown event kind ${JSON.stringify(kind)}`,
+        evidence: `${journalPath}:${i + 1}`,
+      });
+    }
+
+    // A genuine duplicate repeats both event_id AND seq, so classify it FIRST
+    // and skip the monotonicity check — otherwise a replayer-deduped duplicate
+    // (a WARNING) would also raise a non-monotonic-seq ERROR and flip exit 1.
+    const eventId = parsed.event_id;
+    const isDuplicate = typeof eventId === "string" &&
+      seenEventIds.has(eventId);
+    if (isDuplicate) {
+      findings.push({
+        severity: "warning",
+        code: "journal-duplicate-event-id",
+        message: `line ${
+          i + 1
+        } repeats event_id ${eventId}; the replayer dedupes it`,
+        evidence: `${journalPath}:${i + 1}`,
+      });
+      lineStart = nextLineStart;
+      continue;
+    }
+    if (typeof eventId === "string") seenEventIds.add(eventId);
+
+    const seq = parsed.seq;
+    if (typeof seq === "number") {
+      if (prevSeq !== undefined && seq <= prevSeq) {
+        findings.push({
+          severity: "error",
+          code: "journal-nonmonotonic-seq",
+          message: `line ${
+            i + 1
+          } seq ${seq} is not greater than previous ${prevSeq}`,
+          evidence: `${journalPath}:${i + 1}`,
+        });
+      }
+      prevSeq = seq;
+    }
+
+    lineStart = nextLineStart;
+  }
+}
+
+/** Phase b: inspect the replay result for invariant violations. */
+function checkReplayInvariants(
+  replay: Awaited<ReturnType<typeof replayRunJournal>>,
+  journalPath: string,
+  findings: DoctorFinding[],
+): void {
+  const { events, state } = replay;
+
+  // Events after the first terminal run event.
+  let terminalSeen = false;
+  for (const event of events) {
+    if (terminalSeen) {
+      findings.push({
+        severity: "error",
+        code: "event-after-terminal",
+        message:
+          `event ${event.kind} (seq ${event.seq}) appears after a terminal ` +
+          `run event`,
+        evidence: `${journalPath} seq=${event.seq}`,
+      });
+    }
+    if (TERMINAL_KINDS.has(event.kind)) terminalSeen = true;
+  }
+
+  // Node-lifecycle events for nodes never declared.
+  const declared = new Set<string>();
+  for (const event of events) {
+    if (event.kind === "node_declared") declared.add(event.node_id);
+  }
+  for (const event of events) {
+    if (NODE_LIFECYCLE_KINDS.has(event.kind)) {
+      const nodeId = (event as { node_id: string }).node_id;
+      if (!declared.has(nodeId)) {
+        findings.push({
+          severity: "error",
+          code: "undeclared-node-lifecycle",
+          message:
+            `${event.kind} references node '${nodeId}' that was never declared`,
+          evidence: `${journalPath} seq=${event.seq}`,
+        });
+      }
+    }
+  }
+
+  // attempt_completed without a matching attempt_started (same node+iteration).
+  const startedKeys = new Set<string>();
+  for (const event of events) {
+    if (event.kind === "attempt_started") {
+      startedKeys.add(attemptKey(event));
+    }
+  }
+  for (const event of events) {
+    if (
+      event.kind === "attempt_completed" && !startedKeys.has(attemptKey(event))
+    ) {
+      findings.push({
+        severity: "error",
+        code: "attempt-completed-without-start",
+        message: `attempt_completed for node '${event.node_id}'` +
+          `${
+            event.iteration !== undefined ? ` iteration ${event.iteration}` : ""
+          }` +
+          ` has no matching attempt_started`,
+        evidence: `${journalPath} seq=${event.seq}`,
+      });
+    }
+  }
+
+  // Cost reconciliation. The replayer rolls each node SNAPSHOT cost
+  // (`event.node.cost_usd`) into `state.total_cost_usd`. Doctor independently
+  // sums the per-node FLAT metadata `cost_usd` mirror (the field the replayer
+  // does NOT fold into the total) from each node's last lifecycle event.
+  // Healthy journals keep the two fields equal, so this never false-fires; a
+  // divergence means the journal's cost facts are internally inconsistent.
+  const lastNodeCost = new Map<string, number | undefined>();
+  for (const event of events) {
+    if (NODE_LIFECYCLE_KINDS.has(event.kind)) {
+      const e = event as { node_id: string; cost_usd?: number };
+      lastNodeCost.set(e.node_id, e.cost_usd);
+    }
+  }
+  let nodeCostSum = 0;
+  for (const cost of lastNodeCost.values()) nodeCostSum += cost ?? 0;
+  const replayedTotal = state.total_cost_usd ?? 0;
+  if (Math.abs(replayedTotal - nodeCostSum) > COST_EPSILON) {
+    findings.push({
+      severity: "error",
+      code: "cost-sum-divergence",
+      message:
+        `replayed total_cost_usd ${replayedTotal} diverges from per-node ` +
+        `cost_usd sum ${nodeCostSum}`,
+      evidence: journalPath,
+    });
+  }
+}
+
+/** Build the attempt-matching key (node + optional loop iteration). */
+function attemptKey(event: { node_id: string; iteration?: number }): string {
+  return `${event.node_id}::${event.iteration ?? ""}`;
+}
+
+/** Phase c (directory portion): orphan vs missing node directories. */
+async function checkFilesystem(
+  runDir: string,
+  events: RunJournalEvent[],
+  findings: DoctorFinding[],
+): Promise<void> {
+  const declaredRel = collectDeclaredDirs(runDir, events);
+
+  // Missing: declared but absent on disk.
+  for (const rel of declaredRel) {
+    const abs = join(runDir, rel);
+    if (!(await isDirectory(abs))) {
+      findings.push({
+        severity: "error",
+        code: "missing-declared-dir",
+        message:
+          `journal declares node directory '${rel}' but it is missing on disk`,
+        evidence: abs,
+      });
+    }
+  }
+
+  // Orphans: leaf directories on disk that the journal never mentions.
+  for await (const rel of leafDirs(runDir, "", declaredRel)) {
+    if (!declaredRel.has(rel)) {
+      findings.push({
+        severity: "warning",
+        code: "orphan-node-dir",
+        message:
+          `directory '${rel}' exists on disk but no journal event mentions it`,
+        evidence: join(runDir, rel),
+      });
+    }
+  }
+}
+
+/** Resolve run-dir-relative declared node directory paths from journal facts.
+ * Prefers the exact `node_directory_declared` path (rebased onto the run dir
+ * by stripping through the runId segment); falls back to the `node_declared`
+ * node id (+ phase) so detection still works on older journals. */
+function collectDeclaredDirs(
+  runDir: string,
+  events: RunJournalEvent[],
+): Set<string> {
+  const runId = basename(runDir);
+  const declared = new Set<string>();
+  for (const event of events) {
+    if (event.kind === "node_directory_declared") {
+      const rel = relWithinRun(event.node_dir, runId);
+      if (rel) declared.add(rel);
+    } else if (event.kind === "node_declared") {
+      declared.add(
+        event.phase ? `${event.phase}/${event.node_id}` : event.node_id,
+      );
+    }
+  }
+  return declared;
+}
+
+/** Strip a declared `node_dir` (e.g. `runs/<id>/build`) down to its path
+ * relative to the run directory (`build`). Null when the runId segment is
+ * absent (cannot rebase safely). */
+function relWithinRun(nodeDir: string, runId: string): string | null {
+  const segs = nodeDir.split("/").filter((s) => s.length > 0);
+  const idx = segs.lastIndexOf(runId);
+  if (idx === -1) return null;
+  const tail = segs.slice(idx + 1);
+  return tail.length > 0 ? tail.join("/") : null;
+}
+
+/** Yield run-dir-relative leaf directories. A directory whose relative path is
+ * already declared is terminal (not recursed) so artifact subfolders inside a
+ * known node dir are never mistaken for orphans. Reserved runtime/worktree
+ * names are skipped at the top level. */
+async function* leafDirs(
+  root: string,
+  base: string,
+  declaredRel: ReadonlySet<string>,
+): AsyncGenerator<string> {
+  const dirHere = base ? join(root, base) : root;
+  const childDirs: string[] = [];
+  try {
+    for await (const entry of Deno.readDir(dirHere)) {
+      if (entry.isDirectory) childDirs.push(entry.name);
+    }
+  } catch {
+    return;
+  }
+  for (const name of childDirs) {
+    if (base === "" && RESERVED_DIR_NAMES.has(name)) continue;
+    const rel = base ? `${base}/${name}` : name;
+    if (declaredRel.has(rel)) {
+      yield rel; // declared node dir — terminal, not an orphan
+      continue;
+    }
+    const grandchildren: string[] = [];
+    for await (const entry of Deno.readDir(join(root, rel))) {
+      if (entry.isDirectory) grandchildren.push(entry.name);
+    }
+    if (grandchildren.length === 0) {
+      yield rel; // leaf — orphan candidate
+    } else {
+      yield* leafDirs(root, rel, declaredRel);
+    }
+  }
+}
+
+/** Phase c (lock portion): classify the per-workflow lock for this run. */
+async function checkLock(
+  lockPath: string,
+  runId: string,
+  findings: DoctorFinding[],
+  internals: DiagnoseInternals,
+): Promise<void> {
+  let info: LockInfo;
+  try {
+    info = await readLockInfo(lockPath);
+  } catch {
+    // Absent or corrupt lock → no lock finding for this run.
+    return;
+  }
+  if (info.run_id !== runId) return; // lock belongs to a different run
+  if (isProcessAlive(info.pid)) {
+    internals.runActive = true; // running run — normal, not a finding
+    return;
+  }
+  internals.staleLock = { lockPath, pid: info.pid };
+  findings.push({
+    severity: "warning",
+    code: "stale-lock",
+    message:
+      `runs/.lock names this run (pid ${info.pid}) but that process is not ` +
+      `alive — stale lock`,
+    evidence: lockPath,
+  });
+}
+
+/** Apply the narrow mechanical repairs, or refuse with a clear reason. */
+async function applyRepair(
+  internals: DiagnoseInternals,
+): Promise<RepairOutcome> {
+  if (internals.runActive) {
+    return {
+      refused: true,
+      reason: "run is currently active (live process holds runs/.lock)",
+      applied: [],
+    };
+  }
+  if (internals.hasErrors) {
+    return {
+      refused: true,
+      reason:
+        "journal has errors beyond the torn final line — refusing to guess " +
+        "at semantic repairs",
+      applied: [],
+    };
+  }
+
+  const applied: string[] = [];
+  let backupPath: string | undefined;
+
+  if (internals.tornTail && internals.journalContent !== undefined) {
+    backupPath = `${internals.journalPath}.bak`;
+    // Backup preserves the exact original bytes (including the torn tail).
+    await Deno.copyFile(internals.journalPath, backupPath);
+    // Atomic rewrite: write the surviving prefix to a tmp file, then rename.
+    const tmpPath = `${internals.journalPath}.tmp`;
+    const surviving = internals.journalContent.slice(
+      0,
+      internals.tornTail.lineStartChar,
+    );
+    await Deno.writeTextFile(tmpPath, surviving);
+    await Deno.rename(tmpPath, internals.journalPath);
+    applied.push(`removed torn final journal line (backup at ${backupPath})`);
+  }
+
+  if (internals.staleLock) {
+    await releaseLock(internals.staleLock.lockPath);
+    applied.push(`removed stale lock ${internals.staleLock.lockPath}`);
+  }
+
+  return { refused: false, applied, backupPath };
+}
+
+/** ERRORs first, then WARNINGs; original order preserved within a severity. */
+function sortFindings(findings: DoctorFinding[]): DoctorFinding[] {
+  const errors = findings.filter((f) => f.severity === "error");
+  const warnings = findings.filter((f) => f.severity === "warning");
+  return [...errors, ...warnings];
+}
+
+/** True iff `path` exists and is a directory. */
+async function isDirectory(path: string): Promise<boolean> {
+  try {
+    return (await Deno.stat(path)).isDirectory;
+  } catch {
+    return false;
+  }
+}
+
+/** Final path segment (the runId) of a run directory. */
+function basename(path: string): string {
+  const segs = path.split("/").filter((s) => s.length > 0);
+  return segs[segs.length - 1] ?? path;
+}
+
+/** Render the report as grouped human-readable text (ERROR / WARNING / OK). */
+export function formatReport(report: DoctorReport): string {
+  const lines: string[] = [];
+  lines.push(`runs doctor — run ${report.run_id}`);
+  lines.push(`run dir: ${report.run_dir}`);
+  lines.push("");
+
+  const errors = report.findings.filter((f) => f.severity === "error");
+  const warnings = report.findings.filter((f) => f.severity === "warning");
+
+  lines.push(`ERROR (${errors.length}):`);
+  if (errors.length === 0) lines.push("  none");
+  for (const f of errors) {
+    lines.push(`  [${f.code}] ${f.message} — ${f.evidence}`);
+  }
+
+  lines.push("");
+  lines.push(`WARNING (${warnings.length}):`);
+  if (warnings.length === 0) lines.push("  none");
+  for (const f of warnings) {
+    lines.push(`  [${f.code}] ${f.message} — ${f.evidence}`);
+  }
+
+  lines.push("");
+  lines.push(
+    report.ok
+      ? "OK: no errors found."
+      : `NOT OK: ${errors.length} error(s) found.`,
+  );
+
+  if (report.repair) {
+    lines.push("");
+    if (report.repair.refused) {
+      lines.push(`Repair REFUSED: ${report.repair.reason}`);
+    } else if (report.repair.applied.length === 0) {
+      lines.push("Repair: nothing to repair.");
+    } else {
+      lines.push("Repair applied:");
+      for (const a of report.repair.applied) lines.push(`  - ${a}`);
+    }
+  }
+
+  return lines.join("\n");
+}
+
+/** Machine-readable view of the report (the `--json` payload). */
+export function reportToJson(report: DoctorReport): {
+  run_id: string;
+  run_dir: string;
+  ok: boolean;
+  findings: DoctorFinding[];
+  repair?: RepairOutcome;
+} {
+  return {
+    run_id: report.run_id,
+    run_dir: report.run_dir,
+    ok: report.ok,
+    findings: report.findings,
+    ...(report.repair ? { repair: report.repair } : {}),
+  };
+}
