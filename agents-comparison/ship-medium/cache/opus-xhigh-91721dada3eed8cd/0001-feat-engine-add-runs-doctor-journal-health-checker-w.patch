+Deno.test("FR-E83 doctor --repair — torn line round-trip (byte-identical .bak, replays clean)", async () => {
+  const prefix = cleanLines().join("\n") + "\n";
+  const tornFragment = '{"schema_version":1,"run_id":"' + RUN_ID + '","seq":7';
+  const original = prefix + tornFragment;
+  const fx = await writeRun({ journal: original, nodeDirs: ["build"] });
+  const journalPath = `${fx.runDir}/journal.jsonl`;
+  const bakPath = `${journalPath}.bak`;
+  try {
+    const report = await runDoctor({
+      workflowDir: fx.workflowDir,
+      runId: fx.runId,
+      repair: true,
+    });
+    assert(report.repair, "expected a repair outcome");
+    assertEquals(report.repair.refused, false);
+    assert(
+      report.repair.applied.some((a) => a.includes("torn final journal line")),
+      "expected the torn-line repair to be applied",
+    );
+
+    // Backup is byte-identical to the original (torn tail included).
+    assertEquals(await Deno.readTextFile(bakPath), original);
+    // Journal is the surviving prefix — byte-identical minus the torn tail.
+    assertEquals(await Deno.readTextFile(journalPath), prefix);
+    // And it now replays cleanly to a completed run.
+    const replay = await replayRunJournal(fx.runDir);
+    assertEquals(replay.state.status, "completed");
+    assertEquals(replay.ignored_partial_tail, false);
+  } finally {
+    await Deno.remove(fx.workflowDir, { recursive: true });
+  }
+});
