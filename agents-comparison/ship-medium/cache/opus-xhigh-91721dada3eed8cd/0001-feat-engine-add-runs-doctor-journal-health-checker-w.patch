+      repair: true,
+    });
+    assert(report.repair?.refused, "expected repair to be refused");
+    assert(report.repair?.reason?.includes("active"));
+    // Nothing modified: journal unchanged, no backup file written.
+    assertEquals(await Deno.readTextFile(journalPath), original);
+    let bakExists = true;
