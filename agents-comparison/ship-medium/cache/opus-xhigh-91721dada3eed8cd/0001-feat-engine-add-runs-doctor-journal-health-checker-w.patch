+import type { LockInfo } from "./lock.ts";
+
+const RUN_ID = "20260612T101010";
+
+/** Build one fully-enveloped journal line. */
+function line(
+  seq: number,
+  kind: string,
+  extra: Record<string, unknown> = {},
+): string {
+  return JSON.stringify({
+    schema_version: 1,
+    run_id: RUN_ID,
+    seq,
+    event_id: `${RUN_ID}:${seq}:${kind}`,
+    kind,
+    ts: "2026-06-12T00:00:00.000Z",
+    ...extra,
+  });
+}
+
+/** A clean, replayable journal: one declared+completed agent node, terminal. */
+function cleanLines(): string[] {
+  return [
+    line(1, "run_started", {
+      config_path: "workflow.yaml",
+      started_at: "2026-06-12T00:00:00.000Z",
+      args: {},
+      env: {},
+    }),
+    line(2, "node_declared", {
+      node_id: "build",
+      node_type: "agent",
+      label: "Build",
+    }),
+    line(3, "node_directory_declared", {
+      node_id: "build",
+      node_dir: `runs/${RUN_ID}/build`,
+    }),
+    line(4, "node_started", {
+      node_id: "build",
+      status: "running",
+      timestamp: "2026-06-12T00:00:00.000Z",
+      node: { status: "running" },
+      metadata: {},
+    }),
+    line(5, "node_completed", {
+      node_id: "build",
+      status: "completed",
+      timestamp: "2026-06-12T00:00:00.000Z",
+      node: { status: "completed", cost_usd: 0.12 },
+      metadata: { cost_usd: 0.12 },
+      cost_usd: 0.12,
+    }),
+    line(6, "run_completed", {
+      status: "completed",
+      completed_at: "2026-06-12T00:00:01.000Z",
+    }),
+  ];
+}
+
+interface RunFixture {
+  workflowDir: string;
+  runDir: string;
+  runId: string;
+}
+
+/** Create a fabricated run directory under a temp workflow folder. */
+async function writeRun(opts: {
+  journal?: string;
+  lines?: string[];
+  nodeDirs?: string[];
+  lock?: LockInfo;
+}): Promise<RunFixture> {
+  const workflowDir = await Deno.makeTempDir();
+  const runDir = `${workflowDir}/runs/${RUN_ID}`;
+  await Deno.mkdir(runDir, { recursive: true });
+  for (const d of opts.nodeDirs ?? []) {
+    await Deno.mkdir(`${runDir}/${d}`, { recursive: true });
+  }
+  if (opts.lock) {
+    await Deno.writeTextFile(
+      defaultLockPath(workflowDir),
+      JSON.stringify(opts.lock),
+    );
+  }
+  if (opts.journal !== undefined) {
+    await Deno.writeTextFile(`${runDir}/journal.jsonl`, opts.journal);
+  } else if (opts.lines) {
+    await Deno.writeTextFile(
+      `${runDir}/journal.jsonl`,
+      opts.lines.join("\n") + "\n",
+    );
+  }
+  return { workflowDir, runDir, runId: RUN_ID };
+}
+
+function codes(findings: DoctorFinding[]): string[] {
+  return findings.map((f) => f.code);
+}
+
+function findingByCode(
+  findings: DoctorFinding[],
+  code: string,
+): DoctorFinding | undefined {
+  return findings.find((f) => f.code === code);
+}
+
+Deno.test("FR-E83 doctor — clean run reports no errors (exit 0)", async () => {
+  const fx = await writeRun({ lines: cleanLines(), nodeDirs: ["build"] });
+  try {
