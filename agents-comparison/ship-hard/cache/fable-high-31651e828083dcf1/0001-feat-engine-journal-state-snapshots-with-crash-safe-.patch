+import { assertEquals, assertRejects } from "@std/assert";
+import {
+  type CompactionFaultPoint,
+  compactRunJournal,
+  getJournalBackupPath,
+  getJournalTmpPath,
+} from "./journal-compaction.ts";
+import {
+  getJournalPath,
+  replayRunJournal,
+  RunJournalWriter,
+} from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+import type { NewRunJournalEvent } from "./run-journal.ts";
+
+/** Build a rich journal exercising declarations, attempts, loop iterations,
+ * costs, run metadata and a no-cost node — the FR-E83 equivalence fixture. */
+async function makeRichJournal(
+  workflowDir: string,
+  runId: string,
+): Promise<string> {
+  const runDir = getRunDir(runId, workflowDir);
+  const writer = await RunJournalWriter.open(runDir, runId);
+  await writer.append({
+    kind: "run_started",
+    config_path: "workflow.yaml",
+    started_at: "2026-06-12T00:00:00.000Z",
+    ts: "2026-06-12T00:00:00.000Z",
+    args: { issue: "300" },
+    env: { MODE: "test" },
+  });
+  await writer.append({
+    kind: "workflow_loaded",
+    config_path: "workflow.yaml",
+    name: "rich-workflow",
+    version: "1",
+  });
+  for (const nodeId of ["build", "qa"]) {
+    await writer.append({
+      kind: "node_declared",
+      node_id: nodeId,
+      node_type: "agent",
+      label: nodeId,
+    });
+    await writer.append({
+      kind: "node_directory_declared",
+      node_id: nodeId,
+      node_dir: `runs/${runId}/${nodeId}`,
+    });
+  }
+  await writer.append({
+    kind: "run_metadata_updated",
+    claude_cli_version: "1.2.3",
+  });
+  await writer.append({
+    kind: "loop_iteration_started",
+    loop_node_id: "build",
+    iteration: 1,
+    max_iterations: 3,
+  });
+  await writer.append({
+    kind: "attempt_started",
+    node_id: "build",
+    iteration: 1,
+  });
+  await writer.append({
+    kind: "node_started",
+    node_id: "build",
+    status: "running",
+    timestamp: "2026-06-12T00:00:01.000Z",
+    node: { status: "running", started_at: "2026-06-12T00:00:01.000Z" },
+    metadata: {},
+  });
+  await writer.append({
+    kind: "attempt_completed",
+    node_id: "build",
+    iteration: 1,
+    session_id: "sess-rich",
+    continuations: 1,
+    cost_usd: 0.42,
+    result: "built",
+    success: true,
+  });
+  await writer.append({
+    kind: "node_completed",
+    node_id: "build",
+    status: "completed",
+    timestamp: "2026-06-12T00:00:02.000Z",
+    node: {
+      status: "completed",
+      started_at: "2026-06-12T00:00:01.000Z",
+      completed_at: "2026-06-12T00:00:02.000Z",
+      cost_usd: 0.42,
+      result: "built",
+    },
+    metadata: { cost_usd: 0.42, result: "built" },
+  });
+  await writer.append({
+    kind: "loop_iteration_completed",
+    loop_node_id: "build",
+    iteration: 1,
+  });
+  // qa stays pending and cost-free — the no-cost corner.
+  return runDir;
+}
+
+/** Tail events appended after the snapshot/compaction point. */
+function tailEvents(): NewRunJournalEvent[] {
+  return [
+    {
+      kind: "node_started",
+      node_id: "qa",
+      status: "running",
+      timestamp: "2026-06-12T00:01:00.000Z",
+      ts: "2026-06-12T00:01:00.000Z",
+      node: { status: "running", started_at: "2026-06-12T00:01:00.000Z" },
+      metadata: {},
+    },
+    {
+      kind: "node_completed",
+      node_id: "qa",
+      status: "completed",
+      timestamp: "2026-06-12T00:01:05.000Z",
+      ts: "2026-06-12T00:01:05.000Z",
+      node: {
+        status: "completed",
+        started_at: "2026-06-12T00:01:00.000Z",
+        completed_at: "2026-06-12T00:01:05.000Z",
+      },
+      metadata: {},
+    },
+    {
+      kind: "run_completed",
+      status: "completed",
+      completed_at: "2026-06-12T00:01:06.000Z",
+      ts: "2026-06-12T00:01:06.000Z",
+    },
+  ];
+}
+
+Deno.test("FR-E83 equivalence: snapshot + tail replays byte-equal to the full journal", async () => {
+  const wfA = await Deno.makeTempDir();
+  const wfB = await Deno.makeTempDir();
+  const runId = "run-eq";
+  try {
+    const runDirA = await makeRichJournal(wfA, runId);
+    const runDirB = getRunDir(runId, wfB);
+    await Deno.mkdir(runDirB, { recursive: true });
+    await Deno.copyFile(getJournalPath(runDirA), getJournalPath(runDirB));
+
+    await compactRunJournal({ workflowDir: wfA, runId });
+
+    for (const dir of [runDirA, runDirB]) {
+      const writer = await RunJournalWriter.open(dir, runId);
+      for (const event of tailEvents()) await writer.append(event);
+    }
+
+    const compacted = await replayRunJournal(runDirA);
+    const full = await replayRunJournal(runDirB);
+    assertEquals(JSON.stringify(compacted.state), JSON.stringify(full.state));
+    assertEquals(compacted.state.status, "completed");
+    assertEquals(compacted.state.total_cost_usd, 0.42);
