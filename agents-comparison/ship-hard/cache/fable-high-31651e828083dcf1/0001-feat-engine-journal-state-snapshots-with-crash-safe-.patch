+/**
+ * Run the `runs compact` subcommand (FR-E83): crash-safe manual journal
+ * compaction through the shared {@link compactRunJournal} core (the same
+ * protocol and refusal rules the engine uses for auto-compaction). On
+ * success prints EXACTLY one summary line; `--dry-run` reports what would
+ * happen and modifies nothing. All failures (run not found, refusals) exit
+ * non-zero with a one-line error — never a stack trace.
+ */
+async function runRunsCompact(args: string[]): Promise<never> {
+  try {
+    const parsed = parseRunsCompactArgs(args);
+    let workflowDir = parsed.workflowDir;
+    if (!workflowDir) {
+      const resolved = await resolveActiveWorkflow({
+        env: Deno.env.toObject(),
+      });
+      if (resolved === null) {
+        throw new Error(
+          "Could not resolve active workflow. Pass it via " +
+            "`--workflow <dir>`, set FLOWAI_WORKFLOW, or place a " +
+            "workflow under `<cwd>/.flowai-workflow/`.",
+        );
+      }
+      workflowDir = normalizeWorkflowDir(resolved);
+    }
+    const result = await compactRunJournal({
+      workflowDir,
+      runId: parsed.runId,
+      dryRun: parsed.dryRun,
+    });
+    if (parsed.dryRun) {
+      console.log(
+        `dry-run: would compact ${result.runId}: ${result.eventsBefore} -> ` +
+          `${result.eventsAfter} events, ${result.bytesBefore} -> ` +
+          `${result.bytesAfter} bytes (backup: journal.jsonl.bak); ` +
+          "nothing modified",
+      );
+    } else {
+      console.log(formatCompactSummary(result));
+    }
+    Deno.exit(0);
+  } catch (err) {
+    console.error(`Error: ${(err as Error).message}`);
+    Deno.exit(1);
+  }
