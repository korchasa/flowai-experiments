diff --git a/src/state/journal-compaction.ts b/src/state/journal-compaction.ts
new file mode 100644
index 0000000..bea9084
--- /dev/null
+++ b/src/state/journal-compaction.ts
@@ -0,0 +1,178 @@
+/**
+ * @module
+ * Crash-safe journal compaction (FR-E83), shared by the engine
+ * (auto-compaction at node-completion boundaries) and the CLI
+ * (`flowai-workflow runs compact`).
+ *
+ * Protocol, in exactly this order:
+ *   1. replay the current journal;
+ *   2. write `journal.jsonl.tmp` containing one `state_snapshot` event and
+ *      zero tail events;
+ *   3. fsync the tmp file;
+ *   4. copy the current journal to `journal.jsonl.bak` (one generation);
+ *   5. atomically rename tmp over `journal.jsonl`.
+ *
+ * `journal.jsonl` is mutated only by the final atomic rename, so a crash at
+ * any intermediate point leaves either the old or the new content — never
+ * neither — and the journal always replays.
+ */
+
+import { isRunLive } from "./lock.ts";
+import {
+  buildSnapshotEvent,
+  getJournalPath,
+  replayRunJournal,
+} from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+
+/** Boundary between two consecutive protocol steps where the test-only
+ * fault hook can simulate a crash (FR-E83 crash-injection coverage). */
+export type CompactionFaultPoint =
+  | "after_replay"
+  | "after_tmp_write"
+  | "after_tmp_fsync"
+  | "after_backup";
+
+/** Parameters for {@link compactRunJournal}. */
+export interface CompactRunJournalParams {
+  /** Workflow folder containing `workflow.yaml` and `runs/`. */
+  workflowDir: string;
+  /** Target run id whose journal is compacted. */
+  runId: string;
+  /** When true, report counts/sizes and modify nothing. */
+  dryRun?: boolean;
+  /** Set by the engine when it compacts its own run at a node-completion
+   * boundary: the engine holds the workflow lock, so the live-lock refusal
+   * is skipped. External callers (CLI) must leave this unset. */
+  callerHoldsLock?: boolean;
+  /** Test-only crash injection between consecutive protocol steps. */
+  faultHook?: (point: CompactionFaultPoint) => void | Promise<void>;
+}
+
+/** Outcome of {@link compactRunJournal} (also returned for dry-runs). */
+export interface CompactionResult {
+  /** Compacted run id. */
+  runId: string;
+  /** Unique journal events before compaction (subsumed by the snapshot). */
+  eventsBefore: number;
+  /** Journal events after compaction — always 1 (the snapshot). */
+  eventsAfter: number;
+  /** Journal size in bytes before compaction. */
+  bytesBefore: number;
+  /** Journal size in bytes after compaction (computed for dry-runs). */
+  bytesAfter: number;
+  /** Path of the single retained backup generation. */
+  backupPath: string;
+  /** True when nothing was modified (`dryRun`). */
+  dryRun: boolean;
+}
+
+/** Staging sibling written and fsynced before the atomic rename. */
+export function getJournalTmpPath(runDir: string): string {
+  return `${getJournalPath(runDir)}.tmp`;
+}
+
+/** Single retained backup generation from the most recent compaction. */
+export function getJournalBackupPath(runDir: string): string {
+  return `${getJournalPath(runDir)}.bak`;
+}
+
+/**
+ * Compact a run's `journal.jsonl` into one `state_snapshot` event (FR-E83).
+ *
+ * Refuses (clear error, nothing modified) when the run is currently active
+ * (its lock is held by a live process and `callerHoldsLock` is unset), when
+ * the run does not exist, or when the journal does not replay cleanly
+ * beyond the standard torn-line tolerance.
+ */
+export async function compactRunJournal(
+  params: CompactRunJournalParams,
+): Promise<CompactionResult> {
+  const {
+    workflowDir,
+    runId,
+    dryRun = false,
+    callerHoldsLock = false,
+    faultHook,
+  } = params;
+
+  if (!callerHoldsLock && await isRunLive(workflowDir, runId)) {
+    throw new Error(
+      `run ${runId} is currently active (lock held by a live process); ` +
+        "refusing to compact",
+    );
+  }
+
+  const runDir = getRunDir(runId, workflowDir);
+  const journalPath = getJournalPath(runDir);
+  try {
+    await Deno.stat(journalPath);
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) {
+      throw new Error(`run ${runId} not found: ${journalPath} does not exist`);
+    }
+    throw error;
+  }
+
+  // Step 1: replay the current journal. Any failure beyond the torn-line
+  // tolerance is a refusal — the journal is left untouched.
+  let replay;
+  try {
+    replay = await replayRunJournal(runDir);
+  } catch (error) {
+    throw new Error(
+      `refusing to compact ${journalPath}: journal does not replay cleanly: ${
+        error instanceof Error ? error.message : String(error)
+      }`,
+    );
+  }
+
+  const bytesBefore = (await Deno.stat(journalPath)).size;
+  const maxSeq = replay.events.reduce(
+    (max, event) => Math.max(max, event.seq),
+    0,
+  );
+  const snapshot = buildSnapshotEvent(replay, runId, maxSeq + 1);
+  const snapshotLine = new TextEncoder().encode(
+    `${JSON.stringify(snapshot)}\n`,
+  );
+  const result: CompactionResult = {
+    runId,
+    eventsBefore: replay.events.length,
+    eventsAfter: 1,
+    bytesBefore,
+    bytesAfter: snapshotLine.byteLength,
+    backupPath: getJournalBackupPath(runDir),
+    dryRun,
+  };
+  if (dryRun) return result;
+  await faultHook?.("after_replay");
+
+  // Step 2: write the snapshot-only tmp file.
+  const tmpPath = getJournalTmpPath(runDir);
+  const tmpFile = await Deno.open(tmpPath, {
+    write: true,
+    create: true,
+    truncate: true,
+  });
+  try {
+    let written = 0;
+    while (written < snapshotLine.byteLength) {
+      written += await tmpFile.write(snapshotLine.subarray(written));
+    }
+    await faultHook?.("after_tmp_write");
+    // Step 3: fsync the tmp file before it can replace the journal.
+    await tmpFile.sync();
+  } finally {
+    tmpFile.close();
+  }
+  await faultHook?.("after_tmp_fsync");
+
+  // Step 4: keep one backup generation of the pre-compaction journal.
+  await Deno.copyFile(journalPath, getJournalBackupPath(runDir));
+  await faultHook?.("after_backup");
+
+  // Step 5: atomically swap the snapshot-only journal into place.
+  await Deno.rename(tmpPath, journalPath);
+  return result;
+}
