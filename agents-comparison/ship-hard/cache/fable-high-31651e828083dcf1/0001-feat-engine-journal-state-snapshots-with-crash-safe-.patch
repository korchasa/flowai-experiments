+  );
+
+  // Replay of the compacted journal reconstructs the completed run.
+  assertEquals(replayedState.status, "completed");
+  assertEquals(replayedState.nodes.a.status, "completed");
+  assertEquals(replayedState.nodes.c.status, "completed");
+
+  // Compaction happened: the final journal starts with a state_snapshot.
+  assertEquals(journal[0].kind, "state_snapshot");
+  // Boundary-only: a snapshot never sits between a node_started and its
+  // matching node_completed (no mid-node compaction).
+  const open = new Set<string>();
+  for (const event of journal) {
