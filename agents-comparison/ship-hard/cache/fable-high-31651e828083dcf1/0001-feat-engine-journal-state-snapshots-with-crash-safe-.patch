+// --- FR-E83: journal auto-compaction at node-completion boundaries ---
+
+const FR_E83_WORKFLOW = [
+  "name: compaction-engine",
+  "version: '1'",
+  "defaults:",
+  "  worktree_disabled: true",
+  "  journal_compaction_threshold_events: %THRESHOLD%",
+  "nodes:",
+  "  a:",
+  "    type: merge",
+  "    label: A",
+  "    merge_strategy: copy_all",
+  "  b:",
+  "    type: merge",
+  "    label: B",
+  "    merge_strategy: copy_all",
+  "    inputs: [a]",
+  "  c:",
+  "    type: merge",
+  "    label: C",
+  "    merge_strategy: copy_all",
+  "    inputs: [b]",
+  "",
+].join("\n");
+
+async function runCompactionWorkflow(
+  threshold: number,
+  runId: string,
+): Promise<{
+  stderr: string;
+  journal: RunJournalEvent[];
+  replayedState: RunState;
+}> {
+  const tmpDir = await Deno.makeTempDir();
+  const origCwd = Deno.cwd();
+  const origWriteSync = Deno.stderr.writeSync.bind(Deno.stderr);
+  let stderr = "";
+  try {
+    await Deno.writeTextFile(
+      `${tmpDir}/workflow.yaml`,
+      FR_E83_WORKFLOW.replace("%THRESHOLD%", String(threshold)),
+    );
+    Deno.chdir(tmpDir);
+    Deno.stderr.writeSync = (data: Uint8Array): number => {
+      stderr += new TextDecoder().decode(data);
+      return data.byteLength;
+    };
+    const engine = new Engine({
+      config_path: "workflow.yaml",
+      run_id: runId,
+      verbosity: "verbose",
+      args: {},
+      env_overrides: {},
+      lock_path: "test.lock",
+    });
+    const state = await engine.run();
+    assertEquals(state.status, "completed");
+    const journal = (await Deno.readTextFile(
+      `runs/${runId}/journal.jsonl`,
+    ))
+      .trim()
+      .split("\n")
+      .map((line) => JSON.parse(line)) as RunJournalEvent[];
+    const replayedState = (await replayRunJournal(`runs/${runId}`)).state;
+    return { stderr, journal, replayedState };
+  } finally {
+    Deno.stderr.writeSync = origWriteSync;
+    Deno.chdir(origCwd);
+    await Deno.remove(tmpDir, { recursive: true });
+  }
