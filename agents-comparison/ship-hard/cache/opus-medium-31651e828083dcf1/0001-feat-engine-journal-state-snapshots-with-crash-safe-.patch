@@ -0,0 +1,229 @@
+/**
+ * @module
+ * Crash-safe recovery-journal compaction (FR-E83).
+ *
+ * Compaction replaces the replay prefix of `journal.jsonl` with a single
+ * `state_snapshot` line so long runs do not grow the journal — and replay
+ * cost — without bound. The protocol below preserves the durability contract:
+ * at EVERY intermediate point a crash leaves a journal that replays (old
+ * content or new content, never neither).
+ *
+ * Protocol order (shared by engine auto-compaction and the CLI):
+ *   1. replay the current journal;
+ *   2. write `journal.jsonl.tmp` = one `state_snapshot` + zero tail;
+ *   3. fsync the tmp file;
+ *   4. copy the current journal to `journal.jsonl.bak` (one generation);
+ *   5. atomically rename tmp over `journal.jsonl`.
+ *
+ * Replay reads only `journal.jsonl`, so `.tmp`/`.bak` are invisible to it; the
+ * `.bak` is written BEFORE the rename so a crash between copy and rename still
+ * leaves the original `journal.jsonl` intact.
+ */
+
+import {
+  buildStateSnapshotEvent,
+  getJournalPath,
+  replayRunJournal,
+  RunJournalWriter,
+} from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+import { isRunLive } from "./lock.ts";
+
+/** Basename of the one-generation backup kept by compaction. */
+export const JOURNAL_BACKUP_BASENAME = "journal.jsonl.bak";
+
+/** Boundaries at which the fault hook fires (test-only crash injection). One
+ * value per "between consecutive protocol steps" point, plus the terminal
+ * post-rename point. */
+export type CompactionStep =
+  | "after_replay"
+  | "after_write_tmp"
+  | "after_fsync"
+  | "after_copy_bak"
+  | "after_rename";
+
+/** Outcome of a compaction (or a dry-run projection of one). */
+export interface CompactionSummary {
+  /** Run whose journal was compacted. */
+  runId: string;
+  /** Journal events before compaction (the count the snapshot subsumes). */
+  eventsBefore: number;
+  /** Journal events after compaction — always 1 (the snapshot, zero tail). */
+  eventsAfter: number;
+  /** `journal.jsonl` byte size before compaction. */
+  bytesBefore: number;
+  /** `journal.jsonl` byte size after compaction (snapshot line only). */
+  bytesAfter: number;
+  /** Basename of the retained backup ({@link JOURNAL_BACKUP_BASENAME}). */
+  backupPath: string;
+}
+
+/** Options for {@link compactJournalCore}. */
+export interface CompactJournalCoreOptions {
+  /** Test-only crash-injection hook fired after each protocol step. Throwing
+   * from it simulates a crash at that boundary; production passes nothing. */
+  faultHook?: (step: CompactionStep) => void | Promise<void>;
+  /** Override the snapshot timestamp (tests); defaults to now. */
+  ts?: string;
+}
+
+/**
+ * Core crash-safe compaction (no active-run refusal — the engine is the lock
+ * holder and coordinates at safe boundaries; the CLI wraps this with the
+ * active-run guard). Replaying first doubles as the unreplayable-journal
+ * refusal: a malformed non-tail line throws out of {@link replayRunJournal}
+ * before any file is written, so nothing is modified.
+ */
+export async function compactJournalCore(
+  runDir: string,
+  runId: string,
+  opts: CompactJournalCoreOptions = {},
+): Promise<CompactionSummary> {
+  const journalPath = getJournalPath(runDir);
+  const tmpPath = `${journalPath}.tmp`;
+  const bakPath = `${journalPath}.bak`;
+
+  // Step 1: replay (refuses unreplayable journals before touching any file).
+  const replay = await replayRunJournal(runDir);
+  const bytesBefore = (await Deno.stat(journalPath)).size;
+  const eventsBefore = replay.events.length;
+  await opts.faultHook?.("after_replay");
+
+  const maxSeq = replay.events.reduce((m, e) => Math.max(m, e.seq), 0);
+  const ts = opts.ts ?? new Date().toISOString();
+  const snapshot = buildStateSnapshotEvent(
+    runId,
+    maxSeq + 1,
+    replay.state,
+    eventsBefore,
+    ts,
+  );
+  const line = new TextEncoder().encode(`${JSON.stringify(snapshot)}\n`);
+
+  // Step 2: write tmp = one snapshot + zero tail.
+  const tmpFile = await Deno.open(tmpPath, {
+    write: true,
+    create: true,
+    truncate: true,
+  });
+  try {
+    await tmpFile.write(line);
+    await opts.faultHook?.("after_write_tmp");
+    // Step 3: fsync tmp.
+    await tmpFile.sync();
+  } finally {
+    tmpFile.close();
+  }
+  await opts.faultHook?.("after_fsync");
+
+  // Step 4: copy current journal → bak (one generation, overwriting any prior).
+  await Deno.copyFile(journalPath, bakPath);
+  await opts.faultHook?.("after_copy_bak");
+
+  // Step 5: atomic rename tmp over journal.
+  await Deno.rename(tmpPath, journalPath);
+  await opts.faultHook?.("after_rename");
+
+  const bytesAfter = (await Deno.stat(journalPath)).size;
+  return {
+    runId,
+    eventsBefore,
+    eventsAfter: 1,
+    bytesBefore,
+    bytesAfter,
+    backupPath: JOURNAL_BACKUP_BASENAME,
+  };
+}
+
+/**
+ * Manual compaction entry point (CLI `runs compact`). Adds the refusals that
+ * only apply to an external caller: a run not found (no journal) and an active
+ * run (lock held by a live process). `dryRun` projects the summary — event
+ * counts and byte sizes — without modifying anything.
+ */
+export async function compactRunJournal(opts: {
+  workflowDir: string;
+  runId: string;
+  dryRun?: boolean;
+}): Promise<CompactionSummary> {
+  const runDir = getRunDir(opts.runId, opts.workflowDir);
+  const journalPath = getJournalPath(runDir);
+
+  let bytesBefore: number;
+  try {
+    bytesBefore = (await Deno.stat(journalPath)).size;
+  } catch (e) {
+    if (e instanceof Deno.errors.NotFound) {
+      throw new Error(`run not found: no journal at ${journalPath}`);
+    }
+    throw e;
+  }
+
+  if (await isRunLive(opts.workflowDir, opts.runId)) {
+    throw new Error(
+      `refusing to compact ${opts.runId}: run is active ` +
+        `(lock held by a live process)`,
+    );
+  }
+
+  if (opts.dryRun) {
+    // Replay to count events and project the snapshot byte size; modify
+    // nothing. A fixed-width ISO timestamp keeps the projection accurate.
+    const replay = await replayRunJournal(runDir);
+    const eventsBefore = replay.events.length;
+    const maxSeq = replay.events.reduce((m, e) => Math.max(m, e.seq), 0);
+    const snapshot = buildStateSnapshotEvent(
+      opts.runId,
+      maxSeq + 1,
+      replay.state,
+      eventsBefore,
+      "1970-01-01T00:00:00.000Z",
+    );
+    const bytesAfter =
+      new TextEncoder().encode(`${JSON.stringify(snapshot)}\n`).length;
+    return {
+      runId: opts.runId,
+      eventsBefore,
+      eventsAfter: 1,
+      bytesBefore,
+      bytesAfter,
+      backupPath: JOURNAL_BACKUP_BASENAME,
+    };
+  }
+
+  return await compactJournalCore(runDir, opts.runId);
+}
+
+/** True when the journal should be auto-compacted at a boundary (FR-E83):
+ * threshold enabled (`> 0`) and the events-since-last-snapshot strictly
+ * exceed it. `0` disables auto-compaction. */
+export function shouldCompact(
+  eventsSinceSnapshot: number,
+  threshold: number,
+): boolean {
+  return threshold > 0 && eventsSinceSnapshot > threshold;
+}
+
+/**
+ * Engine boundary hook (FR-E83): compact when the threshold is exceeded, then
+ * return a writer reopened on the compacted journal (its
+ * `eventsSinceSnapshot` resets to 0 and `nextSeq` continues past the new
+ * snapshot). When no compaction is needed the same writer is returned
+ * unchanged. MUST be called only at node-completion (level) boundaries — never
+ * mid-node — so it never races a concurrent append.
+ */
+export async function maybeCompactAtBoundary(opts: {
+  journal: RunJournalWriter;
+  runDir: string;
+  runId: string;
+  threshold: number;
+  onCompacted?: (summary: CompactionSummary) => void;
+}): Promise<RunJournalWriter> {
+  if (!shouldCompact(opts.journal.eventsSinceSnapshot, opts.threshold)) {
+    return opts.journal;
+  }
+  const summary = await compactJournalCore(opts.runDir, opts.runId);
+  const reopened = await RunJournalWriter.open(opts.runDir, opts.runId);
+  opts.onCompacted?.(summary);
+  return reopened;
+}
