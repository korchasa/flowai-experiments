+/** Parsed arguments for `runs compact` (FR-E83). */
+export interface RunsCompactArgs {
+  /** Workflow folder containing `runs/<runId>/` (trailing slashes stripped). */
+  workflowDir: string;
+  /** Target run id. */
+  runId: string;
+  /** When true, print the projected summary and modify nothing. */
+  dryRun: boolean;
+}
+
+/**
+ * Parse `runs compact --workflow <dir> --run <runId> [--dry-run]` (FR-E83).
+ * Mirrors the existing manual arg-parsing style (`--flag value` and
+ * `--flag=value` both accepted). Throws a one-line error on missing flags.
+ */
+export function parseRunsCompactArgs(args: string[]): RunsCompactArgs {
+  let workflow: string | undefined;
+  let runId: string | undefined;
+  let dryRun = false;
+  for (let i = 0; i < args.length; i++) {
+    const a = args[i];
+    if (a === "--workflow") {
+      workflow = args[++i];
+    } else if (a.startsWith("--workflow=")) {
+      workflow = a.slice("--workflow=".length);
+    } else if (a === "--run") {
+      runId = args[++i];
+    } else if (a.startsWith("--run=")) {
+      runId = a.slice("--run=".length);
+    } else if (a === "--dry-run") {
+      dryRun = true;
+    } else {
+      throw new Error(
+        `runs compact: unexpected argument '${a}'. Usage: ` +
+          "flowai-workflow runs compact --workflow <dir> --run <runId> [--dry-run]",
+      );
+    }
+  }
+  if (!workflow) {
+    throw new Error(
+      "runs compact: missing --workflow <dir>. Usage: " +
+        "flowai-workflow runs compact --workflow <dir> --run <runId> [--dry-run]",
+    );
+  }
+  if (!runId) {
+    throw new Error(
+      "runs compact: missing --run <runId>. Usage: " +
+        "flowai-workflow runs compact --workflow <dir> --run <runId> [--dry-run]",
+    );
+  }
+  return { workflowDir: normalizeWorkflowDir(workflow), runId, dryRun };
+}
+
+/** Format the one-line compaction summary (FR-E83). The non-dry-run form is
+ * the pinned success line the CLI prints verbatim. */
