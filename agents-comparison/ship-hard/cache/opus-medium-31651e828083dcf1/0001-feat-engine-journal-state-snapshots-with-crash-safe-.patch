+import { compactJournalCore } from "./journal-compaction.ts";
+import { createRunState, markRunCompleted } from "./state.ts";
+import type { RunJournalEvent, RunState } from "../types.ts";
+
+/** Append the ordinary bootstrap facts for a single-node run. */
+async function appendBootstrap(
+  writer: RunJournalWriter,
+  runId: string,
+  nodeId: string,
+): Promise<void> {
+  await writer.append({
+    kind: "run_started",
+    config_path: "workflow.yaml",
+    started_at: "2026-06-12T00:00:00.000Z",
+    ts: "2026-06-12T00:00:00.000Z",
+    args: {},
+    env: {},
+  });
+  await writer.append({
+    kind: "workflow_loaded",
+    config_path: "workflow.yaml",
+    name: "wf",
+    version: "1",
+  });
+  await writer.append({
+    kind: "node_declared",
+    node_id: nodeId,
+    node_type: "agent",
+    label: nodeId,
+  });
+  await writer.append({
+    kind: "node_directory_declared",
+    node_id: nodeId,
+    node_dir: `runs/${runId}/${nodeId}`,
+  });
+}
+
+/** Drive a node through started→completed against `state` + `writer`. */
+async function runNode(
+  state: RunState,
+  writer: RunJournalWriter,
+  nodeId: string,
+  cost: number,
+): Promise<void> {
+  await nodeStarted(state, nodeId, undefined, writer);
+  await nodeCompleted(state, nodeId, cost, `${nodeId} done`, undefined, writer);
+}
