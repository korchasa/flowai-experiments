+Deno.test("FR-E83: forward refusal — snapshot_version above supported fails replay", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    const future = {
+      schema_version: 1,
+      run_id: "run-fwd",
+      seq: 1,
+      event_id: "run-fwd:1:state_snapshot",
+      kind: "state_snapshot",
+      ts: "2026-06-12T00:00:00.000Z",
+      snapshot_version: 2,
+      events_covered: 1,
+      state: createRunState("run-fwd", "workflow.yaml", [], {}, {}),
+    };
+    await Deno.writeTextFile(
+      getJournalPath(dir),
+      `${JSON.stringify(future)}\n`,
+    );
+    await assertRejects(
+      () => replayRunJournal(dir),
+      Error,
+      "unsupported state_snapshot version 2",
+    );
+    // Error names the journal path too.
+    await assertRejects(
+      () => replayRunJournal(dir),
+      Error,
+      getJournalPath(dir),
+    );
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83: torn trailing line immediately after snapshot is tolerated", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    const writer = await RunJournalWriter.open(dir, "run-torn");
+    await appendBootstrap(writer, "run-torn", "a");
+    const state = createRunState("run-torn", "workflow.yaml", ["a"], {}, {});
+    await runNode(state, writer, "a", 0.3);
+    await compactJournalCore(dir, "run-torn", {
+      ts: "2026-06-12T00:00:00.000Z",
+    });
+    // Simulate a crash mid-write of the first post-snapshot record.
+    await Deno.writeTextFile(getJournalPath(dir), '{"schema_version":1', {
+      append: true,
+    });
+
+    const replay = await replayRunJournal(dir);
+    assertEquals(replay.ignored_partial_tail, true);
+    assertEquals(replay.state.nodes.a.status, "completed");
+
+    // A reopened writer truncates the torn tail and continues from the snapshot.
+    const resumed = await RunJournalWriter.open(dir, "run-torn");
+    assertEquals(resumed.eventsSinceSnapshot, 0);
+    await resumed.append({
+      kind: "run_completed",
+      status: "completed",
+      completed_at: "2026-06-12T00:02:00.000Z",
+    });
+    const after = await replayRunJournal(dir);
+    assertEquals(after.state.status, "completed");
+    assertEquals(after.ignored_partial_tail, false);
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
