+    const state = createRunState("run-old", "workflow.yaml", ["a"], {}, {});
+    await runNode(state, writer, "a", 0.5);
+    markRunCompleted(state);
+    await writer.append({
+      kind: "run_completed",
+      status: "completed",
+      completed_at: state.completed_at!,
+    });
+
+    const replay = await replayRunJournal(dir);
+    assertEquals(replay.state.status, "completed");
+    assertEquals(replay.state.nodes.a.status, "completed");
+    assertEquals(replay.state.total_cost_usd, 0.5);
+    // No snapshot present → every event is applied (no seeding/slicing).
+    assertEquals(replay.events.length, 7);
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
