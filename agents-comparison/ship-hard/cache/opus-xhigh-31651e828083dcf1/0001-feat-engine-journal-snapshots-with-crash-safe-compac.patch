+  /** Run id taken from the replayed model. */
+  runId: string;
+  /** Journal events before compaction (everything the snapshot subsumes). */
+  eventsBefore: number;
+  /** Journal events after compaction (always 1 — the lone snapshot). */
+  eventsAfter: number;
+  /** Journal byte size before compaction. */
+  bytesBefore: number;
+  /** Journal byte size after compaction (the snapshot line). */
+  bytesAfter: number;
