+// FR-E83 — Journal snapshots with crash-safe compaction.
+// Covers: snapshot event format (item 1), backward compat (item 2), forward
+// refusal (item 3), snapshot-seeded suffix-only replay (items 5/7),
+// snapshot+tail equivalence (item 6), torn line after snapshot (item 8), the
+// crash-safe protocol + crash injection (items 9/10), and the single .bak
+// generation (item 12).
+
+import { assert, assertEquals, assertRejects } from "@std/assert";
+import {
+  type CompactionStep,
+  compactJournal,
+  getJournalBakPath,
+  getJournalPath,
+  getJournalTmpPath,
+  previewCompaction,
+  replayRunJournal,
+  RunJournalWriter,
+  SUPPORTED_SNAPSHOT_VERSION,
+} from "./run-journal.ts";
+import { nodeCompleted, nodeStarted } from "../engine/node-lifecycle.ts";
+import { createRunState, markRunCompleted } from "./state.ts";
+import type { RunState, StateSnapshotJournalEvent } from "../types.ts";
+
+/** Build a realistic journal (bootstrap + one node lifecycle + terminal). */
+async function writeFullJournal(
+  dir: string,
+  runId: string,
+): Promise<void> {
+  const writer = await RunJournalWriter.open(dir, runId);
+  await writer.append({
+    kind: "run_started",
+    config_path: "workflow.yaml",
+    started_at: "2026-06-12T00:00:00.000Z",
+    ts: "2026-06-12T00:00:00.000Z",
+    args: { issue: "83" },
+    env: { MODE: "test" },
+  });
+  await writer.append({
+    kind: "workflow_loaded",
+    config_path: "workflow.yaml",
+    name: "test-workflow",
+    version: "1",
+  });
+  await writer.append({
+    kind: "node_declared",
+    node_id: "build",
+    node_type: "agent",
+    label: "Build",
+  });
+  await writer.append({
+    kind: "node_directory_declared",
+    node_id: "build",
+    node_dir: `runs/${runId}/build`,
+  });
+  const state = createRunState(runId, "workflow.yaml", ["build"], {}, {});
+  await nodeStarted(state, "build", undefined, writer);
+  await nodeCompleted(state, "build", 0.5, "done", undefined, writer);
+  markRunCompleted(state);
+  await writer.append({
+    kind: "run_completed",
+    status: "completed",
+    completed_at: state.completed_at!,
+  });
+}
+
+/** Compose a `state_snapshot` JSON line seeded with `model`. */
+function snapshotLine(
+  runId: string,
+  seq: number,
