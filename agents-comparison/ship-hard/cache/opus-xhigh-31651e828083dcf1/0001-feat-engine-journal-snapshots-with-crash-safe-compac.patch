+/** Parameters for {@link compactRun}. */
+export interface CompactRunParams {
+  /** Workflow folder containing `workflow.yaml` and `runs/`. */
+  workflowDir: string;
+  /** Target run id. */
+  runId: string;
+  /** When true, report what would happen and modify nothing. */
+  dryRun?: boolean;
+}
+
+/** Result of {@link compactRun}. */
+export interface CompactRunResult {
+  /** Run id (from the replayed model). */
+  runId: string;
+  /** Journal events before compaction. */
+  eventsBefore: number;
+  /** Journal events after compaction (1). */
+  eventsAfter: number;
+  /** Journal byte size before. */
+  bytesBefore: number;
+  /** Journal byte size after (the snapshot line). */
+  bytesAfter: number;
+  /** Single-generation backup path. */
+  backupPath: string;
+  /** Whether this was a dry-run (nothing written). */
+  dryRun: boolean;
+}
+
+/**
+ * Manual journal compaction shared by the CLI `runs compact` subcommand
+ * (FR-E83). Applies the same crash-safe protocol as the engine's automatic
+ * path via {@link compactJournal}, but FIRST enforces the manual-only refusal
+ * rules (item 11), modifying nothing when either holds:
+ *   - the run is currently active (its lock is held by a live process), or
+ *   - the journal does not exist (run not found).
+ * The "journal does not replay cleanly" refusal is enforced inside
+ * `compactJournal`/`previewCompaction` (their replay step throws before any
+ * write). All refusals surface as thrown errors the caller renders as a single
+ * line.
+ */
+export async function compactRun(
+  params: CompactRunParams,
+): Promise<CompactRunResult> {
+  const { workflowDir, runId, dryRun = false } = params;
+  const runDir = getRunDir(runId, workflowDir);
+
+  // Refusal: run not found (no journal to compact).
+  try {
+    await Deno.stat(getJournalPath(runDir));
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) {
+      throw new Error(
+        `run '${runId}' not found (no journal at ${getJournalPath(runDir)})`,
+      );
+    }
+    throw error;
+  }
+
+  // Refusal: active run — a live process holds the workflow lock for it.
+  if (await isRunLive(workflowDir, runId)) {
+    throw new Error(
+      `run '${runId}' is active (its lock is held by a live process); ` +
+        `refusing to compact a running journal`,
+    );
+  }
+
+  if (dryRun) {
+    const preview = await previewCompaction(runDir);
+    return {
+      runId: preview.runId,
+      eventsBefore: preview.eventsBefore,
+      eventsAfter: preview.eventsAfter,
+      bytesBefore: preview.bytesBefore,
+      bytesAfter: preview.bytesAfter,
+      backupPath: getJournalBakPath(runDir),
+      dryRun: true,
+    };
+  }
+
+  const result = await compactJournal(runDir);
+  return {
+    runId: result.runId,
+    eventsBefore: result.eventsBefore,
+    eventsAfter: result.eventsAfter,
+    bytesBefore: result.bytesBefore,
+    bytesAfter: result.bytesAfter,
+    backupPath: result.backupPath,
+    dryRun: false,
+  };
+}
