+
+/** Replay the journal and build the enveloped snapshot line that would replace
+ * it, without writing anything. Shared by the dry-run preview and the real
+ * compaction so both report identical counts/sizes. Throws (nothing written)
+ * when the journal does not replay cleanly beyond torn-tail tolerance (item 11)
+ * or is missing. */
+async function planCompaction(runDir: string): Promise<{
+  snapshotLine: string;
+  preview: CompactionPreview;
+}> {
+  const journalPath = getJournalPath(runDir);
+  // Step 1 of the protocol AND the unreplayable-journal refusal point.
+  const replay = await replayRunJournal(runDir);
+  const bytesBefore = (await Deno.stat(journalPath)).size;
+  const eventsBefore = replay.events.length;
+  const runId = replay.state.run_id;
+  const maxSeq = replay.events.reduce((max, e) => Math.max(max, e.seq), 0);
+  const seq = maxSeq + 1;
+  const snapshot: StateSnapshotJournalEvent = {
+    schema_version: 1,
+    run_id: runId,
+    seq,
+    event_id: `${runId}:${seq}:state_snapshot`,
+    kind: "state_snapshot",
+    ts: new Date().toISOString(),
+    snapshot_version: SUPPORTED_SNAPSHOT_VERSION,
+    events_covered: eventsBefore,
+    model: replay.state,
+  };
+  const snapshotLine = `${JSON.stringify(snapshot)}\n`;
+  const bytesAfter = new TextEncoder().encode(snapshotLine).length;
+  return {
+    snapshotLine,
+    preview: { runId, eventsBefore, eventsAfter: 1, bytesBefore, bytesAfter },
+  };
