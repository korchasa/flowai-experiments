+ * powers the CLI `--dry-run`). */
+export async function previewCompaction(
+  runDir: string,
+): Promise<CompactionPreview> {
+  return (await planCompaction(runDir)).preview;
+}
+
+/**
+ * Compact a run's journal to a single `state_snapshot` using the crash-safe
+ * protocol (FR-E83 item 9), in this exact order:
+ *   1. replay the current journal;
+ *   2. write `journal.jsonl.tmp` with one snapshot event and zero tail events;
+ *   3. fsync the tmp file;
+ *   4. copy the current journal to `journal.jsonl.bak`;
+ *   5. atomically rename tmp over `journal.jsonl`.
+ * At every intermediate point a crash leaves a journal that still replays:
+ * before the rename the original `journal.jsonl` is untouched; after it the
+ * compacted snapshot is in place — never neither. This guarantees process-crash
+ * safety (the contract the fault-hook tests exercise); the tmp file's data is
+ * fsynced, but the directory entry is not, so power-loss durability of the
+ * rename itself is out of scope.
+ *
+ * Lock/active-run refusal is intentionally NOT enforced here: the engine calls
+ * this directly while it legitimately holds the run lock. The manual path
+ * ({@link "../mcp/commands.ts".compactRun}) adds the active-run refusal.
+ */
+export async function compactJournal(
+  runDir: string,
+  opts: CompactJournalOptions = {},
+): Promise<CompactJournalResult> {
+  const journalPath = getJournalPath(runDir);
+  const tmpPath = getJournalTmpPath(runDir);
+  const bakPath = getJournalBakPath(runDir);
+
+  // Step 1: replay (also where an unreplayable journal refuses, nothing yet
+  // written).
+  const { snapshotLine, preview } = await planCompaction(runDir);
+  await opts.faultHook?.("replayed");
+
+  // Step 2: stage the new journal (one snapshot, zero tail events).
+  await Deno.writeTextFile(tmpPath, snapshotLine);
+  await opts.faultHook?.("tmp-written");
+
+  // Step 3: fsync the staged file so the rename cannot expose a torn snapshot.
+  const tmpFile = await Deno.open(tmpPath, { read: true, write: true });
+  try {
+    await tmpFile.sync();
+  } finally {
+    tmpFile.close();
+  }
+  await opts.faultHook?.("tmp-fsynced");
+
+  // Step 4: keep exactly one backup generation of the pre-compaction journal.
+  await Deno.copyFile(journalPath, bakPath);
+  await opts.faultHook?.("bak-written");
+
+  // Step 5: atomic swap.
+  await Deno.rename(tmpPath, journalPath);
+  await opts.faultHook?.("renamed");
+
+  const bytesAfter = (await Deno.stat(journalPath)).size;
+  return {
+    ...preview,
+    bytesAfter,
+    backupPath: bakPath,
+    journalPath,
+  };
+}
