+export function parseRunsCompactArgs(
+  args: string[],
+): RunsCompactArgs | { help: true } {
+  let workflowDir: string | undefined;
+  let runId: string | undefined;
+  let dryRun = false;
+  for (let i = 0; i < args.length; i++) {
+    const arg = args[i];
+    if (arg === "--help" || arg === "-h") return { help: true };
+    if (arg === "--dry-run") {
+      dryRun = true;
+      continue;
+    }
+    if (arg === "--workflow") {
+      workflowDir = normalizeWorkflowDir(requireFlagValue(args, ++i, arg));
+      continue;
+    }
+    if (arg.startsWith("--workflow=")) {
+      workflowDir = normalizeWorkflowDir(arg.slice("--workflow=".length));
