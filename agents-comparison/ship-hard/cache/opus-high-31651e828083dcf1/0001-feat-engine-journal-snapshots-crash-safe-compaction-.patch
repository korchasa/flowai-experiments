index 0000000..afed753
--- /dev/null
+++ b/src/state/journal-snapshot_test.ts
@@ -0,0 +1,261 @@
+import { assert, assertEquals, assertRejects } from "@std/assert";
+import {
+  buildStateSnapshotEvent,
+  getJournalPath,
+  replayRunJournal,
+  RunJournalWriter,
+} from "./run-journal.ts";
+import { createRunState, markRunCompleted } from "./state.ts";
+import { nodeCompleted, nodeStarted } from "../engine/node-lifecycle.ts";
+import type { RunState } from "../types.ts";
+
+/**
+ * Build a realistic full journal (run bootstrap + two nodes + terminal) under
+ * `dir` and return its raw lines. Mirrors what the engine writes so snapshot
+ * round-trips are tested against authentic event shapes.
+ */
+async function buildSampleJournal(
+  dir: string,
+  runId: string,
+): Promise<string[]> {
+  const writer = await RunJournalWriter.open(dir, runId);
+  await writer.append({
+    kind: "run_started",
+    config_path: "workflow.yaml",
+    started_at: "2026-06-12T00:00:00.000Z",
+    ts: "2026-06-12T00:00:00.000Z",
+    args: { issue: "42" },
+    env: { MODE: "test" },
+  });
+  await writer.append({
+    kind: "workflow_loaded",
+    config_path: "workflow.yaml",
+    name: "wf",
+    version: "1",
+    ts: "2026-06-12T00:00:01.000Z",
+  });
+  for (const id of ["a", "b"]) {
+    await writer.append({
+      kind: "node_declared",
+      node_id: id,
+      node_type: "agent",
+      label: id.toUpperCase(),
+      ts: "2026-06-12T00:00:02.000Z",
+    });
+  }
+  const state = createRunState(runId, "workflow.yaml", ["a", "b"], {
+    issue: "42",
+  }, { MODE: "test" });
+  state.started_at = "2026-06-12T00:00:00.000Z";
+  await nodeStarted(state, "a", undefined, writer);
+  await nodeCompleted(state, "a", 0.1, "a-done", undefined, writer);
+  await nodeStarted(state, "b", undefined, writer);
+  await nodeCompleted(state, "b", 0.2, "b-done", undefined, writer);
+  markRunCompleted(state);
+  await writer.append({
+    kind: "run_completed",
+    status: "completed",
+    completed_at: state.completed_at!,
+  });
+  return (await Deno.readTextFile(getJournalPath(dir))).trimEnd().split("\n");
+}
+
+function snapshotLine(
+  runId: string,
+  seq: number,
+  model: RunState,
+  covered: number,
+): string {
+  return JSON.stringify(
+    buildStateSnapshotEvent(
+      runId,
+      seq,
+      model,
+      covered,
+      "2026-06-12T00:01:00.000Z",
+    ),
+  );
+}
+
+Deno.test("journal snapshot — round-trip equivalence: snapshot + tail replays byte-equal to full journal (item 6)", async () => {
+  const full = await Deno.makeTempDir();
+  const prefixDir = await Deno.makeTempDir();
+  const snapDir = await Deno.makeTempDir();
+  try {
+    const lines = await buildSampleJournal(full, "run-eq");
+    const fullReplay = await replayRunJournal(full);
+
+    // Coverage point: replay the prefix up to and including node `a`'s
+    // completion, then snapshot that model.
+    const events = lines.map((l) => JSON.parse(l));
+    const coverIdx = events.findIndex(
+      (e) => e.kind === "node_completed" && e.node_id === "a",
+    );
+    const prefix = lines.slice(0, coverIdx + 1);
+    const tail = lines.slice(coverIdx + 1);
+    await Deno.writeTextFile(
+      getJournalPath(prefixDir),
+      prefix.join("\n") + "\n",
+    );
+    const prefixReplay = await replayRunJournal(prefixDir);
+
+    const seedSeq = Math.max(...prefix.map((l) => JSON.parse(l).seq)) + 1;
+    const snap = snapshotLine(
+      "run-eq",
+      seedSeq,
+      prefixReplay.state,
+      coverIdx + 1,
+    );
+    await Deno.writeTextFile(
+      getJournalPath(snapDir),
+      [snap, ...tail].join("\n") + "\n",
+    );
+    const snapReplay = await replayRunJournal(snapDir);
+
+    // The reconstructed run model (item 1's "complete replayed run model")
+    // must serialize byte-for-byte identically.
+    assertEquals(
+      JSON.stringify(snapReplay.state),
+      JSON.stringify(fullReplay.state),
+    );
+    assert(snapReplay.replayed_from_snapshot);
+    assert(!fullReplay.replayed_from_snapshot);
+  } finally {
+    await Deno.remove(full, { recursive: true });
+    await Deno.remove(prefixDir, { recursive: true });
+    await Deno.remove(snapDir, { recursive: true });
+  }
+});
+
+Deno.test("journal snapshot — replay seeds from the LATEST snapshot (item 5)", async () => {
+  const base = await Deno.makeTempDir();
+  const dir = await Deno.makeTempDir();
+  try {
+    const lines = await buildSampleJournal(base, "run-latest");
+    const replay = await replayRunJournal(base);
+
+    // Two snapshots; the later one carries a deliberately distinct marker so we
+    // can prove the latest wins.
+    const early: RunState = { ...replay.state, status: "running" };
+    const late: RunState = { ...replay.state, status: "completed" };
+    const e1 = snapshotLine("run-latest", 100, early, 3);
+    const e2 = snapshotLine("run-latest", 200, late, lines.length);
+    await Deno.writeTextFile(
+      getJournalPath(dir),
+      [e1, e2].join("\n") + "\n",
+    );
+    const seeded = await replayRunJournal(dir);
+    assertEquals(seeded.state.status, "completed");
+    assert(seeded.replayed_from_snapshot);
+  } finally {
+    await Deno.remove(base, { recursive: true });
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("journal snapshot — suffix-only replay never parses pre-snapshot history (item 7)", async () => {
+  const base = await Deno.makeTempDir();
+  const dir = await Deno.makeTempDir();
+  try {
+    await buildSampleJournal(base, "run-suffix");
+    const replay = await replayRunJournal(base);
+
+    // Garbage pre-snapshot lines: if replay parsed them it would throw
+    // "Malformed journal record". Their survival proves suffix-only replay.
+    const garbage = ["THIS IS NOT JSON", "{ broken", "42 not an event"];
+    const snap = snapshotLine("run-suffix", 50, replay.state, 999);
+    // One post-snapshot tail event so we exercise seed + tail.
+    const tail = JSON.stringify({
+      schema_version: 1,
+      run_id: "run-suffix",
+      seq: 51,
+      event_id: "run-suffix:51:run_failed",
+      kind: "run_failed",
+      ts: "2026-06-12T00:02:00.000Z",
+      status: "failed",
+      completed_at: "2026-06-12T00:02:00.000Z",
+    });
+    await Deno.writeTextFile(
+      getJournalPath(dir),
+      [...garbage, snap, tail].join("\n") + "\n",
+    );
+
+    const seeded = await replayRunJournal(dir);
+    assert(seeded.replayed_from_snapshot);
+    assertEquals(seeded.pre_snapshot_lines_skipped, garbage.length);
+    // Only the snapshot + the single tail event were parsed.
+    assertEquals(seeded.events.length, 2);
+    // Tail applied on top of the seed.
+    assertEquals(seeded.state.status, "failed");
+  } finally {
+    await Deno.remove(base, { recursive: true });
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("journal snapshot — torn trailing line after snapshot is tolerated (item 8)", async () => {
+  const base = await Deno.makeTempDir();
+  const dir = await Deno.makeTempDir();
+  try {
+    await buildSampleJournal(base, "run-torn");
+    const replay = await replayRunJournal(base);
+    const snap = snapshotLine("run-torn", 60, replay.state, 999);
+    // Snapshot line (terminated) immediately followed by a torn fragment with
+    // NO trailing newline — a crash mid-append right after compaction.
+    await Deno.writeTextFile(
+      getJournalPath(dir),
+      snap + "\n" + '{"schema_version":1',
+    );
+    const seeded = await replayRunJournal(dir);
+    assert(seeded.ignored_partial_tail);
+    assert(seeded.replayed_from_snapshot);
+    assertEquals(seeded.state.status, replay.state.status);
+  } finally {
+    await Deno.remove(base, { recursive: true });
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("journal snapshot — forward refusal on unsupported snapshot_version (item 3)", async () => {
+  const base = await Deno.makeTempDir();
+  const dir = await Deno.makeTempDir();
+  try {
+    await buildSampleJournal(base, "run-fwd");
+    const replay = await replayRunJournal(base);
+    const future = buildStateSnapshotEvent("run-fwd", 70, replay.state, 999);
+    future.snapshot_version = 2;
+    await Deno.writeTextFile(
+      getJournalPath(dir),
+      JSON.stringify(future) + "\n",
+    );
+    await assertRejects(
+      () => replayRunJournal(dir),
+      Error,
+      "Unsupported snapshot_version 2",
+    );
+    // Error names the journal path.
+    await assertRejects(
+      () => replayRunJournal(dir),
+      Error,
+      getJournalPath(dir),
+    );
+  } finally {
+    await Deno.remove(base, { recursive: true });
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("journal snapshot — snapshot-free journals replay unchanged (item 2)", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    await buildSampleJournal(dir, "run-compat");
+    const replay = await replayRunJournal(dir);
+    assertEquals(replay.replayed_from_snapshot, false);
+    assertEquals(replay.pre_snapshot_lines_skipped, 0);
+    assertEquals(replay.state.status, "completed");
+    assertEquals(replay.state.nodes.a.status, "completed");
+    assertEquals(replay.state.nodes.b.status, "completed");
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
