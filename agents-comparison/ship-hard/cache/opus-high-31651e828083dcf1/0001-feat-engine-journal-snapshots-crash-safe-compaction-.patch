+
+/**
+ * Parse `runs compact --workflow <dir> --run <runId> [--dry-run]` (FR-E83).
+ * Follows the same manual flag-loop style as {@link parseAnswerArgs}; both
+ * `--flag value` and `--flag=value` forms are accepted. `--workflow` and
+ * `--run` are mandatory.
+ */
+export function parseCompactArgs(args: string[]): CompactArgs {
+  let workflow: string | undefined;
+  let runId: string | undefined;
+  let dryRun = false;
+  for (let i = 0; i < args.length; i++) {
+    const a = args[i];
+    if (a === "--workflow") {
+      workflow = args[++i];
+      continue;
+    }
+    if (a.startsWith("--workflow=")) {
+      workflow = a.slice("--workflow=".length);
+      continue;
+    }
+    if (a === "--run") {
+      runId = args[++i];
+      continue;
+    }
+    if (a.startsWith("--run=")) {
+      runId = a.slice("--run=".length);
+      continue;
+    }
+    if (a === "--dry-run") {
+      dryRun = true;
+      continue;
+    }
+    throw new Error(`runs compact: unexpected argument: ${a}`);
+  }
+  if (!workflow) {
+    throw new Error(
+      "runs compact: missing --workflow <dir>. " +
+        "Usage: flowai-workflow runs compact --workflow <dir> --run <runId> [--dry-run]",
+    );
+  }
+  if (!runId) {
+    throw new Error(
+      "runs compact: missing --run <runId>. " +
+        "Usage: flowai-workflow runs compact --workflow <dir> --run <runId> [--dry-run]",
+    );
+  }
+  return { workflowDir: normalizeWorkflowDir(workflow), runId, dryRun };
