+/**
+ * @module
+ * Crash-safe journal compaction (FR-E83).
+ *
+ * Truncates a run's append-only `journal.jsonl` replay prefix by replacing it
+ * with a single `state_snapshot` event, without ever weakening the FR-E69
+ * durability contract. The protocol is shared verbatim by engine
+ * auto-compaction and the `runs compact` CLI subcommand.
+ *
+ * Protocol (exact order — item 9):
+ *   1. replay the current journal (refuse if it does not replay cleanly
+ *      beyond the standard torn-line tolerance);
+ *   2. write `journal.jsonl.tmp` = one `state_snapshot` event + zero tail;
+ *   3. fsync the tmp file;
+ *   4. copy the current journal to `journal.jsonl.bak` (one generation);
+ *   5. atomically rename tmp over `journal.jsonl`.
+ *
+ * Only `journal.jsonl` is consulted by replay, and it is replaced atomically
+ * at the final step — so a crash at any intermediate boundary leaves a journal
+ * that still replays (old content until step 5, new content after).
+ */
+
+import { getJournalPath, replayRunJournal } from "./run-journal.ts";
+import { buildStateSnapshotEvent } from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+import { isRunLive } from "./lock.ts";
+
+/** Protocol checkpoints, named by the step they follow. A crash simulated at
+ * checkpoint `k` models an abort in the gap between step `k` and step `k+1`. */
+export type CompactionStep =
+  | "after-replay"
+  | "after-write-tmp"
+  | "after-fsync"
+  | "after-copy-bak"
+  | "after-rename";
+
+/** Options for {@link compactJournal}. */
+export interface CompactJournalOptions {
+  /** Owning run id (stamped into the snapshot envelope and summary). */
+  runId: string;
+  /** When true, compute and return the summary but modify nothing on disk. */
+  dryRun?: boolean;
+  /** Optional pinned ISO timestamp for the snapshot (determinism in tests). */
+  ts?: string;
+  /** Test-only fault seam: invoked after each protocol step. Throwing from it
+   * simulates a crash in the gap before the next step. */
+  faultHook?: (step: CompactionStep) => void | Promise<void>;
+}
+
+/** Outcome of a compaction (or dry-run projection). */
+export interface CompactionSummary {
+  /** Owning run id. */
+  runId: string;
+  /** Journal event count before compaction. */
+  eventsBefore: number;
+  /** Journal event count after compaction (always `1` — the snapshot). */
+  eventsAfter: number;
+  /** Journal byte size before compaction. */
+  bytesBefore: number;
+  /** Journal byte size after compaction (the snapshot line). */
+  bytesAfter: number;
+  /** Path of the retained one-generation backup. */
+  backupPath: string;
+  /** Whether this was a dry-run (nothing modified). */
+  dryRun: boolean;
+}
+
+function describe(error: unknown): string {
+  return error instanceof Error ? error.message : String(error);
+}
+
+/**
+ * Execute the crash-safe compaction protocol for the run rooted at `runDir`.
+ *
+ * Refuses (throws, nothing modified) when the journal does not replay cleanly
+ * beyond torn-line tolerance. The active-lock refusal (item 11) is enforced by
+ * callers that can race a live run (the CLI) — engine auto-compaction holds
+ * its own lock and must not self-refuse.
+ */
+export async function compactJournal(
+  runDir: string,
+  opts: CompactJournalOptions,
+): Promise<CompactionSummary> {
+  const journalPath = getJournalPath(runDir);
+  const tmpPath = `${journalPath}.tmp`;
+  const bakPath = `${journalPath}.bak`;
+
+  let bytesBefore: number;
+  try {
+    bytesBefore = (await Deno.stat(journalPath)).size;
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) {
+      throw new Error(
+        `Cannot compact ${opts.runId}: journal not found at ${journalPath}`,
+      );
+    }
+    throw error;
+  }
+
+  // (1) Replay current journal — refusal when it does not replay cleanly.
+  let replay;
+  try {
+    replay = await replayRunJournal(runDir);
+  } catch (error) {
+    throw new Error(
+      `Cannot compact ${opts.runId}: journal does not replay cleanly: ${
+        describe(error)
+      }`,
+    );
+  }
+
+  const eventsBefore = replay.events.length;
+  const maxSeq = replay.events.reduce((max, e) => Math.max(max, e.seq), 0);
+  const snapshot = buildStateSnapshotEvent(
+    opts.runId,
+    maxSeq + 1,
+    replay.state,
+    eventsBefore,
+    opts.ts,
+  );
+  const snapshotLine = `${JSON.stringify(snapshot)}\n`;
+  const bytesAfter = new TextEncoder().encode(snapshotLine).length;
+
+  const summary: CompactionSummary = {
+    runId: opts.runId,
+    eventsBefore,
+    eventsAfter: 1,
+    bytesBefore,
+    bytesAfter,
+    backupPath: bakPath,
+    dryRun: opts.dryRun === true,
+  };
+
+  if (opts.dryRun) return summary;
+
+  await opts.faultHook?.("after-replay");
+
+  // (2) Write tmp = one snapshot event, zero tail.
+  await Deno.writeTextFile(tmpPath, snapshotLine);
+  await opts.faultHook?.("after-write-tmp");
+
+  // (3) fsync the tmp file so its bytes are durable before it becomes canonical.
+  {
+    using file = await Deno.open(tmpPath, { read: true, write: true });
+    await file.sync();
+  }
+  await opts.faultHook?.("after-fsync");
+
+  // (4) Copy current journal to the one-generation backup.
+  await Deno.copyFile(journalPath, bakPath);
+  await opts.faultHook?.("after-copy-bak");
+
+  // (5) Atomically rename tmp over the journal.
+  await Deno.rename(tmpPath, journalPath);
+  await opts.faultHook?.("after-rename");
+
+  return summary;
+}
+
+/** Options for {@link compactRun}. */
+export interface CompactRunOptions {
+  /** Workflow folder containing `workflow.yaml`. */
+  workflowDir: string;
+  /** Target run id. */
+  runId: string;
+  /** When true, report what would happen and modify nothing. */
+  dryRun?: boolean;
+  /** Optional pinned ISO timestamp for the snapshot (determinism in tests). */
+  ts?: string;
+}
+
+/**
+ * Manual compaction entry shared by the CLI (FR-E83): resolves the run
+ * directory from the standard path helper and applies BOTH refusal rules
+ * (item 11) — active live lock and non-replayable journal — before running the
+ * crash-safe protocol. A `--dry-run` skips the active-lock refusal because it
+ * cannot corrupt a live run. Engine auto-compaction does NOT use this wrapper:
+ * it holds its own lock and would otherwise always self-refuse.
+ */
+export async function compactRun(
+  opts: CompactRunOptions,
+): Promise<CompactionSummary> {
+  const runDir = getRunDir(opts.runId, opts.workflowDir);
+  if (!opts.dryRun && await isRunLive(opts.workflowDir, opts.runId)) {
+    throw new Error(
+      `run ${opts.runId} is currently active (lock held by a live process); ` +
+        `refusing to compact`,
+    );
+  }
+  return await compactJournal(runDir, {
+    runId: opts.runId,
+    dryRun: opts.dryRun,
+    ts: opts.ts,
+  });
+}
+
+/** Render the canonical one-line success summary (item 15). */
+export function formatCompactionSummary(s: CompactionSummary): string {
+  return `compacted ${s.runId}: ${s.eventsBefore} -> ${s.eventsAfter} events, ` +
+    `${s.bytesBefore} -> ${s.bytesAfter} bytes (backup: journal.jsonl.bak)`;
+}
diff --git a/src/state/journal-compaction_test.ts b/src/state/journal-compaction_test.ts
new file mode 100644
index 0000000..01bd788
--- /dev/null
+++ b/src/state/journal-compaction_test.ts
@@ -0,0 +1,240 @@
+import { assert, assertEquals, assertRejects } from "@std/assert";
+import {
+  type CompactionStep,
+  compactJournal,
+  compactRun,
+  formatCompactionSummary,
+} from "./journal-compaction.ts";
+import {
+  getJournalPath,
+  replayRunJournal,
+  RunJournalWriter,
+} from "./run-journal.ts";
+import { createRunState, getRunDir, markRunCompleted } from "./state.ts";
+import { nodeCompleted, nodeStarted } from "../engine/node-lifecycle.ts";
+import { acquireLock, defaultLockPath, releaseLock } from "./lock.ts";
+
+/** Write a clean multi-event journal under `dir` and return its event count. */
+async function seedJournal(dir: string, runId: string): Promise<number> {
+  const writer = await RunJournalWriter.open(dir, runId);
+  await writer.append({
+    kind: "run_started",
+    config_path: "workflow.yaml",
+    started_at: "2026-06-12T00:00:00.000Z",
+    ts: "2026-06-12T00:00:00.000Z",
+    args: {},
+    env: {},
+  });
+  await writer.append({
+    kind: "node_declared",
+    node_id: "a",
+    node_type: "agent",
+    label: "A",
+    ts: "2026-06-12T00:00:01.000Z",
+  });
+  const state = createRunState(runId, "workflow.yaml", ["a"], {}, {});
+  state.started_at = "2026-06-12T00:00:00.000Z";
+  await nodeStarted(state, "a", undefined, writer);
+  await nodeCompleted(state, "a", 0.3, "done", undefined, writer);
+  markRunCompleted(state);
+  await writer.append({
+    kind: "run_completed",
+    status: "completed",
+    completed_at: state.completed_at!,
+  });
+  const replay = await replayRunJournal(dir);
+  return replay.events.length;
+}
+
+async function exists(path: string): Promise<boolean> {
+  try {
+    await Deno.stat(path);
+    return true;
+  } catch {
+    return false;
+  }
+}
+
+Deno.test("journal compaction — crash injection between every protocol step still replays (item 10)", async () => {
+  const steps: CompactionStep[] = [
+    "after-replay",
+    "after-write-tmp",
+    "after-fsync",
+    "after-copy-bak",
+  ];
+  for (const crashAt of steps) {
+    const dir = await Deno.makeTempDir();
+    try {
+      await seedJournal(dir, "run-crash");
+      const before = await replayRunJournal(dir);
+      const beforeJson = JSON.stringify(before.state);
+
+      await assertRejects(
+        () =>
+          compactJournal(dir, {
+            runId: "run-crash",
+            faultHook: (step) => {
+              if (step === crashAt) throw new Error(`injected crash @ ${step}`);
+            },
+          }),
+        Error,
+        "injected crash",
+      );
+
+      // Whatever the crash point, the journal still replays. For every crash
+      // before the final rename, it replays the OLD content unchanged.
+      const after = await replayRunJournal(dir);
+      assertEquals(JSON.stringify(after.state), beforeJson);
+      assert(
+        !after.replayed_from_snapshot,
+        `crash @ ${crashAt}: not compacted`,
+      );
+    } finally {
+      await Deno.remove(dir, { recursive: true });
+    }
+  }
+});
+
+Deno.test("journal compaction — successful compaction replaces the prefix with a snapshot (items 9, 12)", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    const eventsBefore = await seedJournal(dir, "run-ok");
+    const before = await replayRunJournal(dir);
+
+    const summary = await compactJournal(dir, { runId: "run-ok" });
+    assertEquals(summary.eventsBefore, eventsBefore);
+    assertEquals(summary.eventsAfter, 1);
+
+    const after = await replayRunJournal(dir);
+    assert(after.replayed_from_snapshot);
+    // State preserved across compaction.
+    assertEquals(JSON.stringify(after.state), JSON.stringify(before.state));
+    // Exactly one journal event remains (the snapshot).
+    assertEquals(after.events.length, 1);
+
+    // One-generation backup kept, holding the pre-compaction content.
+    assert(await exists(`${getJournalPath(dir)}.bak`));
+    assert(!await exists(`${getJournalPath(dir)}.tmp`));
+    const bak = await Deno.readTextFile(`${getJournalPath(dir)}.bak`);
+    assertEquals(bak.trimEnd().split("\n").length, eventsBefore);
+
+    // Summary line names the backup.
+    assert(
+      formatCompactionSummary(summary).includes("backup: journal.jsonl.bak"),
+    );
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("journal compaction — keeps exactly one backup generation across repeated compaction (item 12)", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    await seedJournal(dir, "run-bak");
+    await compactJournal(dir, { runId: "run-bak" });
+    const firstSnapshot = await Deno.readTextFile(getJournalPath(dir));
+
+    // Append a post-snapshot event, then compact again.
+    const writer = await RunJournalWriter.open(dir, "run-bak");
+    await writer.append({
+      kind: "run_failed",
+      status: "failed",
+      completed_at: "2026-06-12T00:05:00.000Z",
+    });
+    await compactJournal(dir, { runId: "run-bak" });
+
+    // The single .bak now holds the content from BEFORE the second compaction
+    // (the first snapshot + the appended event) — the prior generation is gone.
+    const bak = await Deno.readTextFile(`${getJournalPath(dir)}.bak`);
+    assert(bak.startsWith(firstSnapshot.trimEnd()));
+    // No multi-generation suffixes (.bak.1 etc.) exist.
+    let bakCount = 0;
+    for await (const entry of Deno.readDir(dir)) {
+      if (entry.name.startsWith("journal.jsonl.bak")) bakCount++;
+    }
+    assertEquals(bakCount, 1);
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("journal compaction — refuses a non-replayable journal, nothing modified (item 11)", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    // Malformed NON-tail line (terminated) → replay fails beyond torn tolerance.
+    await Deno.writeTextFile(
+      getJournalPath(dir),
+      '{ broken not json\n{"schema_version":1}\n',
+    );
+    const sizeBefore = (await Deno.stat(getJournalPath(dir))).size;
+    await assertRejects(
+      () => compactJournal(dir, { runId: "run-bad" }),
+      Error,
+      "does not replay cleanly",
+    );
+    // Nothing modified: no tmp, no bak, same size.
+    assert(!await exists(`${getJournalPath(dir)}.tmp`));
+    assert(!await exists(`${getJournalPath(dir)}.bak`));
+    assertEquals((await Deno.stat(getJournalPath(dir))).size, sizeBefore);
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("journal compaction — refuses while the run is active (live lock), nothing modified (item 11)", async () => {
+  const workflowDir = await Deno.makeTempDir();
+  const runId = "run-active";
+  const runDir = getRunDir(runId, workflowDir);
+  await Deno.mkdir(runDir, { recursive: true });
+  const lockPath = defaultLockPath(workflowDir);
+  try {
+    await seedJournal(runDir, runId);
+    const sizeBefore = (await Deno.stat(getJournalPath(runDir))).size;
+
+    // This test process is alive, so a lock naming our PID is "live".
+    await acquireLock(lockPath, runId);
+
+    await assertRejects(
+      () => compactRun({ workflowDir, runId }),
+      Error,
+      "currently active",
+    );
+    assert(!await exists(`${getJournalPath(runDir)}.tmp`));
+    assert(!await exists(`${getJournalPath(runDir)}.bak`));
+    assertEquals((await Deno.stat(getJournalPath(runDir))).size, sizeBefore);
+
+    // --dry-run is allowed even while active (it modifies nothing).
+    const dry = await compactRun({ workflowDir, runId, dryRun: true });
+    assertEquals(dry.dryRun, true);
+    assertEquals(dry.eventsAfter, 1);
+    assert(!await exists(`${getJournalPath(runDir)}.bak`));
+  } finally {
+    await releaseLock(lockPath);
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("journal compaction — dry-run reports counts and modifies nothing (item 15)", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    const eventsBefore = await seedJournal(dir, "run-dry");
+    const sizeBefore = (await Deno.stat(getJournalPath(dir))).size;
+    const summary = await compactJournal(dir, {
+      runId: "run-dry",
+      dryRun: true,
+    });
+    assertEquals(summary.dryRun, true);
+    assertEquals(summary.eventsBefore, eventsBefore);
+    assertEquals(summary.eventsAfter, 1);
+    assertEquals(summary.bytesBefore, sizeBefore);
+    assert(summary.bytesAfter > 0);
+    // Nothing written.
+    assert(!await exists(`${getJournalPath(dir)}.tmp`));
+    assert(!await exists(`${getJournalPath(dir)}.bak`));
+    assertEquals((await Deno.stat(getJournalPath(dir))).size, sizeBefore);
+    const replay = await replayRunJournal(dir);
+    assert(!replay.replayed_from_snapshot);
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
diff --git a/src/state/journal-snapshot_test.ts b/src/state/journal-snapshot_test.ts
