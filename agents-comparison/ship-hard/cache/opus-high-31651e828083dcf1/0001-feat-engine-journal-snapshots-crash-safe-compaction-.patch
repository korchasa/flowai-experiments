+/** Parsed arguments for the `runs compact` subcommand (FR-E83). */
+export interface CompactArgs {
+  /** Workflow folder containing `workflow.yaml` (trailing slashes stripped). */
+  workflowDir: string;
+  /** Target run id. */
+  runId: string;
+  /** When true, report what would happen and modify nothing. */
+  dryRun: boolean;
