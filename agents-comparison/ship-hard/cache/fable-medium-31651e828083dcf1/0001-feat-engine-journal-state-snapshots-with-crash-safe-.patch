+/** Parsed flags for the `runs compact` subcommand (FR-E83). */
+export interface RunsCompactArgs {
+  /** Workflow folder (trailing slashes stripped). `undefined` when the
+   * user did not pass `--workflow <dir>`; the caller falls back to the
+   * shared `resolveActiveWorkflow` resolver (FR-E78). */
+  workflowDir: string | undefined;
+  /** Target run id (from `--run`/`--run=`). */
+  runId: string;
+  /** When true, report what would happen without modifying any file. */
+  dryRun: boolean;
+}
+
+/**
+ * Parse `runs compact --workflow <dir> --run <run-id> [--dry-run]` (FR-E83).
+ * `--workflow <dir>`/`--workflow=` and `--run <id>`/`--run=` are both
+ * accepted; positionals are rejected.
+ */
+export function parseRunsCompactArgs(args: string[]): RunsCompactArgs {
+  let workflow: string | undefined;
+  let runId: string | undefined;
+  let dryRun = false;
+  for (let i = 0; i < args.length; i++) {
+    const a = args[i];
+    if (a === "--workflow") {
+      workflow = args[++i];
+      continue;
+    }
+    if (a.startsWith("--workflow=")) {
+      workflow = a.slice("--workflow=".length);
+      continue;
+    }
+    if (a === "--run") {
+      runId = args[++i];
+      continue;
+    }
+    if (a.startsWith("--run=")) {
+      runId = a.slice("--run=".length);
+      continue;
+    }
+    if (a === "--dry-run") {
+      dryRun = true;
+      continue;
+    }
+    throw new Error(
+      `Unexpected argument: ${a}. Usage: flowai-workflow runs compact ` +
+        "--workflow <dir> --run <run-id> [--dry-run]",
+    );
+  }
+  if (!runId) {
+    throw new Error(
+      "runs compact: missing --run <run-id> (the run whose journal to compact).",
+    );
+  }
+  return {
+    workflowDir: workflow ? normalizeWorkflowDir(workflow) : undefined,
+    runId,
+    dryRun,
+  };
+}
+
+/**
+ * Run the `runs compact` subcommand core (FR-E83): manual crash-safe journal
+ * compaction through the shared `compactRun` operation (same protocol and
+ * refusal rules as engine auto-compaction). Returns the exit code plus the
+ * stdout/stderr lines so the behaviour is unit-testable; `import.meta.main`
+ * does the printing. Errors are always a single line — never a stack trace.
+ */
+export async function runsCompactCommand(
+  args: string[],
+): Promise<{ code: number; out: string[]; err: string[] }> {
+  try {
+    const parsed = parseRunsCompactArgs(args);
+    let workflowDir = parsed.workflowDir;
+    if (!workflowDir) {
+      const resolved = await resolveActiveWorkflow({
+        env: Deno.env.toObject(),
+      });
+      if (resolved === null) {
+        throw new Error(
+          "Could not resolve active workflow. Pass it via " +
+            "`--workflow <dir>`, set FLOWAI_WORKFLOW, or place a " +
+            "workflow under `<cwd>/.flowai-workflow/`.",
+        );
+      }
+      workflowDir = normalizeWorkflowDir(resolved);
+    }
+    const summary = await compactRun({
+      workflowDir,
+      runId: parsed.runId,
+      dryRun: parsed.dryRun,
+    });
+    const counts = `${summary.events_before} -> ${summary.events_after} ` +
+      `events, ${summary.bytes_before} -> ${summary.bytes_after} bytes ` +
+      `(backup: journal.jsonl.bak)`;
+    const line = parsed.dryRun
+      ? `dry-run: would compact ${parsed.runId}: ${counts}; nothing modified`
+      : `compacted ${parsed.runId}: ${counts}`;
+    return { code: 0, out: [line], err: [] };
+  } catch (err) {
+    const message = (err as Error).message.split("\n")[0];
+    return { code: 1, out: [], err: [`Error: ${message}`] };
+  }
+}
