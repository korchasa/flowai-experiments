+// --- FR-E83: journal state snapshots + crash-safe compaction ---
+
+/** Lay out `<workflowDir>/runs/<runId>` and seed a valid journal there. */
+async function setupRunJournal(
+  runId: string,
+): Promise<{ workflowDir: string; runDir: string }> {
+  const workflowDir = await Deno.makeTempDir({ prefix: "compact-wf-" });
+  const runDir = getRunDir(runId, workflowDir);
+  const writer = await RunJournalWriter.open(runDir, runId);
+  await appendRunStart(writer, runId);
+  await appendFixedNodeLifecycle(writer, "build", 0.12);
+  return { workflowDir, runDir };
+}
+
+/** Append deterministic started+completed facts for a node (fixed ts). */
+async function appendFixedNodeLifecycle(
+  writer: RunJournalWriter,
+  nodeId: string,
+  costUsd: number,
+): Promise<void> {
+  const startedAt = "2026-06-12T00:00:01.000Z";
+  const completedAt = "2026-06-12T00:00:02.000Z";
+  await writer.append({
+    kind: "node_started",
+    node_id: nodeId,
+    status: "running",
+    timestamp: startedAt,
+    ts: startedAt,
+    node: { status: "running", started_at: startedAt },
+    metadata: {},
+  });
+  await writer.append({
+    kind: "node_completed",
+    node_id: nodeId,
+    status: "completed",
+    timestamp: completedAt,
+    ts: completedAt,
+    node: {
+      status: "completed",
+      started_at: startedAt,
+      completed_at: completedAt,
+      duration_ms: 1000,
+      cost_usd: costUsd,
+    },
+    metadata: { duration_ms: 1000, cost_usd: costUsd },
+    duration_ms: 1000,
+    cost_usd: costUsd,
+  });
+}
