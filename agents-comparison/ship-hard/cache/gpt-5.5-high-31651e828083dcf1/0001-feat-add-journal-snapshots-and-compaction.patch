+/** Parse `runs compact --workflow <dir> --run <runId> [--dry-run]`. */
+export function parseRunsCompactArgs(args: string[]): RunsCompactArgs {
+  const [action, ...rest] = args;
+  if (action !== "compact") {
+    throw new Error(
+      "runs: unknown action. Usage: flowai-workflow runs compact --workflow <dir> --run <runId> [--dry-run]",
+    );
+  }
+  let workflowDir: string | undefined;
+  let runId: string | undefined;
+  let dryRun = false;
+  for (let i = 0; i < rest.length; i++) {
+    const arg = rest[i];
+    if (arg === "--workflow") {
+      workflowDir = normalizeWorkflowDir(rest[++i] ?? "");
+      continue;
+    }
+    if (arg.startsWith("--workflow=")) {
+      workflowDir = normalizeWorkflowDir(arg.slice("--workflow=".length));
+      continue;
+    }
+    if (arg === "--run") {
+      runId = rest[++i];
+      continue;
+    }
+    if (arg.startsWith("--run=")) {
+      runId = arg.slice("--run=".length);
+      continue;
+    }
+    if (arg === "--dry-run") {
+      dryRun = true;
+      continue;
+    }
+    throw new Error(`runs compact: unknown argument '${arg}'`);
+  }
+  if (!workflowDir) throw new Error("runs compact: missing --workflow <dir>");
+  if (!runId) throw new Error("runs compact: missing --run <runId>");
+  return { workflowDir, runId, dryRun };
+}
+
+/** Format the exact manual compaction success line required by FR-E83. */
+export function formatRunCompactSummary(
+  summary: Pick<
+    JournalCompactionSummary,
+    | "run_id"
+    | "events_before"
+    | "events_after"
+    | "bytes_before"
+    | "bytes_after"
+    | "backup_path"
+  >,
+): string {
+  const backup = summary.backup_path.endsWith("journal.jsonl.bak")
+    ? "journal.jsonl.bak"
+    : summary.backup_path;
+  return `compacted ${summary.run_id}: ${summary.events_before} -> ${summary.events_after} events, ${summary.bytes_before} -> ${summary.bytes_after} bytes (backup: ${backup})`;
+}
