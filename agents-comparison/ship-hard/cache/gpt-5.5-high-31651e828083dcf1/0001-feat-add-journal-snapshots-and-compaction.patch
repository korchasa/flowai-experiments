+  const journalPath = getJournalPath(opts.runDir);
+  const tmpPath = `${journalPath}.tmp`;
+  const backupPath = `${journalPath}.bak`;
+  const parsed = await parseJournal(opts.runDir, { allowMissing: false });
+  validateSnapshotVersions(parsed.events, journalPath);
+  const replay = await replayRunJournal(opts.runDir);
+  maybeCrash("after_replay", opts.crashAfterStep);
+
+  const bytesBefore = await statSize(journalPath);
+  const snapshot = buildSnapshotEvent(opts.runId, replay, parsed.events.length);
+  const file = await Deno.open(tmpPath, {
+    create: true,
+    write: true,
+    truncate: true,
