+/**
+ * @module
+ * Safe local cleanup for old workflow run directories.
+ * [REF:fr:e83]
+ */
+
+import { defaultLockPath, readLockInfo } from "./lock.ts";
+import { replayRunJournal } from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+import type { RunState } from "../types.ts";
+
+/** Reason a run was protected from pruning. */
+export type RunPruneSkipReason =
+  | "locked"
+  | "lock_unreadable"
+  | "non_terminal"
+  | "journal_missing"
+  | "journal_unreplayable";
+
+/** A terminal run selected for keeping or deletion. */
+export interface RunPruneEntry {
+  /** Run identifier, equal to the run directory basename. */
+  run_id: string;
+  /** Absolute or caller-relative run directory path. */
+  run_dir: string;
+  /** Replayed run status. */
+  status: RunState["status"];
+  /** Replayed run start timestamp. */
+  started_at: string;
+}
+
+/** A run skipped because deletion is unsafe. */
+export interface RunPruneSkippedEntry {
+  /** Run identifier, equal to the run directory basename. */
+  run_id: string;
+  /** Absolute or caller-relative run directory path. */
+  run_dir: string;
+  /** Machine-readable skip reason. */
+  reason: RunPruneSkipReason;
+  /** Replayed run status when available. */
+  status?: RunState["status"];
+  /** Diagnostic text for unreadable state. */
+  detail?: string;
+}
+
+/** Planned prune operation, before filesystem deletion. */
+export interface RunsPrunePlan {
+  /** Workflow directory containing `workflow.yaml` and `runs/`. */
+  workflow_dir: string;
+  /** Number of newest terminal unlocked runs retained. */
+  keep: number;
+  /** Terminal unlocked runs selected for deletion, oldest first. */
+  toDelete: RunPruneEntry[];
+  /** Terminal unlocked runs retained by `keep`, newest first. */
+  kept: RunPruneEntry[];
+  /** Runs protected from deletion. */
+  skipped: RunPruneSkippedEntry[];
+}
+
+/** Result of applying or dry-running a prune plan. */
+export interface RunsPruneResult {
+  /** Workflow directory containing `workflow.yaml` and `runs/`. */
+  workflow_dir: string;
+  /** Number of newest terminal unlocked runs retained. */
+  keep: number;
+  /** True when no directories were deleted. */
+  dry_run: boolean;
+  /** Runs selected by the plan; deleted unless `dry_run` is true. */
+  deleted: RunPruneEntry[];
+  /** Terminal unlocked runs retained by `keep`, newest first. */
+  kept: RunPruneEntry[];
+  /** Runs protected from deletion. */
+  skipped: RunPruneSkippedEntry[];
+}
+
+/** Build a safe prune plan without deleting anything. */
+export async function createRunsPrunePlan(
+  workflowDir: string,
+  keep: number,
+): Promise<RunsPrunePlan> {
+  assertNonNegativeInteger(keep, "keep");
+  const runIds = await listRunIds(workflowDir);
+  const lockState = await readLockedRun(workflowDir);
+  const terminal: RunPruneEntry[] = [];
+  const skipped: RunPruneSkippedEntry[] = [];
+
+  for (const runId of runIds) {
+    const runDir = getRunDir(runId, workflowDir);
+    if (lockState.error) {
+      skipped.push({
+        run_id: runId,
+        run_dir: runDir,
+        reason: "lock_unreadable",
+        detail: lockState.error,
+      });
+      continue;
+    }
+    if (lockState.runId === runId) {
+      skipped.push({ run_id: runId, run_dir: runDir, reason: "locked" });
+      continue;
+    }
+
+    let state: RunState;
+    try {
+      state = (await replayRunJournal(runDir)).state;
+    } catch (error) {
+      skipped.push({
+        run_id: runId,
+        run_dir: runDir,
+        reason: error instanceof Deno.errors.NotFound
+          ? "journal_missing"
+          : "journal_unreplayable",
+        detail: error instanceof Error ? error.message : String(error),
+      });
+      continue;
+    }
+
+    if (!isTerminalStatus(state.status)) {
+      skipped.push({
+        run_id: runId,
+        run_dir: runDir,
+        reason: "non_terminal",
+        status: state.status,
+      });
+      continue;
+    }
+
+    terminal.push({
+      run_id: runId,
+      run_dir: runDir,
+      status: state.status,
+      started_at: state.started_at,
+    });
+  }
+
+  terminal.sort(compareNewestFirst);
+  const kept = terminal.slice(0, keep);
+  const toDelete = terminal.slice(keep).sort(compareOldestFirst);
+  skipped.sort((a, b) => a.run_id.localeCompare(b.run_id));
+  return { workflow_dir: workflowDir, keep, toDelete, kept, skipped };
+}
+
+/** Apply a safe prune plan, or return the same targets without deleting. */
+export async function pruneRuns(
+  workflowDir: string,
+  options: { keep: number; dryRun?: boolean },
+): Promise<RunsPruneResult> {
+  const plan = await createRunsPrunePlan(workflowDir, options.keep);
+  if (!options.dryRun) {
+    for (const entry of plan.toDelete) {
+      await Deno.remove(entry.run_dir, { recursive: true });
+    }
+  }
+  return {
+    workflow_dir: plan.workflow_dir,
+    keep: plan.keep,
+    dry_run: options.dryRun === true,
+    deleted: plan.toDelete,
+    kept: plan.kept,
+    skipped: plan.skipped,
+  };
+}
+
+function assertNonNegativeInteger(value: number, name: string): void {
+  if (!Number.isInteger(value) || value < 0) {
+    throw new Error(`${name} must be a non-negative integer.`);
+  }
+}
+
+async function listRunIds(workflowDir: string): Promise<string[]> {
+  const runsDir = `${workflowDir}/runs`;
+  const runIds: string[] = [];
+  try {
+    for await (const entry of Deno.readDir(runsDir)) {
+      if (entry.isDirectory) runIds.push(entry.name);
+    }
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return [];
+    throw error;
+  }
+  return runIds.sort();
+}
+
+async function readLockedRun(
+  workflowDir: string,
+): Promise<{ runId?: string; error?: string }> {
+  try {
+    const lock = await readLockInfo(defaultLockPath(workflowDir));
+    return { runId: lock.run_id };
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return {};
+    return { error: error instanceof Error ? error.message : String(error) };
+  }
+}
+
+function isTerminalStatus(status: RunState["status"]): boolean {
+  return status === "completed" || status === "failed" || status === "aborted";
+}
+
+function compareNewestFirst(a: RunPruneEntry, b: RunPruneEntry): number {
+  return b.started_at.localeCompare(a.started_at) ||
+    b.run_id.localeCompare(a.run_id);
+}
+
+function compareOldestFirst(a: RunPruneEntry, b: RunPruneEntry): number {
+  return a.started_at.localeCompare(b.started_at) ||
+    a.run_id.localeCompare(b.run_id);
+}
