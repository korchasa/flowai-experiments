+import { assertEquals, assertRejects } from "@std/assert";
+import { getRunDir } from "./state.ts";
+import { RunJournalWriter } from "./run-journal.ts";
+import { createRunsPrunePlan, pruneRuns } from "./runs-prune.ts";
+import { defaultLockPath } from "./lock.ts";
+
+async function writeRun(
+  workflowDir: string,
+  runId: string,
+  startedAt: string,
+  status: "running" | "completed" | "failed" | "aborted",
+): Promise<void> {
+  const runDir = getRunDir(runId, workflowDir);
+  const writer = await RunJournalWriter.open(runDir, runId);
+  await writer.append({
+    kind: "run_started",
+    config_path: `${workflowDir}/workflow.yaml`,
+    started_at: startedAt,
+    args: {},
+    env: {},
+    ts: startedAt,
+  });
+  if (status !== "running") {
+    await writer.append({
+      kind: status === "completed"
+        ? "run_completed"
+        : status === "failed"
+        ? "run_failed"
+        : "run_aborted",
+      status,
+      completed_at: startedAt,
+      ts: startedAt,
+    });
+  }
+}
+
+async function withWorkflow(
+  fn: (workflowDir: string) => Promise<void>,
+): Promise<void> {
+  const root = await Deno.makeTempDir({ prefix: "runs-prune-" });
+  try {
+    const workflowDir = `${root}/workflow`;
+    await Deno.mkdir(`${workflowDir}/runs`, { recursive: true });
+    await fn(workflowDir);
+  } finally {
+    await Deno.remove(root, { recursive: true });
+  }
+}
+
+Deno.test("runsPrunePlan keeps N newest terminal unlocked runs", async () => {
+  await withWorkflow(async (workflowDir) => {
+    await writeRun(workflowDir, "old", "2026-01-01T00:00:00.000Z", "failed");
+    await writeRun(
+      workflowDir,
+      "middle",
+      "2026-01-02T00:00:00.000Z",
+      "completed",
+    );
+    await writeRun(
+      workflowDir,
+      "new",
+      "2026-01-03T00:00:00.000Z",
+      "aborted",
+    );
+
+    const plan = await createRunsPrunePlan(workflowDir, 2);
+
+    assertEquals(plan.toDelete.map((entry) => entry.run_id), ["old"]);
+    assertEquals(plan.kept.map((entry) => entry.run_id), ["new", "middle"]);
+    assertEquals(plan.skipped, []);
+  });
+});
+
+Deno.test("runsPrunePlan skips protected and unknown runs", async () => {
+  await withWorkflow(async (workflowDir) => {
+    await writeRun(
+      workflowDir,
+      "locked",
+      "2026-01-01T00:00:00.000Z",
+      "completed",
+    );
+    await writeRun(
+      workflowDir,
+      "running",
+      "2026-01-02T00:00:00.000Z",
+      "running",
+    );
+    await Deno.mkdir(getRunDir("missing-journal", workflowDir), {
+      recursive: true,
+    });
+    const badDir = getRunDir("bad-journal", workflowDir);
+    await Deno.mkdir(badDir, { recursive: true });
+    await Deno.writeTextFile(`${badDir}/journal.jsonl`, "{bad json}\n");
+    await Deno.writeTextFile(
+      defaultLockPath(workflowDir),
+      JSON.stringify({
+        pid: 123,
+        hostname: "test",
+        run_id: "locked",
+        started_at: "2026-01-01T00:00:00.000Z",
+      }) + "\n",
+    );
+
+    const plan = await createRunsPrunePlan(workflowDir, 0);
+
+    assertEquals(plan.toDelete, []);
+    assertEquals(
+      plan.skipped.map((entry) => [entry.run_id, entry.reason]),
+      [
+        ["bad-journal", "journal_unreplayable"],
+        ["locked", "locked"],
+        ["missing-journal", "journal_missing"],
+        ["running", "non_terminal"],
+      ],
+    );
+  });
+});
+
+Deno.test("pruneRuns applies keep zero and dry run", async () => {
+  await withWorkflow(async (workflowDir) => {
+    await writeRun(
+      workflowDir,
+      "delete-me",
+      "2026-01-01T00:00:00.000Z",
+      "completed",
+    );
+    const dry = await pruneRuns(workflowDir, { keep: 0, dryRun: true });
+    assertEquals(dry.deleted.map((entry) => entry.run_id), ["delete-me"]);
+    await Deno.stat(getRunDir("delete-me", workflowDir));
+
+    const applied = await pruneRuns(workflowDir, { keep: 0, dryRun: false });
+    assertEquals(applied.deleted.map((entry) => entry.run_id), ["delete-me"]);
+    await assertRejects(
+      () => Deno.stat(getRunDir("delete-me", workflowDir)),
+      Deno.errors.NotFound,
+    );
+  });
+});
