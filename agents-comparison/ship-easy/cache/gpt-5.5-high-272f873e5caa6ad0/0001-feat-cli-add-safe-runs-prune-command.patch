+
+function formatRunsPruneSummary(result: RunsPruneResult): string {
+  const action = result.dry_run ? "would delete" : "deleted";
+  const lines = [
+    `Runs prune ${result.dry_run ? "dry-run " : ""}summary:`,
+    `  ${action}: ${result.deleted.length}`,
+    `  kept: ${result.kept.length}`,
+    `  skipped: ${result.skipped.length}`,
+  ];
+  if (result.deleted.length > 0) {
+    lines.push(`${result.dry_run ? "Would delete" : "Deleted"}:`);
+    for (const entry of result.deleted) lines.push(`  ${entry.run_id}`);
+  }
+  if (result.skipped.length > 0) {
+    lines.push("Skipped:");
+    for (const entry of result.skipped) {
+      const suffix = entry.detail ? ` (${entry.detail})` : "";
+      lines.push(`  ${entry.run_id}: ${entry.reason}${suffix}`);
+    }
+  }
+  return lines.join("\n");
+}
