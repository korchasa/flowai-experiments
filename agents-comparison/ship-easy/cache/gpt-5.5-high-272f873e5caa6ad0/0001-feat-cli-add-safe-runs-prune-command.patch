+async function runRunsPrune(args: string[]): Promise<never> {
+  try {
+    const parsed = parseRunsPruneArgs(args);
+    const result = await pruneRuns(parsed.workflowDir, {
+      keep: parsed.keep,
+      dryRun: parsed.dryRun,
+    });
+    console.log(formatRunsPruneSummary(result));
+    Deno.exit(0);
+  } catch (err) {
