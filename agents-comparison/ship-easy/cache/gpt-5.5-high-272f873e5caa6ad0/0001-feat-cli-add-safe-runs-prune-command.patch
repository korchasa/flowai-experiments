+/** Parse `runs prune --workflow <dir> --keep <N> [--dry-run]` (FR-E83). */
+export function parseRunsPruneArgs(args: string[]): RunsPruneArgs {
+  let workflow: string | undefined;
+  let keepRaw: string | undefined;
+  let dryRun = false;
+  for (let i = 0; i < args.length; i++) {
+    const arg = args[i];
+    if (arg === "--workflow") {
+      workflow = args[++i];
+      continue;
+    }
+    if (arg.startsWith("--workflow=")) {
+      workflow = arg.slice("--workflow=".length);
+      continue;
+    }
+    if (arg === "--keep") {
+      keepRaw = args[++i];
+      continue;
+    }
+    if (arg.startsWith("--keep=")) {
+      keepRaw = arg.slice("--keep=".length);
+      continue;
+    }
+    if (arg === "--dry-run") {
+      dryRun = true;
+      continue;
+    }
+    if (arg.startsWith("--")) {
+      throw new Error(`runs prune: unknown flag ${arg}.`);
+    }
+    throw new Error(`runs prune: unexpected positional argument: ${arg}.`);
+  }
+  if (!workflow) {
+    throw new Error(
+      "runs prune: missing --workflow <dir>. " +
+        "Usage: flowai-workflow runs prune --workflow <dir> --keep <N> [--dry-run]",
+    );
+  }
+  if (keepRaw === undefined) {
+    throw new Error("runs prune: missing --keep <N>.");
+  }
+  if (!/^(0|[1-9]\d*)$/.test(keepRaw)) {
+    throw new Error(
+      `Invalid --keep value: ${keepRaw}. Expected non-negative integer.`,
+    );
+  }
+  return {
+    workflowDir: normalizeWorkflowDir(workflow),
+    keep: Number(keepRaw),
+    dryRun,
+  };
+}
