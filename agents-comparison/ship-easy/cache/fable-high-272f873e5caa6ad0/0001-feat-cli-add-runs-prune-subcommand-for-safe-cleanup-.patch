+// FR-E83: `runs prune` — safe cleanup of old run directories. Selection
+// logic is exercised on temp-dir fixtures with engine-shaped journals
+// written through the real RunJournalWriter (no hand-rolled journal
+// format), and every deletion/retention assertion checks the actual
+// filesystem state, not just the returned report.
+import { assert, assertEquals, assertRejects } from "@std/assert";
+import { pruneRuns } from "./prune.ts";
+import { getRunDir } from "./state.ts";
+import { RunJournalWriter } from "./run-journal.ts";
+import { defaultLockPath, type LockInfo } from "./lock.ts";
+
+type TerminalKind = "run_completed" | "run_failed" | "run_aborted";
+
+/** Write an engine-shaped journal for a run: `run_started` plus, for
+ * terminal runs, the matching terminal record. */
+async function makeRun(
+  workflowDir: string,
+  runId: string,
+  opts: { startedAt: string; terminal?: TerminalKind | false },
+): Promise<void> {
+  const writer = await RunJournalWriter.open(
+    getRunDir(runId, workflowDir),
+    runId,
+  );
+  await writer.append({
+    kind: "run_started",
+    config_path: "workflow.yaml",
+    started_at: opts.startedAt,
+    ts: opts.startedAt,
+    args: {},
+    env: {},
+  });
+  const terminal = opts.terminal ?? "run_completed";
+  if (terminal !== false) {
+    await writer.append({
+      kind: terminal,
+      status: terminal === "run_completed"
+        ? "completed"
+        : terminal === "run_failed"
+        ? "failed"
+        : "aborted",
+      completed_at: opts.startedAt,
+    });
+  }
+}
+
+async function runDirExists(
+  workflowDir: string,
+  runId: string,
+): Promise<boolean> {
+  try {
+    await Deno.stat(getRunDir(runId, workflowDir));
+    return true;
+  } catch (err) {
+    if (err instanceof Deno.errors.NotFound) return false;
+    throw err;
+  }
+}
+
+Deno.test("FR-E83 pruneRuns — keeps N newest terminal runs, deletes oldest", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "prune-keep-n-" });
+  try {
+    await makeRun(workflowDir, "r1", { startedAt: "2026-06-01T00:00:00.000Z" });
+    await makeRun(workflowDir, "r2", { startedAt: "2026-06-02T00:00:00.000Z" });
+    await makeRun(workflowDir, "r3", { startedAt: "2026-06-03T00:00:00.000Z" });
+
+    const result = await pruneRuns({ workflowDir, keep: 2 });
+
+    assertEquals(result.deleted.map((r) => r.run_id), ["r1"]);
+    assertEquals(
+      result.kept.map((r) => r.run_id).toSorted(),
+      ["r2", "r3"],
+    );
+    assertEquals(result.skipped, []);
+    assertEquals(await runDirExists(workflowDir, "r1"), false);
+    assertEquals(await runDirExists(workflowDir, "r2"), true);
+    assertEquals(await runDirExists(workflowDir, "r3"), true);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns — non-terminal run is never deleted regardless of keep", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "prune-nonterm-" });
+  try {
+    await makeRun(workflowDir, "r-running", {
+      startedAt: "2026-06-01T00:00:00.000Z",
+      terminal: false,
+    });
+    await makeRun(workflowDir, "r-done", {
+      startedAt: "2026-06-02T00:00:00.000Z",
+    });
+
+    const result = await pruneRuns({ workflowDir, keep: 0 });
+
+    assertEquals(result.deleted.map((r) => r.run_id), ["r-done"]);
+    assertEquals(result.skipped.length, 1);
+    assertEquals(result.skipped[0].run_id, "r-running");
+    assert(result.skipped[0].reason.includes("non-terminal"));
+    assertEquals(await runDirExists(workflowDir, "r-running"), true);
+    assertEquals(await runDirExists(workflowDir, "r-done"), false);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns — run referenced by runs/.lock is never deleted", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "prune-locked-" });
+  try {
+    await makeRun(workflowDir, "r-locked", {
+      startedAt: "2026-06-01T00:00:00.000Z",
+    });
+    await makeRun(workflowDir, "r-free", {
+      startedAt: "2026-06-02T00:00:00.000Z",
+    });
+    const lock: LockInfo = {
+      pid: 999999, // dead PID on purpose: lock reference alone protects
+      hostname: "test-host",
+      run_id: "r-locked",
+      started_at: "2026-06-01T00:00:00.000Z",
+    };
+    await Deno.writeTextFile(
+      defaultLockPath(workflowDir),
+      JSON.stringify(lock),
+    );
+
+    const result = await pruneRuns({ workflowDir, keep: 0 });
+
+    assertEquals(result.deleted.map((r) => r.run_id), ["r-free"]);
+    assertEquals(result.skipped.length, 1);
+    assertEquals(result.skipped[0].run_id, "r-locked");
+    assert(result.skipped[0].reason.includes("runs/.lock"));
+    assertEquals(await runDirExists(workflowDir, "r-locked"), true);
+    assertEquals(await runDirExists(workflowDir, "r-free"), false);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns — missing journal counts as non-terminal and is skipped", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "prune-no-journal-" });
+  try {
+    await Deno.mkdir(getRunDir("r-bare", workflowDir), { recursive: true });
+
+    const result = await pruneRuns({ workflowDir, keep: 0 });
+
+    assertEquals(result.deleted, []);
+    assertEquals(result.skipped.length, 1);
+    assertEquals(result.skipped[0].run_id, "r-bare");
+    assert(result.skipped[0].reason.includes("journal"));
+    assertEquals(await runDirExists(workflowDir, "r-bare"), true);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns — unreplayable journal counts as non-terminal and is skipped", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "prune-corrupt-" });
+  try {
+    const runDir = getRunDir("r-corrupt", workflowDir);
+    await Deno.mkdir(runDir, { recursive: true });
+    // Malformed non-tail record → replay throws (run-journal contract).
+    await Deno.writeTextFile(
+      `${runDir}/journal.jsonl`,
+      '{"schema_version":1\n{"schema_version":1}\n',
+    );
+
+    const result = await pruneRuns({ workflowDir, keep: 0 });
+
+    assertEquals(result.deleted, []);
+    assertEquals(result.skipped.length, 1);
+    assertEquals(result.skipped[0].run_id, "r-corrupt");
+    assert(result.skipped[0].reason.includes("replay failed"));
+    assertEquals(await runDirExists(workflowDir, "r-corrupt"), true);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns — keep 0 deletes all terminal unlocked runs", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "prune-keep-0-" });
+  try {
+    await makeRun(workflowDir, "r1", {
+      startedAt: "2026-06-01T00:00:00.000Z",
+      terminal: "run_completed",
+    });
+    await makeRun(workflowDir, "r2", {
+      startedAt: "2026-06-02T00:00:00.000Z",
+      terminal: "run_failed",
+    });
+    await makeRun(workflowDir, "r3", {
+      startedAt: "2026-06-03T00:00:00.000Z",
+      terminal: "run_aborted",
+    });
+
+    const result = await pruneRuns({ workflowDir, keep: 0 });
+
+    assertEquals(
+      result.deleted.map((r) => r.run_id).toSorted(),
+      ["r1", "r2", "r3"],
+    );
+    assertEquals(result.kept, []);
+    assertEquals(result.skipped, []);
+    for (const runId of ["r1", "r2", "r3"]) {
+      assertEquals(await runDirExists(workflowDir, runId), false);
+    }
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns — dry-run reports deletions but deletes nothing", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "prune-dry-run-" });
+  try {
+    await makeRun(workflowDir, "r1", { startedAt: "2026-06-01T00:00:00.000Z" });
+    await makeRun(workflowDir, "r2", { startedAt: "2026-06-02T00:00:00.000Z" });
+
+    const result = await pruneRuns({ workflowDir, keep: 0, dryRun: true });
+
+    assertEquals(result.dry_run, true);
+    assertEquals(
+      result.deleted.map((r) => r.run_id).toSorted(),
+      ["r1", "r2"],
+    );
+    assertEquals(await runDirExists(workflowDir, "r1"), true);
+    assertEquals(await runDirExists(workflowDir, "r2"), true);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns — keep larger than run count deletes nothing", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "prune-keep-big-" });
+  try {
+    await makeRun(workflowDir, "r1", { startedAt: "2026-06-01T00:00:00.000Z" });
+    await makeRun(workflowDir, "r2", { startedAt: "2026-06-02T00:00:00.000Z" });
+
+    const result = await pruneRuns({ workflowDir, keep: 5 });
+
+    assertEquals(result.deleted, []);
+    assertEquals(result.kept.map((r) => r.run_id).toSorted(), ["r1", "r2"]);
+    assertEquals(await runDirExists(workflowDir, "r1"), true);
+    assertEquals(await runDirExists(workflowDir, "r2"), true);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns — rejects negative or non-integer keep", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "prune-bad-keep-" });
+  try {
+    await assertRejects(
+      () => pruneRuns({ workflowDir, keep: -1 }),
+      Error,
+      "Invalid keep",
+    );
+    await assertRejects(
+      () => pruneRuns({ workflowDir, keep: 1.5 }),
+      Error,
+      "Invalid keep",
+    );
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns — missing runs/ directory yields an empty report", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "prune-empty-" });
+  try {
+    const result = await pruneRuns({ workflowDir, keep: 0 });
+    assertEquals(result, {
+      deleted: [],
+      kept: [],
+      skipped: [],
+      dry_run: false,
+    });
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
