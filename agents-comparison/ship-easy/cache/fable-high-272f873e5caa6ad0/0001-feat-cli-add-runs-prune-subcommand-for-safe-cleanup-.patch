index 0000000..4e27e2d
--- /dev/null
+++ b/src/state/prune.ts
@@ -0,0 +1,147 @@
+/**
+ * @module
+ * `runs prune` selection and execution (FR-E83): delete the oldest run
+ * directories under `<workflowDir>/runs/` so that at most `keep` of the
+ * deletable runs remain, under strict safety rules:
+ *
+ * - a run whose replayed journal status is not terminal is untouchable;
+ * - the run referenced by an existing `runs/.lock` file is untouchable
+ *   (the reference alone protects it — PID liveness is not consulted);
+ * - a run whose `journal.jsonl` is missing or cannot be replayed has
+ *   unknown state and counts as NOT terminal (when in doubt, keep).
+ *
+ * Protected runs are reported as skipped (with a reason) and do NOT
+ * consume the `keep` budget — a protection never widens the deletion
+ * set. The journal replayer (`run-journal.ts`) is the only state
+ * source; this module is workflow-agnostic and knows nothing about
+ * node names or workflow structure.
+ */
+
+import type { RunState } from "../types.ts";
+import { getRunDir, getRunsRoot } from "./state.ts";
+import { isTerminalRunStatus, loadStateFromJournal } from "./run-journal.ts";
+import { defaultLockPath, readLockInfo } from "./lock.ts";
+
+/** Identity and replayed facts of one run considered by the prune. */
+export interface PruneRunInfo {
+  /** Run directory name under `<workflowDir>/runs/`. */
+  run_id: string;
+  /** Replayed `RunState.started_at`; absent when the journal did not yield one. */
+  started_at?: string;
+  /** Replayed run status; absent when the journal could not be replayed. */
+  status?: RunState["status"];
+}
+
+/** A run excluded from deletion, with the safety reason. */
+export interface PruneSkip extends PruneRunInfo {
+  /** Human-readable reason why the run is untouchable. */
+  reason: string;
+}
+
+/** Outcome of one {@link pruneRuns} invocation. */
+export interface PruneResult {
+  /** Runs deleted (or, under dry-run, that WOULD be deleted), oldest last. */
+  deleted: PruneRunInfo[];
+  /** Deletable runs retained by the `keep` budget, newest first. */
+  kept: PruneRunInfo[];
+  /** Protected runs, each with its skip reason. */
+  skipped: PruneSkip[];
+  /** True when no directory was removed (`dryRun`). */
+  dry_run: boolean;
+}
+
+/**
+ * Delete the oldest deletable run directories under
+ * `<workflowDir>/runs/`, keeping the `keep` newest (by replayed run
+ * start time). See the module doc for the safety rules. With `dryRun`
+ * the selection is identical but nothing is removed.
+ */
+export async function pruneRuns(opts: {
+  workflowDir: string;
+  keep: number;
+  dryRun?: boolean;
+}): Promise<PruneResult> {
+  const { workflowDir, keep } = opts;
+  const dryRun = opts.dryRun ?? false;
+  if (!Number.isInteger(keep) || keep < 0) {
+    throw new Error(
+      `Invalid keep value: ${keep}. Expected non-negative integer.`,
+    );
+  }
+
+  // The lock reference alone protects its run — even a stale lock from a
+  // dead PID. A corrupt/absent lock references no run; every run is then
+  // still independently protected by the journal-status rules below.
+  let lockedRunId: string | undefined;
+  try {
+    lockedRunId = (await readLockInfo(defaultLockPath(workflowDir))).run_id;
+  } catch (err) {
+    if (
+      !(err instanceof Deno.errors.NotFound) && !(err instanceof SyntaxError)
+    ) {
+      throw err;
+    }
+  }
+
+  const runIds: string[] = [];
+  try {
+    for await (const entry of Deno.readDir(getRunsRoot(workflowDir))) {
+      if (entry.isDirectory) runIds.push(entry.name);
+    }
+  } catch (err) {
+    if (err instanceof Deno.errors.NotFound) {
+      return { deleted: [], kept: [], skipped: [], dry_run: dryRun };
+    }
+    throw err;
+  }
+  runIds.sort();
+
+  const skipped: PruneSkip[] = [];
+  const deletable: PruneRunInfo[] = [];
+  for (const runId of runIds) {
+    if (runId === lockedRunId) {
+      skipped.push({ run_id: runId, reason: "referenced by runs/.lock" });
+      continue;
+    }
+    let state: RunState;
+    try {
+      state = await loadStateFromJournal(getRunDir(runId, workflowDir));
+    } catch (err) {
+      const reason = err instanceof Deno.errors.NotFound
+        ? "journal.jsonl missing — state unknown, kept"
+        : `journal replay failed (${
+          err instanceof Error ? err.message : String(err)
+        }) — state unknown, kept`;
+      skipped.push({ run_id: runId, reason });
+      continue;
+    }
+    const info: PruneRunInfo = {
+      run_id: runId,
+      started_at: state.started_at,
+      status: state.status,
+    };
+    if (!isTerminalRunStatus(state.status)) {
+      skipped.push({ ...info, reason: `non-terminal status: ${state.status}` });
+      continue;
+    }
+    deletable.push(info);
+  }
+
+  // Newest first. A missing started_at sorts oldest — the status is
+  // still proven terminal, so the rule only fixes ordering, not safety.
+  deletable.sort((a, b) =>
+    (b.started_at ?? "").localeCompare(a.started_at ?? "") ||
+    b.run_id.localeCompare(a.run_id)
+  );
+  const kept = deletable.slice(0, keep);
+  const deleted = deletable.slice(keep);
+
+  if (!dryRun) {
+    for (const run of deleted) {
+      await Deno.remove(getRunDir(run.run_id, workflowDir), {
+        recursive: true,
+      });
+    }
+  }
+  return { deleted, kept, skipped, dry_run: dryRun };
+}
