+/**
+ * Run the `runs prune` subcommand (FR-E83): delete the oldest run
+ * directories under `<workflowDir>/runs/` keeping the `--keep <N>`
+ * newest deletable runs. Safety rules (non-terminal, lock-referenced,
+ * and unreplayable runs are untouchable) live in `state/prune.ts`;
+ * this handler only resolves the workflow folder and prints the
+ * per-run report + summary.
+ */
+async function runRunsPrune(args: string[]): Promise<never> {
+  try {
+    const parsed = parseRunsPruneArgs(args);
+    let workflowDir = parsed.workflowDir;
+    if (!workflowDir) {
+      const resolved = await resolveActiveWorkflow({
+        env: Deno.env.toObject(),
+      });
+      if (resolved === null) {
