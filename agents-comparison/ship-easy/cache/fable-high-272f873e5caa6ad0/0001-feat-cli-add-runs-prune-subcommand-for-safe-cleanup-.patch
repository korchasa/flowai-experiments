+      console.log(
+        `kept  ${run.run_id}  (started ${
+          run.started_at ?? "unknown"
+        }, ${run.status})`,
+      );
+    }
+    for (const run of result.skipped) {
+      console.log(`skipped  ${run.run_id} — ${run.reason}`);
+    }
+    console.log(
+      `Pruned: ${result.deleted.length} ${deletedLabel}, ` +
+        `${result.kept.length} kept, ${result.skipped.length} skipped.`,
+    );
+    Deno.exit(0);
+  } catch (err) {
+    console.error(`Error: ${(err as Error).message}`);
+    Deno.exit(1);
+  }
+}
