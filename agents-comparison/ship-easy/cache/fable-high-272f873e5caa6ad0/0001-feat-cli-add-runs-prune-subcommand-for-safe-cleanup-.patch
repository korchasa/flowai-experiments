+/**
+ * Parse `runs prune [--workflow <dir>] --keep <N> [--dry-run]` (FR-E83).
+ * `--keep` is mandatory and must be a non-negative integer; `--workflow`
+ * and `--keep` accept both `--flag value` and `--flag=value` forms.
+ */
+export function parseRunsPruneArgs(args: string[]): RunsPruneArgs {
+  let workflow: string | undefined;
+  let keepRaw: string | undefined;
+  let keepSet = false;
+  let dryRun = false;
+  for (let i = 0; i < args.length; i++) {
+    const a = args[i];
+    if (a === "--workflow") {
+      workflow = args[++i];
+      continue;
+    }
+    if (a.startsWith("--workflow=")) {
+      workflow = a.slice("--workflow=".length);
+      continue;
+    }
+    if (a === "--keep") {
+      keepRaw = args[++i];
+      keepSet = true;
+      continue;
+    }
+    if (a.startsWith("--keep=")) {
+      keepRaw = a.slice("--keep=".length);
+      keepSet = true;
+      continue;
+    }
+    if (a === "--dry-run") {
+      dryRun = true;
+      continue;
+    }
+    throw new Error(
+      `runs prune: unexpected argument: ${a}. ` +
+        "Usage: flowai-workflow runs prune [--workflow <dir>] --keep <N> [--dry-run]",
+    );
+  }
+  if (!keepSet) {
+    throw new Error(
+      "runs prune: missing --keep <N> (non-negative integer of newest runs to retain).",
+    );
+  }
+  const keep = Number(keepRaw);
+  if (
+    keepRaw === undefined || keepRaw.trim() === "" ||
+    !Number.isInteger(keep) || keep < 0
+  ) {
+    throw new Error(
+      `Invalid --keep value: ${keepRaw}. Expected non-negative integer.`,
+    );
+  }
+  return {
+    workflowDir: workflow ? normalizeWorkflowDir(workflow) : undefined,
+    keep,
+    dryRun,
+  };
+}
