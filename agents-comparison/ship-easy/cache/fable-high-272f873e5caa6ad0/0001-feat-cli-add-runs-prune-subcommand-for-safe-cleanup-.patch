+          "Could not resolve active workflow. Pass it via " +
+            "`--workflow <dir>`, set FLOWAI_WORKFLOW, or place a " +
+            "workflow under `<cwd>/.flowai-workflow/`.",
+        );
+      }
+      workflowDir = normalizeWorkflowDir(resolved);
+    }
+    const result = await pruneRuns({
+      workflowDir,
+      keep: parsed.keep,
+      dryRun: parsed.dryRun,
+    });
+    const deletedLabel = result.dry_run ? "would delete" : "deleted";
+    for (const run of result.deleted) {
+      console.log(
+        `${deletedLabel}  ${run.run_id}  (started ${
+          run.started_at ?? "unknown"
