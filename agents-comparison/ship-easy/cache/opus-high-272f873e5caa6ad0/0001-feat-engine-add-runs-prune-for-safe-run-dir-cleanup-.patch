index 0000000..14de086
--- /dev/null
+++ b/src/state/prune.ts
@@ -0,0 +1,230 @@
+/**
+ * @module
+ * Safe `runs prune` cleanup (FR-E83). Deletes the OLDEST run directories under
+ * `<workflowDir>/runs/` so that at most `N` most-recent SAFE-to-delete runs
+ * remain. Run status + start time come ONLY from replaying each run's durable
+ * `journal.jsonl` ({@link replayRunJournal}). All run-folder knowledge (run-dir
+ * path, lock location/format) reuses the existing `state/` helpers — this
+ * module adds no parallel path or replay logic.
+ *
+ * Safety rules (each overrides `--keep`):
+ *  - A run whose replayed status is not terminal (`running`) is never deleted.
+ *  - The run named by `runs/.lock` is never deleted.
+ *  - A run whose journal is missing or unreplayable has unknown state by
+ *    definition → treated as NOT terminal (kept), reported as skipped.
+ *
+ * The `--keep N` window is computed over the ELIGIBLE set (terminal, unlocked,
+ * replayable): the N newest eligible runs are kept, older eligible runs are
+ * deleted. Protected runs (skipped) are retained additionally and do not
+ * consume keep slots — "when in doubt, keep".
+ */
+
+import { dirname } from "@std/path";
+import { replayRunJournal } from "./run-journal.ts";
+import { defaultLockPath, readLockInfo } from "./lock.ts";
+import { getRunDir } from "./state.ts";
+import type { RunState } from "../types.ts";
+
+/** A run selected for keeping or deletion (terminal, unlocked, replayable). */
+export interface EligibleRun {
+  /** Run id (directory name under `runs/`). */
+  runId: string;
+  /** Absolute-or-relative run directory path (`getRunDir`). */
+  runDir: string;
+  /** Replayed run start timestamp (ISO 8601), used as the recency key. */
+  startedAt: string;
+}
+
+/** A run that was NOT eligible for deletion, with the reason it was kept. */
+export interface SkippedRun {
+  /** Run id (directory name under `runs/`). */
+  runId: string;
+  /** Run directory path. */
+  runDir: string;
+  /** Human-readable reason the run was skipped (kept). */
+  reason: string;
+}
+
+/** Outcome of {@link selectRunsForPrune}: nothing is deleted yet. */
+export interface PrunePlan {
+  /** Eligible runs marked for deletion (older than the keep window). */
+  toDelete: EligibleRun[];
+  /** Eligible runs retained by the `--keep` window (the N newest). */
+  toKeep: EligibleRun[];
+  /** Protected runs skipped by a safety rule, each with its reason. */
+  skipped: SkippedRun[];
+}
+
+/** Summary of an {@link executePrune} invocation. */
+export interface PruneSummary {
+  /** Whether this was a dry run (nothing removed). */
+  dryRun: boolean;
+  /** The selection plan that drove the run. */
+  plan: PrunePlan;
+  /** Run ids actually removed from disk (empty on a dry run). */
+  removed: string[];
+}
+
+const TERMINAL_STATUSES: ReadonlySet<RunState["status"]> = new Set([
+  "completed",
+  "failed",
+  "aborted",
+]);
+
+/**
+ * Parse and validate a `--keep <N>` value. Accepts a non-negative integer
+ * string only; rejects missing, negative, fractional, or non-numeric input
+ * with a clear error (mirrors the `--budget` / `--cycles` validators in
+ * `cli.ts`).
+ */
+export function parseKeep(raw: string | undefined): number {
+  if (raw === undefined || raw.trim() === "") {
+    throw new Error(
+      "Missing --keep <N>. Expected a non-negative integer (runs to retain).",
+    );
+  }
+  // Reject anything that is not a run of ASCII digits (excludes "-1", "1.5",
+  // "3x", "1e2", whitespace-padded values, etc.).
+  if (!/^\d+$/.test(raw.trim())) {
+    throw new Error(
+      `Invalid --keep value: ${raw}. Expected a non-negative integer.`,
+    );
+  }
+  return Number(raw.trim());
+}
+
+/**
+ * Classify every run directory under `<workflowDir>/runs/` and select which
+ * eligible runs to delete to retain at most `keep` of the newest. Reads the
+ * filesystem and replays journals; deletes nothing.
+ */
+export async function selectRunsForPrune(
+  workflowDir: string,
+  keep: number,
+): Promise<PrunePlan> {
+  // Reuse the lock helper for the `runs/` root — no duplicated `/runs` literal.
+  const runsDir = dirname(defaultLockPath(workflowDir));
+
+  const lockedRunId = await readLockedRunId(workflowDir);
+
+  const eligible: EligibleRun[] = [];
+  const skipped: SkippedRun[] = [];
+
+  let entries: Deno.DirEntry[];
+  try {
+    entries = [];
+    for await (const entry of Deno.readDir(runsDir)) entries.push(entry);
+  } catch (err) {
+    if (err instanceof Deno.errors.NotFound) {
+      // No runs/ directory yet → nothing to prune.
+      return { toDelete: [], toKeep: [], skipped: [] };
+    }
+    throw err;
+  }
+
+  for (const entry of entries) {
+    if (!entry.isDirectory) continue; // skip `.lock` and any stray files
+    const runId = entry.name;
+    const runDir = getRunDir(runId, workflowDir);
+
+    if (lockedRunId !== undefined && runId === lockedRunId) {
+      skipped.push({ runId, runDir, reason: "referenced by runs/.lock" });
+      continue;
+    }
+
+    let state: RunState;
+    try {
+      state = (await replayRunJournal(runDir)).state;
+    } catch {
+      // Missing or unreplayable journal → unknown state, keep (when in doubt).
+      skipped.push({
+        runId,
+        runDir,
+        reason: "journal missing or unreplayable — unknown state (kept)",
+      });
+      continue;
+    }
+
+    if (!TERMINAL_STATUSES.has(state.status)) {
+      skipped.push({
+        runId,
+        runDir,
+        reason: `status '${state.status}' not terminal (kept)`,
+      });
+      continue;
+    }
+
+    eligible.push({ runId, runDir, startedAt: state.started_at });
+  }
+
+  // Newest first; deterministic tie-break on run id so equal timestamps order
+  // stably across filesystems.
+  eligible.sort((a, b) => {
+    if (a.startedAt !== b.startedAt) return a.startedAt < b.startedAt ? 1 : -1;
+    return a.runId < b.runId ? 1 : -1;
+  });
+
+  return {
+    toKeep: eligible.slice(0, keep),
+    toDelete: eligible.slice(keep),
+    skipped,
+  };
+}
+
+/**
+ * Build the prune plan and, unless `dryRun`, recursively delete each run
+ * directory marked for deletion. Returns a {@link PruneSummary}.
+ */
+export async function executePrune(
+  workflowDir: string,
+  keep: number,
+  dryRun: boolean,
+): Promise<PruneSummary> {
+  const plan = await selectRunsForPrune(workflowDir, keep);
+  const removed: string[] = [];
+  if (!dryRun) {
+    for (const run of plan.toDelete) {
+      await Deno.remove(run.runDir, { recursive: true });
+      removed.push(run.runId);
+    }
+  }
+  return { dryRun, plan, removed };
+}
+
+/** Render a human-readable summary of a prune run for CLI output. */
+export function formatPruneSummary(summary: PruneSummary): string {
+  const { plan, dryRun } = summary;
+  const lines: string[] = [];
+  lines.push(
+    dryRun
+      ? "Dry run — nothing deleted. The following WOULD be deleted:"
+      : "Prune complete.",
+  );
+  lines.push(
+    `Deleted: ${dryRun ? plan.toDelete.length : summary.removed.length}  ` +
+      `Kept: ${plan.toKeep.length}  Skipped: ${plan.skipped.length}`,
+  );
+  if (plan.toDelete.length > 0) {
+    lines.push(dryRun ? "Would delete:" : "Deleted:");
+    for (const run of plan.toDelete) lines.push(`  - ${run.runId}`);
+  }
+  if (plan.skipped.length > 0) {
+    lines.push("Skipped:");
+    for (const run of plan.skipped) {
+      lines.push(`  - ${run.runId}: ${run.reason}`);
+    }
+  }
+  return lines.join("\n");
+}
+
+/** Read the `run_id` held by `runs/.lock`, or undefined when absent/corrupt. */
+async function readLockedRunId(
+  workflowDir: string,
+): Promise<string | undefined> {
+  try {
+    return (await readLockInfo(defaultLockPath(workflowDir))).run_id;
+  } catch {
+    // No lock file, or unreadable/corrupt lock → no protected run.
+    return undefined;
+  }
+}
