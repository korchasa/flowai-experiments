+++ b/src/state/prune_test.ts
@@ -0,0 +1,237 @@
+// FR-E83: safe `runs prune` cleanup — selection policy + execution tests on
+// temp-dir fixtures with engine-shaped journals (built via RunJournalWriter so
+// replay uses the real journal contract).
+import { assertEquals, assertThrows } from "@std/assert";
+import {
+  executePrune,
+  formatPruneSummary,
+  parseKeep,
+  selectRunsForPrune,
+} from "./prune.ts";
+import { RunJournalWriter } from "./run-journal.ts";
+import { defaultLockPath } from "./lock.ts";
+import { getRunDir } from "./state.ts";
+import type { LockInfo } from "./lock.ts";
+
+/** Build a run directory with an engine-shaped journal. Omitting `terminal`
+ * leaves the run in the non-terminal `running` state. */
+async function writeRun(
+  workflowDir: string,
+  runId: string,
+  opts: { startedAt: string; terminal?: "completed" | "failed" | "aborted" },
+): Promise<void> {
+  const runDir = getRunDir(runId, workflowDir);
+  const writer = await RunJournalWriter.open(runDir, runId);
+  await writer.append({
+    kind: "run_started",
+    config_path: `${workflowDir}/workflow.yaml`,
+    started_at: opts.startedAt,
+    args: {},
+    env: {},
+  });
+  if (opts.terminal) {
+    await writer.append({
+      kind: `run_${opts.terminal}` as
+        | "run_completed"
+        | "run_failed"
+        | "run_aborted",
+      status: opts.terminal,
+      completed_at: opts.startedAt,
+    });
+  }
+}
+
+/** Create a run directory with no/garbled journal (unknown state). */
+async function writeBrokenRun(
+  workflowDir: string,
+  runId: string,
+  mode: "missing" | "garbled",
+): Promise<void> {
+  const runDir = getRunDir(runId, workflowDir);
+  await Deno.mkdir(runDir, { recursive: true });
+  if (mode === "garbled") {
+    // First line is unparseable and NOT a partial tail (file ends with "\n"),
+    // so replayRunJournal throws "Malformed journal record".
+    await Deno.writeTextFile(`${runDir}/journal.jsonl`, "not-json\n");
+  }
+}
+
+async function writeLock(workflowDir: string, runId: string): Promise<void> {
+  const info: LockInfo = {
+    pid: 999999,
+    hostname: "test-host",
+    run_id: runId,
+    started_at: "2026-06-11T00:00:00.000Z",
+  };
+  const lockPath = defaultLockPath(workflowDir);
+  await Deno.mkdir(lockPath.slice(0, lockPath.lastIndexOf("/")), {
+    recursive: true,
+  });
+  await Deno.writeTextFile(lockPath, JSON.stringify(info));
+}
+
+Deno.test("selectRunsForPrune — keeps N newest eligible, deletes older", async () => {
+  const wf = await Deno.makeTempDir();
+  await writeRun(wf, "r1", {
+    startedAt: "2026-06-01T00:00:00.000Z",
+    terminal: "completed",
+  });
+  await writeRun(wf, "r2", {
+    startedAt: "2026-06-02T00:00:00.000Z",
+    terminal: "failed",
+  });
+  await writeRun(wf, "r3", {
+    startedAt: "2026-06-03T00:00:00.000Z",
+    terminal: "aborted",
+  });
+  await writeRun(wf, "r4", {
+    startedAt: "2026-06-04T00:00:00.000Z",
+    terminal: "completed",
+  });
+
+  const plan = await selectRunsForPrune(wf, 2);
