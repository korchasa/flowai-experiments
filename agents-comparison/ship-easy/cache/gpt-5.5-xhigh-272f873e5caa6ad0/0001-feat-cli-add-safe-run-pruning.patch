+/** Run `runs prune` (FR-E83). */
+async function runRuns(args: string[]): Promise<never> {
+  try {
+    const parsed = parseRunsPruneArgs(args);
+    const summary = await pruneRuns({
+      workflowDir: parsed.workflowDir,
+      keep: parsed.keep,
+      dryRun: parsed.dryRun,
+    });
+    printPruneSummary(summary);
+    Deno.exit(0);
