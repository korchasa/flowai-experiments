+/** Parse `runs prune --workflow <dir> --keep <N> [--dry-run]` (FR-E83). */
+export function parseRunsPruneArgs(args: string[]): RunsPruneArgs {
+  const [command, ...rest] = args;
+  if (command !== "prune") {
+    throw new Error(
+      "runs: expected subcommand `prune`. Usage: " +
+        "flowai-workflow runs prune --workflow <dir> --keep <N> [--dry-run]",
+    );
+  }
+
+  let workflowDir: string | undefined;
+  let keepRaw: string | undefined;
+  let dryRun = false;
+
+  for (let i = 0; i < rest.length; i++) {
+    const arg = rest[i];
+    if (arg === "--workflow") {
+      workflowDir = requireFlagValue(rest, ++i, "--workflow");
+      continue;
+    }
+    if (arg.startsWith("--workflow=")) {
+      workflowDir = arg.slice("--workflow=".length);
+      continue;
+    }
+    if (arg === "--keep") {
+      keepRaw = requireFlagValue(rest, ++i, "--keep");
+      continue;
+    }
+    if (arg.startsWith("--keep=")) {
+      keepRaw = arg.slice("--keep=".length);
+      continue;
+    }
+    if (arg === "--dry-run") {
+      dryRun = true;
+      continue;
+    }
+    throw new Error(`runs prune: unknown argument: ${arg}`);
+  }
+
+  if (!workflowDir) {
+    throw new Error("runs prune: missing --workflow <dir>.");
+  }
+  if (keepRaw === undefined) {
+    throw new Error("runs prune: missing --keep <N>.");
+  }
+
+  return {
+    workflowDir: normalizeWorkflowDir(workflowDir),
+    keep: parseKeepCount(keepRaw),
+    dryRun,
+  };
+}
+
+function requireFlagValue(
+  args: string[],
+  index: number,
+  flag: string,
+): string {
+  const value = args[index];
+  if (value === undefined || value.startsWith("--")) {
+    throw new Error(`runs prune: ${flag} requires a value.`);
+  }
+  return value;
+}
