+    console.error(`Error: ${(err as Error).message}`);
+    Deno.exit(1);
+  }
+}
+
+function printPruneSummary(summary: PruneRunsSummary): void {
+  const deleteLabel = summary.dryRun ? "Would delete" : "Deleted";
+  console.log(`${deleteLabel}: ${summary.deleted.length}`);
+  for (const run of summary.deleted) {
+    console.log(`  ${run.runId} (${run.status}, started ${run.startedAt})`);
+  }
+  console.log(`Kept: ${summary.kept.length}`);
+  console.log(`Skipped: ${summary.skipped.length}`);
+  for (const run of summary.skipped) {
+    console.log(`  ${run.runId}: ${run.reason}`);
+  }
