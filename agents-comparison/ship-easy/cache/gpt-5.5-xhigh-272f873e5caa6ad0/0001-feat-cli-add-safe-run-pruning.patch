--- /dev/null
+++ b/src/state/run-prune.ts
@@ -0,0 +1,193 @@
+/**
+ * @module
+ * Local run-directory pruning (FR-E83).
+ *
+ * Safety is journal-first: a run is deletable only when replaying its
+ * `journal.jsonl` proves a terminal run status and the workflow lock does not
+ * reference it.
+ */
+
+import { dirname } from "@std/path";
+import { defaultLockPath, readLockInfo } from "./lock.ts";
+import { replayRunJournal } from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+import type { RunState } from "../types.ts";
+
+/** Terminal workflow statuses that are safe to prune when unlocked. */
+const TERMINAL_STATUSES = new Set<RunState["status"]>([
+  "completed",
+  "failed",
+  "aborted",
+]);
+
+/** One run preserved because it is within the requested keep window. */
+export interface KeptPruneRun {
+  /** Run id, equal to the run directory name. */
+  runId: string;
+  /** Absolute or caller-relative run directory path. */
+  path: string;
+  /** Replayed workflow start timestamp. */
+  startedAt: string;
+  /** Replayed terminal status. */
+  status: RunState["status"];
+}
+
+/** One run selected for deletion, or dry-run deletion. */
+export interface DeletedPruneRun extends KeptPruneRun {
+  /** True when the command was a dry run and no filesystem deletion occurred. */
+  dryRun: boolean;
+}
+
+/** One run kept for a hard safety reason. */
+export interface SkippedPruneRun {
+  /** Run id, equal to the run directory name. */
+  runId: string;
+  /** Absolute or caller-relative run directory path. */
+  path: string;
+  /** Human-readable safety reason. */
+  reason: string;
+}
+
+/** Summary returned by {@link pruneRuns}. */
+export interface PruneRunsSummary {
+  /** Runs selected by the prune policy. In dry-run mode these still exist. */
+  deleted: DeletedPruneRun[];
+  /** Terminal unlocked runs retained because they are among the newest N. */
+  kept: KeptPruneRun[];
+  /** Runs retained because deleting them would be unsafe. */
+  skipped: SkippedPruneRun[];
+  /** Echo of the command mode. */
+  dryRun: boolean;
+}
+
+/** Options for {@link pruneRuns}. */
+export interface PruneRunsOptions {
+  /** Workflow folder containing `workflow.yaml` and `runs/`. */
+  workflowDir: string;
+  /** Number of newest terminal unlocked runs to retain. */
+  keep: number;
+  /** Select deletions and report them without deleting directories. */
+  dryRun?: boolean;
+}
+
+/** Parse the `--keep` value for `runs prune`. */
+export function parseKeepCount(raw: string): number {
+  if (!/^(0|[1-9]\d*)$/.test(raw)) {
+    throw new Error(
+      `Invalid --keep value: ${raw}. Expected non-negative integer.`,
+    );
+  }
+  const parsed = Number(raw);
+  if (!Number.isSafeInteger(parsed)) {
+    throw new Error(
+      `Invalid --keep value: ${raw}. Expected non-negative integer.`,
+    );
+  }
+  return parsed;
+}
+
+/** Prune old terminal, unlocked run directories under a workflow folder. */
+export async function pruneRuns(
+  options: PruneRunsOptions,
+): Promise<PruneRunsSummary> {
+  const dryRun = options.dryRun ?? false;
+  const lockedRunId = await readLockedRunId(options.workflowDir);
+  const runsDir = dirname(defaultLockPath(options.workflowDir));
+  const runIds = await listRunIds(runsDir);
+
+  const candidates: KeptPruneRun[] = [];
+  const skipped: SkippedPruneRun[] = [];
+
+  for (const runId of runIds) {
+    const path = getRunDir(runId, options.workflowDir);
+    if (runId === lockedRunId) {
+      skipped.push({ runId, path, reason: "referenced by runs/.lock" });
+      continue;
+    }
+    try {
+      const { state } = await replayRunJournal(path);
+      if (!TERMINAL_STATUSES.has(state.status)) {
+        skipped.push({
+          runId,
+          path,
+          reason: `not terminal: ${state.status}`,
+        });
+        continue;
+      }
+      candidates.push({
+        runId,
+        path,
+        startedAt: state.started_at,
+        status: state.status,
+      });
+    } catch (error) {
+      skipped.push({
+        runId,
+        path,
+        reason: replayErrorReason(error),
+      });
+    }
+  }
+
+  candidates.sort(compareNewestFirst);
+  const kept = candidates.slice(0, options.keep);
+  const selected = candidates.slice(options.keep).sort(compareOldestFirst);
+  const deleted: DeletedPruneRun[] = selected.map((run) => ({
+    ...run,
+    dryRun,
+  }));
+
+  if (!dryRun) {
+    for (const run of deleted) {
+      await Deno.remove(run.path, { recursive: true });
+    }
+  }
+
+  return { deleted, kept, skipped, dryRun };
+}
+
+async function readLockedRunId(
+  workflowDir: string,
+): Promise<string | undefined> {
+  try {
+    const info = await readLockInfo(defaultLockPath(workflowDir));
+    return info.run_id;
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return undefined;
+    throw new Error(
+      `Cannot read run lock at ${defaultLockPath(workflowDir)}: ${
+        error instanceof Error ? error.message : String(error)
+      }`,
+    );
+  }
+}
+
+async function listRunIds(runsDir: string): Promise<string[]> {
+  const runIds: string[] = [];
+  try {
+    for await (const entry of Deno.readDir(runsDir)) {
+      if (entry.isDirectory) runIds.push(entry.name);
+    }
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return [];
+    throw error;
+  }
+  return runIds.sort();
+}
+
+function replayErrorReason(error: unknown): string {
+  if (error instanceof Deno.errors.NotFound) return "journal missing";
+  return "journal cannot be replayed";
+}
+
+function compareNewestFirst(a: KeptPruneRun, b: KeptPruneRun): number {
+  const byStartedAt = b.startedAt.localeCompare(a.startedAt);
+  if (byStartedAt !== 0) return byStartedAt;
+  return b.runId.localeCompare(a.runId);
+}
+
+function compareOldestFirst(a: KeptPruneRun, b: KeptPruneRun): number {
+  const byStartedAt = a.startedAt.localeCompare(b.startedAt);
+  if (byStartedAt !== 0) return byStartedAt;
+  return a.runId.localeCompare(b.runId);
+}
