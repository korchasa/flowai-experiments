+          raw,
+        ]),
+      Error,
+      "non-negative integer",
+    );
+  }
+});
+
+Deno.test("FR-E83 parseRunsPruneArgs requires workflow and keep", () => {
+  assertThrows(
+    () => parseRunsPruneArgs(["prune", "--keep", "1"]),
+    Error,
+    "--workflow",
+  );
+  assertThrows(
+    () => parseRunsPruneArgs(["prune", "--workflow", ".flowai-workflow/x"]),
+    Error,
+    "--keep",
+  );
+});
+
+Deno.test("FR-E83 CLI help mentions runs prune", () => {
+  const usage = getUsageText();
+  assertEquals(usage.includes("flowai-workflow runs prune"), true);
+  assertEquals(usage.includes("--keep <N>"), true);
+});
