new file mode 100644
index 0000000..d1c43ed
--- /dev/null
+++ b/src/state/run-prune_test.ts
@@ -0,0 +1,190 @@
+import { assertEquals } from "@std/assert";
+import { defaultLockPath } from "./lock.ts";
+import { pruneRuns } from "./run-prune.ts";
+import { getJournalPath, RunJournalWriter } from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+
+async function writeRun(
+  workflowDir: string,
+  runId: string,
+  status: "running" | "completed" | "failed" | "aborted",
+  startedAt: string,
+): Promise<void> {
+  const runDir = getRunDir(runId, workflowDir);
+  const writer = await RunJournalWriter.open(runDir, runId);
+  await writer.append({
+    kind: "run_started",
+    config_path: "workflow.yaml",
+    started_at: startedAt,
+    ts: startedAt,
+    args: {},
+    env: {},
+  });
+  if (status === "completed") {
+    await writer.append({
+      kind: "run_completed",
+      status,
+      completed_at: `${startedAt}.done`,
+    });
+  } else if (status === "failed") {
+    await writer.append({
+      kind: "run_failed",
+      status,
+      completed_at: `${startedAt}.done`,
+    });
+  } else if (status === "aborted") {
+    await writer.append({
+      kind: "run_aborted",
+      status,
+      completed_at: `${startedAt}.done`,
+    });
+  }
+}
+
+async function exists(path: string): Promise<boolean> {
+  try {
+    await Deno.stat(path);
+    return true;
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return false;
+    throw error;
+  }
+}
+
+Deno.test("FR-E83 prune selection keeps newest terminal and skips unsafe runs", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "runs-prune-" });
+  try {
+    await writeRun(
+      workflowDir,
+      "terminal-old",
+      "completed",
+      "2026-01-01T00:00:00.000Z",
+    );
+    await writeRun(
+      workflowDir,
+      "terminal-mid",
+      "completed",
+      "2026-01-02T00:00:00.000Z",
+    );
+    await writeRun(
+      workflowDir,
+      "terminal-new",
+      "failed",
+      "2026-01-03T00:00:00.000Z",
+    );
+    await writeRun(
+      workflowDir,
+      "running-old",
+      "running",
+      "2026-01-01T00:00:00.000Z",
+    );
+    await writeRun(
+      workflowDir,
+      "locked-old",
+      "aborted",
+      "2026-01-01T00:00:00.000Z",
+    );
+
+    await Deno.writeTextFile(
+      defaultLockPath(workflowDir),
+      JSON.stringify({
+        pid: Deno.pid,
+        hostname: "test",
+        run_id: "locked-old",
+        started_at: "2026-01-01T00:00:00.000Z",
+      }) + "\n",
+    );
+
+    await Deno.mkdir(getRunDir("missing-journal", workflowDir), {
+      recursive: true,
+    });
+    const malformed = getRunDir("bad-journal", workflowDir);
+    await Deno.mkdir(malformed, { recursive: true });
+    await Deno.writeTextFile(
+      getJournalPath(malformed),
+      '{"schema_version":1\n{"schema_version":1}\n',
+    );
+
+    const summary = await pruneRuns({ workflowDir, keep: 2, dryRun: false });
+
+    assertEquals(summary.deleted.map((run) => run.runId), ["terminal-old"]);
+    assertEquals(summary.kept.map((run) => run.runId), [
+      "terminal-new",
+      "terminal-mid",
+    ]);
+    assertEquals(
+      Object.fromEntries(
+        summary.skipped.map((run) => [run.runId, run.reason]),
+      ),
+      {
+        "bad-journal": "journal cannot be replayed",
+        "locked-old": "referenced by runs/.lock",
+        "missing-journal": "journal missing",
+        "running-old": "not terminal: running",
+      },
+    );
+    assertEquals(await exists(getRunDir("terminal-old", workflowDir)), false);
+    assertEquals(await exists(getRunDir("running-old", workflowDir)), true);
+    assertEquals(await exists(getRunDir("locked-old", workflowDir)), true);
+    assertEquals(await exists(getRunDir("missing-journal", workflowDir)), true);
+    assertEquals(await exists(getRunDir("bad-journal", workflowDir)), true);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 keep zero deletes terminal unlocked runs and dry run deletes nothing", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "runs-prune-zero-" });
+  try {
+    await writeRun(
+      workflowDir,
+      "terminal-a",
+      "completed",
+      "2026-01-01T00:00:00.000Z",
+    );
+    await writeRun(
+      workflowDir,
+      "terminal-b",
+      "failed",
+      "2026-01-02T00:00:00.000Z",
+    );
+    await writeRun(
+      workflowDir,
+      "running",
+      "running",
+      "2026-01-03T00:00:00.000Z",
+    );
+
+    const dry = await pruneRuns({ workflowDir, keep: 0, dryRun: true });
+    assertEquals(dry.deleted.map((run) => run.runId), [
+      "terminal-a",
+      "terminal-b",
+    ]);
+    assertEquals(await exists(getRunDir("terminal-a", workflowDir)), true);
+    assertEquals(await exists(getRunDir("terminal-b", workflowDir)), true);
+
+    const real = await pruneRuns({ workflowDir, keep: 0, dryRun: false });
+    assertEquals(real.deleted.map((run) => run.runId), [
+      "terminal-a",
+      "terminal-b",
+    ]);
+    assertEquals(real.kept, []);
+    assertEquals(await exists(getRunDir("terminal-a", workflowDir)), false);
+    assertEquals(await exists(getRunDir("terminal-b", workflowDir)), false);
+    assertEquals(await exists(getRunDir("running", workflowDir)), true);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 missing runs directory returns an empty prune summary", async () => {
+  const workflowDir = await Deno.makeTempDir({ prefix: "runs-prune-empty-" });
+  try {
+    const summary = await pruneRuns({ workflowDir, keep: 1, dryRun: false });
+    assertEquals(summary.deleted, []);
+    assertEquals(summary.kept, []);
+    assertEquals(summary.skipped, []);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
