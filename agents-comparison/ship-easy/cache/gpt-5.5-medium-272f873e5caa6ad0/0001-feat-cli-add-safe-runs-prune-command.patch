+/** Parse `runs prune --workflow <dir> --keep <N> [--dry-run]` (FR-E83). */
+export function parseRunsPruneArgs(args: string[]): RunsPruneArgs {
+  const [command, ...rest] = args;
+  if (command !== "prune") {
+    throw new Error(
+      "runs: missing or unknown command. " +
+        "Usage: flowai-workflow runs prune --workflow <dir> --keep <N> [--dry-run]",
+    );
+  }
+
+  let workflowDir: string | undefined;
+  let keepRaw: string | undefined;
+  let dryRun = false;
+  for (let i = 0; i < rest.length; i++) {
+    const arg = rest[i];
+    if (arg === "--workflow") {
+      workflowDir = rest[++i];
+      continue;
+    }
+    if (arg.startsWith("--workflow=")) {
+      workflowDir = arg.slice("--workflow=".length);
+      continue;
+    }
+    if (arg === "--keep") {
+      keepRaw = rest[++i];
+      continue;
+    }
+    if (arg.startsWith("--keep=")) {
+      keepRaw = arg.slice("--keep=".length);
+      continue;
+    }
+    if (arg === "--dry-run") {
+      dryRun = true;
+      continue;
+    }
+    throw new Error(`runs prune: unknown argument: ${arg}`);
+  }
+
+  if (!workflowDir) {
+    throw new Error("runs prune: missing --workflow <path>.");
+  }
+  if (keepRaw === undefined) {
+    throw new Error("runs prune: missing --keep <N>.");
+  }
+
+  return {
+    command: "prune",
+    workflowDir: normalizeWorkflowDir(workflowDir),
+    keep: parseNonNegativeInteger(keepRaw, "--keep"),
+    dryRun,
+  };
+}
