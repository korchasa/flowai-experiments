+
+    const result = await pruneRuns({ workflowDir, keep: 0, dryRun: false });
+
+    assertEquals(result.deleted.map((run) => run.runId), [
+      "done",
+      "failed",
+      "aborted",
+    ]);
+    assertEquals(await exists(getRunDir("done", workflowDir)), false);
+    assertEquals(await exists(getRunDir("failed", workflowDir)), false);
+    assertEquals(await exists(getRunDir("aborted", workflowDir)), false);
+  });
+});
+
+Deno.test("FR-E83 dry-run deletes nothing", async () => {
+  await withWorkflow(async (workflowDir) => {
+    await writeRun(workflowDir, "old", "2026-06-01T00:00:00.000Z", "completed");
+    await writeRun(workflowDir, "new", "2026-06-02T00:00:00.000Z", "completed");
+
+    const result = await pruneRuns({ workflowDir, keep: 1, dryRun: true });
+
+    assertEquals(result.deleted.map((run) => run.runId), ["old"]);
