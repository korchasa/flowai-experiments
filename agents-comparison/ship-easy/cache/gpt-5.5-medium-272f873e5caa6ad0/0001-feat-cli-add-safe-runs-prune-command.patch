+import { assert, assertEquals } from "@std/assert";
+import { defaultLockPath } from "./lock.ts";
+import { RunJournalWriter } from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+import { pruneRuns, selectRunsForPrune } from "./runs-prune.ts";
+
+async function withWorkflow(
+  fn: (workflowDir: string) => Promise<void>,
+): Promise<void> {
+  const root = await Deno.makeTempDir();
+  try {
+    const workflowDir = `${root}/workflow`;
+    await Deno.mkdir(`${workflowDir}/runs`, { recursive: true });
+    await fn(workflowDir);
+  } finally {
+    await Deno.remove(root, { recursive: true });
+  }
+}
+
+async function writeRun(
+  workflowDir: string,
+  runId: string,
+  startedAt: string,
+  status: "completed" | "failed" | "aborted" | "running",
+): Promise<void> {
+  const runDir = getRunDir(runId, workflowDir);
+  const writer = await RunJournalWriter.open(runDir, runId);
+  await writer.append({
+    kind: "run_started",
+    config_path: `${workflowDir}/workflow.yaml`,
+    started_at: startedAt,
+    ts: startedAt,
+    args: {},
+    env: {},
+  });
+  if (status !== "running") {
+    await writer.append({
+      kind: status === "completed"
+        ? "run_completed"
+        : status === "failed"
+        ? "run_failed"
+        : "run_aborted",
+      status,
+      completed_at: new Date(Date.parse(startedAt) + 1000).toISOString(),
+    });
+  }
+}
+
+async function exists(path: string): Promise<boolean> {
+  try {
+    await Deno.stat(path);
+    return true;
+  } catch (err) {
+    if (err instanceof Deno.errors.NotFound) return false;
+    throw err;
+  }
+}
+
+Deno.test("FR-E83 prune keeps N newest terminal unlocked runs", async () => {
+  await withWorkflow(async (workflowDir) => {
+    await writeRun(workflowDir, "old", "2026-06-01T00:00:00.000Z", "completed");
+    await writeRun(
+      workflowDir,
+      "middle",
+      "2026-06-02T00:00:00.000Z",
+      "completed",
+    );
+    await writeRun(workflowDir, "new", "2026-06-03T00:00:00.000Z", "completed");
+
+    const result = await pruneRuns({ workflowDir, keep: 2, dryRun: false });
+
+    assertEquals(result.deleted.map((run) => run.runId), ["old"]);
+    assertEquals(result.kept.map((run) => run.runId), ["new", "middle"]);
+    assertEquals(result.skipped, []);
+    assertEquals(await exists(getRunDir("old", workflowDir)), false);
+    assertEquals(await exists(getRunDir("middle", workflowDir)), true);
+    assertEquals(await exists(getRunDir("new", workflowDir)), true);
+  });
+});
+
+Deno.test("FR-E83 prune skips non-terminal and locked runs", async () => {
+  await withWorkflow(async (workflowDir) => {
+    await writeRun(
+      workflowDir,
+      "terminal-old",
+      "2026-06-01T00:00:00.000Z",
+      "completed",
+    );
+    await writeRun(
+      workflowDir,
+      "running",
+      "2026-06-02T00:00:00.000Z",
+      "running",
+    );
+    await writeRun(
+      workflowDir,
+      "locked",
+      "2026-06-03T00:00:00.000Z",
+      "completed",
+    );
+    await Deno.writeTextFile(
+      defaultLockPath(workflowDir),
+      JSON.stringify({
+        pid: 999999,
+        hostname: "test",
+        run_id: "locked",
+        started_at: "2026-06-03T00:00:00.000Z",
+      }) + "\n",
+    );
+
+    const result = await pruneRuns({ workflowDir, keep: 0, dryRun: false });
+
+    assertEquals(result.deleted.map((run) => run.runId), ["terminal-old"]);
+    assertEquals(result.skipped, [
+      { runId: "locked", reason: "locked by runs/.lock" },
+      { runId: "running", reason: "non-terminal status: running" },
+    ]);
+    assertEquals(await exists(getRunDir("terminal-old", workflowDir)), false);
+    assertEquals(await exists(getRunDir("running", workflowDir)), true);
+    assertEquals(await exists(getRunDir("locked", workflowDir)), true);
+  });
+});
+
+Deno.test("FR-E83 missing or unreplayable journals are unknown", async () => {
+  await withWorkflow(async (workflowDir) => {
+    await Deno.mkdir(getRunDir("missing", workflowDir), { recursive: true });
+    await Deno.mkdir(getRunDir("bad", workflowDir), { recursive: true });
+    await Deno.writeTextFile(
+      `${getRunDir("bad", workflowDir)}/journal.jsonl`,
+      '{"schema_version":1}\nnot-json\n',
