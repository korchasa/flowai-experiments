@@ -0,0 +1,176 @@
+/**
+ * @module
+ * Safe local run-directory pruning (FR-E83).
+ */
+
+import { defaultLockPath, readLockInfo } from "./lock.ts";
+import { replayRunJournal } from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+import type { RunState } from "../types.ts";
+
+/** Run selected for deletion or retention. */
+export interface PrunableRun {
+  /** Run directory basename. */
+  runId: string;
+  /** Absolute or caller-relative run directory path. */
+  runDir: string;
+  /** Replayed run start timestamp. */
+  startedAt: string;
+  /** Replayed terminal run status. */
+  status: RunState["status"];
+}
+
+/** Run skipped because deleting it would be unsafe. */
+export interface SkippedRun {
+  /** Run directory basename. */
+  runId: string;
+  /** Human-readable reason printed in the prune summary. */
+  reason: string;
+}
+
+/** Full prune plan. `deleted` is planned deletions for dry-run calls. */
+export interface RunsPruneResult {
+  /** Terminal unlocked runs selected for deletion. */
+  deleted: PrunableRun[];
+  /** Terminal unlocked runs retained by the keep window. */
+  kept: PrunableRun[];
+  /** Runs preserved for safety reasons. */
+  skipped: SkippedRun[];
+}
+
+/** Arguments for selecting old runs. */
+export interface SelectRunsForPruneOptions {
+  /** Workflow folder containing `workflow.yaml`. */
+  workflowDir: string;
+  /** Number of newest terminal unlocked runs to retain. */
+  keep: number;
+}
+
+/** Arguments for applying a prune plan. */
+export interface PruneRunsOptions extends SelectRunsForPruneOptions {
+  /** When true, return planned deletions without touching the filesystem. */
+  dryRun: boolean;
+}
+
+/** Parse a CLI non-negative integer flag. */
+export function parseNonNegativeInteger(raw: string, flagName: string): number {
+  const parsed = Number(raw);
+  if (!Number.isInteger(parsed) || parsed < 0) {
+    throw new Error(
+      `Invalid ${flagName} value: ${raw}. Expected non-negative integer.`,
+    );
+  }
+  return parsed;
+}
+
+/** Select old terminal unlocked run directories for safe pruning. */
+export async function selectRunsForPrune(
+  options: SelectRunsForPruneOptions,
+): Promise<RunsPruneResult> {
+  const lockedRunId = await readLockedRunId(options.workflowDir);
+  const candidates: PrunableRun[] = [];
+  const skipped: SkippedRun[] = [];
+
+  let entries: Deno.DirEntry[];
+  try {
+    entries = [];
+    for await (const entry of Deno.readDir(`${options.workflowDir}/runs`)) {
+      entries.push(entry);
+    }
+  } catch (err) {
+    if (err instanceof Deno.errors.NotFound) {
+      return { deleted: [], kept: [], skipped: [] };
+    }
+    throw err;
+  }
+
+  for (const entry of entries.sort((a, b) => a.name.localeCompare(b.name))) {
+    if (!entry.isDirectory) continue;
+    const runId = entry.name;
+    const runDir = getRunDir(runId, options.workflowDir);
+
+    if (lockedRunId === runId) {
+      skipped.push({ runId, reason: "locked by runs/.lock" });
+      continue;
+    }
+
+    let state: RunState;
+    try {
+      state = (await replayRunJournal(runDir)).state;
+    } catch (err) {
+      skipped.push({
+        runId,
+        reason: `unknown state: ${errorMessage(err)}`,
+      });
+      continue;
+    }
+
+    if (!isTerminalStatus(state.status)) {
+      skipped.push({
+        runId,
+        reason: `non-terminal status: ${state.status}`,
+      });
+      continue;
+    }
+
+    if (Number.isNaN(Date.parse(state.started_at))) {
+      skipped.push({
+        runId,
+        reason: `unknown state: invalid started_at: ${state.started_at}`,
+      });
+      continue;
+    }
+
+    candidates.push({
+      runId,
+      runDir,
+      startedAt: state.started_at,
+      status: state.status,
+    });
+  }
+
+  const newestFirst = candidates.toSorted(compareNewestFirst);
+  const kept = newestFirst.slice(0, options.keep);
+  const deleted = newestFirst.slice(options.keep).toSorted(compareOldestFirst);
+  return { deleted, kept, skipped };
+}
+
+/** Apply safe pruning unless `dryRun` is set. */
+export async function pruneRuns(
+  options: PruneRunsOptions,
+): Promise<RunsPruneResult> {
+  const result = await selectRunsForPrune(options);
+  if (!options.dryRun) {
+    for (const run of result.deleted) {
+      await Deno.remove(run.runDir, { recursive: true });
+    }
+  }
+  return result;
+}
+
+async function readLockedRunId(workflowDir: string): Promise<string | null> {
+  try {
+    return (await readLockInfo(defaultLockPath(workflowDir))).run_id;
+  } catch (err) {
+    if (err instanceof Deno.errors.NotFound) return null;
+    throw err;
+  }
+}
+
+function isTerminalStatus(status: RunState["status"]): boolean {
+  return status === "completed" || status === "failed" || status === "aborted";
+}
+
+function compareNewestFirst(a: PrunableRun, b: PrunableRun): number {
+  return Date.parse(b.startedAt) - Date.parse(a.startedAt) ||
+    a.runId.localeCompare(b.runId);
+}
+
+function compareOldestFirst(a: PrunableRun, b: PrunableRun): number {
+  return Date.parse(a.startedAt) - Date.parse(b.startedAt) ||
+    a.runId.localeCompare(b.runId);
+}
+
+function errorMessage(err: unknown): string {
+  return err instanceof Error ? err.message : String(err);
+}
