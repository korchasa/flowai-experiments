+    assertEquals(result.deleted, []);
+    assertEquals(result.kept, []);
+    assertEquals(result.skipped.length, 2);
+    assert(
+      result.skipped.every((run) => run.reason.startsWith("unknown state: ")),
+    );
+  });
+});
+
+Deno.test("FR-E83 keep zero deletes all terminal unlocked runs", async () => {
+  await withWorkflow(async (workflowDir) => {
+    await writeRun(
+      workflowDir,
+      "done",
+      "2026-06-01T00:00:00.000Z",
+      "completed",
