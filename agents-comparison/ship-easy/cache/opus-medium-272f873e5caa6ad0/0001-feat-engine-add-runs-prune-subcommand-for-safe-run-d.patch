@@ -0,0 +1,219 @@
+/**
+ * @module
+ * Safe cleanup of old run directories under `<workflowDir>/runs/` (FR-E83).
+ *
+ * A run's only durable record is its `journal.jsonl`; status and start time
+ * come from replaying it with the existing replayer
+ * ({@link loadStateFromJournal}). A run whose journal is missing or cannot
+ * be replayed has unknown state by definition and is treated as
+ * NOT terminal (keep when in doubt).
+ *
+ * Safety rules (hard requirements):
+ *  - never delete a run whose replayed status is not terminal;
+ *  - never delete the run referenced by `runs/.lock`;
+ *  - a missing/unreplayable journal counts as not terminal (skipped);
+ *  - `--keep N` retains the N newest *prunable* (terminal AND unlocked)
+ *    runs; protected runs always remain and do not consume keep slots.
+ */
+
+import { dirname } from "@std/path";
+import type { RunState } from "../types.ts";
+import { getRunDir } from "./state.ts";
+import { defaultLockPath, readLockInfo } from "./lock.ts";
+import { isTerminalStatus, loadStateFromJournal } from "./run-journal.ts";
+
+/** Why a run was excluded from deletion (and thus kept). */
+export type SkipReason = "non-terminal" | "unreplayable" | "locked";
+
+/** One classified run directory. */
+export interface RunRecord {
+  /** Run id == run directory name under `<workflowDir>/runs/`. */
+  runId: string;
+  /** Replayed run start time (ISO 8601), or null when unreplayable. */
+  startedAt: string | null;
+  /** Replayed run status, or null when unreplayable. */
+  status: string | null;
+  /** True when the run is terminal AND unlocked → eligible for deletion. */
+  prunable: boolean;
+  /** Set when the run is protected from deletion. */
+  skipReason?: SkipReason;
+  /** Human-readable detail for the summary. */
+  detail: string;
+}
+
+/** Partition of classified runs produced by {@link planPrune}. */
+export interface PrunePlan {
+  /** Prunable runs selected for deletion (oldest beyond `keep`). */
+  deleted: RunRecord[];
+  /** Prunable runs retained as the `keep` newest. */
+  kept: RunRecord[];
+  /** Protected runs (non-terminal / unreplayable / locked). */
+  skipped: RunRecord[];
+}
+
+/** Options for {@link prune}. */
+export interface PruneOptions {
+  /** Workflow folder containing `runs/`. */
+  workflowDir: string;
+  /** Retain this many newest prunable runs. Non-negative integer. */
+  keep: number;
+  /** When true, compute the plan but delete nothing. */
+  dryRun: boolean;
+}
+
+/** Outcome of a {@link prune} call. */
+export interface PruneResult extends PrunePlan {
+  dryRun: boolean;
+  keep: number;
+  workflowDir: string;
+}
+
+/** Resolve the `runs/` directory for a workflow folder without duplicating
+ * the path literal — reuses {@link defaultLockPath} (`<dir>/runs/.lock`). */
+function runsDirOf(workflowDir: string): string {
+  return dirname(defaultLockPath(workflowDir));
+}
+
+/** Enumerate and classify every run directory under `<workflowDir>/runs/`.
+ * Reads the lock once; replays each run's journal via the shared replayer.
+ * A missing `runs/` directory yields an empty list (nothing to prune). */
+export async function classifyRuns(workflowDir: string): Promise<RunRecord[]> {
+  const runsDir = runsDirOf(workflowDir);
+
+  let lockedRunId: string | null = null;
+  try {
+    lockedRunId = (await readLockInfo(defaultLockPath(workflowDir))).run_id;
+  } catch (e) {
+    // No lock file → no protected run. Any other error (corrupt/permission)
+    // surfaces — we must not prune while lock state is uncertain.
+    if (!(e instanceof Deno.errors.NotFound)) throw e;
+  }
+
+  const records: RunRecord[] = [];
+  const entries: Deno.DirEntry[] = [];
+  try {
+    // `Deno.readDir` defers the missing-dir error to first iteration, so the
+    // NotFound guard must wrap the drain, not the call.
+    for await (const entry of Deno.readDir(runsDir)) entries.push(entry);
+  } catch (e) {
+    if (e instanceof Deno.errors.NotFound) return records; // no runs yet
+    throw e;
+  }
+
+  for (const entry of entries) {
+    if (!entry.isDirectory) continue; // skip `.lock` and stray files
+    const runId = entry.name;
+
+    if (runId === lockedRunId) {
+      records.push({
+        runId,
+        startedAt: null,
+        status: null,
+        prunable: false,
+        skipReason: "locked",
+        detail: "referenced by runs/.lock",
+      });
+      continue;
+    }
+
+    let status: RunState["status"];
+    let startedAt: string;
+    try {
+      const state = await loadStateFromJournal(getRunDir(runId, workflowDir));
+      status = state.status;
+      startedAt = state.started_at;
+    } catch {
+      records.push({
+        runId,
+        startedAt: null,
+        status: null,
+        prunable: false,
+        skipReason: "unreplayable",
+        detail: "journal missing or unreplayable (non-terminal)",
+      });
+      continue;
+    }
+
+    if (!isTerminalStatus(status)) {
+      records.push({
+        runId,
+        startedAt,
+        status,
+        prunable: false,
+        skipReason: "non-terminal",
+        detail: `status '${status}' is not terminal`,
+      });
+      continue;
+    }
+
+    records.push({
+      runId,
+      startedAt,
+      status,
+      prunable: true,
+      detail: status,
+    });
+  }
+
+  return records;
+}
+
+/** Pure selection: keep the `keep` newest prunable runs, delete the older
+ * prunable ones; protected runs pass through as skipped. Sort is by start
+ * time ascending, run id as a deterministic tie-breaker. */
+export function planPrune(records: RunRecord[], keep: number): PrunePlan {
+  const prunable = records
+    .filter((r) => r.prunable)
+    .sort((a, b) => {
+      const ta = Date.parse(a.startedAt ?? "");
+      const tb = Date.parse(b.startedAt ?? "");
+      if (ta !== tb) return ta - tb; // oldest first
+      return a.runId < b.runId ? -1 : a.runId > b.runId ? 1 : 0;
+    });
+  const skipped = records.filter((r) => !r.prunable);
+
+  const deleteCount = Math.max(0, prunable.length - keep);
+  return {
+    deleted: prunable.slice(0, deleteCount),
+    kept: prunable.slice(deleteCount),
+    skipped,
+  };
+}
+
+/** Classify, plan, and (unless `dryRun`) delete the selected run dirs. */
+export async function prune(opts: PruneOptions): Promise<PruneResult> {
+  const records = await classifyRuns(opts.workflowDir);
+  const plan = planPrune(records, opts.keep);
+
+  if (!opts.dryRun) {
+    for (const record of plan.deleted) {
+      await Deno.remove(getRunDir(record.runId, opts.workflowDir), {
+        recursive: true,
+      });
+    }
+  }
+
+  return {
+    ...plan,
+    dryRun: opts.dryRun,
+    keep: opts.keep,
+    workflowDir: opts.workflowDir,
+  };
+}
+
+/** Render a human-readable two-level-list summary (no tables). */
+export function formatPruneSummary(result: PruneResult): string {
+  const verb = result.dryRun ? "would delete" : "deleted";
+  const lines: string[] = [];
+  lines.push(
+    `runs prune${result.dryRun ? " (dry-run)" : ""}: workflow ` +
+      `${result.workflowDir}, keep ${result.keep}`,
+  );
+  lines.push(`- ${verb}: ${result.deleted.length}`);
+  for (const r of result.deleted) lines.push(`  - ${r.runId} (${r.detail})`);
+  lines.push(`- kept (newest): ${result.kept.length}`);
+  for (const r of result.kept) lines.push(`  - ${r.runId} (${r.detail})`);
+  lines.push(`- skipped: ${result.skipped.length}`);
+  for (const r of result.skipped) lines.push(`  - ${r.runId} — ${r.detail}`);
+  return lines.join("\n");
+}
diff --git a/src/state/prune_test.ts b/src/state/prune_test.ts
