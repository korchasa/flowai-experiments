+// FR-E83: `runs prune` selection logic. Unit tests on temp-dir fixtures
+// with engine-shaped journals. Covers: keeps N newest, skips non-terminal,
+// skips locked, missing/unreplayable journal counts as non-terminal,
+// `--keep 0` deletes all terminal unlocked runs, dry-run deletes nothing,
+// bad `--keep` rejected.
+import { assert, assertEquals, assertThrows } from "@std/assert";
+import { prune } from "./prune.ts";
+import { getRunDir } from "./state.ts";
+import { defaultLockPath } from "./lock.ts";
+import { RunJournalWriter } from "./run-journal.ts";
+import { parseRunsPruneArgs } from "../cli.ts";
+
+type Status = "running" | "completed" | "failed" | "aborted";
+
+/** Write an engine-shaped journal for `runId` with the given replayed
+ * status and start time. Reuses the real `RunJournalWriter` so the fixture
+ * exercises the production replay path. */
+async function writeRun(
+  workflowDir: string,
+  runId: string,
+  opts: { status: Status; startedAt: string },
+): Promise<void> {
+  const runDir = getRunDir(runId, workflowDir);
+  const writer = await RunJournalWriter.open(runDir, runId);
+  await writer.append({
+    kind: "run_started",
+    config_path: "workflow.yaml",
+    started_at: opts.startedAt,
+    ts: opts.startedAt,
+    args: {},
+    env: {},
+  });
+  if (opts.status !== "running") {
+    const kind = opts.status === "completed"
+      ? "run_completed"
+      : opts.status === "failed"
+      ? "run_failed"
+      : "run_aborted";
+    await writer.append({
+      kind,
+      status: opts.status,
+      completed_at: opts.startedAt,
+    });
+  }
+}
+
+async function writeLock(workflowDir: string, runId: string): Promise<void> {
+  await Deno.writeTextFile(
+    defaultLockPath(workflowDir),
+    JSON.stringify({
+      pid: 999999,
+      hostname: "test",
+      run_id: runId,
+      started_at: "2026-06-01T00:00:00.000Z",
+    }) + "\n",
+  );
+}
+
+async function exists(path: string): Promise<boolean> {
+  try {
+    await Deno.stat(path);
+    return true;
+  } catch (e) {
+    if (e instanceof Deno.errors.NotFound) return false;
+    throw e;
+  }
+}
+
+async function withTemp(
+  fn: (dir: string) => Promise<void>,
+): Promise<void> {
+  const dir = await Deno.makeTempDir();
+  try {
+    await fn(dir);
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+}
+
+Deno.test("FR-E83 prune — keeps N newest, deletes older", async () => {
+  await withTemp(async (wf) => {
+    await writeRun(wf, "r1-old", {
+      status: "completed",
+      startedAt: "2026-06-01T00:00:00.000Z",
+    });
+    await writeRun(wf, "r2-mid", {
+      status: "failed",
+      startedAt: "2026-06-02T00:00:00.000Z",
+    });
+    await writeRun(wf, "r3-new", {
+      status: "aborted",
+      startedAt: "2026-06-03T00:00:00.000Z",
+    });
+
+    const result = await prune({ workflowDir: wf, keep: 2, dryRun: false });
+
+    assertEquals(result.deleted.map((r) => r.runId), ["r1-old"]);
+    assertEquals(
+      result.kept.map((r) => r.runId).sort(),
+      ["r2-mid", "r3-new"],
+    );
+    assertEquals(result.skipped.length, 0);
+    assertEquals(await exists(getRunDir("r1-old", wf)), false);
+    assertEquals(await exists(getRunDir("r3-new", wf)), true);
+  });
+});
+
+Deno.test("FR-E83 prune — skips non-terminal regardless of keep", async () => {
+  await withTemp(async (wf) => {
+    await writeRun(wf, "running1", {
+      status: "running",
+      startedAt: "2026-06-01T00:00:00.000Z",
+    });
+    await writeRun(wf, "done1", {
+      status: "completed",
+      startedAt: "2026-06-02T00:00:00.000Z",
+    });
+
+    const result = await prune({ workflowDir: wf, keep: 0, dryRun: false });
+
+    // Running run is untouchable even with keep 0.
+    assertEquals(result.deleted.map((r) => r.runId), ["done1"]);
+    const skipped = result.skipped.find((r) => r.runId === "running1");
+    assert(skipped, "running run should be skipped");
+    assertEquals(skipped.skipReason, "non-terminal");
+    assertEquals(await exists(getRunDir("running1", wf)), true);
+  });
+});
+
+Deno.test("FR-E83 prune — skips the locked run", async () => {
+  await withTemp(async (wf) => {
+    await writeRun(wf, "locked1", {
+      status: "completed",
+      startedAt: "2026-06-01T00:00:00.000Z",
+    });
+    await writeRun(wf, "free1", {
+      status: "completed",
+      startedAt: "2026-06-02T00:00:00.000Z",
+    });
+    await writeLock(wf, "locked1");
+
+    const result = await prune({ workflowDir: wf, keep: 0, dryRun: false });
+
+    assertEquals(result.deleted.map((r) => r.runId), ["free1"]);
+    const skipped = result.skipped.find((r) => r.runId === "locked1");
+    assert(skipped, "locked run should be skipped");
+    assertEquals(skipped.skipReason, "locked");
+    assertEquals(await exists(getRunDir("locked1", wf)), true);
+  });
+});
+
+Deno.test("FR-E83 prune — missing/unreplayable journal counts as non-terminal", async () => {
+  await withTemp(async (wf) => {
+    // Run dir with no journal at all.
+    await Deno.mkdir(getRunDir("nojournal", wf), { recursive: true });
+    // Run dir with a corrupt (non-tail) journal record.
+    const badDir = getRunDir("corrupt", wf);
+    await Deno.mkdir(badDir, { recursive: true });
+    await Deno.writeTextFile(
+      `${badDir}/journal.jsonl`,
+      '{"schema_version":1\n{"schema_version":1}\n',
+    );
+    await writeRun(wf, "done1", {
+      status: "completed",
+      startedAt: "2026-06-02T00:00:00.000Z",
+    });
+
+    const result = await prune({ workflowDir: wf, keep: 0, dryRun: false });
+
+    assertEquals(result.deleted.map((r) => r.runId), ["done1"]);
+    for (const id of ["nojournal", "corrupt"]) {
+      const skipped = result.skipped.find((r) => r.runId === id);
+      assert(skipped, `${id} should be skipped`);
+      assertEquals(skipped.skipReason, "unreplayable");
+      assertEquals(await exists(getRunDir(id, wf)), true);
+    }
+  });
+});
+
+Deno.test("FR-E83 prune — keep 0 deletes all terminal unlocked runs", async () => {
+  await withTemp(async (wf) => {
+    await writeRun(wf, "a", {
+      status: "completed",
+      startedAt: "2026-06-01T00:00:00.000Z",
+    });
+    await writeRun(wf, "b", {
+      status: "failed",
+      startedAt: "2026-06-02T00:00:00.000Z",
+    });
+
+    const result = await prune({ workflowDir: wf, keep: 0, dryRun: false });
+
+    assertEquals(result.deleted.map((r) => r.runId).sort(), ["a", "b"]);
+    assertEquals(result.kept.length, 0);
+    assertEquals(await exists(getRunDir("a", wf)), false);
+    assertEquals(await exists(getRunDir("b", wf)), false);
+  });
+});
+
+Deno.test("FR-E83 prune — dry-run deletes nothing", async () => {
+  await withTemp(async (wf) => {
+    await writeRun(wf, "a", {
+      status: "completed",
+      startedAt: "2026-06-01T00:00:00.000Z",
+    });
+    await writeRun(wf, "b", {
+      status: "completed",
+      startedAt: "2026-06-02T00:00:00.000Z",
+    });
+
+    const result = await prune({ workflowDir: wf, keep: 0, dryRun: true });
+
+    assertEquals(result.dryRun, true);
+    assertEquals(result.deleted.map((r) => r.runId).sort(), ["a", "b"]);
+    // Nothing actually removed.
+    assertEquals(await exists(getRunDir("a", wf)), true);
+    assertEquals(await exists(getRunDir("b", wf)), true);
+  });
+});
+
+Deno.test("FR-E83 prune — no runs dir is a clean no-op", async () => {
+  await withTemp(async (wf) => {
+    const result = await prune({ workflowDir: wf, keep: 3, dryRun: false });
+    assertEquals(result.deleted.length, 0);
+    assertEquals(result.kept.length, 0);
+    assertEquals(result.skipped.length, 0);
+  });
+});
+
+Deno.test("FR-E83 parseRunsPruneArgs — bad --keep rejected", () => {
+  for (const bad of ["-1", "3.5", "abc", "", "1e3"]) {
+    assertThrows(
+      () => parseRunsPruneArgs(["--workflow", "wf", "--keep", bad]),
+      Error,
+      "non-negative integer",
+    );
+  }
+});
+
+Deno.test("FR-E83 parseRunsPruneArgs — missing --keep rejected", () => {
+  assertThrows(
+    () => parseRunsPruneArgs(["--workflow", "wf"]),
+    Error,
+    "--keep",
+  );
+});
+
+Deno.test("FR-E83 parseRunsPruneArgs — parses valid flags", () => {
+  const a = parseRunsPruneArgs([
+    "--workflow",
+    ".flowai-workflow/github-inbox/",
+    "--keep",
+    "5",
+    "--dry-run",
+  ]);
+  assertEquals(a.workflowDir, ".flowai-workflow/github-inbox");
+  assertEquals(a.keep, 5);
+  assertEquals(a.dryRun, true);
+});
+
+Deno.test("FR-E83 parseRunsPruneArgs — unknown flag rejected", () => {
+  assertThrows(
+    () => parseRunsPruneArgs(["--bogus", "--keep", "1"]),
+    Error,
+    "Unknown",
+  );
+});
