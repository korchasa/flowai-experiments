+/** Parsed flags for the `runs prune` subcommand (FR-E83). */
+export interface RunsPruneArgs {
+  /** Workflow folder (trailing slashes stripped). `undefined` when the user
+   * did not pass `--workflow`; the caller falls back to the shared
+   * `resolveActiveWorkflow` resolver (FR-E78). */
+  workflowDir: string | undefined;
+  /** Retain this many newest prunable runs. Non-negative integer. */
+  keep: number;
+  /** `--dry-run`: report what would be deleted, delete nothing. */
+  dryRun: boolean;
+}
+
+/**
+ * Parse `runs prune [--workflow <dir>] --keep <N> [--dry-run]` (FR-E83).
+ * `--workflow` is optional (falls back to {@link resolveActiveWorkflow}).
+ * `--keep` is mandatory and MUST be a non-negative integer — anything else
+ * throws a clear error so the caller can exit non-zero. Mirrors the
+ * hand-rolled flag-loop style of {@link parseAnswerArgs}.
+ */
+export function parseRunsPruneArgs(args: string[]): RunsPruneArgs {
+  let workflow: string | undefined;
+  let keepRaw: string | undefined;
+  let dryRun = false;
+  for (let i = 0; i < args.length; i++) {
+    const a = args[i];
+    if (a === "--workflow") {
+      workflow = args[++i];
+    } else if (a.startsWith("--workflow=")) {
+      workflow = a.slice("--workflow=".length);
+    } else if (a === "--keep") {
+      keepRaw = args[++i];
+    } else if (a.startsWith("--keep=")) {
+      keepRaw = a.slice("--keep=".length);
+    } else if (a === "--dry-run") {
+      dryRun = true;
+    } else {
+      throw new Error(
+        `Unknown flag for \`runs prune\`: ${a}. ` +
+          "Usage: flowai-workflow runs prune [--workflow <dir>] --keep <N> " +
+          "[--dry-run]",
+      );
+    }
+  }
+  if (keepRaw === undefined) {
+    throw new Error(
+      "runs prune: missing --keep <N> (number of newest runs to retain).",
+    );
+  }
+  if (!/^\d+$/.test(keepRaw)) {
+    throw new Error(
+      `runs prune: --keep must be a non-negative integer, got '${keepRaw}'.`,
+    );
+  }
+  return {
+    workflowDir: workflow ? normalizeWorkflowDir(workflow) : undefined,
+    keep: Number(keepRaw),
+    dryRun,
+  };
+}
