+        throw new Error(
+          "Could not resolve active workflow. Pass it via " +
+            "`--workflow <dir>`, set FLOWAI_WORKFLOW, or place a workflow " +
+            "under `<cwd>/.flowai-workflow/`.",
+        );
+      }
+      workflowDir = normalizeWorkflowDir(resolved);
+    }
+    const result = await prune({
+      workflowDir,
+      keep: parsed.keep,
+      dryRun: parsed.dryRun,
+    });
+    console.log(formatPruneSummary(result));
+    Deno.exit(0);
+  } catch (err) {
+    console.error(`Error: ${(err as Error).message}`);
+    Deno.exit(1);
+  }
+}
