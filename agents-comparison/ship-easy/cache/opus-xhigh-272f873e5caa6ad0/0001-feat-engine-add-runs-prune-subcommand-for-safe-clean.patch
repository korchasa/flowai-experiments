@@ -0,0 +1,373 @@
+import {
+  assert,
+  assertEquals,
+  assertRejects,
+  assertStringIncludes,
+} from "@std/assert";
+import { RunJournalWriter } from "./run-journal.ts";
+import {
+  type ClassifiedRun,
+  formatPruneSummary,
+  planPrune,
+  pruneRuns,
+} from "./prune.ts";
+import { defaultLockPath, type LockInfo } from "./lock.ts";
+
+// --- Fixtures: engine-shaped run directories under <workflowDir>/runs/ ---
+
+/** Create a run directory with an engine-shaped journal (or a broken one). */
+async function makeRun(
+  workflowDir: string,
+  runId: string,
+  opts: {
+    startedAt?: string;
+    terminal?: "completed" | "failed" | "aborted";
+    journal?: "ok" | "missing" | "malformed";
+  },
+): Promise<void> {
+  const runDir = `${workflowDir}/runs/${runId}`;
+  await Deno.mkdir(runDir, { recursive: true });
+  const journalKind = opts.journal ?? "ok";
+  if (journalKind === "missing") return;
+  if (journalKind === "malformed") {
+    await Deno.writeTextFile(
+      `${runDir}/journal.jsonl`,
+      '{"schema_version":1\n{"kind":"node_started"}\n',
+    );
+    return;
+  }
+  const writer = await RunJournalWriter.open(runDir, runId);
+  const startedAt = opts.startedAt ?? "2026-01-01T00:00:00.000Z";
+  await writer.append({
+    kind: "run_started",
+    config_path: "workflow.yaml",
+    started_at: startedAt,
+    ts: startedAt,
+    args: {},
+    env: {},
+  });
+  if (opts.terminal) {
+    const kind = opts.terminal === "completed"
+      ? "run_completed"
+      : opts.terminal === "failed"
+      ? "run_failed"
+      : "run_aborted";
+    await writer.append({
+      kind,
+      status: opts.terminal,
+      completed_at: "2026-02-01T00:00:00.000Z",
+    });
+  }
+}
+
+/** Write a per-workflow run lock referencing `runId`. */
+async function writeLock(workflowDir: string, runId: string): Promise<void> {
+  const info: LockInfo = {
+    pid: Deno.pid,
+    hostname: "test-host",
+    run_id: runId,
+    started_at: "2026-01-01T00:00:00.000Z",
+  };
+  await Deno.mkdir(`${workflowDir}/runs`, { recursive: true });
+  await Deno.writeTextFile(
+    defaultLockPath(workflowDir),
+    JSON.stringify(info, null, 2) + "\n",
+  );
+}
+
+/** List remaining run-directory names under <workflowDir>/runs/. */
+async function listRuns(workflowDir: string): Promise<string[]> {
+  const out: string[] = [];
+  for await (const entry of Deno.readDir(`${workflowDir}/runs`)) {
+    if (entry.isDirectory) out.push(entry.name);
+  }
+  return out.sort();
+}
+
+function actionFor(
+  plan: ReturnType<typeof planPrune>,
+  runId: string,
+): string | undefined {
+  return plan.find((e) => e.runId === runId)?.action;
+}
+
+// --- pruneRuns: integration over temp-dir fixtures ---
+
+Deno.test("FR-E83 pruneRuns keeps N newest terminal runs, deletes older", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    await makeRun(dir, "r1", {
+      startedAt: "2026-01-01T00:00:00.000Z",
+      terminal: "completed",
+    });
+    await makeRun(dir, "r2", {
+      startedAt: "2026-01-02T00:00:00.000Z",
+      terminal: "completed",
+    });
+    await makeRun(dir, "r3", {
+      startedAt: "2026-01-03T00:00:00.000Z",
+      terminal: "failed",
+    });
+    await makeRun(dir, "r4", {
+      startedAt: "2026-01-04T00:00:00.000Z",
+      terminal: "aborted",
+    });
+
+    const summary = await pruneRuns({
+      workflowDir: dir,
+      keep: 2,
+      dryRun: false,
+    });
+
+    assertEquals(summary.deleted.sort(), ["r1", "r2"]);
+    assertEquals(summary.kept.sort(), ["r3", "r4"]);
+    assertEquals(summary.skipped, []);
+    assertEquals(await listRuns(dir), ["r3", "r4"]);
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns never deletes a non-terminal run", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    await makeRun(dir, "done", {
+      startedAt: "2026-01-01T00:00:00.000Z",
+      terminal: "completed",
+    });
+    // No terminal event => replayed status stays "running" (non-terminal).
+    await makeRun(dir, "running", { startedAt: "2026-01-02T00:00:00.000Z" });
+
+    const summary = await pruneRuns({
+      workflowDir: dir,
+      keep: 0,
+      dryRun: false,
+    });
+
+    assertEquals(summary.deleted, ["done"]);
+    assertEquals(summary.skipped.map((s) => s.runId), ["running"]);
+    assertStringIncludes(summary.skipped[0].reason, "non-terminal");
+    assertEquals(await listRuns(dir), ["running"]);
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns never deletes the locked run", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    await makeRun(dir, "r1", {
+      startedAt: "2026-01-01T00:00:00.000Z",
+      terminal: "completed",
+    });
+    await makeRun(dir, "r2", {
+      startedAt: "2026-01-02T00:00:00.000Z",
+      terminal: "completed",
+    });
+    await writeLock(dir, "r1"); // oldest; would be deleted at keep=1 if unlocked
+
+    const summary = await pruneRuns({
+      workflowDir: dir,
+      keep: 1,
+      dryRun: false,
+    });
+
+    assertEquals(summary.deleted, []);
+    assertEquals(summary.kept, ["r2"]);
+    assertEquals(summary.skipped.map((s) => s.runId), ["r1"]);
+    assertStringIncludes(summary.skipped[0].reason, "lock");
+    assertEquals(await listRuns(dir), ["r1", "r2"]);
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns treats a missing journal as non-terminal (kept, skipped)", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    await makeRun(dir, "good", {
+      startedAt: "2026-01-02T00:00:00.000Z",
+      terminal: "completed",
+    });
+    await makeRun(dir, "nojournal", { journal: "missing" });
+
+    const summary = await pruneRuns({
+      workflowDir: dir,
+      keep: 0,
+      dryRun: false,
+    });
+
+    assertEquals(summary.deleted, ["good"]);
+    assertEquals(summary.skipped.map((s) => s.runId), ["nojournal"]);
+    assertStringIncludes(summary.skipped[0].reason, "missing");
+    assert((await listRuns(dir)).includes("nojournal"));
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns treats an unreplayable journal as non-terminal (kept, skipped)", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    await makeRun(dir, "bad", { journal: "malformed" });
+    await makeRun(dir, "good", {
+      startedAt: "2026-01-02T00:00:00.000Z",
+      terminal: "completed",
+    });
+
+    const summary = await pruneRuns({
+      workflowDir: dir,
+      keep: 0,
+      dryRun: false,
+    });
+
+    assertEquals(summary.deleted, ["good"]);
+    assertEquals(summary.skipped.map((s) => s.runId), ["bad"]);
+    assertStringIncludes(summary.skipped[0].reason, "unreplayable");
+    assert((await listRuns(dir)).includes("bad"));
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns --keep 0 deletes all terminal unlocked runs", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    await makeRun(dir, "a", {
+      startedAt: "2026-01-01T00:00:00.000Z",
+      terminal: "completed",
+    });
+    await makeRun(dir, "b", {
+      startedAt: "2026-01-02T00:00:00.000Z",
+      terminal: "failed",
+    });
+    await makeRun(dir, "c", {
+      startedAt: "2026-01-03T00:00:00.000Z",
+      terminal: "aborted",
+    });
+
+    const summary = await pruneRuns({
+      workflowDir: dir,
+      keep: 0,
+      dryRun: false,
+    });
+
+    assertEquals(summary.deleted.sort(), ["a", "b", "c"]);
+    assertEquals(summary.kept, []);
+    assertEquals(await listRuns(dir), []);
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns --dry-run deletes nothing", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    await makeRun(dir, "a", {
+      startedAt: "2026-01-01T00:00:00.000Z",
+      terminal: "completed",
+    });
+    await makeRun(dir, "b", {
+      startedAt: "2026-01-02T00:00:00.000Z",
+      terminal: "completed",
+    });
+
+    const summary = await pruneRuns({
+      workflowDir: dir,
+      keep: 0,
+      dryRun: true,
+    });
+
+    assertEquals(summary.dryRun, true);
+    assertEquals(summary.deleted.sort(), ["a", "b"]); // would-be deletions
+    assertEquals(await listRuns(dir), ["a", "b"]); // nothing removed
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns aborts on an unreadable (corrupted) lock", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    await makeRun(dir, "r1", {
+      startedAt: "2026-01-01T00:00:00.000Z",
+      terminal: "completed",
+    });
+    await Deno.mkdir(`${dir}/runs`, { recursive: true });
+    await Deno.writeTextFile(defaultLockPath(dir), "{not valid json");
+
+    await assertRejects(() =>
+      pruneRuns({ workflowDir: dir, keep: 0, dryRun: false })
+    );
+    assert((await listRuns(dir)).includes("r1")); // nothing deleted
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+Deno.test("FR-E83 pruneRuns returns empty summary when runs/ is absent", async () => {
+  const dir = await Deno.makeTempDir();
+  try {
+    const summary = await pruneRuns({
+      workflowDir: dir,
+      keep: 3,
+      dryRun: false,
+    });
+    assertEquals(summary, {
+      deleted: [],
+      kept: [],
+      skipped: [],
+      dryRun: false,
+    });
+  } finally {
+    await Deno.remove(dir, { recursive: true });
+  }
+});
+
+// --- planPrune: pure selection logic ---
+
+Deno.test("FR-E83 planPrune ranks by start time and applies the keep window", () => {
+  const runs: ClassifiedRun[] = [
+    { runId: "a", startedMs: 30, terminal: true, locked: false },
+    { runId: "b", startedMs: 20, terminal: true, locked: false },
+    { runId: "c", startedMs: 10, terminal: true, locked: false },
+  ];
+  const plan = planPrune(runs, 1);
+  assertEquals(actionFor(plan, "a"), "keep");
+  assertEquals(actionFor(plan, "b"), "delete");
+  assertEquals(actionFor(plan, "c"), "delete");
+});
+
+Deno.test("FR-E83 planPrune protects non-terminal, locked, and unreplayable runs", () => {
+  const runs: ClassifiedRun[] = [
+    { runId: "new", startedMs: 30, terminal: true, locked: false },
+    { runId: "run", startedMs: 20, terminal: false, locked: false },
+    { runId: "lock", startedMs: 10, terminal: true, locked: true },
+    {
+      runId: "bad",
+      terminal: false,
+      locked: false,
+      unreplayableReason: "journal.jsonl missing",
+    },
+  ];
+  const plan = planPrune(runs, 0);
+  assertEquals(actionFor(plan, "new"), "delete");
+  assertEquals(actionFor(plan, "run"), "skip");
+  assertEquals(actionFor(plan, "lock"), "skip");
+  assertEquals(actionFor(plan, "bad"), "skip");
+});
+
+Deno.test("FR-E83 formatPruneSummary reports counts, reasons, and dry-run", () => {
+  const text = formatPruneSummary({
+    deleted: ["old1"],
+    kept: ["new1"],
+    skipped: [{ runId: "busy", reason: "non-terminal run status: running" }],
+    dryRun: true,
+  });
+  assertStringIncludes(text, "dry-run");
+  assertStringIncludes(text, "deleted 1");
+  assertStringIncludes(text, "kept 1");
+  assertStringIncludes(text, "skipped 1");
+  assertStringIncludes(text, "busy");
+  assertStringIncludes(text, "non-terminal");
+});
