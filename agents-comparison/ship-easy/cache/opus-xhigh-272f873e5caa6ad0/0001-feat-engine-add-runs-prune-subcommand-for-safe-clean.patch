+/**
+ * Run the `runs` subcommand group (FR-E83). Currently routes the single
+ * `prune` action to {@link pruneRuns} and prints the summary. Unknown actions
+ * and bad arguments exit non-zero with a clear message.
+ */
+async function runRuns(args: string[]): Promise<never> {
+  try {
+    const action = args[0];
+    if (action !== "prune") {
+      throw new Error(
+        `runs: unknown action '${action ?? ""}'. Supported: prune. ` +
+          "Usage: flowai-workflow runs prune --workflow <dir> --keep <N> " +
+          "[--dry-run]",
+      );
+    }
+    const parsed = parseRunsPruneArgs(args.slice(1));
+    const summary = await pruneRuns({
+      workflowDir: parsed.workflowDir,
+      keep: parsed.keep,
+      dryRun: parsed.dryRun,
+    });
+    console.log(formatPruneSummary(summary));
+    Deno.exit(0);
+  } catch (err) {
+    console.error(`Error: ${(err as Error).message}`);
+    Deno.exit(1);
+  }
+}
