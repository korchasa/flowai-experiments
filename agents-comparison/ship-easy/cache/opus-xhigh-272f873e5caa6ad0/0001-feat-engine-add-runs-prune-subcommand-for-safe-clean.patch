+/** Parsed arguments for `runs prune` (FR-E83). */
+export interface RunsPruneArgs {
+  /** Workflow folder whose `runs/` directory is pruned (trailing slash stripped). */
+  workflowDir: string;
+  /** Retain at most this many most-recent runs (non-negative integer). */
+  keep: number;
+  /** When true, report would-be deletions without removing anything. */
+  dryRun: boolean;
+}
+
+/**
+ * Parse `runs prune --workflow <dir> --keep <N> [--dry-run]` (FR-E83).
+ *
+ * `--workflow` is required (an explicit target is mandatory for a destructive
+ * command); `--keep` must be a non-negative integer. Both `--flag value` and
+ * `--flag=value` forms are accepted, matching {@link parseAnswerArgs}. Throws a
+ * clear error on any unknown/missing/invalid argument so the caller can exit
+ * non-zero.
+ */
+export function parseRunsPruneArgs(args: string[]): RunsPruneArgs {
+  const usage = "Usage: flowai-workflow runs prune --workflow <dir> " +
+    "--keep <N> [--dry-run]";
+  let workflow: string | undefined;
+  let keepRaw: string | undefined;
+  let dryRun = false;
+  for (let i = 0; i < args.length; i++) {
+    const a = args[i];
+    if (a === "--workflow") {
+      workflow = args[++i];
+    } else if (a.startsWith("--workflow=")) {
+      workflow = a.slice("--workflow=".length);
+    } else if (a === "--keep") {
+      keepRaw = args[++i];
+    } else if (a.startsWith("--keep=")) {
+      keepRaw = a.slice("--keep=".length);
+    } else if (a === "--dry-run") {
+      dryRun = true;
+    } else {
+      throw new Error(`runs prune: unknown argument '${a}'. ${usage}`);
+    }
+  }
+  if (!workflow) {
+    throw new Error(`runs prune: missing --workflow <dir>. ${usage}`);
+  }
+  if (keepRaw === undefined) {
+    throw new Error(`runs prune: missing --keep <N>. ${usage}`);
+  }
+  if (!/^\d+$/.test(keepRaw)) {
+    throw new Error(
+      `runs prune: invalid --keep value '${keepRaw}'. ` +
+        `Expected a non-negative integer.`,
+    );
+  }
+  return {
+    workflowDir: normalizeWorkflowDir(workflow),
+    keep: Number(keepRaw),
+    dryRun,
+  };
+}
