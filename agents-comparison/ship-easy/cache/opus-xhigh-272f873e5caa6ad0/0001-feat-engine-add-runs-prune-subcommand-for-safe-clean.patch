index 0000000..dd567e1
--- /dev/null
+++ b/src/state/prune.ts
@@ -0,0 +1,253 @@
+/**
+ * @module
+ * Run-directory pruning (FR-E83): delete the oldest run directories under a
+ * workflow's `runs/` folder while obeying strict, conservative safety rules.
+ *
+ * Selection is split into a pure policy ({@link planPrune}) and an I/O layer
+ * ({@link collectRuns} / {@link pruneRuns}). All run-folder knowledge —
+ * directory paths, journal replay, and lock parsing — is reused from the
+ * sibling `src/state/` helpers (`getRunDir`, `replayRunJournal`,
+ * `defaultLockPath`/`readLockInfo`, terminal-status classification); nothing
+ * about the run-folder layout is re-implemented here.
+ */
+
+import { dirname } from "@std/path";
+import { defaultLockPath, readLockInfo } from "./lock.ts";
+import { isTerminalStatus, replayRunJournal } from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+
+/** A run directory classified for pruning. */
+export interface ClassifiedRun {
+  /** Run-directory name (the run id). */
+  runId: string;
+  /**
+   * Epoch milliseconds of the replayed `started_at`. Present iff the journal
+   * replayed and yielded a parseable start time; absent runs are excluded from
+   * recency ranking and always skipped.
+   */
+  startedMs?: number;
+  /** True when the replayed run status is terminal (completed/failed/aborted). */
+  terminal: boolean;
+  /** True when this run is the one referenced by `runs/.lock`. */
+  locked: boolean;
+  /**
+   * Reason the run could not be replayed (missing/malformed journal). Present
+   * iff the run is unreplayable; such runs count as non-terminal ("keep").
+   */
+  unreplayableReason?: string;
+}
+
+/** Per-run decision produced by {@link planPrune}. */
+export interface PrunePlanEntry {
+  /** Run-directory name. */
+  runId: string;
+  /** What pruning will do with the run. */
+  action: "delete" | "keep" | "skip";
+  /** Human-readable rationale for the action. */
+  reason: string;
+}
+
+/** Summary of a {@link pruneRuns} invocation. */
+export interface PruneSummary {
+  /** Run ids deleted (or, under dry-run, that WOULD be deleted). */
+  deleted: string[];
+  /** Run ids retained by the `--keep` recency window. */
+  kept: string[];
+  /** Protected/unevaluable run ids, each with its skip reason. */
+  skipped: Array<{ runId: string; reason: string }>;
+  /** True when no deletion was actually performed (`--dry-run`). */
+  dryRun: boolean;
+}
+
+/**
+ * Pure retention policy. Given classified runs and a non-negative `keep`,
+ * decide which to delete, keep, or skip.
+ *
+ * Runs with a replayable start time are ranked newest-first (tie-break: run id
+ * descending). The `keep` newest form the retention window (`keep`). Older
+ * ranked runs are deletion candidates: deleted iff terminal AND unlocked;
+ * otherwise skipped (safety overrides the count). Unreplayable runs have no
+ * comparable start time, so they are excluded from ranking and always skipped.
+ */
+export function planPrune(
+  runs: readonly ClassifiedRun[],
+  keep: number,
+): PrunePlanEntry[] {
+  const ranked = runs
+    .filter((r) =>
+      r.unreplayableReason === undefined && r.startedMs !== undefined
+    )
+    .slice()
+    .sort((a, b) => {
+      const byTime = (b.startedMs as number) - (a.startedMs as number);
+      if (byTime !== 0) return byTime;
+      return a.runId < b.runId ? 1 : a.runId > b.runId ? -1 : 0;
+    });
+
+  const entries: PrunePlanEntry[] = [];
+  ranked.forEach((run, index) => {
+    if (index < keep) {
+      entries.push({
+        runId: run.runId,
+        action: "keep",
+        reason: `within --keep ${keep} window`,
+      });
+      return;
+    }
+    if (run.locked) {
+      entries.push({
+        runId: run.runId,
+        action: "skip",
+        reason: "referenced by runs/.lock",
+      });
+    } else if (!run.terminal) {
+      entries.push({
+        runId: run.runId,
+        action: "skip",
+        reason: "non-terminal run status",
+      });
+    } else {
+      entries.push({
+        runId: run.runId,
+        action: "delete",
+        reason: "older than --keep window",
+      });
+    }
+  });
+
+  for (const run of runs) {
+    if (run.unreplayableReason !== undefined || run.startedMs === undefined) {
+      entries.push({
+        runId: run.runId,
+        action: "skip",
+        reason: run.unreplayableReason ?? "run start time unparseable",
+      });
+    }
+  }
+  return entries;
+}
+
+/** Read the run id named by `runs/.lock`, or `undefined` when no lock exists.
+ * A present-but-unreadable lock rethrows: pruning must fail safe rather than
+ * risk deleting the directory the lock protects. */
+async function lockedRunId(workflowDir: string): Promise<string | undefined> {
+  try {
+    return (await readLockInfo(defaultLockPath(workflowDir))).run_id;
+  } catch (err) {
+    if (err instanceof Deno.errors.NotFound) return undefined;
+    throw new Error(
+      `Cannot read ${
+        defaultLockPath(workflowDir)
+      } to determine the protected ` +
+        `run; refusing to prune: ${(err as Error).message}`,
+    );
+  }
+}
+
+/**
+ * Enumerate and classify every run directory under `<workflowDir>/runs/`.
+ * The runs root is derived from the lock helper ({@link defaultLockPath}) so
+ * the `<dir>/runs/` shape is not duplicated. Missing runs root → `[]`.
+ */
+export async function collectRuns(
+  workflowDir: string,
+): Promise<ClassifiedRun[]> {
+  const runsRoot = dirname(defaultLockPath(workflowDir));
+  const locked = await lockedRunId(workflowDir);
+
+  // Deno.readDir throws NotFound lazily on first iteration, so collect under
+  // a guard: an absent runs/ root means "no runs to prune".
+  const dirEntries: Deno.DirEntry[] = [];
+  try {
+    for await (const entry of Deno.readDir(runsRoot)) dirEntries.push(entry);
+  } catch (err) {
+    if (err instanceof Deno.errors.NotFound) return [];
+    throw err;
+  }
+
+  const runs: ClassifiedRun[] = [];
+  for (const entry of dirEntries) {
+    if (!entry.isDirectory) continue; // skip the `.lock` file and stray files
+    const runId = entry.name;
+    const isLocked = runId === locked;
+    try {
+      const { state } = await replayRunJournal(getRunDir(runId, workflowDir));
+      const startedMs = Date.parse(state.started_at);
+      if (!Number.isFinite(startedMs)) {
+        runs.push({
+          runId,
+          terminal: false,
+          locked: isLocked,
+          unreplayableReason: "run start time unparseable",
+        });
+        continue;
+      }
+      runs.push({
+        runId,
+        startedMs,
+        terminal: isTerminalStatus(state.status),
+        locked: isLocked,
+      });
+    } catch (err) {
+      const reason = err instanceof Deno.errors.NotFound
+        ? "journal.jsonl missing"
+        : `journal.jsonl unreplayable: ${(err as Error).message}`;
+      runs.push({
+        runId,
+        terminal: false,
+        locked: isLocked,
+        unreplayableReason: reason,
+      });
+    }
+  }
+  return runs;
+}
+
+/**
+ * Prune old run directories under `<workflowDir>/runs/` per {@link planPrune}.
+ * Deletes each `delete`-classified run recursively unless `dryRun` is set.
+ */
+export async function pruneRuns(opts: {
+  workflowDir: string;
+  keep: number;
+  dryRun: boolean;
+}): Promise<PruneSummary> {
+  const plan = planPrune(await collectRuns(opts.workflowDir), opts.keep);
+  const summary: PruneSummary = {
+    deleted: [],
+    kept: [],
+    skipped: [],
+    dryRun: opts.dryRun,
+  };
+  for (const entry of plan) {
+    if (entry.action === "delete") {
+      if (!opts.dryRun) {
+        await Deno.remove(getRunDir(entry.runId, opts.workflowDir), {
+          recursive: true,
+        });
+      }
+      summary.deleted.push(entry.runId);
+    } else if (entry.action === "keep") {
+      summary.kept.push(entry.runId);
+    } else {
+      summary.skipped.push({ runId: entry.runId, reason: entry.reason });
+    }
+  }
+  return summary;
+}
+
+/** Render a {@link PruneSummary} as a human-readable multi-line report. */
+export function formatPruneSummary(summary: PruneSummary): string {
+  const prefix = summary.dryRun ? "[dry-run] " : "";
+  const lines = [
+    `${prefix}runs prune: deleted ${summary.deleted.length}, ` +
+    `kept ${summary.kept.length}, skipped ${summary.skipped.length}`,
+  ];
+  const verb = summary.dryRun ? "would delete" : "deleted";
+  for (const runId of summary.deleted) lines.push(`  ${verb}: ${runId}`);
+  for (const runId of summary.kept) lines.push(`  kept: ${runId}`);
+  for (const { runId, reason } of summary.skipped) {
+    lines.push(`  skipped: ${runId} — ${reason}`);
+  }
+  return lines.join("\n");
+}
