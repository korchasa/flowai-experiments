+    // Journal whose records cannot be replayed (no run_started).
+    const brokenDir = getRunDir("broken", workflowDir);
+    await Deno.mkdir(brokenDir, { recursive: true });
+    await Deno.writeTextFile(
+      `${brokenDir}/journal.jsonl`,
