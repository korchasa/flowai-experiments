+// FR-E83: `runs prune` selection logic — keeps N newest terminal runs,
+// never touches non-terminal, locked, or unreplayable runs.
+import { assert, assertEquals, assertRejects } from "@std/assert";
+import { planRunsPrune, pruneRuns } from "./prune.ts";
+import { RunJournalWriter } from "./run-journal.ts";
+import { getRunDir } from "./state.ts";
+import { defaultLockPath } from "./lock.ts";
+
+/** Write an engine-shaped journal for one run: bootstrap `run_started`
+ * (carrying the start time used for prune ordering) plus an optional
+ * terminal record. `terminal: undefined` leaves the run non-terminal. */
+async function writeRunJournal(
+  workflowDir: string,
+  runId: string,
+  startedAt: string,
+  terminal?: "completed" | "failed" | "aborted",
+): Promise<void> {
+  const runDir = getRunDir(runId, workflowDir);
+  const writer = await RunJournalWriter.open(runDir, runId);
+  await writer.append({
+    kind: "run_started",
+    config_path: "workflow.yaml",
+    started_at: startedAt,
+    ts: startedAt,
+    args: {},
+    env: {},
+  });
+  await writer.append({
+    kind: "node_declared",
+    node_id: "build",
+    node_type: "agent",
+    label: "Build",
+  });
+  if (terminal) {
+    await writer.append({
+      kind: `run_${terminal}`,
+      status: terminal,
+      completed_at: startedAt,
+    });
+  }
+}
+
+async function dirExists(path: string): Promise<boolean> {
+  try {
+    const stat = await Deno.stat(path);
+    return stat.isDirectory;
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return false;
+    throw error;
+  }
+}
+
+Deno.test("FR-E83 prune — keeps N newest terminal runs, deletes older ones", async () => {
+  const workflowDir = await Deno.makeTempDir();
+  try {
+    await writeRunJournal(
+      workflowDir,
+      "r1",
+      "2026-06-01T00:00:00Z",
+      "completed",
+    );
+    await writeRunJournal(workflowDir, "r2", "2026-06-02T00:00:00Z", "failed");
+    await writeRunJournal(workflowDir, "r3", "2026-06-03T00:00:00Z", "aborted");
+    await writeRunJournal(
+      workflowDir,
+      "r4",
+      "2026-06-04T00:00:00Z",
+      "completed",
+    );
+
+    const report = await pruneRuns({ workflowDir, keep: 2 });
+    assertEquals(report.deleted.map((d) => d.run_id).sort(), ["r1", "r2"]);
+    assertEquals(report.kept.map((d) => d.run_id).sort(), ["r3", "r4"]);
+    assertEquals(report.skipped, []);
+    assertEquals(await dirExists(getRunDir("r1", workflowDir)), false);
+    assertEquals(await dirExists(getRunDir("r2", workflowDir)), false);
+    assertEquals(await dirExists(getRunDir("r3", workflowDir)), true);
+    assertEquals(await dirExists(getRunDir("r4", workflowDir)), true);
+  } finally {
+    await Deno.remove(workflowDir, { recursive: true });
+  }
+});
