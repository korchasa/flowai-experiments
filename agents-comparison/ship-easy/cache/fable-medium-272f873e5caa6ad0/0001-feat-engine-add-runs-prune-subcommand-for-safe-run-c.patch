index 0000000..eddcf67
--- /dev/null
+++ b/src/state/prune.ts
@@ -0,0 +1,179 @@
+/**
+ * @module
+ * Safe pruning of old run directories under `<workflowDir>/runs/` (FR-E83).
+ *
+ * The only durable record of a run is its `journal.jsonl`; status and start
+ * time come exclusively from replaying it ({@link replayRunJournal}). When in
+ * doubt — missing or unreplayable journal, non-terminal status, or the run
+ * named by the live `runs/.lock` file — the run is kept and reported as
+ * skipped with the reason. The `keep` budget counts only deletable runs
+ * (terminal, unlocked, replayable); skipped runs remain in addition, so a
+ * flood of non-terminal runs never forces deletion of recent terminal
+ * history.
+ */
+
+import type { RunState } from "../types.ts";
+import { getRunDir } from "./state.ts";
+import { replayRunJournal } from "./run-journal.ts";
+import { defaultLockPath, readLockInfo } from "./lock.ts";
+
+/** Per-run outcome of a prune plan (FR-E83). */
+export interface RunPruneDecision {
+  /** Run directory name under `<workflowDir>/runs/`. */
+  run_id: string;
+  /** What the plan does with this run. */
+  action: "delete" | "keep" | "skip";
+  /** Human-readable skip reason; present when `action` is `"skip"`. */
+  reason?: string;
+  /** Run start time from the replayed journal; absent when replay failed. */
+  started_at?: string;
+}
+
+/** Summary returned by {@link pruneRuns} (FR-E83). */
+export interface RunsPruneReport {
+  /** Workflow folder whose `runs/` tree was pruned. */
+  workflow_dir: string;
+  /** True when no directory was actually removed. */
+  dry_run: boolean;
+  /** Runs deleted (or, in dry-run, that would be deleted). */
+  deleted: RunPruneDecision[];
+  /** Deletable runs retained by the `keep` budget. */
+  kept: RunPruneDecision[];
+  /** Untouchable runs with per-run reasons. */
+  skipped: RunPruneDecision[];
+}
+
+function isTerminal(status: RunState["status"]): boolean {
+  return status === "completed" || status === "failed" || status === "aborted";
+}
+
+/** Return the run id named by `runs/.lock`, or undefined when the lock is
+ * absent or unreadable (an absent/corrupt lock cannot reference a run). */
+async function lockedRunId(workflowDir: string): Promise<string | undefined> {
+  try {
+    return (await readLockInfo(defaultLockPath(workflowDir))).run_id;
+  } catch {
+    return undefined;
+  }
+}
+
+/**
+ * Decide, without mutating anything, what pruning `<workflowDir>/runs/` to
+ * at most `keep` deletable runs would do (FR-E83).
+ *
+ * Safety rules (hard): a run whose replayed status is not terminal, the run
+ * referenced by an existing `runs/.lock`, and any run whose journal is
+ * missing or cannot be replayed are never marked for deletion — they are
+ * reported as skipped with the reason. Deletable candidates are ordered by
+ * the replayed run start time; the `keep` newest stay, older ones are
+ * marked for deletion. Stray non-directory entries under `runs/` (e.g. the
+ * `.lock` file itself) are ignored silently.
+ *
+ * @param workflowDir — workflow folder containing the `runs/` tree.
+ * @param keep — non-negative integer count of deletable runs to retain.
+ */
+export async function planRunsPrune(
+  workflowDir: string,
+  keep: number,
+): Promise<RunPruneDecision[]> {
+  if (!Number.isInteger(keep) || keep < 0) {
+    throw new Error(
+      `Invalid keep value: ${keep}. Expected a non-negative integer.`,
+    );
+  }
+
+  const runIds: string[] = [];
+  try {
+    for await (const entry of Deno.readDir(`${workflowDir}/runs`)) {
+      if (entry.isDirectory) runIds.push(entry.name);
+    }
+  } catch (error) {
+    if (error instanceof Deno.errors.NotFound) return [];
+    throw error;
+  }
+
+  const locked = await lockedRunId(workflowDir);
+  const skipped: RunPruneDecision[] = [];
+  const candidates: RunPruneDecision[] = [];
+
+  for (const runId of runIds) {
+    let state: RunState;
+    try {
+      state = (await replayRunJournal(getRunDir(runId, workflowDir))).state;
+    } catch (error) {
+      skipped.push({
+        run_id: runId,
+        action: "skip",
+        reason: `journal missing or unreplayable: ${
+          error instanceof Error ? error.message : String(error)
+        }`,
+      });
+      continue;
+    }
+    if (runId === locked) {
+      skipped.push({
+        run_id: runId,
+        action: "skip",
+        reason: "referenced by runs/.lock",
+        started_at: state.started_at,
+      });
+      continue;
+    }
+    if (!isTerminal(state.status)) {
+      skipped.push({
+        run_id: runId,
+        action: "skip",
+        reason: `non-terminal status: ${state.status}`,
+        started_at: state.started_at,
+      });
+      continue;
+    }
+    candidates.push({
+      run_id: runId,
+      action: "delete",
+      started_at: state.started_at,
+    });
+  }
+
+  // Newest first by replayed start time; run-id tiebreak for determinism.
+  candidates.sort((a, b) =>
+    b.started_at!.localeCompare(a.started_at!) ||
+    b.run_id.localeCompare(a.run_id)
+  );
+  for (let i = 0; i < Math.min(keep, candidates.length); i++) {
+    candidates[i].action = "keep";
+  }
+
+  return [...candidates, ...skipped];
+}
+
+/**
+ * Prune `<workflowDir>/runs/` to at most `keep` deletable runs (FR-E83).
+ *
+ * Computes the plan via {@link planRunsPrune} and, unless `dryRun` is set,
+ * recursively removes each run directory marked for deletion. Deletion
+ * errors propagate — a partial prune surfaces loudly instead of being
+ * swallowed.
+ */
+export async function pruneRuns(opts: {
+  workflowDir: string;
+  keep: number;
+  dryRun?: boolean;
+}): Promise<RunsPruneReport> {
+  const plan = await planRunsPrune(opts.workflowDir, opts.keep);
+  const deleted = plan.filter((d) => d.action === "delete");
+  if (!opts.dryRun) {
+    for (const decision of deleted) {
+      await Deno.remove(getRunDir(decision.run_id, opts.workflowDir), {
+        recursive: true,
+      });
+    }
+  }
+  return {
+    workflow_dir: opts.workflowDir,
+    dry_run: opts.dryRun ?? false,
+    deleted,
+    kept: plan.filter((d) => d.action === "keep"),
+    skipped: plan.filter((d) => d.action === "skip"),
+  };
+}
