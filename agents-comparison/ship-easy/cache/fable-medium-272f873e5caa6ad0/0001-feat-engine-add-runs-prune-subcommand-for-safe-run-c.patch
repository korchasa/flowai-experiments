+    assertEquals(report.deleted.map((d) => d.run_id), ["done"]);
+    assertEquals(
+      report.skipped.map((d) => d.run_id).sort(),
+      ["broken", "no-journal"],
+    );
+    for (const skip of report.skipped) {
+      assert(skip.reason?.includes("journal"), `reason: ${skip.reason}`);
+    }
+    assertEquals(await dirExists(getRunDir("no-journal", workflowDir)), true);
