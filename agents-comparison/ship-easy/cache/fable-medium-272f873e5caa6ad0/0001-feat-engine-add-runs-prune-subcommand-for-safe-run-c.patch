+      continue;
+    }
+    if (a === "--dry-run") {
+      dryRun = true;
+      continue;
+    }
+    throw new Error(
+      `Unexpected argument: ${a}. ` +
+        "Usage: flowai-workflow runs prune [--workflow <path>] " +
+        "--keep <N> [--dry-run]",
+    );
+  }
+  if (keepRaw === undefined) {
+    throw new Error(
+      "runs prune: missing --keep <N> (number of most-recent runs to retain).",
+    );
+  }
+  const keep = Number(keepRaw);
+  if (keepRaw.trim() === "" || !Number.isInteger(keep) || keep < 0) {
+    throw new Error(
+      `Invalid --keep value: ${keepRaw}. Expected a non-negative integer.`,
+    );
+  }
+  return {
+    workflowDir: workflow ? normalizeWorkflowDir(workflow) : undefined,
+    keep,
+    dryRun,
+  };
