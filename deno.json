{
  "imports": {
    "@korchasa/ai-ide-cli": "jsr:@korchasa/ai-ide-cli@0.8.3",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.29",
    "@std/flags": "jsr:@std/flags@^0.224.0",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4"
  },
  "tasks": {
    "check": "deno fmt --check && deno lint && deno test -A --ignore=.agents,.codex,.claude,compression-decompression,tokenizers,images-hard && gitleaks git . --no-banner --no-color",
    "test": "deno test -A --ignore=.agents,.codex,.claude,compression-decompression,tokenizers,images-hard",
    "check:compression": "cd compression-decompression && BENCH_HEALTH_DISABLE=1 deno task check",
    "check:all": "deno task check && deno task check:compression",
    "experiment": "deno run -A scripts/task-experiment.ts",
    "experiment:anchor-systems": "deno run -A anchor-systems/run-all.ts",
    "experiment:tokenizers": "deno run -A --env-file=.env tokenizers/run.ts",
    "experiment:compression": "deno run -A compression-decompression/run.ts",
    "experiment:images-hard": "deno run -A --env-file=.env images-hard/run.ts"
  },
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "**/*.md",
      "**/results/",
      ".agents/",
      ".codex/",
      ".claude/",
      "compression-decompression/",
      "tokenizers/public/",
      "images-hard/public/",
      "**/cache/"
    ]
  },
  "lint": {
    "exclude": [
      ".agents/",
      ".codex/",
      ".claude/",
      "compression-decompression/",
      "tokenizers/public/",
      "tokenizers/bench.ts",
      "tokenizers/merge-results.ts",
      "images-hard/public/",
      "images-hard/bench.ts",
      "**/cache/"
    ]
  }
}
