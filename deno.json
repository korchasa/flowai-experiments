{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/flags": "jsr:@std/flags@^0.224.0",
    "@std/fs": "jsr:@std/fs@^1.0.17",
    "@std/path": "jsr:@std/path@^1.1.4"
  },
  "tasks": {
    "check": "deno fmt --check && deno lint && deno test -A --ignore=results",
    "test": "deno test -A --ignore=results",
    "experiment": "deno run -A scripts/task-experiment.ts"
  },
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "**/*.md",
      "results/"
    ]
  }
}
